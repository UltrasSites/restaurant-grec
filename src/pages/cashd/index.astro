      {/* Hidden username pour permettre au navigateur d'enregistrer le mot de passe */}
      <input type="text" name="username" id="login-user" value="kalamaki-caisse" autocomplete="username" readonly hidden aria-hidden="true" tabindex="-1" />
      <input type="password" name="password" id="login-pw" autocomplete="current-password" required />
      <button type="submit" id="login-btn">Σύνδεση</button>
      <p id="login-error" class="login-error" style="display:none;"></p>
    </form>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" class="dashboard">
    <div class="topbar">
      <h1 id="topbar-title">📡 ΚΑΛΑΜΑΚΙ — ΠΙΝΑΚΑΣ</h1>
      <div class="status" id="conn-status">
        <span class="dot"></span>
        <span class="clock" id="clock">--:--</span>
        <a href="/cashd/pos" class="new-order-cta" title="Καταχώρηση πώλησης στο κατάστημα">🆕 <span class="new-order-label">Νέα παραγγελία</span></a>
        <button type="button" id="lang-toggle" class="lang-toggle" aria-label="Language" style="display:none"></button>
        <a href="/cashd/messages" id="global-msg-btn" class="msg-icon-btn" title="Όλα τα μηνύματα">💬<span id="global-unread-badge" class="global-unread hidden">0</span></a>
        <select id="sound-select" class="sound-select" aria-label="Ήχος ειδοποίησης"></select>
        <button type="button" id="sound-test" class="sound-test" title="Test">🔊 Test</button>
        <button type="button" id="sound-toggle" class="sound-toggle" aria-pressed="false"></button>
      </div>
    </div>
    <nav class="mobile-tabs" id="mobile-tabs" aria-label="Sections">
      <button type="button" class="mobile-tab tab-pending active" data-tab="pending">
        <span id="mtab-pending-label">🔴 Σε αναμονή</span>
        <span class="tab-count" id="mtab-pending-count">0</span>
      </button>
      <button type="button" class="mobile-tab tab-prep" data-tab="prep">
        <span id="mtab-prep-label">🟡 Σε προετ.</span>
        <span class="tab-count" id="mtab-prep-count">0</span>
      </button>
      <button type="button" class="mobile-tab tab-history" data-tab="history">
        <span id="mtab-history-label">📋 Ιστορικό</span>
        <span class="tab-count" id="mtab-history-count">0</span>
      </button>
    </nav>
    <div class="orders-area">
      <div class="columns">
        <section class="column col-pending active" data-col="pending">
          <div class="col-head">
            <span id="col-pending-title">Σε αναμονή</span>
            <span class="count" id="col-pending-count">0</span>
          </div>
          <div id="list-pending"></div>
          <div id="empty-pending" class="col-empty"></div>
