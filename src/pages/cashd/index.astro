<body>

  <CashdNav />

  <!-- LOGIN SCREEN -->
  <div id="login-screen" class="login-wrap" style="display:none;">
    <form class="login-box" id="login-form" method="post" action="#" autocomplete="on">
      <div style="display:flex; justify-content:flex-end; margin-bottom:0.5rem;">
