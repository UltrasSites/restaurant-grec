    if (langToggleBtn) langToggleBtn.addEventListener('click', toggleLang);
    if (loginLangToggleBtn) loginLangToggleBtn.addEventListener('click', toggleLang);

    var orders = {}; // id -> order (status 'new' ou 'seen' uniquement)
    var since = 0;
    var polling = false;
    var soundOn = true;
    var beepInterval = null;
    var audioCtx = null;

    // ═══ Sound selection (localStorage) ═══
    var SOUND_KEY = 'caisse_sound';
    var DEFAULT_SOUND = 'ding';
    function getSoundChoice() {
      try {
        var v = localStorage.getItem(SOUND_KEY);
        return v || DEFAULT_SOUND;
      } catch (e) { return DEFAULT_SOUND; }
    }
    function setSoundChoice(v) {
      try { localStorage.setItem(SOUND_KEY, v); } catch (e) {}
    }

    function tickClock() {
      var d = new Date();
      var hh = String(d.getHours()).padStart(2, '0');
      var mm = String(d.getMinutes()).padStart(2, '0');
      var ss = String(d.getSeconds()).padStart(2, '0');
      clockEl.textContent = hh + ':' + mm + ':' + ss;
    }
    setInterval(tickClock, 1000); tickClock();

    function ensureAudio() {
      if (window.TroubaSounds && typeof window.TroubaSounds.unlock === 'function') {
        try { window.TroubaSounds.unlock(); } catch (e) {}
      }
      if (!audioCtx) {
        try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
        catch (e) { audioCtx = null; }
      }
      if (audioCtx && audioCtx.state === 'suspended') {
        audioCtx.resume().catch(function(){});
      }
    }

    function beep() {
      if (!soundOn) return;
      ensureAudio();
      // Utilise la lib synthétique commune
      if (window.TroubaSounds && typeof window.TroubaSounds.play === 'function') {
        try { window.TroubaSounds.play(getSoundChoice()); } catch (e) {}
        return;
      }
      // Fallback : ding inline si TroubaSounds non chargé
      if (!audioCtx) return;
      try {
        var osc = audioCtx.createOscillator();
        var gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.value = 880;
        gain.gain.setValueAtTime(0.0001, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.35, audioCtx.currentTime + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.4);
        osc.connect(gain).connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.42);
      } catch (e) {}
    }

    function startBeeping() {
      if (beepInterval) return;
      beep();
      beepInterval = setInterval(beep, 2000);
    }
    function stopBeeping() {
      if (beepInterval) { clearInterval(beepInterval); beepInterval = null; }
    }

    soundToggle.addEventListener('click', function() {
      soundOn = !soundOn;
      soundToggle.textContent = soundOn ? t.soundOn : t.soundOff;
      soundToggle.classList.toggle('muted', !soundOn);
      soundToggle.setAttribute('aria-pressed', String(!soundOn));
      if (soundOn) {
        ensureAudio();
        if (hasNewPending()) startBeeping();
      } else {
        stopBeeping();
      }
    });

    // ═══ Sound selector (préférence patron) ═══
    var soundSelect = document.getElementById('sound-select');
    var soundTest = document.getElementById('sound-test');
    if (soundSelect && window.TroubaSounds && Array.isArray(window.TroubaSounds.list)) {
      var current = getSoundChoice();
      var optsHtml = '';
      window.TroubaSounds.list.forEach(function(s) {
        var sel = s.value === current ? ' selected' : '';
        optsHtml += '<option value="' + s.value + '"' + sel + '>' + s.label + '</option>';
      });
      soundSelect.innerHTML = optsHtml;
      soundSelect.addEventListener('change', function() {
        setSoundChoice(soundSelect.value);
        ensureAudio();
        if (window.TroubaSounds) window.TroubaSounds.play(soundSelect.value);
      });
    }
    if (soundTest) {
      soundTest.addEventListener('click', function() {
        ensureAudio();
        if (window.TroubaSounds) window.TroubaSounds.play(getSoundChoice());
      });
    }

    function hasNewPending() {
      for (var k in orders) if (orders[k].status === 'new') return true;
      return false;
    }

    function escapeHtml(s) {
      return String(s || '').replace(/[&<>"']/g, function(c) {
        return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
      });
    }

    function fmt(n) { return (Math.round(n * 100) / 100).toFixed(2).replace('.', ',') + '€'; }

    function pickupLabel(p) {
      var v = String(p);
      if (v === '60') return '1 ' + t.hour;
      return v + ' ' + t.min;
    }

    function buildCardBody(o) {
      var itemsHtml = '';
      (o.items || []).forEach(function(it) {
        itemsHtml += '<li>'
          + '<span><span class="qty">×' + it.qty + '</span><span class="item-name">' + escapeHtml(it.name) + '</span></span>'
          + '<span class="item-total">' + fmt(it.price * it.qty) + '</span>'
          + '</li>';
      });
      var d = new Date(o.created_at);
      var time = String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');

      var isDelivery = o.mode === 'delivery';
      var payLoc = isDelivery ? t.payAtCourier : t.payAtCounter;
      var modePill = isDelivery
        ? '<span class="pill pill-delivery">' + t.modeDelivery + '</span>'
        : '<span class="pill pill-takeaway">' + t.modeTakeaway + '</span>';
      var payPill = o.payment === 'card'
        ? '<span class="pill pill-card">' + t.payCard + ' ' + payLoc + '</span>'
        : '<span class="pill pill-cash">' + t.payCash + ' ' + payLoc + '</span>';
      var pickupText = '⏱ ' + (isDelivery ? t.deliveryIn : t.pickupIn) + ' ' + pickupLabel(o.pickup_time);
      // Si pickup_time vide ou "0" (option supprimée côté form), on n'affiche pas le bloc
      var hasPickup = o.pickup_time && String(o.pickup_time) !== '0';

      // Note client : si traduction grecque dispo et différente de l'original,
      // on affiche la traduction en gros + l'original en petit. Sinon note brute.
      var notesHtml = '';
      if (o.notes) {
        var hasTrans = o.notes_translated && o.notes_translated !== o.notes;
        if (hasTrans) {
          notesHtml = '<div class="deliv-notes" style="font-size:1.1rem;color:#fbbf24;font-weight:700;font-style:normal;">📝 ' + escapeHtml(o.notes_translated) + '</div>'
            + '<div style="font-size:0.78rem;color:#888;margin-top:0.25rem;font-style:italic;">(' + (lang === 'el' ? 'Αρχικό' : 'Original') + ': ' + escapeHtml(o.notes) + ')</div>';
        } else {
          notesHtml = '<div class="deliv-notes">📝 ' + escapeHtml(o.notes) + '</div>';
        }
      }

      var deliveryBlock = '';
      if (isDelivery && o.address) {
        var extra = [];
        if (o.floor) extra.push(t.floor + ' : ' + escapeHtml(o.floor));
        if (o.bell)  extra.push(t.bell + ' : ' + escapeHtml(o.bell));
        deliveryBlock = '<div class="delivery-box">'
          + '<div class="deliv-label">' + t.deliveryLabel + '</div>'
          + '<div class="deliv-addr">' + escapeHtml(o.address) + '</div>'
          + (extra.length ? '<div class="deliv-extra">' + extra.join(' · ') + '</div>' : '')
          + notesHtml
          + '</div>';
      } else if (notesHtml) {
        deliveryBlock = '<div class="delivery-box">' + notesHtml + '</div>';
      }

      return ''
        + '<div class="order-head">'
          + '<div><div class="order-id">' + escapeHtml(o.id) + '</div><div style="font-size:0.8rem;color:#999;margin-top:0.25rem;">' + t.receivedAt + ' ' + time + '</div></div>'
          + '<div class="order-meta"><div class="name">' + escapeHtml(o.name) + '</div><div class="phone">📞 <a href="tel:' + encodeURIComponent(o.phone) + '" style="color:inherit;text-decoration:none;">' + escapeHtml(o.phone) + '</a></div></div>'
        + '</div>'
        + '<div class="order-mode-row">' + modePill + payPill + '</div>'
        + (hasPickup ? '<div class="order-pickup">' + pickupText + '</div>' : '')
        + deliveryBlock
        + '<ul class="order-items">' + itemsHtml + '</ul>'
        + '<div class="order-total"><span>' + t.total + '</span><span>' + fmt(o.total) + '</span></div>';
    }

    function buildChatHtml(o) {
      var unread = Number(o.unread_client_messages) || 0;
      var badge = unread > 0 ? '<span class="unread-badge">' + unread + '</span>' : '';
      var isOpen = !!openChats[o.id];
      return ''
        + '<div class="chat-wrap" data-chat-wrap="' + escapeHtml(o.id) + '">'
          + '<button type="button" class="chat-toggle" data-action="toggle-chat" data-id="' + escapeHtml(o.id) + '">'
            + '<span>' + t.chatToggle + '</span>'
            + badge
          + '</button>'
          + '<div class="chat-body' + (isOpen ? ' open' : '') + '" data-chat-body="' + escapeHtml(o.id) + '">'
            + '<div class="chat-messages" data-chat-messages="' + escapeHtml(o.id) + '"></div>'
            + '<div class="chat-input-row">'
              + '<input type="text" placeholder="' + escapeHtml(t.chatPlaceholder) + '" data-chat-input="' + escapeHtml(o.id) + '" maxlength="500" />'
              + '<button type="button" data-action="send-msg" data-id="' + escapeHtml(o.id) + '">' + t.chatSend + '</button>'
            + '</div>'
          + '</div>'
        + '</div>';
    }

    function buildEtaBadge(o) {
      if (!o.prep_minutes) return '';
      var remaining = o.prep_minutes;
      if (o.accepted_at) {
        var elapsed = Math.floor((Date.now() - o.accepted_at) / 60000);
        remaining = Math.max(0, o.prep_minutes - elapsed);
      }
      return '<div style="display:inline-block;padding:0.3rem 0.7rem;border-radius:999px;background:rgba(96,165,250,0.15);color:#60a5fa;border:1px solid rgba(96,165,250,0.4);font-weight:800;font-size:0.85rem;margin-left:0.5rem;">⏱ ' + remaining + ' ' + t.min + '</div>';
    }

    function renderOrders() {
      var pending = [];
      var prep = [];
      Object.keys(orders).forEach(function(id) {
        var o = orders[id];
        if (o.status === 'new') pending.push(o);
        else if (o.status === 'seen') prep.push(o);
      });
      pending.sort(function(a, b) { return a.created_at - b.created_at; });
      prep.sort(function(a, b) { return a.created_at - b.created_at; });

      countPending.textContent = String(pending.length);
      countPrep.textContent = String(prep.length);
      // Sync mobile tab counts + pulse pending tab if not active
      var mtabPC = document.getElementById('mtab-pending-count');
      var mtabPR = document.getElementById('mtab-prep-count');
      if (mtabPC) mtabPC.textContent = String(pending.length);
      if (mtabPR) mtabPR.textContent = String(prep.length);
      var mtabPending = document.querySelector('.mobile-tab.tab-pending');
      if (mtabPending) mtabPending.classList.toggle('has-orders', pending.length > 0);

      // Colonne EN ATTENTE : carte rouge clignotante + bouton "Accepter" → popup temps
      if (pending.length === 0) {
        listPending.innerHTML = '';
        emptyPending.style.display = 'block';
        emptyPending.textContent = t.emptyPending;
      } else {
        emptyPending.style.display = 'none';
        var html = '';
        pending.forEach(function(o) {
          html += '<article class="order-card card-pending" data-order="' + escapeHtml(o.id) + '">'
            + '<div class="actions two">'
              + '<button type="button" class="btn-action btn-prepare" data-action="open-accept" data-id="' + escapeHtml(o.id) + '">' + t.btnPrepare + '</button>'
              + '<button type="button" class="btn-action btn-decline" data-action="open-decline" data-id="' + escapeHtml(o.id) + '">' + t.btnDecline + '</button>'
            + '</div>'
            + buildCardBody(o)
            + buildChatHtml(o)
            + '</article>';
        });
        listPending.innerHTML = html;
      }

      // Colonne EN PREPARATION : gold + 3 boutons (ETA / Ready / Paid) + ETA badge dans head
      if (prep.length === 0) {
        listPrep.innerHTML = '';
        emptyPrep.style.display = 'block';
        emptyPrep.textContent = t.emptyPrep;
      } else {
        emptyPrep.style.display = 'none';
        var html2 = '';
        prep.forEach(function(o) {
          html2 += '<article class="order-card card-prep" data-order="' + escapeHtml(o.id) + '">'
            + '<div class="actions" style="grid-template-columns: 1fr 1fr 1fr;">'
              + '<button type="button" class="btn-action btn-eta" data-action="open-eta" data-id="' + escapeHtml(o.id) + '">' + t.btnEta + '</button>'
              + '<button type="button" class="btn-action btn-ready" data-action="ready" data-id="' + escapeHtml(o.id) + '">' + t.btnReady + '</button>'
              + '<button type="button" class="btn-action btn-paid" data-action="paid" data-id="' + escapeHtml(o.id) + '">' + t.btnPaid + '</button>'
            + '</div>'
            + buildCardBody(o)
            + buildChatHtml(o)
            + '</article>';
        });
        listPrep.innerHTML = html2;
      }

      // Re-fetch messages des chats ouverts
      Object.keys(openChats).forEach(function(id) {
        if (openChats[id] && orders[id]) fetchChatMessages(id);
      });

      // Beep tant qu'il y a au moins une commande "new"
      if (pending.length > 0) {
        document.body.classList.add('has-pending');
        if (soundOn) startBeeping();
      } else {
        document.body.classList.remove('has-pending');
        stopBeeping();
      }
    }

    // ═══ POPUPS (acceptation + ETA) ═══
    function openAcceptModal(id) {
      pendingAcceptId = id;
      var o = orders[id];
      var name = o ? (o.name || '') : '';
      var total = o ? fmt(o.total || 0) : '';
      acceptSubEl.textContent = t.acceptSub + ' ' + id + (name ? ' — ' + name : '') + (total ? ' · ' + total : '');
      acceptCustom.value = '';
      acceptModal.classList.add('show');
      setTimeout(function() { acceptCustom.focus(); }, 50);
    }
    function closeAcceptModal() {
      acceptModal.classList.remove('show');
      pendingAcceptId = null;
    }
    function openEtaModal(id) {
      pendingEtaId = id;
      var o = orders[id];
      pendingEtaCurrent = (o && o.prep_minutes) ? Number(o.prep_minutes) : 0;
      etaSubEl.textContent = t.etaSub + ' ' + (pendingEtaCurrent || '?') + ' ' + t.min;
      etaCustom.value = '';
      etaReason.value = '';
      etaModal.classList.add('show');
      setTimeout(function() { etaCustom.focus(); }, 50);
    }
    function closeEtaModal() {
      etaModal.classList.remove('show');
      pendingEtaId = null;
      pendingEtaCurrent = 0;
    }

    async function submitAccept(prepMin) {
      if (!pendingAcceptId) return;
      var id = pendingAcceptId;
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/ack', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prep_minutes: prepMin }),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'fail');
        if (orders[id]) {
          orders[id].status = 'seen';
          orders[id].prep_minutes = data.prep_minutes || prepMin;
          orders[id].accepted_at = Date.now();
        }
        closeAcceptModal();
        renderOrders();
        // Auto-ouverture onglet chat avec le client (Messenger-style natif)
        openFloatingChat(id);
      } catch (err) {
        alert(t.actionError + (err && err.message ? err.message : err));
      }
    }

    async function submitEta(prepMin, reason) {
      if (!pendingEtaId) return;
      var id = pendingEtaId;
      try {
        var body = { prep_minutes: prepMin };
        if (reason) body.reason = reason;
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/eta', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'fail');
        if (orders[id]) {
          orders[id].prep_minutes = data.prep_minutes || prepMin;
          orders[id].eta_changed_at = Date.now();
        }
        closeEtaModal();
        renderOrders();
      } catch (err) {
        alert(t.actionError + (err && err.message ? err.message : err));
      }
    }

    // Listeners popups
    if (acceptGrid) acceptGrid.addEventListener('click', function(e) {
      var el = e.target;
      if (!(el instanceof Element)) return;
      var min = parseInt(el.getAttribute('data-min') || '0', 10);
      if (min > 0) submitAccept(min);
    });
    if (acceptCustomGo) acceptCustomGo.addEventListener('click', function() {
      var v = parseInt(acceptCustom.value || '0', 10);
      if (v >= 1 && v <= 180) submitAccept(v);
    });
    if (acceptCustom) acceptCustom.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); acceptCustomGo.click(); }
    });
    if (acceptCancelBtn) acceptCancelBtn.addEventListener('click', closeAcceptModal);
    if (acceptModal) acceptModal.addEventListener('click', function(e) {
      if (e.target === acceptModal) closeAcceptModal();
    });
    var acceptCloseX = document.getElementById('accept-close-x');
    if (acceptCloseX) acceptCloseX.addEventListener('click', closeAcceptModal);

    if (etaGrid) etaGrid.addEventListener('click', function(e) {
      var el = e.target;
      if (!(el instanceof Element)) return;
      var delta = el.getAttribute('data-delta');
      if (!delta) return;
      var d = parseInt(delta, 10);
      var newVal = Math.max(1, pendingEtaCurrent + d);
      submitEta(newVal, etaReason.value.trim());
    });
    if (etaCustomGo) etaCustomGo.addEventListener('click', function() {
      var v = parseInt(etaCustom.value || '0', 10);
      if (v >= 1 && v <= 180) submitEta(v, etaReason.value.trim());
    });
    if (etaCustom) etaCustom.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); etaCustomGo.click(); }
    });
    if (etaCancelBtn) etaCancelBtn.addEventListener('click', closeEtaModal);
    if (etaModal) etaModal.addEventListener('click', function(e) {
      if (e.target === etaModal) closeEtaModal();
    });
    var etaCloseX = document.getElementById('eta-close-x');
    if (etaCloseX) etaCloseX.addEventListener('click', closeEtaModal);

    // Esc ferme le modal ouvert
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      if (acceptModal && acceptModal.classList.contains('show')) { closeAcceptModal(); return; }
      if (etaModal && etaModal.classList.contains('show')) { closeEtaModal(); return; }
    });

    // ═══ CHAT (par carte) ═══
    async function fetchChatMessages(id) {
      try {
        var res = await fetch('/api/orders/history', { credentials: 'include' });
        // simplification : on lit via /api/orders/[id]/public mais en mode admin on n'a pas le phone.
        // Solution : on récupère les messages directement via une route admin si dispo.
        // Pour MVP : on lit via poll qui retourne unread_client_messages.
        // Vrai fetch messages : on fait un endpoint /api/orders/[id]/messages (admin)
        // Pour l'instant on utilise un fetch direct sur public avec le phone connu (récupéré de orders[id])
      } catch (e) { /* ignore */ }
    }

    // Vrai fetch messages côté admin : on passe par /api/orders/[id]/public avec phone last4
    async function loadChatForCard(id) {
      var o = orders[id];
      if (!o || !o.phone) return;
      var phone4 = String(o.phone).replace(/\D/g, '').slice(-4);
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/public?phone=' + phone4, {
          cache: 'no-store',
        });
        var data = await res.json();
        if (!data.ok) return;
        var container = document.querySelector('[data-chat-messages="' + cssId(id) + '"]');
        if (!container) return;
        renderChatMessages(container, data.messages || []);
        // unread = 0 maintenant (chat ouvert = patron a lu)
        if (o.unread_client_messages) {
          o.unread_client_messages = 0;
          // Update badge UI
          var toggle = document.querySelector('[data-action="toggle-chat"][data-id="' + cssId(id) + '"]');
          if (toggle) {
            var badge = toggle.querySelector('.unread-badge');
            if (badge) badge.remove();
          }
        }
      } catch (e) { /* ignore */ }
    }

    function cssId(id) {
      return String(id).replace(/[^A-Za-z0-9_-]/g, '');
    }

    function renderChatMessages(container, messages) {
      var html = '';
      messages.forEach(function(m) {
        var d = new Date(m.created_at);
        var time = String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0');
        var who, cls, text;
        if (m.sender === 'patron') {
          who = t.chatFromPatron; cls = 'from-patron'; text = m.text;
        } else if (m.sender === 'client') {
          who = t.chatFromClient; cls = 'from-client'; text = m.text;
        } else {
          // system : 'accepted:25' ou 'eta:30' ou 'eta:30:embouteillage'
          cls = 'from-system';
          who = '';
          var raw = String(m.text || '');
          if (raw.indexOf('accepted:') === 0) {
            text = t.chatSystemAccepted + raw.slice(9) + ' ' + t.min;
          } else if (raw.indexOf('eta:') === 0) {
            var parts = raw.slice(4).split(':');
            text = t.chatSystemEta + parts[0] + ' ' + t.min + (parts[1] ? ' (' + parts[1] + ')' : '');
          } else {
            text = raw;
          }
        }
        html += '<div class="chat-msg ' + cls + '">'
          + (who ? '<div style="font-size:0.7rem;opacity:0.7;margin-bottom:0.2rem;">' + escapeHtml(who) + '</div>' : '')
          + escapeHtml(text)
          + '<div class="meta">' + time + '</div>'
          + '</div>';
      });
      container.innerHTML = html;
      // scroll to bottom
      container.scrollTop = container.scrollHeight;
    }

    async function toggleChat(id) {
      // On redirige le toggle chat sur les onglets flottants Messenger-style
      openFloatingChat(id);
    }

    // ═══ ONGLETS CHAT FLOTTANTS (Messenger-style) ═══
    var chatTabs = {};       // id -> { minimized: bool, lastMsgId: number, polling: int, lastSeenAt: number }
    var chatTabsHost = document.getElementById('chat-tabs-host');
    var MAX_OPEN_TABS = 4;
    var MAX_MOBILE_TABS = 6;

    function isMobileLayout() {
      return window.matchMedia && window.matchMedia('(max-width: 768px)').matches;
    }

    function openFloatingChat(id) {
      if (!chatTabsHost) return;
      var order = orders[id];
      // Si la commande n'est plus active, on regarde dans history (pour ouverture depuis carte de toute façon présente côté DOM)
      if (!order) {
        var h = historyRows.find(function(r) { return r.id === id; });
        if (h) order = h;
      }
      if (!order) return;

      if (chatTabs[id]) {
        // Déjà ouvert : on l'expand
        chatTabs[id].minimized = false;
        renderFloatingTabs();
        return;
      }

      // Limite : si trop d'onglets, on ferme le plus vieux (qui n'a pas d'unread)
      var openIds = Object.keys(chatTabs);
      var max = isMobileLayout() ? MAX_MOBILE_TABS : MAX_OPEN_TABS;
      if (openIds.length >= max) {
        // Cherche le premier sans unread, sinon le premier
        var toClose = openIds.find(function(k) { return !chatTabs[k]._unread; }) || openIds[0];
        closeFloatingChat(toClose, true);
      }

      chatTabs[id] = {
        minimized: false,
        lastMsgId: 0,
        polling: 0,
        _unread: 0,
        _name: order.name || '',
        _phone: order.phone || '',
      };
      renderFloatingTabs();
      // Fetch messages immédiatement
      fetchTabMessages(id, true);
      // Polling 4s
      chatTabs[id].polling = setInterval(function() {
        if (chatTabs[id]) fetchTabMessages(id, false);
      }, 4000);
    }

    function closeFloatingChat(id, silent) {
      if (!chatTabs[id]) return;
      if (chatTabs[id].polling) clearInterval(chatTabs[id].polling);
      delete chatTabs[id];
      renderFloatingTabs();
      if (!silent) updateGlobalUnreadBadge();
    }

    function toggleMinimizeFloatingChat(id) {
      if (!chatTabs[id]) return;
      chatTabs[id].minimized = !chatTabs[id].minimized;
      if (!chatTabs[id].minimized) {
        // Lire les messages -> reset unread
        chatTabs[id]._unread = 0;
      }
      renderFloatingTabs();
    }

    function initialOf(name) {
      var s = String(name || '?').trim();
      return s ? s.charAt(0).toUpperCase() : '?';
    }

    function renderFloatingTabs() {
      if (!chatTabsHost) return;
      var ids = Object.keys(chatTabs);
      var html = '';
      ids.forEach(function(id) {
        var c = chatTabs[id];
        var av = initialOf(c._name);
        var unread = c._unread || 0;
        var unreadHtml = unread > 0 ? '<span class="ftab-unread">' + unread + '</span>' : '<span class="ftab-unread hidden">0</span>';
        html += '<div class="ftab' + (c.minimized ? ' min' : '') + '" data-tab-id="' + escapeHtml(id) + '">'
          + '<div class="ftab-head" data-act-tab="toggle" data-id="' + escapeHtml(id) + '">'
            + '<span class="av">' + escapeHtml(av) + '</span>'
            + '<div class="who">'
              + '<div class="nm">' + escapeHtml(c._name || '—') + '</div>'
              + '<div class="id">' + escapeHtml(id) + '</div>'
            + '</div>'
            + unreadHtml
            + '<button type="button" class="ftab-min" data-act-tab="min" data-id="' + escapeHtml(id) + '" aria-label="Minimize">' + (c.minimized ? '▴' : '▾') + '</button>'
            + '<button type="button" class="ftab-close" data-act-tab="close" data-id="' + escapeHtml(id) + '" aria-label="Close">×</button>'
          + '</div>'
          + '<div class="ftab-body" data-ftab-body="' + escapeHtml(id) + '">'
            + '<div class="ftab-loader">' + escapeHtml(t.chatLoading) + '</div>'
          + '</div>'
          + '<div class="ftab-foot">'
            + '<div class="ftab-templates">'
              + '<button type="button" class="tpl" data-act-tab="tpl" data-id="' + escapeHtml(id) + '" data-tpl="' + escapeHtml(t.chatAccepted) + '">✓ ' + escapeHtml(lang === 'el' ? 'Σε προετοιμασία' : 'Preparing') + '</button>'
              + '<button type="button" class="tpl" data-act-tab="tpl" data-id="' + escapeHtml(id) + '" data-tpl="' + escapeHtml(lang === 'el' ? 'Ο διανομέας είναι καθ\'οδόν.' : 'Courier is on the way.') + '">🛵 ' + escapeHtml(lang === 'el' ? 'Καθ\'οδόν' : 'On the way') + '</button>'
              + '<button type="button" class="tpl" data-act-tab="tpl" data-id="' + escapeHtml(id) + '" data-tpl="' + escapeHtml(lang === 'el' ? 'Συγγνώμη, μικρή καθυστέρηση.' : 'Sorry, small delay.') + '">⏰ ' + escapeHtml(lang === 'el' ? 'Καθυστέρηση' : 'Delay') + '</button>'
              + '<button type="button" class="tpl" data-act-tab="tpl" data-id="' + escapeHtml(id) + '" data-tpl="' + escapeHtml(lang === 'el' ? 'Η παραγγελία είναι έτοιμη!' : 'Your order is ready!') + '">✅ ' + escapeHtml(lang === 'el' ? 'Έτοιμο' : 'Ready') + '</button>'
            + '</div>'
            + '<form class="ftab-input-row" data-act-tab="form" data-id="' + escapeHtml(id) + '">'
              + '<input type="text" data-ftab-input="' + escapeHtml(id) + '" placeholder="' + escapeHtml(t.chatPlaceholderShort) + '" maxlength="500" autocomplete="off" />'
              + '<button type="submit" class="send" aria-label="Send">➤</button>'
            + '</form>'
          + '</div>'
        + '</div>';
      });
      chatTabsHost.innerHTML = html;
      chatTabsHost.classList.toggle('has-open', ids.some(function(id) { return !chatTabs[id].minimized; }));
      // Pour chaque onglet expand: charger messages déjà fetched
      ids.forEach(function(id) {
        if (chatTabs[id]._cachedMessages) {
          var body = document.querySelector('[data-ftab-body="' + cssId(id) + '"]');
          if (body) renderTabBubbles(body, chatTabs[id]._cachedMessages);
        }
      });
    }

    function renderTabBubbles(container, messages) {
      if (!messages || messages.length === 0) {
        container.innerHTML = '<div class="ftab-loader">' + escapeHtml(t.chatEmpty) + '</div>';
        return;
      }
      var html = '';
      messages.forEach(function(m, idx) {
        var cls = '';
        var text = m.text || '';
        if (m.sender === 'patron') cls = 'from-patron';
        else if (m.sender === 'client') cls = 'from-client';
        else {
          cls = 'from-system';
          var raw = String(text);
          if (raw.indexOf('accepted:') === 0) {
            var rest = raw.slice(9); var parts = rest.split(':');
            text = t.chatSystemAccepted + parts[0] + ' ' + t.min + (parts[1] ? ' + ' + parts[1] + ' ' + t.min : '');
          } else if (raw.indexOf('eta:') === 0) {
            var rs = raw.slice(4); var pp = rs.split(':');
            text = t.chatSystemEta + pp[0] + ' ' + t.min + (pp[1] && /\D/.test(pp[1]) ? ' (' + pp[1] + ')' : '');
          }
        }
        var d = new Date(m.created_at);
        var time = String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0');
        var showTime = (idx === messages.length - 1)
          || (messages[idx+1] && messages[idx+1].sender !== m.sender)
          || (messages[idx+1] && (messages[idx+1].created_at - m.created_at > 5*60*1000));
        html += '<div class="b-wrap ' + cls + '">'
          + '<div class="bubble ' + cls + '">' + escapeHtml(text) + '</div>'
          + (showTime ? '<div class="b-time">' + time + '</div>' : '')
        + '</div>';
      });
      container.innerHTML = html;
      container.scrollTop = container.scrollHeight;
    }

    async function fetchTabMessages(id, firstLoad) {
      if (!chatTabs[id]) return;
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/messages', {
          credentials: 'include', cache: 'no-store',
        });
        if (!res.ok) return;
        var data = await res.json();
        if (!data.ok) return;
        var msgs = data.messages || [];
        var prev = chatTabs[id]._cachedMessages || [];
        var prevLastId = prev.length ? prev[prev.length-1].id : 0;
        var lastMsg = msgs.length ? msgs[msgs.length-1] : null;
        // Detect new client messages depuis dernier fetch
        var newClient = 0;
        msgs.forEach(function(m) {
          if (m.sender === 'client' && m.id > prevLastId) newClient++;
        });
        chatTabs[id]._cachedMessages = msgs;

        // Si l'onglet est minimisé et qu'on a recu un message client, increment unread + son
        if (chatTabs[id].minimized && newClient > 0 && !firstLoad) {
          chatTabs[id]._unread = (chatTabs[id]._unread || 0) + newClient;
          if (soundOn) beep();
          updateGlobalUnreadBadge();
        }
        var body = document.querySelector('[data-ftab-body="' + cssId(id) + '"]');
        if (body) renderTabBubbles(body, msgs);
        // Met à jour le badge unread sur le head
        var headUnread = document.querySelector('[data-tab-id="' + cssId(id) + '"] .ftab-unread');
        if (headUnread) {
          var u = chatTabs[id]._unread || 0;
          if (u > 0 && chatTabs[id].minimized) { headUnread.textContent = String(u); headUnread.classList.remove('hidden'); }
          else { headUnread.classList.add('hidden'); }
        }
      } catch (e) { /* ignore */ }
    }

    async function sendTabMessage(id) {
      if (!chatTabs[id]) return;
      var input = document.querySelector('[data-ftab-input="' + cssId(id) + '"]');
      if (!input) return;
      var text = (input.value || '').trim();
      if (!text) return;
      var send = input.parentElement.querySelector('.send');
      if (send) send.disabled = true;
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/message-patron', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: text }),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'fail');
        input.value = '';
        await fetchTabMessages(id, false);
      } catch (err) {
        alert(t.actionError + (err && err.message ? err.message : err));
      } finally {
        if (send) send.disabled = false;
        input.focus();
      }
    }

    // Delegation events on chat tabs host
    if (chatTabsHost) {
      chatTabsHost.addEventListener('click', function(e) {
        var el = e.target;
        if (!(el instanceof Element)) return;
        var actEl = el.closest('[data-act-tab]');
        if (!actEl) return;
        var act = actEl.getAttribute('data-act-tab');
        var id = actEl.getAttribute('data-id');
        if (!id) return;
        if (act === 'close') { e.stopPropagation(); closeFloatingChat(id); }
        else if (act === 'min') { e.stopPropagation(); toggleMinimizeFloatingChat(id); }
        else if (act === 'toggle') { toggleMinimizeFloatingChat(id); }
        else if (act === 'tpl') {
          var tpl = actEl.getAttribute('data-tpl');
          var inp = document.querySelector('[data-ftab-input="' + cssId(id) + '"]');
          if (inp && tpl) { inp.value = tpl; inp.focus(); }
        }
      });
      chatTabsHost.addEventListener('submit', function(e) {
        var el = e.target;
        if (!(el instanceof Element)) return;
        var f = el.closest('[data-act-tab="form"]');
        if (!f) return;
        e.preventDefault();
        var id = f.getAttribute('data-id');
        if (id) sendTabMessage(id);
      });
    }

    // Esc ferme le dernier onglet ouvert (non minimisé) -- en priorité après modals
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      // Ne pas court-circuiter si un modal est déjà ouvert (gestion existante prend la main)
      var modalsOpen = document.querySelectorAll('.modal-back.show').length > 0;
      if (modalsOpen) return;
      var ids = Object.keys(chatTabs);
      // ferme le premier expand
      var openId = ids.find(function(k) { return !chatTabs[k].minimized; });
      if (openId) closeFloatingChat(openId);
    });

    // ═══ Decline modal ═══
    var declineModal = document.getElementById('decline-modal');
    var declineReasonEl = document.getElementById('decline-reason');
    var declineConfirmBtn = document.getElementById('decline-confirm');
    var declineCancelBtn = document.getElementById('decline-cancel');
    var declineCloseX = document.getElementById('decline-close-x');
    var declineSubEl = document.getElementById('decline-sub');
    var pendingDeclineId = null;

    function openDeclineModal(id) {
      pendingDeclineId = id;
      var o = orders[id];
      var name = o ? (o.name || '') : '';
      if (declineSubEl) declineSubEl.textContent = t.declineSub + ' ' + id + (name ? ' — ' + name : '');
      if (declineReasonEl) declineReasonEl.value = '';
      if (declineModal) declineModal.classList.add('show');
      setTimeout(function() { if (declineReasonEl) declineReasonEl.focus(); }, 50);
    }
    function closeDeclineModal() {
      if (declineModal) declineModal.classList.remove('show');
      pendingDeclineId = null;
    }
    async function confirmDecline() {
      if (!pendingDeclineId) return;
      var id = pendingDeclineId;
      var reason = declineReasonEl ? declineReasonEl.value.trim() : '';
      try {
        // 1. Envoie message au client (avant le status pour que la commande existe encore)
        var msgText = t.declineSystemMsg + (reason ? ' (' + reason + ')' : '');
        await fetch('/api/orders/' + encodeURIComponent(id) + '/message-patron', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: msgText }),
        }).catch(function(){});
        // 2. Mise à jour status
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/status', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'cancelled' }),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'fail');
        delete orders[id];
        closeDeclineModal();
        renderOrders();
        fetchHistory();
      } catch (err) {
        alert(t.actionError + (err && err.message ? err.message : err));
      }
    }
    if (declineConfirmBtn) declineConfirmBtn.addEventListener('click', confirmDecline);
    if (declineCancelBtn) declineCancelBtn.addEventListener('click', closeDeclineModal);
    if (declineCloseX) declineCloseX.addEventListener('click', closeDeclineModal);
    if (declineModal) declineModal.addEventListener('click', function(e) {
      if (e.target === declineModal) closeDeclineModal();
    });
    if (declineReasonEl) declineReasonEl.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); confirmDecline(); }
    });
    // Esc decline (priorité sur les autres modals — handled separately in existing listener)
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && declineModal && declineModal.classList.contains('show')) {
        closeDeclineModal();
      }
    });

    // ═══ Badge global non-lus (additionne unread sur orders actifs) ═══
    async function fetchGlobalUnread() {
      try {
        var res = await fetch('/api/orders/messages-summary', { credentials: 'include', cache: 'no-store' });
        if (!res.ok) return;
        var data = await res.json();
        if (!data.ok) return;
        var totalConv = 0;
        (data.conversations || []).forEach(function(c) {
          if (Number(c.unread_client) > 0) totalConv++;
        });
        var badge = document.getElementById('global-unread-badge');
        if (badge) {
          if (totalConv > 0) { badge.textContent = String(totalConv); badge.classList.remove('hidden'); }
          else { badge.classList.add('hidden'); }
        }
      } catch (e) { /* ignore */ }
    }
    function updateGlobalUnreadBadge() {
      // Recompte rapide depuis chatTabs cachés + appel API soft
      fetchGlobalUnread();
    }
    setInterval(fetchGlobalUnread, 12000);

    async function sendChatMessage(id) {
      var input = document.querySelector('[data-chat-input="' + cssId(id) + '"]');
      if (!input) return;
      var text = (input.value || '').trim();
      if (!text) return;
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/message-patron', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: text }),
        });
