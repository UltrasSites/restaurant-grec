    // ═══ doAction dispatcher (toutes les actions sur cartes + history) ═══
    async function doAction(id, action) {
      if (action === 'open-accept') return openAcceptModal(id);
      if (action === 'open-decline') return openDeclineModal(id);
      if (action === 'open-eta') return openEtaModal(id);
      if (action === 'toggle-chat') return toggleChat(id);
      if (action === 'send-msg') return sendChatMessage(id);
      if (action === 'hist-print') return printOneHistory(id);
      if (action === 'hist-delete') return deleteHistoryRow(id);

      var btn = document.querySelector('button[data-action="' + action + '"][data-id="' + id + '"]');
      if (btn) { btn.disabled = true; btn.dataset.prev = btn.textContent; btn.textContent = '…'; }
      try {
        if (action === 'ready' || action === 'paid' || action === 'cancelled') {
          var res2 = await fetch('/api/orders/' + encodeURIComponent(id) + '/status', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: action })
          });
          var data2 = await res2.json();
          if (!res2.ok || !data2.ok) throw new Error(data2.error || 'fail');
          // sort de l'écran actif et apparaît dans l'history au prochain refresh
          delete orders[id];
          renderOrders();
          fetchHistory();
        }
      } catch (err) {
        if (btn) {
          btn.disabled = false;
          btn.textContent = btn.dataset.prev || '';
        }
        alert(t.actionError + (err && err.message ? err.message : err));
      }
    }

    function onActionClick(e) {
      var el = e.target;
      if (!(el instanceof Element)) return;
      // remonte jusqu'au [data-action] le plus proche
      var actionEl = el.closest ? el.closest('[data-action]') : null;
      if (!actionEl) return;
      var action = actionEl.getAttribute('data-action');
      var id = actionEl.getAttribute('data-id');
      if (!action || !id) return;
      doAction(id, action);
    }
    listPending.addEventListener('click', onActionClick);
    listPrep.addEventListener('click', onActionClick);
    if (listHistory) listHistory.addEventListener('click', onActionClick);
    // Enter dans chat input pour envoyer
    function onChatKeydown(e) {
      if (e.key !== 'Enter') return;
      var el = e.target;
      if (!el || !el.getAttribute) return;
      var id = el.getAttribute('data-chat-input');
      if (id) { e.preventDefault(); sendChatMessage(id); }
    }
    listPending.addEventListener('keydown', onChatKeydown);
    listPrep.addEventListener('keydown', onChatKeydown);

    // Buttons history actions globales
    if (histRefresh) histRefresh.addEventListener('click', fetchHistory);
    if (histPrintAll) histPrintAll.addEventListener('click', printAllHistory);

    // ═══ MOBILE TABS + TABLET DRAWER ═══
    function setActiveTab(tab) {
      try { localStorage.setItem('caisse_active_tab', tab); } catch (e) {}
      var tabs = document.querySelectorAll('.mobile-tab');
      tabs.forEach(function(b) { b.classList.toggle('active', b.getAttribute('data-tab') === tab); });
      var cols = document.querySelectorAll('.column');
      cols.forEach(function(c) { c.classList.toggle('active', c.getAttribute('data-col') === tab); });
    }
    function getActiveTab() {
      try { return localStorage.getItem('caisse_active_tab') || 'pending'; }
      catch (e) { return 'pending'; }
    }
    var mobileTabsNav = document.getElementById('mobile-tabs');
    if (mobileTabsNav) {
      mobileTabsNav.addEventListener('click', function(e) {
        var btn = e.target && e.target.closest ? e.target.closest('.mobile-tab') : null;
        if (!btn) return;
        var tab = btn.getAttribute('data-tab');
        if (tab) setActiveTab(tab);
      });
    }
    // Restore last tab on mobile
    if (window.matchMedia && window.matchMedia('(max-width: 768px)').matches) {
      setActiveTab(getActiveTab());
    } else {
      // Desktop/tablet: ensure pending col is "active" (used as default on mobile when resized)
      setActiveTab('pending');
    }
    // Re-evaluate active tab visibility on resize between mobile/desktop
    window.addEventListener('resize', function() {
      if (window.matchMedia('(max-width: 768px)').matches) {
        setActiveTab(getActiveTab());
      }
    });

    // Tablet history drawer toggle (clicking col-head opens/closes)
    var colHistoryHead = document.getElementById('col-history-head');
    if (colHistoryHead) {
      colHistoryHead.addEventListener('click', function() {
        var col = document.querySelector('.col-history');
        if (!col) return;
        // Only toggle drawer behavior on tablet width
        if (window.matchMedia('(max-width: 1199px) and (min-width: 769px)').matches) {
          col.classList.toggle('drawer-open');
        }
      });
    }

    async function pollLoop() {
      if (polling) return;
      polling = true;
      while (polling) {
        try {
          var res = await fetch('/api/orders/poll?since=' + encodeURIComponent(since), {
            credentials: 'include',
            cache: 'no-store'
          });
          if (res.status === 401) {
            polling = false;
            showLogin();
            return;
          }
          var data = await res.json();
          connEl.classList.remove('disconnected');
          if (data && Array.isArray(data.orders)) {
            // Le poll renvoie l'état COMPLET des commandes actives
            // (status IN 'new','seen' depuis 24h). On reconstruit l'index local.
            var nextOrders = {};
            data.orders.forEach(function(o) { nextOrders[o.id] = o; });
            orders = nextOrders;
            if (typeof data.now === 'number') since = data.now;
            renderOrders();
          }
        } catch (err) {
          connEl.classList.add('disconnected');
          await new Promise(function(r) { setTimeout(r, 3000); });
        }
        await new Promise(function(r) { setTimeout(r, 500); });
      }
    }

    function showDashboard() {
      loginScreen.style.display = 'none';
      dashboard.classList.add('show');
      ensureAudio();
      pollLoop();
      // Démarre le polling history (toutes les 30s) + fetch immédiat
      fetchHistory();
      if (historyPollTimer) clearInterval(historyPollTimer);
      historyPollTimer = setInterval(fetchHistory, historyPollIntervalMs);
    }
    function showLogin() {
      polling = false;
      if (historyPollTimer) { clearInterval(historyPollTimer); historyPollTimer = null; }
      loginScreen.style.display = 'flex';
      dashboard.classList.remove('show');
      // Focus sur le champ password (élément masqué initialement → ne pas autofocus dans le HTML)
      setTimeout(function() {
        var pw = document.getElementById('login-pw');
        if (pw) pw.focus();
      }, 50);
    }

    loginForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var pw = document.getElementById('login-pw').value;
      loginError.style.display = 'none';
      try {
        var res = await fetch('/api/caisse-login', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: pw })
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'Wrong password');
        // Session unifiée 2h : zéro re-prompt entre pages /cashd/*.
        // refresh auto à chaque event utilisateur (cf. cashd-auth.js).
        try { window.cashdAuth.setSession(pw); } catch(e) {}
        showDashboard();
      } catch (err) {
        var msg = (err && err.message) || t.loginErrorDefault;
        if (/wrong\s*password/i.test(msg)) msg = t.loginErrorWrong;
        loginError.textContent = msg;
        loginError.style.display = 'block';
      }
    });

    // Auto-tentative : si déjà cookie valide ET poll ok, on va direct sur le dashboard.
    // IMPORTANT : si poll renvoie 500 (server error) mais qu'on a une session 2h valide,
    // on AFFICHE le dashboard quand meme (le cookie est probablement OK, poll est juste cassé).
    // On force showLogin UNIQUEMENT si poll renvoie 401 ET bootAuth echoue.
    async function tryAutoReauthThenPoll() {
      var hasSession = false;
      try { hasSession = !!window.cashdAuth.getSession(); } catch (e) {}
      try {
        var r = await fetch('/api/orders/poll?since=0', { credentials: 'include', cache: 'no-store' });
        if (r.status === 200) {
          var d = null;
          try { d = await r.json(); } catch (e) { d = null; }
          if (d && d.ok) {
            if (Array.isArray(d.orders)) {
              var pre = {};
              d.orders.forEach(function(o) { pre[o.id] = o; });
              orders = pre;
              if (typeof d.now === 'number') since = d.now;
            }
            applyI18n();
            showDashboard();
            renderOrders();
            return;
          }
        }
        // Si poll renvoie 401 → cookie drop, tente bootAuth
        if (r.status === 401) {
          var ok = false;
          try { ok = await window.cashdAuth.bootAuth(); } catch (e) {}
          if (ok) {
            // re-poll après login auto
            try {
              var r2 = await fetch('/api/orders/poll?since=0', { credentials: 'include', cache: 'no-store' });
              if (r2.status === 200) {
                var d2 = await r2.json();
                if (d2 && d2.ok) {
                  if (Array.isArray(d2.orders)) {
                    var pre2 = {};
                    d2.orders.forEach(function(o) { pre2[o.id] = o; });
                    orders = pre2;
                    if (typeof d2.now === 'number') since = d2.now;
                  }
                  applyI18n();
                  showDashboard();
                  renderOrders();
                  return;
                }
              }
              // Poll plante apres bootAuth ok → affiche quand meme dashboard (vide, refresh prendra le relais)
              applyI18n();
              showDashboard();
              return;
            } catch (e) {
              // Idem : bootAuth ok, poll fail → dashboard quand meme
              applyI18n();
              showDashboard();
              return;
            }
          }
        }
        // Poll renvoie 500/autre : si on a une session 2h valide → dashboard quand meme
        // (la session a un cookie probablement valide ; poll cassé != desauth)
        if (hasSession && r.status !== 401) {
          applyI18n();
          showDashboard();
          return;
        }
        applyI18n();
        showLogin();
      } catch (e) {
        applyI18n();
        showLogin();
      }
    }
    tryAutoReauthThenPoll();

    // Service Worker pour PWA (best-effort)
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/caisse-sw.js').catch(function(){});
    }
  })();
  </script>
</body>
</html>
