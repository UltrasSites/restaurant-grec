---
// Σελίδα ταμείου — για τον υπάλληλο / το αφεντικό (στα ελληνικά).
// Δεν συνδέεται με το i18n του δημόσιου site.
import CashdNav from "../../components/cashd/CashdNav.astro";
import CashdAuthScript from "../../components/cashd/CashdAuthScript.astro";
---
<!doctype html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Ταμείο — Καλαμάκι Της Τρούμπας</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <CashdAuthScript />
  <style>
    :root { --gold: #E5B32A; --bg: #0a0a0a; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: var(--bg); color: #fff; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; min-height: 100vh; }
    body { overflow-x: hidden; }

    /* ====== LOGIN ====== */
    .login-wrap {
      position: fixed; inset: 0; z-index: 200;
      background: var(--bg);
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center; padding: 2rem;
      margin-left: -220px; /* compense le padding-left du body desktop */
    }
    @media (max-width: 768px) {
      .login-wrap { margin-left: 0; margin-top: -52px; }
    }
    .login-box {
      width: 100%; max-width: 380px;
      background: #111; border: 1px solid rgba(229,179,42,0.3);
      border-radius: 1rem; padding: 2rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .login-box h1 { margin: 0 0 1.5rem; font-size: 1.25rem; color: var(--gold); text-align: center; letter-spacing: 0.05em; }
    .login-box input {
      width: 100%; padding: 0.9rem 1rem;
      background: #000; border: 1.5px solid rgba(255,255,255,0.15);
      border-radius: 0.5rem; color: #fff; font-size: 1rem;
      margin-bottom: 1rem;
    }
    .login-box input:focus { outline: none; border-color: var(--gold); }
    .login-box button[type="submit"] {
      width: 100%; padding: 0.9rem; background: var(--gold); color: #000;
      border: none; border-radius: 0.5rem; font-weight: 800; font-size: 0.95rem;
      letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;
    }
    .login-box button[type="submit"]:hover { background: #fff; }
    .login-error { color: #ef4444; font-size: 0.85rem; margin-top: 0.75rem; text-align: center; }

    /* ====== DASHBOARD ====== */
    .dashboard { display: none; min-height: 100vh; flex-direction: column; }
    .dashboard.show { display: flex; }
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.5rem; background: #000;
      border-bottom: 2px solid rgba(229,179,42,0.4);
      position: sticky; top: 0; z-index: 10;
    }
    .topbar h1 { margin: 0; font-size: 1.1rem; color: var(--gold); letter-spacing: 0.05em; }
    .topbar .status {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.85rem; color: #aaa;
      flex-wrap: wrap; justify-content: flex-end;
    }
    .status .dot { width: 10px; height: 10px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px #22c55e; }
    .status.disconnected .dot { background: #ef4444; box-shadow: 0 0 8px #ef4444; }
    .clock { font-variant-numeric: tabular-nums; font-weight: 700; color: #fff; }

    .orders-area { flex: 1; padding: 1.25rem; }

    /* ====== 3 colonnes : En attente | En préparation | Historique ====== */
    .columns {
      display: grid;
      grid-template-columns: 1.1fr 1.1fr 0.85fr;
      gap: 1.25rem;
      max-width: 1900px; margin: 0 auto;
    }
    .column { display: flex; flex-direction: column; gap: 1rem; min-width: 0; }
    .col-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.85rem 1.1rem; border-radius: 0.85rem;
      font-size: 1.1rem; font-weight: 900; letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .col-head .count {
      background: rgba(0,0,0,0.35); padding: 0.15rem 0.65rem;
      border-radius: 999px; font-size: 0.9rem; min-width: 2.2rem; text-align: center;
    }
    .col-pending .col-head { background: rgba(239,68,68,0.18); color: #fca5a5; border: 2px solid rgba(239,68,68,0.55); }
    .col-prep .col-head    { background: rgba(229,179,42,0.18); color: var(--gold); border: 2px solid rgba(229,179,42,0.55); }
    .col-history .col-head { background: rgba(148,163,184,0.15); color: #cbd5e1; border: 2px solid rgba(148,163,184,0.45); }

    /* History column : scroll indépendant */
    .col-history { max-height: calc(100vh - 8rem); }
    .col-history .col-body {
      flex: 1; overflow-y: auto;
      background: #0d0d0d; border: 1px solid rgba(255,255,255,0.06);
      border-radius: 0.7rem; padding: 0.5rem;
    }
    .history-actions { display: flex; gap: 0.4rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .history-actions .btn-mini {
      padding: 0.4rem 0.7rem; font-size: 0.78rem;
      background: #1a1a1a; color: #cbd5e1;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.4rem; cursor: pointer;
      font-weight: 700;
    }
    .history-actions .btn-mini:hover { background: #222; color: #fff; }
    .history-actions .lang-toggle-mini {
      padding: 0.4rem 0.5rem; font-size: 0.78rem;
      background: #1a1a1a; color: #cbd5e1;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.4rem; cursor: pointer;
      font-weight: 700;
      display: inline-flex; align-items: center; gap: 0.3rem;
    }
    .history-actions .lang-toggle-mini img {
      width: 12px; height: 9px; object-fit: cover; border-radius: 2px;
    }

    .hist-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0.45rem;
      padding: 0.55rem 0.65rem;
      border-radius: 0.5rem;
      background: rgba(0,0,0,0.35);
      border: 1px solid rgba(255,255,255,0.04);
      margin-bottom: 0.35rem;
      font-size: 0.82rem;
      align-items: center;
    }
    .hist-row:hover { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
    .hist-row .h-id { color: var(--gold); font-weight: 800; font-size: 0.82rem; }
    .hist-row .h-name { color: #fff; font-weight: 600; font-size: 0.85rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .hist-row .h-meta { color: #888; font-size: 0.72rem; margin-top: 0.1rem; }
    .hist-row .h-total { color: var(--gold); font-weight: 700; text-align: right; white-space: nowrap; font-size: 0.85rem; }
    .hist-row .h-status {
      display: inline-block; padding: 0.1rem 0.45rem;
      border-radius: 999px; font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.04em; text-transform: uppercase;
      margin-top: 0.15rem;
    }
    .hist-row .h-status.s-paid { background: rgba(34,197,94,0.15); color: #4ade80; }
    .hist-row .h-status.s-ready { background: rgba(96,165,250,0.15); color: #60a5fa; }
    .hist-row .h-status.s-cancelled { background: rgba(239,68,68,0.15); color: #f87171; }
    .hist-row .h-actions { display: flex; gap: 0.3rem; margin-top: 0.3rem; }
    .hist-row .h-act {
      width: 28px; height: 28px; border-radius: 0.35rem;
      border: 1px solid rgba(255,255,255,0.1);
      background: transparent; color: #888;
      cursor: pointer; font-size: 0.85rem;
      display: inline-flex; align-items: center; justify-content: center;
    }
    .hist-row .h-act:hover { color: #fff; background: rgba(255,255,255,0.06); }
    .hist-row .h-act.danger:hover { color: #f87171; border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); }
    .hist-empty { color: #555; text-align: center; padding: 2rem 1rem; font-size: 0.85rem; }

    /* ====== POPUPS (acceptation temps + modif ETA) ====== */
    .modal-back {
      position: fixed; inset: 0; background: rgba(0,0,0,0.7);
      backdrop-filter: blur(4px);
      display: none; align-items: center; justify-content: center;
      padding: 1rem; z-index: 100;
    }
    .modal-back.show { display: flex; }
    .modal {
      width: 100%; max-width: 460px;
      background: #111; border: 1px solid rgba(229,179,42,0.4);
      border-radius: 1rem; padding: 1.5rem;
      box-shadow: 0 30px 80px rgba(0,0,0,0.7);
      position: relative;
    }
    .modal-close-x {
      position: absolute; top: 0.5rem; right: 0.5rem;
      width: 40px; height: 40px;
      background: transparent; color: rgba(255,255,255,0.6);
      border: none; font-size: 1.5rem; cursor: pointer;
      border-radius: 50%; transition: all 0.2s;
      display: flex; align-items: center; justify-content: center;
      line-height: 1;
      z-index: 2;
    }
    .modal-close-x:hover { background: rgba(239,68,68,0.15); color: #ef4444; }
    @media (max-width: 768px) {
      .modal-close-x { width: 48px; height: 48px; font-size: 1.75rem; top: 0.75rem; right: 0.75rem; }
    }
    .modal h2 {
      margin: 0 0 0.5rem; color: var(--gold);
      font-size: 1.1rem; letter-spacing: 0.05em;
    }
    .modal .modal-sub { color: #999; font-size: 0.85rem; margin-bottom: 1rem; }
    .modal .time-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0.6rem; margin-bottom: 0.85rem;
    }
    .modal .time-btn {
      padding: 1rem 0.5rem; border-radius: 0.6rem;
      background: rgba(229,179,42,0.12); color: var(--gold);
      border: 2px solid rgba(229,179,42,0.4);
      font-weight: 900; font-size: 1.15rem; cursor: pointer;
      transition: all 0.12s;
    }
    .modal .time-btn:hover { background: var(--gold); color: #000; }
    .modal .custom-row {
      display: flex; gap: 0.5rem; align-items: stretch;
      margin-bottom: 1rem;
    }
    .modal .custom-row input {
      flex: 1; padding: 0.85rem 1rem;
      background: #000; color: #fff;
      border: 2px solid rgba(255,255,255,0.15);
      border-radius: 0.5rem; font-size: 1rem;
    }
    .modal .custom-row input:focus { outline: none; border-color: var(--gold); }
    .modal .custom-row button {
      padding: 0.85rem 1.2rem;
      background: var(--gold); color: #000;
      border: none; border-radius: 0.5rem;
      font-weight: 900; cursor: pointer;
    }
    .modal .reason-row {
      margin-bottom: 1rem;
    }
    .modal .reason-row input {
      width: 100%; padding: 0.7rem 1rem;
      background: #000; color: #fff;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.5rem; font-size: 0.9rem;
    }
    .modal .modal-actions {
      display: flex; gap: 0.5rem; justify-content: flex-end;
    }
    .modal .btn-cancel {
      padding: 0.7rem 1.2rem;
      background: transparent; color: #999;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.5rem; cursor: pointer;
    }
    .modal .btn-cancel:hover { color: #fff; }

    /* ====== Bouton "Modifier temps" (sur carte prep) ====== */
    .btn-eta {
      background: linear-gradient(180deg, #6366f1 0%, #4338ca 100%);
      box-shadow: 0 6px 16px rgba(99,102,241,0.4);
    }
    .btn-eta:hover { background: linear-gradient(180deg, #818cf8 0%, #6366f1 100%); }

    /* ====== CHAT par carte ====== */
    .chat-wrap {
      margin-top: 0.85rem;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 0.6rem;
      background: rgba(0,0,0,0.35);
      overflow: hidden;
    }
    .chat-toggle {
      width: 100%; padding: 0.7rem 0.85rem;
      background: rgba(99,102,241,0.1); color: #a5b4fc;
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: space-between;
      font-weight: 700; font-size: 0.9rem; letter-spacing: 0.04em;
    }
    .chat-toggle:hover { background: rgba(99,102,241,0.18); color: #c7d2fe; }
    .chat-toggle .unread-badge {
      display: inline-block; min-width: 1.4rem; padding: 0 0.4rem;
      background: #ef4444; color: #fff;
      border-radius: 999px; font-size: 0.75rem;
      font-weight: 800; text-align: center;
    }
    .chat-body { display: none; padding: 0.7rem 0.85rem; }
    .chat-body.open { display: block; }
    .chat-messages {
      max-height: 220px; overflow-y: auto;
      display: flex; flex-direction: column; gap: 0.4rem;
      margin-bottom: 0.6rem;
    }
    .chat-msg {
      max-width: 85%; padding: 0.5rem 0.7rem;
      border-radius: 0.6rem; font-size: 0.88rem; line-height: 1.35;
      word-wrap: break-word;
    }
    .chat-msg.from-patron { align-self: flex-end; background: rgba(229,179,42,0.18); color: var(--gold); border: 1px solid rgba(229,179,42,0.35); }
    .chat-msg.from-client { align-self: flex-start; background: rgba(99,102,241,0.18); color: #c7d2fe; border: 1px solid rgba(99,102,241,0.35); }
    .chat-msg.from-system { align-self: center; background: rgba(255,255,255,0.05); color: #999; font-style: italic; font-size: 0.78rem; border: 1px dashed rgba(255,255,255,0.1); }
    .chat-msg .meta { font-size: 0.65rem; opacity: 0.7; margin-top: 0.15rem; }
    .chat-input-row { display: flex; gap: 0.4rem; }
    .chat-input-row input {
      flex: 1; padding: 0.6rem 0.85rem;
      background: #000; color: #fff;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.45rem; font-size: 0.88rem;
    }
    .chat-input-row input:focus { outline: none; border-color: rgba(99,102,241,0.5); }
    .chat-input-row button {
      padding: 0.6rem 1rem;
      background: rgba(99,102,241,0.25); color: #c7d2fe;
      border: 1px solid rgba(99,102,241,0.4);
      border-radius: 0.45rem; cursor: pointer;
      font-weight: 700; font-size: 0.85rem;
    }
    .chat-input-row button:hover { background: rgba(99,102,241,0.45); color: #fff; }

    .col-empty {
      padding: 2rem 1rem; text-align: center;
      border: 2px dashed rgba(255,255,255,0.08);
      border-radius: 0.85rem; color: #555; font-size: 0.95rem;
    }

    /* ====== CARDS ====== */
    .order-card {
      background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
      border-radius: 1.1rem;
      padding: 1.1rem 1.2rem;
      box-shadow: 0 18px 36px rgba(0,0,0,0.55);
    }
    .card-pending {
      border: 3px solid #ef4444;
      box-shadow: 0 0 0 4px rgba(239,68,68,0.18), 0 18px 36px rgba(0,0,0,0.55);
      animation: pulse-red 1.6s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%, 100% { box-shadow: 0 0 0 4px rgba(239,68,68,0.18), 0 18px 36px rgba(0,0,0,0.55); border-color: #ef4444; }
      50%      { box-shadow: 0 0 0 8px rgba(239,68,68,0.45), 0 18px 44px rgba(0,0,0,0.65); border-color: #ff6666; }
    }
    .card-prep {
      border: 3px solid var(--gold);
      box-shadow: 0 0 0 4px rgba(229,179,42,0.15), 0 18px 36px rgba(0,0,0,0.55);
    }

    /* === Boutons d'action TOUJOURS visibles en haut === */
    .actions {
      display: grid; gap: 0.6rem;
      margin-bottom: 1rem;
    }
    .actions.two { grid-template-columns: 1fr 1fr; }

    .btn-action {
      width: 100%; padding: 1.15rem 0.6rem;
      border: none; border-radius: 0.75rem;
      font-size: 1.15rem; font-weight: 900;
      letter-spacing: 0.06em; text-transform: uppercase;
      cursor: pointer; transition: transform 0.12s, box-shadow 0.18s, filter 0.18s;
      color: #fff;
    }
    .btn-action:hover { transform: translateY(-2px); }
    .btn-action:active { transform: scale(0.98); }
    .btn-action:disabled { opacity: 0.6; cursor: wait; }

    .btn-prepare {
      background: linear-gradient(180deg, #22c55e 0%, #16a34a 100%);
      box-shadow: 0 8px 22px rgba(34,197,94,0.45);
      font-size: 1.35rem; padding: 1.4rem 0.6rem;
    }
    .btn-prepare:hover { box-shadow: 0 12px 28px rgba(34,197,94,0.6); }

    .btn-ready {
      background: linear-gradient(180deg, #4b5563 0%, #1f2937 100%);
      box-shadow: 0 8px 22px rgba(31,41,55,0.55);
    }
    .btn-ready:hover { background: linear-gradient(180deg, #22c55e 0%, #16a34a 100%); box-shadow: 0 12px 28px rgba(34,197,94,0.55); }

    .btn-paid {
      background: linear-gradient(180deg, #E5B32A 0%, #b8901c 100%);
      color: #000;
      box-shadow: 0 8px 22px rgba(229,179,42,0.5);
    }
    .btn-paid:hover { background: linear-gradient(180deg, #22c55e 0%, #16a34a 100%); color: #fff; box-shadow: 0 12px 28px rgba(34,197,94,0.55); }

    .order-head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 0.85rem; }
    .order-id { font-size: 2.2rem; font-weight: 900; color: var(--gold); letter-spacing: 0.05em; line-height: 1; }
    .order-meta { font-size: 0.95rem; color: #ccc; text-align: right; }
    .order-meta .name { font-size: 1.25rem; color: #fff; font-weight: 700; }
    .order-meta .phone { color: var(--gold); font-weight: 700; margin-top: 0.25rem; }

    .order-pickup {
      display: inline-block; padding: 0.35rem 0.8rem;
      background: rgba(229,179,42,0.18); color: var(--gold);
      border: 2px solid var(--gold); border-radius: 999px;
      font-weight: 800; font-size: 0.95rem;
      margin-bottom: 0.85rem;
    }

    .order-mode-row { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 0.85rem; align-items: center; }
    .pill {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.35rem 0.8rem; border-radius: 999px;
      font-weight: 800; font-size: 0.9rem; letter-spacing: 0.04em;
    }
    .pill-takeaway { background: rgba(229,179,42,0.18); color: var(--gold); border: 2px solid var(--gold); }
    .pill-delivery { background: rgba(59,130,246,0.18); color: #60a5fa; border: 2px solid #3b82f6; }
    .pill-cash { background: rgba(34,197,94,0.18); color: #4ade80; border: 2px solid #22c55e; }
    .pill-card { background: rgba(168,85,247,0.18); color: #c084fc; border: 2px solid #a855f7; }

    .delivery-box {
      background: rgba(59,130,246,0.08);
      border: 2px solid rgba(59,130,246,0.35);
      border-radius: 0.7rem;
      padding: 0.75rem 0.9rem;
      margin-bottom: 0.85rem;
    }
    .delivery-box .deliv-label {
      font-size: 0.7rem; color: #60a5fa;
      text-transform: uppercase; letter-spacing: 0.1em;
      font-weight: 800; margin-bottom: 0.35rem;
    }
    .delivery-box .deliv-addr {
      font-size: 1.1rem; color: #fff; font-weight: 700;
      line-height: 1.35;
    }
    .delivery-box .deliv-extra {
      font-size: 0.9rem; color: #bbb; margin-top: 0.35rem;
    }
    .delivery-box .deliv-notes {
      font-size: 0.9rem; color: #fbbf24;
      margin-top: 0.5rem; font-style: italic;
    }

    .order-items {
      list-style: none; padding: 0; margin: 0 0 0.85rem;
      background: rgba(0,0,0,0.4); border-radius: 0.7rem; padding: 0.75rem 0.9rem;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .order-items li {
      display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
      padding: 0.35rem 0; font-size: 1.05rem;
      border-bottom: 1px dashed rgba(255,255,255,0.08);
    }
    .order-items li:last-child { border-bottom: none; }
    .order-items .qty {
      display: inline-block; min-width: 2.3rem; text-align: center;
      background: var(--gold); color: #000; font-weight: 900;
      border-radius: 0.4rem; padding: 0.1rem 0.4rem; margin-right: 0.5rem;
      font-size: 0.95rem;
    }
    .order-items .item-name { flex: 1; color: #fff; font-weight: 600; }
    .order-items .item-total { color: var(--gold); font-weight: 700; min-width: 80px; text-align: right; }

    .order-total {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.5rem 0 0.2rem;
      font-size: 1.4rem; font-weight: 900;
      color: var(--gold);
    }
    .order-total span:first-child { color: #fff; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; }

    /* CLIGNOTEMENT GLOBAL quand commande non acquittée */
    body.has-pending::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 50;
      background: rgba(239,68,68,0.0);
      animation: flash-bg 1.2s ease-in-out infinite;
    }
    @keyframes flash-bg {
      0%, 100% { background: rgba(239,68,68,0); }
      50% { background: rgba(239,68,68,0.12); }
    }

    .sound-toggle {
      padding: 0.5rem 0.85rem; font-size: 0.8rem;
      background: #222; color: #ccc; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.4rem; cursor: pointer;
      letter-spacing: 0.05em;
    }
    .sound-toggle.muted { background: #3a1a1a; color: #ef4444; border-color: #7a2d2d; }
    .sound-toggle:hover { background: #333; }

    .sound-select {
      padding: 0.5rem 0.6rem; font-size: 0.8rem;
      background: #222; color: #ccc;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.4rem; cursor: pointer;
      max-width: 150px;
    }
    .sound-select:focus { outline: none; border-color: var(--gold); }
    .sound-test {
      padding: 0.5rem 0.7rem; font-size: 0.8rem;
      background: #222; color: var(--gold);
      border: 1px solid rgba(229,179,42,0.4);
      border-radius: 0.4rem; cursor: pointer;
    }
    .sound-test:hover { background: rgba(229,179,42,0.15); }

    .history-btn {
      padding: 0.5rem 0.85rem; font-size: 0.8rem;
      background: #1a1a1a; color: var(--gold);
      border: 1px solid rgba(229,179,42,0.45);
      border-radius: 0.4rem; cursor: pointer;
      font-weight: 700; letter-spacing: 0.05em;
      text-decoration: none; display: inline-flex; align-items: center; gap: 0.35rem;
    }
    .history-btn:hover { background: rgba(229,179,42,0.12); }

    /* Prominent "New order" CTA in the dashboard topbar */
    .new-order-cta {
      padding: 0.55rem 0.95rem; font-size: 0.85rem;
      background: linear-gradient(135deg, #E5B32A 0%, #c89518 100%);
      color: #0a0a0a;
      border: 1px solid #E5B32A;
      border-radius: 0.45rem;
      font-weight: 800; letter-spacing: 0.05em;
      text-decoration: none;
      display: inline-flex; align-items: center; gap: 0.4rem;
      box-shadow: 0 4px 14px rgba(229,179,42,0.35);
      transition: transform 0.12s ease, box-shadow 0.18s ease;
    }
    .new-order-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 22px rgba(229,179,42,0.55);
      background: linear-gradient(135deg, #f7c64a 0%, #E5B32A 100%);
    }
    .new-order-cta:active { transform: scale(0.97); }
    @media (max-width: 768px) {
      .new-order-cta { padding: 0.45rem 0.65rem; font-size: 0.78rem; }
      .new-order-cta .new-order-label { display: none; }
    }

    .lang-toggle {
      padding: 0.5rem 0.7rem; font-size: 0.8rem;
      background: #222; color: #ccc; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.4rem; cursor: pointer;
      letter-spacing: 0.05em; font-weight: 700;
      display: inline-flex; align-items: center; gap: 0.4rem;
    }
    .lang-toggle:hover { background: #333; }
    .lang-toggle img { width: 14px; height: 10px; display: inline-block; object-fit: cover; border-radius: 2px; }

    /* ====== MOBILE TABS (hidden on desktop) ====== */
    .mobile-tabs { display: none; }
    .tablet-drawer-handle { display: none; }

    /* ====== TABLET (769-1199px) : 2 cols + history drawer ====== */
    @media (max-width: 1199px) and (min-width: 769px) {
      .columns {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        position: relative;
      }
      .col-history {
        position: fixed;
        left: 0; right: 0; bottom: 0;
        max-height: 60vh;
        transform: translateY(calc(100% - 3rem));
        transition: transform 0.3s ease;
        background: #0a0a0a;
        border-top: 2px solid rgba(229,179,42,0.45);
        box-shadow: 0 -16px 40px rgba(0,0,0,0.6);
        padding: 0.5rem 1rem 1rem;
        z-index: 20;
        margin: 0;
      }
      .col-history.drawer-open {
        transform: translateY(0);
      }
      .col-history .col-head {
        cursor: pointer;
        margin-bottom: 0.5rem;
      }
      .col-history .col-head::after {
        content: '▲';
        font-size: 0.7rem;
        margin-left: 0.5rem;
        transition: transform 0.2s;
      }
      .col-history.drawer-open .col-head::after {
        transform: rotate(180deg);
        display: inline-block;
      }
      .col-history .col-body { max-height: calc(60vh - 6rem); }
      .orders-area { padding-bottom: 4rem; }
    }

    /* ====== MOBILE (≤768px) : tabs + 1 screen ====== */
    @media (max-width: 768px) {
      html, body { height: 100%; overflow: hidden; }
      .dashboard.show { height: 100vh; height: 100dvh; display: flex; flex-direction: column; }
      .topbar {
        padding: 0.5rem 0.6rem;
        flex-wrap: wrap;
        gap: 0.4rem;
        position: relative;
      }
      .topbar h1 {
        font-size: 0.8rem;
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .topbar .status {
        font-size: 0.7rem;
        gap: 0.3rem;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .topbar .status .clock { font-size: 0.75rem; }
      .topbar .status .sound-select { max-width: 140px; padding: 0.4rem 0.5rem; font-size: 0.72rem; }
      .topbar .status .sound-test,
      .topbar .status .sound-toggle,
      .topbar .status .lang-toggle,
      .topbar .status .history-btn {
        padding: 0.4rem 0.55rem; font-size: 0.72rem; min-height: 36px;
      }
      /* Empêche tout débordement horizontal sur mobile */
      .dashboard, .orders-area, .columns, .topbar, .topbar .status { max-width: 100vw; min-width: 0; }
      .topbar .status { flex: 1 1 100%; min-width: 0; }

      .mobile-tabs {
        display: flex;
        gap: 0.35rem;
        padding: 0.5rem;
        background: #000;
        border-bottom: 2px solid rgba(229,179,42,0.3);
        position: sticky; top: 0; z-index: 9;
      }
      .mobile-tab {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.15rem;
        padding: 0.55rem 0.4rem;
        min-height: 52px;
        background: #181818;
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 0.6rem;
        color: #888;
        font-weight: 800;
        font-size: 0.72rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        cursor: pointer;
        position: relative;
        transition: all 0.15s;
      }
      .mobile-tab .tab-count {
        display: inline-block;
        min-width: 1.4rem;
        padding: 0.05rem 0.4rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 900;
        background: rgba(0,0,0,0.45);
      }
      .mobile-tab.tab-pending.active {
        background: rgba(239,68,68,0.18);
        border-color: rgba(239,68,68,0.65);
        color: #fca5a5;
      }
      .mobile-tab.tab-prep.active {
        background: rgba(229,179,42,0.18);
        border-color: rgba(229,179,42,0.65);
        color: var(--gold);
      }
      .mobile-tab.tab-history.active {
        background: rgba(148,163,184,0.15);
        border-color: rgba(148,163,184,0.55);
        color: #cbd5e1;
      }
      .mobile-tab.has-orders.tab-pending:not(.active) {
        border-color: rgba(239,68,68,0.5);
        color: #fca5a5;
        animation: pulse-tab-red 1.4s ease-in-out infinite;
      }
      @keyframes pulse-tab-red {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
        50%      { box-shadow: 0 0 0 4px rgba(239,68,68,0); }
      }

      .orders-area {
        flex: 1;
        min-height: 0;
        overflow: hidden;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
      }
      .columns {
        grid-template-columns: 1fr;
        gap: 0;
        flex: 1;
        min-height: 0;
        max-width: 100%;
      }
      .column {
        display: none;
        flex: 1;
        min-height: 0;
        overflow: hidden;
      }
      .column.active {
        display: flex;
      }
      .col-history { max-height: none; }
      .column .col-head { display: none; }
      .column #list-pending,
      .column #list-prep {
        flex: 1;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        padding: 0.25rem 0.1rem 5rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .col-history .col-body {
        flex: 1;
        max-height: none;
        padding: 0.5rem 0.3rem 5rem;
      }
      .col-history .history-actions {
        margin-bottom: 0.5rem;
      }

      /* Cartes mobile */
      .order-card {
        padding: 0.85rem 0.85rem;
        border-radius: 0.85rem;
      }
      .order-head { gap: 0.5rem; margin-bottom: 0.6rem; }
      .order-id { font-size: 1.6rem; }
      .order-meta { font-size: 0.85rem; }
      .order-meta .name { font-size: 1.05rem; }
      .order-mode-row { gap: 0.3rem; margin-bottom: 0.6rem; }
      .pill { font-size: 0.78rem; padding: 0.25rem 0.6rem; }
      .order-pickup { font-size: 0.85rem; padding: 0.3rem 0.7rem; margin-bottom: 0.6rem; }
      .delivery-box { padding: 0.6rem 0.7rem; margin-bottom: 0.6rem; }
      .delivery-box .deliv-addr { font-size: 1rem; }
      .order-items { padding: 0.55rem 0.7rem; margin-bottom: 0.6rem; }
      .order-items li { font-size: 0.95rem; gap: 0.6rem; }
      .order-items .qty { min-width: 2rem; font-size: 0.85rem; }
      .order-total { font-size: 1.15rem; }
      .order-total span:first-child { font-size: 0.85rem; }

      /* Boutons d'action - mini 48px iOS target */
      .actions { gap: 0.5rem; margin-bottom: 0.75rem; }
      .btn-action {
        min-height: 52px;
        font-size: 1rem;
        padding: 0.85rem 0.4rem;
        letter-spacing: 0.04em;
      }
      .btn-prepare { font-size: 1.15rem; padding: 1.05rem 0.4rem; min-height: 58px; }
      .actions[style*="1fr 1fr 1fr"] {
        grid-template-columns: 1fr 1fr 1fr !important;
        gap: 0.35rem !important;
      }
      .actions[style*="1fr 1fr 1fr"] .btn-action {
        font-size: 0.78rem;
        padding: 0.75rem 0.25rem;
        letter-spacing: 0.02em;
        min-height: 48px;
      }

      /* Chat compact */
      .chat-toggle { min-height: 44px; padding: 0.6rem 0.75rem; font-size: 0.85rem; }
      .chat-messages { max-height: 180px; }
      .chat-input-row input { min-height: 44px; }
      .chat-input-row button { min-height: 44px; padding: 0.6rem 0.85rem; }

      /* History rows compactes mobile */
      .hist-row {
        grid-template-columns: 1fr auto;
        gap: 0.4rem;
        padding: 0.5rem 0.6rem;
        font-size: 0.8rem;
      }
      .hist-row > div:nth-child(2) { grid-column: 1 / -1; }
      .hist-row > div:nth-child(3) { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
      .hist-row .h-actions { margin-top: 0; }
      .hist-row .h-act { width: 44px; height: 44px; font-size: 1.1rem; }

      /* MODALS FULLSCREEN MOBILE */
      .modal-back {
        padding: 0;
        align-items: stretch;
        justify-content: stretch;
      }
      .modal {
        width: 100%; max-width: none;
        max-height: 100vh; max-height: 100dvh;
        height: 100%;
        border-radius: 0;
        border: none;
        padding: 1.25rem 1rem 1.5rem;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
      }
      .modal h2 { font-size: 1.25rem; padding-top: 0.5rem; }
      .modal .modal-sub { font-size: 0.95rem; margin-bottom: 1.25rem; }
      .modal .time-grid {
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
      }
      .modal .time-btn {
        padding: 1.5rem 0.5rem;
        font-size: 1.4rem;
        min-height: 64px;
      }
      .modal .custom-row input { min-height: 52px; font-size: 1.1rem; }
      .modal .custom-row button { min-height: 52px; padding: 0.85rem 1.4rem; font-size: 1.2rem; }
      .modal .reason-row input { min-height: 48px; }
      .modal .modal-actions {
        margin-top: auto;
        padding-top: 1.5rem;
      }
      .modal .btn-cancel {
        flex: 1;
        min-height: 52px;
        font-size: 1rem;
        padding: 0.85rem 1.2rem;
      }

      /* Login mobile */
      .login-box { padding: 1.5rem 1.25rem; }
      .login-box input { min-height: 48px; }
      .login-box button { min-height: 52px; font-size: 1rem; }
    }

    /* iPhone safe-area */
    @supports (padding: env(safe-area-inset-bottom)) {
      @media (max-width: 768px) {
        .orders-area { padding-bottom: env(safe-area-inset-bottom); }
        .column #list-pending,
        .column #list-prep,
        .col-history .col-body {
          padding-bottom: calc(5rem + env(safe-area-inset-bottom));
        }
      }
    }

    /* ====== BOUTON REFUSER (sur cartes pending) ====== */
    .btn-decline {
      background: linear-gradient(180deg, #6b7280 0%, #4b5563 100%);
      box-shadow: 0 8px 22px rgba(75,85,99,0.45);
      color: #fff;
      border: 1px solid rgba(239,68,68,0.35);
    }
    .btn-decline:hover { background: linear-gradient(180deg, #ef4444 0%, #b91c1c 100%); box-shadow: 0 12px 28px rgba(239,68,68,0.5); }

    /* ====== HEADER MSG BADGE (icone messages non-lus globaux) ====== */
    .msg-icon-btn {
      position: relative;
      padding: 0.5rem 0.7rem; font-size: 0.95rem;
      background: #1a1a1a; color: var(--gold);
      border: 1px solid rgba(229,179,42,0.45);
      border-radius: 0.4rem; cursor: pointer;
      font-weight: 700;
      text-decoration: none; display: inline-flex; align-items: center; gap: 0.35rem;
    }
    .msg-icon-btn:hover { background: rgba(229,179,42,0.12); }
    .msg-icon-btn .global-unread {
      position: absolute; top: -6px; right: -6px;
      min-width: 18px; height: 18px; padding: 0 5px;
      background: #ef4444; color: #fff;
      border-radius: 999px; font-size: 0.65rem; font-weight: 900;
      display: inline-flex; align-items: center; justify-content: center;
      box-shadow: 0 0 8px rgba(239,68,68,0.6);
      animation: badge-pulse 1.6s ease-in-out infinite;
    }
    @keyframes badge-pulse {
      0%, 100% { transform: scale(1); }
      50%      { transform: scale(1.18); }
    }
    .msg-icon-btn .global-unread.hidden { display: none; }

    /* ====== ONGLETS CHAT FLOTTANTS (Messenger-style) ====== */
    .chat-tabs-host {
      position: fixed; bottom: 0; right: 1rem;
      z-index: 80;
      display: flex; flex-direction: row-reverse;
      gap: 0.6rem;
      align-items: flex-end;
      pointer-events: none;
    }
    .chat-tabs-host > .ftab { pointer-events: auto; }

    .ftab {
      width: 300px;
      background: #0c0c0c;
      border: 1px solid rgba(229,179,42,0.4);
      border-bottom: none;
      border-radius: 0.7rem 0.7rem 0 0;
      box-shadow: 0 -8px 32px rgba(0,0,0,0.55);
      display: flex; flex-direction: column;
      overflow: hidden;
      max-height: 480px;
      transition: max-height 0.22s ease, transform 0.22s ease;
    }
    .ftab.min { max-height: 48px; }
    .ftab.min .ftab-body, .ftab.min .ftab-foot { display: none; }

    .ftab-head {
      height: 48px; flex-shrink: 0;
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0 0.65rem;
      background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
      border-bottom: 1px solid rgba(229,179,42,0.3);
      cursor: pointer;
      position: relative;
    }
    .ftab-head .av {
      width: 30px; height: 30px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold) 0%, #8a6a14 100%);
      color: #000; font-weight: 900; font-size: 0.85rem;
      display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .ftab-head .who { flex: 1; min-width: 0; line-height: 1.15; }
    .ftab-head .who .nm { color: #fff; font-weight: 800; font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ftab-head .who .id { color: var(--gold); font-size: 0.7rem; font-weight: 700; opacity: 0.9; }
    .ftab-head .ftab-unread {
      min-width: 18px; height: 18px; padding: 0 5px;
      background: #ef4444; color: #fff;
      border-radius: 999px; font-size: 0.65rem; font-weight: 900;
      display: inline-flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ftab-head .ftab-unread.hidden { display: none; }
    .ftab-head .ftab-min, .ftab-head .ftab-close {
      width: 28px; height: 28px;
      background: transparent; color: rgba(255,255,255,0.65);
      border: none; cursor: pointer; font-size: 1rem;
      border-radius: 50%;
      display: inline-flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ftab-head .ftab-min:hover, .ftab-head .ftab-close:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .ftab-head .ftab-close:hover { color: #ef4444; background: rgba(239,68,68,0.15); }

    .ftab-body {
      flex: 1; overflow-y: auto;
      padding: 0.7rem 0.6rem;
      display: flex; flex-direction: column; gap: 0.25rem;
      background: #0a0a0a;
      min-height: 200px;
    }
    .ftab-body .b-wrap { display: flex; flex-direction: column; max-width: 100%; }
    .ftab-body .b-wrap.from-patron { align-items: flex-end; }
    .ftab-body .b-wrap.from-client { align-items: flex-start; }
    .ftab-body .b-wrap.from-system { align-items: center; }
    .ftab-body .bubble {
      max-width: 80%;
      padding: 7px 11px; line-height: 1.35; font-size: 0.86rem;
      word-wrap: break-word; margin-bottom: 3px;
    }
    .ftab-body .bubble.from-client {
      background: #1f1f1f; color: #fff;
      border-radius: 18px 18px 18px 4px;
    }
    .ftab-body .bubble.from-patron {
      background: linear-gradient(135deg, #E5B32A 0%, #c89518 100%);
      color: #000;
      border-radius: 18px 18px 4px 18px;
      font-weight: 600;
    }
    .ftab-body .bubble.from-system {
      background: rgba(255,255,255,0.05); color: #aaa; font-style: italic; font-size: 0.74rem;
      border: 1px dashed rgba(255,255,255,0.1);
      border-radius: 12px; max-width: 92%; text-align: center;
    }
    .ftab-body .b-time { color: #666; font-size: 9px; margin: 1px 4px 6px; }
    .ftab-body .ftab-loader { text-align: center; color: #555; padding: 1rem; font-size: 0.85rem; }

    .ftab-foot {
      padding: 0.45rem 0.55rem 0.6rem;
      border-top: 1px solid rgba(255,255,255,0.06);
      background: #0c0c0c;
    }
    .ftab-templates {
      display: flex; gap: 0.3rem; overflow-x: auto;
      padding-bottom: 0.4rem;
      scrollbar-width: none;
    }
    .ftab-templates::-webkit-scrollbar { display: none; }
    .ftab-templates .tpl {
      padding: 0.3rem 0.55rem;
      background: rgba(229,179,42,0.1); color: #E5B32A;
      border: 1px solid rgba(229,179,42,0.3); border-radius: 999px;
      font-size: 0.72rem; font-weight: 700; white-space: nowrap;
      cursor: pointer; flex-shrink: 0;
    }
    .ftab-templates .tpl:hover { background: rgba(229,179,42,0.22); color: #fff; }

    .ftab-input-row { display: flex; gap: 0.35rem; align-items: center; }
    .ftab-input-row input {
      flex: 1; padding: 0.55rem 0.8rem;
      background: #1a1a1a; color: #fff;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 18px; font-size: 0.88rem;
      min-height: 36px;
    }
    .ftab-input-row input:focus { outline: none; border-color: rgba(229,179,42,0.5); }
    .ftab-input-row .send {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #E5B32A 0%, #b8901c 100%);
      color: #000; border: none; cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 0.95rem; font-weight: 800;
    }
    .ftab-input-row .send:disabled { opacity: 0.4; cursor: not-allowed; }

    @media (max-width: 768px) {
      .chat-tabs-host {
        left: 0; right: 0; bottom: 0; padding: 0;
        flex-direction: column;
      }
      .ftab {
        width: 100%;
        max-height: 100dvh; height: 100dvh;
        border-radius: 0; border: none;
      }
      .ftab.min {
        height: 48px; max-height: 48px;
        border-top: 1px solid rgba(229,179,42,0.35);
      }
      /* On n'affiche qu'un seul onglet ouvert plein-ecran sur mobile, et empile les autres minimises au-dessus */
      .chat-tabs-host:not(.has-open) .ftab { display: none; }
      .chat-tabs-host:not(.has-open) .ftab.min { display: flex; }
      .chat-tabs-host.has-open .ftab.min {
        position: fixed; left: 0; right: 0; top: 0;
        z-index: 81;
        border-top: none; border-bottom: 1px solid rgba(229,179,42,0.35);
      }
    }

    /* ====== MODAL DECLINE (raison optionnelle) ====== */
    .decline-modal { max-width: 460px; }
    .decline-modal .reason-row { margin-bottom: 0.85rem; }
    .decline-modal .reason-row input {
      width: 100%; padding: 0.75rem 0.85rem;
      background: #000; color: #fff;
      border: 1.5px solid rgba(255,255,255,0.15);
      border-radius: 0.5rem; font-size: 0.95rem;
    }
    .decline-modal .reason-row input:focus { outline: none; border-color: #ef4444; }
    .decline-modal .modal-actions { display: flex; gap: 0.6rem; }
    .decline-modal .btn-ok-decline {
      flex: 1; padding: 0.85rem 1rem;
      background: linear-gradient(180deg, #ef4444 0%, #b91c1c 100%); color: #fff;
      border: none; border-radius: 0.5rem; font-weight: 800; cursor: pointer;
      letter-spacing: 0.05em;
