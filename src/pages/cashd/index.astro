    // ═══ HISTORY (colonne droite) ═══
    var historyPollIntervalMs = 30000;
    var historyPollTimer = null;

    async function fetchHistory() {
      try {
        var res = await fetch('/api/orders/history', {
          credentials: 'include',
          cache: 'no-store',
        });
        if (res.status === 401) return;
        var data = await res.json();
        if (!data.ok) return;
        // filtrer : on garde uniquement statuts terminés (pas new/seen qui sont dans les autres colonnes)
        historyRows = (data.rows || []).filter(function(r) {
          return r.status === 'ready' || r.status === 'paid' || r.status === 'cancelled' || r.status === 'completed';
        });
        renderHistory();
      } catch (e) { /* ignore */ }
    }

    function histStatusLabel(s) {
      if (s === 'paid') return t.histStatusPaid;
      if (s === 'ready') return t.histStatusReady;
      if (s === 'cancelled') return t.histStatusCancelled;
      if (s === 'seen') return t.histStatusSeen;
      if (s === 'completed') return t.histStatusPaid;
      return t.histStatusNew;
    }

    function renderHistory() {
      if (!listHistory) return;
      countHistory.textContent = String(historyRows.length);
      var mtabHC = document.getElementById('mtab-history-count');
      if (mtabHC) mtabHC.textContent = String(historyRows.length);
      if (historyRows.length === 0) {
        listHistory.innerHTML = '<div class="hist-empty">' + escapeHtml(t.emptyHistory) + '</div>';
        return;
      }
      var html = '';
      historyRows.forEach(function(r) {
        var d = new Date(r.created_at);
        var dd = String(d.getDate()).padStart(2, '0') + '/' + String(d.getMonth()+1).padStart(2, '0');
        var hh = String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0');
        var sCls = 's-' + r.status;
        html += '<div class="hist-row" data-hist-id="' + escapeHtml(r.id) + '">'
          + '<div>'
            + '<div class="h-id">' + escapeHtml(r.id) + '</div>'
            + '<div class="h-meta">' + dd + ' ' + hh + '</div>'
          + '</div>'
          + '<div>'
            + '<div class="h-name">' + escapeHtml(r.name || '') + '</div>'
            + '<div class="h-meta">' + (r.mode === 'delivery' ? '🛵' : '🥡') + ' · ' + Number(r.items_count || 0) + ' it.</div>'
          + '</div>'
          + '<div>'
            + '<div class="h-total">' + fmt(r.total) + '</div>'
            + '<span class="h-status ' + sCls + '">' + escapeHtml(histStatusLabel(r.status)) + '</span>'
            + '<div class="h-actions">'
              + '<button type="button" class="h-act" data-action="hist-print" data-id="' + escapeHtml(r.id) + '" title="' + escapeHtml(t.histPrint) + '">🖨</button>'
              + '<button type="button" class="h-act danger" data-action="hist-delete" data-id="' + escapeHtml(r.id) + '" title="' + escapeHtml(t.histDelete) + '">🗑</button>'
            + '</div>'
          + '</div>'
        + '</div>';
      });
      listHistory.innerHTML = html;
    }

    async function deleteHistoryRow(id) {
      if (!confirm(t.histDeleteConfirm + id + ' ?')) return;
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/delete', {
          method: 'POST',
          credentials: 'include',
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'fail');
        historyRows = historyRows.filter(function(r) { return r.id !== id; });
        renderHistory();
      } catch (err) {
        alert(t.actionError + (err && err.message ? err.message : err));
      }
    }

