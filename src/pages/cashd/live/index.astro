---
// Interface PATRON commandes live — vue mobile-first dédiée pour usage en cuisine.
// Différente de /cashd : ultra simple, gros boutons, focus sur valider + ETA.
// Reuse les endpoints existants (caisse-login, poll, ack, eta, message-patron, status).
// i18n : EL par défaut (restaurant grec), EN dispo via toggle caisse_lang.
// Cookie partagé "caisse_auth" avec /cashd : si déjà loggé sur cashd, accès direct.
import CashdNav from "../../../components/cashd/CashdNav.astro";
import CashdAuthScript from "../../../components/cashd/CashdAuthScript.astro";
---
<!doctype html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Καλαμάκι — Παραγγελίες</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <CashdAuthScript />
  <style>
    :root { --gold: #E5B32A; --bg: #0a0a0a; --red: #ef4444; --green: #22c55e; --blue: #6366f1; }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; background: var(--bg); color: #fff; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; min-height: 100dvh; overscroll-behavior-y: none; }

    /* LOGIN */
    .login-wrap {
      position: fixed; inset: 0; z-index: 200;
      background: var(--bg);
      min-height: 100dvh;
      display: flex; align-items: center; justify-content: center; padding: 1.5rem;
      margin-left: -220px;
    }
    @media (max-width: 768px) {
      .login-wrap { margin-left: 0; margin-top: -52px; }
    }
    .login-box { width: 100%; max-width: 360px; background: #111; border: 1px solid rgba(229,179,42,0.3); border-radius: 1rem; padding: 1.5rem; }
    .login-box h1 { margin: 0 0 1.25rem; font-size: 1.15rem; color: var(--gold); text-align: center; letter-spacing: 0.05em; }
    .login-box input { width: 100%; padding: 1rem; background: #000; border: 1.5px solid rgba(255,255,255,0.15); border-radius: 0.6rem; color: #fff; font-size: 1.1rem; margin-bottom: 1rem; }
    .login-box input:focus { outline: none; border-color: var(--gold); }
    .login-box button { width: 100%; padding: 1.1rem; background: var(--gold); color: #000; border: none; border-radius: 0.6rem; font-weight: 800; font-size: 1rem; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; }
    .login-error { color: var(--red); font-size: 0.85rem; margin-top: 0.75rem; text-align: center; }

    /* DASHBOARD */
    .dash { display: none; flex-direction: column; min-height: 100dvh; }
    .dash.show { display: flex; }

    .top {
      position: sticky; top: 0; z-index: 20;
      background: #000; border-bottom: 2px solid rgba(229,179,42,0.4);
      padding: 0.75rem 1rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .top h1 { margin: 0; font-size: 1rem; color: var(--gold); letter-spacing: 0.05em; }
    .top .info { font-size: 0.8rem; color: #888; display: flex; align-items: center; gap: 0.5rem; }
    .top .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px var(--green); }
    .top.offline .dot { background: var(--red); box-shadow: 0 0 6px var(--red); }

    .tabs {
      display: flex; gap: 0.4rem; padding: 0.6rem 0.75rem; background: #0d0d0d;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      position: sticky; top: 53px; z-index: 19;
    }
    .tab {
      flex: 1; padding: 0.65rem 0.4rem; border-radius: 0.55rem;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      color: #aaa; font-weight: 700; font-size: 0.82rem; cursor: pointer;
      text-align: center; letter-spacing: 0.04em;
    }
    .tab .badge {
      display: inline-block; min-width: 1.4rem; padding: 0 0.4rem; margin-left: 0.35rem;
      background: rgba(0,0,0,0.4); border-radius: 999px; font-size: 0.72rem; font-weight: 800;
    }
    .tab.pending .badge { background: var(--red); color: #fff; }
    .tab.active { background: var(--gold); color: #000; border-color: var(--gold); }
    .tab.active .badge { background: rgba(0,0,0,0.18); }

    .list { padding: 0.85rem; display: flex; flex-direction: column; gap: 0.85rem; padding-bottom: 4rem; }
    .empty { text-align: center; color: #555; padding: 3rem 1rem; font-size: 0.9rem; }

    /* CARD */
    .card {
      background: #111; border: 1px solid rgba(255,255,255,0.08);
      border-radius: 0.85rem; overflow: hidden;
    }
    .card.new { border-color: rgba(239,68,68,0.5); box-shadow: 0 0 0 1px rgba(239,68,68,0.18); animation: pulse-red 1.8s ease-in-out infinite; }
    @keyframes pulse-red { 0%, 100% { box-shadow: 0 0 0 1px rgba(239,68,68,0.18); } 50% { box-shadow: 0 0 0 4px rgba(239,68,68,0.28); } }
    .card.seen { border-color: rgba(229,179,42,0.4); }

    .card-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.75rem 0.95rem; border-bottom: 1px solid rgba(255,255,255,0.06);
      background: rgba(255,255,255,0.02);
    }
    .id-block { display: flex; align-items: baseline; gap: 0.5rem; }
    .id { font-weight: 900; font-size: 1.25rem; color: var(--gold); letter-spacing: 0.04em; }
    .when { font-size: 0.75rem; color: #777; }
    .mode-pill {
      padding: 0.2rem 0.55rem; border-radius: 999px; font-size: 0.72rem;
      font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;
    }
    .mode-pill.takeaway { background: rgba(96,165,250,0.18); color: #93c5fd; border: 1px solid rgba(96,165,250,0.4); }
    .mode-pill.delivery { background: rgba(229,179,42,0.18); color: var(--gold); border: 1px solid rgba(229,179,42,0.4); }

    .card-body { padding: 0.75rem 0.95rem; display: flex; flex-direction: column; gap: 0.45rem; }
    .row { display: flex; gap: 0.5rem; align-items: baseline; font-size: 0.92rem; }
    .row .label { color: #777; font-size: 0.78rem; min-width: 4.5rem; }
    .row .val { color: #fff; flex: 1; word-break: break-word; }
    .row .val.gold { color: var(--gold); font-weight: 800; }
    .row .val.phone { font-variant-numeric: tabular-nums; }
    .row .val a { color: #93c5fd; text-decoration: none; }

    .items { background: rgba(0,0,0,0.35); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 0.55rem 0.7rem; font-size: 0.88rem; }
    .items .item { display: flex; justify-content: space-between; padding: 0.15rem 0; }
    .items .qty { color: var(--gold); font-weight: 800; min-width: 1.7rem; }
    .items .nm { flex: 1; padding: 0 0.4rem; color: #ddd; }
    .items .pr { color: #999; font-variant-numeric: tabular-nums; }
    .items .sep { height: 1px; background: rgba(255,255,255,0.06); margin: 0.3rem 0; }
    .items .tot { display: flex; justify-content: space-between; font-weight: 800; color: var(--gold); padding-top: 0.2rem; }

    .notes { background: rgba(251,146,60,0.08); border: 1px solid rgba(251,146,60,0.25); border-radius: 0.5rem; padding: 0.55rem 0.7rem; color: #fdba74; font-size: 0.88rem; }
    .notes .lbl { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: #fb923c; margin-bottom: 0.2rem; }
    .notes .tr { color: #fed7aa; font-style: italic; font-size: 0.82rem; margin-top: 0.25rem; }

    .eta-info {
      background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.3);
      border-radius: 0.5rem; padding: 0.55rem 0.75rem;
      display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
    }
    .eta-info .eta-vals { font-size: 0.9rem; color: #86efac; }
    .eta-info .eta-vals b { color: #fff; font-size: 1rem; }
    .eta-info .eta-times { font-size: 0.78rem; color: #4ade80; margin-top: 0.15rem; }

    .actions { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; padding: 0 0.95rem 0.95rem; }
    .actions.single { grid-template-columns: 1fr; }
    .actions.triple { grid-template-columns: 1fr 1fr 1fr; }
    .btn {
      padding: 0.95rem 0.5rem; border-radius: 0.6rem; border: none; font-weight: 800;
      font-size: 0.95rem; letter-spacing: 0.04em; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 0.4rem;
    }
    .btn-validate { background: var(--green); color: #000; }
    .btn-validate:active { background: #16a34a; color: #fff; }
    .btn-eta { background: var(--blue); color: #fff; }
    .btn-eta:active { background: #4338ca; }
    .btn-ready { background: var(--gold); color: #000; }
    .btn-ready:active { background: #ca8a04; color: #fff; }
    .btn-done { background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.15); }
    .btn-done:active { background: rgba(255,255,255,0.15); }
    .btn-cancel { background: transparent; color: var(--red); border: 1px solid rgba(239,68,68,0.4); }
    .btn-cancel:active { background: rgba(239,68,68,0.15); }
    .btn-msg { background: rgba(99,102,241,0.15); color: #c7d2fe; border: 1px solid rgba(99,102,241,0.4); }
    .btn-msg:active { background: rgba(99,102,241,0.3); }

    /* MODAL */
    .modal-back {
      position: fixed; inset: 0; background: rgba(0,0,0,0.8);
      display: none; align-items: flex-end; justify-content: center;
      z-index: 100; padding: 0; backdrop-filter: blur(6px);
    }
    .modal-back.show { display: flex; }
    .modal {
      width: 100%; max-width: 480px;
      background: #111; border: 1px solid rgba(229,179,42,0.4);
      border-radius: 1.2rem 1.2rem 0 0;
      padding: 1.25rem 1rem 1.5rem;
      max-height: 92dvh; overflow-y: auto;
      animation: slide-up 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
      position: relative;
    }
    .modal-close-x {
      position: absolute; top: 0.5rem; right: 0.5rem;
      width: 44px; height: 44px;
      background: transparent; color: rgba(255,255,255,0.6);
      border: none; font-size: 1.6rem; cursor: pointer;
      border-radius: 50%; transition: all 0.2s;
      display: flex; align-items: center; justify-content: center;
      line-height: 1;
      z-index: 2;
    }
    .modal-close-x:hover, .modal-close-x:active { background: rgba(239,68,68,0.15); color: #ef4444; }
    @media (max-width: 768px) {
      .modal-close-x { width: 48px; height: 48px; font-size: 1.75rem; }
    }
    @keyframes slide-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
    .modal h2 { margin: 0 0 0.3rem; color: var(--gold); font-size: 1.05rem; letter-spacing: 0.05em; }
    .modal .sub { color: #999; font-size: 0.82rem; margin-bottom: 1rem; }
    .modal .section-label {
      display: flex; align-items: center; gap: 0.5rem;
      color: #fff; font-size: 0.85rem; font-weight: 700;
      letter-spacing: 0.05em; text-transform: uppercase;
      margin: 0.75rem 0 0.5rem;
    }
    .modal .section-label .icon { font-size: 1.1rem; }
    .time-grid {
      display: grid; grid-template-columns: repeat(5, 1fr);
      gap: 0.45rem; margin-bottom: 0.65rem;
    }
    .time-btn {
      padding: 0.95rem 0.3rem; border-radius: 0.55rem;
      background: rgba(229,179,42,0.12); color: var(--gold);
      border: 2px solid rgba(229,179,42,0.4);
      font-weight: 800; font-size: 1rem; cursor: pointer;
      transition: all 0.1s;
    }
    .time-btn.selected { background: var(--gold); color: #000; }
    .time-btn:active { transform: scale(0.96); }
    .time-btn.zero {
      background: rgba(96,165,250,0.12); color: #93c5fd;
      border-color: rgba(96,165,250,0.4);
    }
    .time-btn.zero.selected { background: #60a5fa; color: #000; }
    .custom-row {
      display: flex; gap: 0.5rem; align-items: stretch;
      margin-bottom: 0.75rem;
    }
    .custom-row input {
      flex: 1; padding: 0.85rem 0.85rem;
      background: #000; color: #fff;
      border: 2px solid rgba(255,255,255,0.15);
      border-radius: 0.55rem; font-size: 1.1rem;
      font-variant-numeric: tabular-nums;
    }
    .custom-row input:focus { outline: none; border-color: var(--gold); }
    .custom-row .unit {
      align-self: center; color: #888; padding: 0 0.35rem;
      font-size: 0.88rem;
    }
    .reason-row { margin: 0.5rem 0 0.85rem; }
    .reason-row input {
      width: 100%; padding: 0.75rem 0.85rem;
      background: #000; color: #fff;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 0.5rem; font-size: 0.9rem;
    }
    .modal-actions { display: flex; gap: 0.55rem; margin-top: 0.5rem; }
    .modal-actions .btn-x {
      padding: 1rem 0.5rem; border-radius: 0.6rem;
      font-weight: 800; font-size: 0.95rem; letter-spacing: 0.04em;
      cursor: pointer; border: none;
    }
    .modal-actions .btn-x-cancel {
      background: transparent; color: #aaa; border: 1px solid rgba(255,255,255,0.15);
      flex: 0 0 35%;
    }
    .modal-actions .btn-x-ok {
      background: var(--green); color: #000; flex: 1;
    }
    .modal-actions .btn-x-ok:disabled { background: #333; color: #666; cursor: not-allowed; }

    /* CHAT MODAL */
    .chat-msgs {
      background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 0.6rem; padding: 0.6rem;
      min-height: 8rem; max-height: 50dvh; overflow-y: auto;
      display: flex; flex-direction: column; gap: 0.4rem;
      margin-bottom: 0.65rem;
    }
    .chat-empty { text-align: center; color: #555; padding: 1.5rem 0; font-size: 0.85rem; }
    .chat-msg { max-width: 85%; padding: 0.5rem 0.7rem; border-radius: 0.6rem; font-size: 0.9rem; word-wrap: break-word; }
    .chat-msg.from-client { align-self: flex-start; background: rgba(99,102,241,0.18); color: #c7d2fe; border: 1px solid rgba(99,102,241,0.35); }
    .chat-msg.from-patron { align-self: flex-end; background: rgba(229,179,42,0.18); color: #fcd34d; border: 1px solid rgba(229,179,42,0.4); }
    .chat-msg.from-system { align-self: center; background: rgba(255,255,255,0.04); color: #888; font-style: italic; font-size: 0.78rem; border: 1px dashed rgba(255,255,255,0.1); text-align: center; }
    .chat-msg .meta { font-size: 0.68rem; opacity: 0.7; margin-top: 0.18rem; }
    .chat-input-row { display: flex; gap: 0.45rem; }
    .chat-input-row input {
      flex: 1; padding: 0.85rem 0.85rem; background: #000; color: #fff;
      border: 1px solid rgba(255,255,255,0.15); border-radius: 0.5rem; font-size: 0.95rem;
    }
    .chat-input-row button {
      padding: 0.85rem 1.1rem; background: var(--blue); color: #fff;
      border: none; border-radius: 0.5rem; font-weight: 800; cursor: pointer;
    }
    .chat-shortcuts { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.55rem; }
    .chat-shortcuts button {
      padding: 0.45rem 0.7rem; background: rgba(99,102,241,0.1); color: #a5b4fc;
      border: 1px solid rgba(99,102,241,0.3); border-radius: 999px;
      font-size: 0.78rem; cursor: pointer;
    }

    .toast {
      position: fixed; left: 50%; bottom: 1.5rem;
      transform: translateX(-50%); z-index: 200;
      background: #111; color: #fff;
      padding: 0.85rem 1.25rem; border-radius: 0.6rem;
      border: 1px solid rgba(255,255,255,0.15);
      font-size: 0.9rem; font-weight: 600;
      box-shadow: 0 10px 30px rgba(0,0,0,0.6);
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .toast.show { opacity: 1; }
    .toast.ok { border-color: var(--green); color: #86efac; }
    .toast.err { border-color: var(--red); color: #fca5a5; }
  </style>
</head>
<body>

  <CashdNav />

  <!-- LOGIN (cache au boot si session valide, evite flash) -->
  <div id="login" class="login-wrap" style="display:none;">
    <form id="login-form" class="login-box">
      <h1 id="login-title">Σύνδεση αφεντικού</h1>
      <input type="password" id="pw" placeholder="Κωδικός πρόσβασης" autocomplete="current-password" required />
      <button type="submit" id="login-btn">Είσοδος</button>
      <div id="login-err" class="login-error" hidden></div>
    </form>
  </div>
  <script is:inline>
    // Anti-flash : montre le login UNIQUEMENT si pas de session valide.
    // Sinon tryAutoLogin va prendre le relais et masquer ce overlay une fois pret.
    (function() {
      try {
        var s = window.cashdAuth && window.cashdAuth.getSession();
        if (!s) document.getElementById('login').style.display = 'flex';
      } catch (e) {
        document.getElementById('login').style.display = 'flex';
      }
    })();
  </script>

  <!-- DASHBOARD -->
  <div id="dash" class="dash">
    <div class="top" id="top">
      <h1 id="dash-title">Καλαμάκι — Παραγγελίες</h1>
      <div class="info"><span class="dot"></span><span id="clock">--:--</span></div>
    </div>

    <div class="tabs">
      <button class="tab pending active" data-tab="pending">
        <span id="tab-pending-label">ΣΕ ΑΝΑΜΟΝΗ</span> <span class="badge" id="badge-pending">0</span>
      </button>
      <button class="tab" data-tab="prep">
        <span id="tab-prep-label">ΣΕ ΕΞΕΛΙΞΗ</span> <span class="badge" id="badge-prep">0</span>
      </button>
    </div>

    <div id="list" class="list"></div>
  </div>

  <!-- MODAL VALIDATION + ETA -->
  <div id="modal-eta-back" class="modal-back">
    <div class="modal">
      <button type="button" class="modal-close-x" id="modal-eta-close-x" aria-label="Κλείσιμο">×</button>
      <h2 id="modal-eta-title">Αποδοχή παραγγελίας</h2>
      <div class="sub" id="modal-eta-sub">Διάλεξε χρόνο προετοιμασίας και παράδοσης</div>

      <div class="section-label"><span class="icon">🍳</span> <span id="prep-section-label">Χρόνος προετοιμασίας</span></div>
      <div class="time-grid" id="prep-grid">
        <button type="button" class="time-btn" data-min="10">10</button>
        <button type="button" class="time-btn" data-min="15">15</button>
        <button type="button" class="time-btn" data-min="20">20</button>
        <button type="button" class="time-btn" data-min="30">30</button>
        <button type="button" class="time-btn" data-min="45">45</button>
      </div>
      <div class="custom-row">
        <input type="number" id="prep-custom" min="1" max="180" placeholder="Άλλος (λεπτά)" />
        <span class="unit" id="prep-unit">λεπτά</span>
      </div>

      <div id="delivery-block">
        <div class="section-label"><span class="icon">🛵</span> <span id="delivery-section-label">Χρόνος παράδοσης στον πελάτη</span> <span id="delivery-section-sub" style="font-size:0.7rem;color:#777;font-weight:500;text-transform:none;letter-spacing:0;">(μετά την προετοιμασία)</span></div>
        <div class="time-grid" id="delivery-grid">
          <button type="button" class="time-btn zero" data-min="0">0</button>
          <button type="button" class="time-btn" data-min="10">10</button>
          <button type="button" class="time-btn" data-min="15">15</button>
          <button type="button" class="time-btn" data-min="20">20</button>
          <button type="button" class="time-btn" data-min="30">30</button>
        </div>
        <div class="custom-row">
          <input type="number" id="delivery-custom" min="0" max="180" placeholder="Άλλος (λεπτά)" />
          <span class="unit" id="delivery-unit">λεπτά</span>
        </div>
      </div>

      <div class="reason-row" id="reason-block" hidden>
        <input type="text" id="eta-reason" maxlength="100" placeholder="Λόγος (π.χ. κίνηση στο δρόμο) — προαιρετικό" />
      </div>

      <div class="modal-actions">
        <button type="button" class="btn-x btn-x-cancel" id="modal-eta-cancel">Άκυρο</button>
        <button type="button" class="btn-x btn-x-ok" id="modal-eta-ok">Επιβεβαίωση</button>
      </div>
    </div>
  </div>

  <!-- MODAL CHAT -->
  <div id="modal-chat-back" class="modal-back">
    <div class="modal">
      <button type="button" class="modal-close-x" id="modal-chat-close-x" aria-label="Κλείσιμο">×</button>
      <h2 id="modal-chat-title">Μήνυμα πελάτη</h2>
      <div class="sub" id="modal-chat-sub"></div>

      <div class="chat-msgs" id="chat-msgs"></div>

      <div class="chat-shortcuts" id="chat-shortcuts">
        <button type="button" data-tpl-key="inProgress">👋 <span class="tpl-label">Σε εξέλιξη</span></button>
        <button type="button" data-tpl-key="onTheWay">🛵 <span class="tpl-label">Καθ' οδόν</span></button>
        <button type="button" data-tpl-key="delay">⏰ <span class="tpl-label">Καθυστέρηση</span></button>
        <button type="button" data-tpl-key="replacement">❓ <span class="tpl-label">Αντικατάσταση</span></button>
      </div>

      <div class="chat-input-row">
        <input type="text" id="chat-input" maxlength="500" placeholder="Γράψε στον πελάτη…" />
        <button type="button" id="chat-send">Αποστολή</button>
      </div>

      <div class="modal-actions" style="margin-top:0.65rem;">
        <button type="button" class="btn-x btn-x-cancel" id="modal-chat-close" style="flex:1;">Κλείσιμο</button>
      </div>
    </div>
  </div>

  <!-- TOAST -->
  <div id="toast" class="toast"></div>

  <script is:inline>
  (function() {
    // ===== I18N (EL default, EN via 'caisse_lang') =====
    var I18N = {
      el: {
