        agoSec: 'πριν {n}δ',
        agoMin: 'πριν {n}λ',
        agoHour: 'πριν {n}ώ',
        readyIn: 'Έτοιμη σε',
        deliveryEta: 'παράδοση',
        readyAt: 'Έτοιμη',
        deliveredAt: 'παρέδωσε',
        btnValidate: '✓ ΑΠΟΔΟΧΗ',
        btnRefuse: '✗ Απόρριψη',
        btnUpdateTime: '⏱️ Νέος χρόνος',
        btnReady: '🛵 Έτοιμη',
        btnCancel: 'Άκυρο',
        btnDone: '✓ Ολοκληρωμένη',
        btnMsg: '💬 Μήνυμα',
        confirmCancel: 'Ακύρωση παραγγελίας ',
        toastValidated: '✓ Παραγγελία επιβεβαιώθηκε',
        toastUpdated: '✓ Ο χρόνος ενημερώθηκε',
        toastStatus: '✓ Κατάσταση : ',
        toastError: 'Σφάλμα : ',
        toastNeedPrep: 'Διάλεξε χρόνο προετοιμασίας',
        toastNeedDelivery: 'Διάλεξε χρόνο παράδοσης (0 αν παραλαβή)',
        apiError: 'Σφάλμα API',
        wrongPassword: 'Λάθος κωδικός',
        sysAcceptedPrefix: 'Επιβεβαιωμένη — έτοιμη σε ',
        sysEtaPrefix: 'Νέος χρόνος → ',
        sysDeliveryExtra: ' + παράδοση ',
      },
      en: {
        loginTitle: 'Owner login',
        loginPwPh: 'Password',
        loginBtn: 'Sign in',
        loginErrorDefault: 'Error',
        loginErrorWrong: 'Wrong password',
        dashTitle: 'Kalamaki — Orders',
        tabPending: 'PENDING',
        tabPrep: 'IN PROGRESS',
        emptyPending: '✓ No pending orders',
        emptyPrep: '✓ No orders in progress',
        modalValidateTitle: 'Accept order',
        modalUpdateTitle: 'Update ETA',
        modalValidateSub: 'Pick prep and delivery time',
        modalUpdateSub: 'Customer will see the update instantly',
        prepSection: 'Prep time',
        deliverySection: 'Delivery time to customer',
        deliverySectionSub: '(after prep)',
        otherMin: 'Other (min)',
        min: 'min',
        reasonPh: 'Reason (e.g. heavy traffic) — optional',
        cancel: 'Cancel',
        confirm: 'Confirm',
        chatTitle: 'Customer message',
        chatPlaceholder: 'Write to the customer…',
        chatSend: 'Send',
        chatClose: 'Close',
        chatEmpty: 'No messages yet',
        chatLoading: 'Loading…',
        tplInProgress:  { label: 'In progress',  text: 'Hello, your order is being prepared.' },
        tplOnTheWay:    { label: 'On the way',   text: 'The courier is on the way.' },
        tplDelay:       { label: 'Delay',        text: 'Sorry, a slight delay.' },
        tplReplacement: { label: 'Replacement',  text: 'Item out of stock, OK for replacement?' },
        modeDelivery: '🛵 Delivery',
        modeTakeaway: '🥡 Pickup',
        modeDinein: '🍽️ Dine-in',
        labelClient: 'Customer',
        labelPhone: 'Phone',
        labelAddress: 'Address',
        labelTotal: 'Total',
        labelNote: '📝 Note',
        floorShort: 'fl.',
        bellShort: 'bell',
        agoSec: '{n}s ago',
        agoMin: '{n}min ago',
        agoHour: '{n}h ago',
        readyIn: 'Ready in',
        deliveryEta: 'delivery',
        readyAt: 'Ready',
        deliveredAt: 'delivered',
        btnValidate: '✓ ACCEPT',
        btnRefuse: '✗ Decline',
        btnUpdateTime: '⏱️ Update time',
        btnReady: '🛵 Ready',
        btnCancel: 'Cancel',
        btnDone: '✓ Completed',
        btnMsg: '💬 Message',
        confirmCancel: 'Cancel order ',
        toastValidated: '✓ Order validated',
        toastUpdated: '✓ Time updated',
        toastStatus: '✓ Status: ',
        toastError: 'Error: ',
        toastNeedPrep: 'Pick a prep time',
        toastNeedDelivery: 'Pick a delivery time (0 if pickup)',
        apiError: 'API error',
        wrongPassword: 'Wrong password',
        sysAcceptedPrefix: 'Validated — ready in ',
        sysEtaPrefix: 'Time updated → ',
        sysDeliveryExtra: ' + delivery ',
      },
    };
    function getLang() {
      try { return 'el'; /* dashboard grec uniquement */ }
      catch (e) { return 'el'; }
    }
    var lang = getLang();
    var t = I18N[lang] || I18N.el;

    function applyI18n() {
      function setText(id, txt) { var el = document.getElementById(id); if (el) el.textContent = txt; }
      function setPlaceholder(id, txt) { var el = document.getElementById(id); if (el) el.setAttribute('placeholder', txt); }
      setText('login-title', t.loginTitle);
      setPlaceholder('pw', t.loginPwPh);
      setText('login-btn', t.loginBtn);
      setText('dash-title', t.dashTitle);
      setText('tab-pending-label', t.tabPending);
      setText('tab-prep-label', t.tabPrep);
      setText('prep-section-label', t.prepSection);
      setText('delivery-section-label', t.deliverySection);
      setText('delivery-section-sub', t.deliverySectionSub);
      setText('prep-unit', t.min);
      setText('delivery-unit', t.min);
      setPlaceholder('prep-custom', t.otherMin);
      setPlaceholder('delivery-custom', t.otherMin);
      setPlaceholder('eta-reason', t.reasonPh);
      setText('modal-eta-cancel', t.cancel);
      setText('modal-eta-ok', t.confirm);
      setText('modal-chat-title', t.chatTitle);
      setPlaceholder('chat-input', t.chatPlaceholder);
      setText('chat-send', t.chatSend);
      setText('modal-chat-close', t.chatClose);
      // Chat shortcuts buttons
      var shortcutMap = { inProgress: t.tplInProgress, onTheWay: t.tplOnTheWay, delay: t.tplDelay, replacement: t.tplReplacement };
      var shortcuts = document.querySelectorAll('#chat-shortcuts button[data-tpl-key]');
      shortcuts.forEach(function(b) {
        var k = b.getAttribute('data-tpl-key');
        var data = shortcutMap[k];
        if (!data) return;
        b.setAttribute('data-tpl', data.text);
        var labelEl = b.querySelector('.tpl-label');
        if (labelEl) labelEl.textContent = data.label;
      });
    }
    applyI18n();

    // ===== State =====
    var state = {
      authed: false,
      orders: [],
      since: 0,
      currentTab: 'pending',
      modalEtaCtx: null,   // { orderId, mode, kind: 'validate'|'update' }
      modalChatCtx: null,  // { orderId, lastMsgId, pollTimer }
      audioCtx: null,
      lastNewSeen: 0,
      pollAbort: null,
    };

    // ===== Helpers =====
    var $ = function(id) { return document.getElementById(id); };
    function showToast(msg, kind) {
      var t = $('toast'); t.textContent = msg; t.className = 'toast show ' + (kind || '');
      setTimeout(function() { t.classList.remove('show'); }, 2200);
    }
    function escapeHtml(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
        return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
      });
    }
    function fmtEUR(n) {
      return (Math.round((Number(n) || 0) * 100) / 100).toFixed(2).replace('.', ',') + '€';
    }
    function fmtTime(ts) {
      var d = new Date(ts);
      return String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0');
    }
    function fmtAgo(ts) {
      var sec = Math.max(0, Math.floor((Date.now() - ts) / 1000));
      if (sec < 60) return t.agoSec.replace('{n}', sec);
      var min = Math.floor(sec / 60);
      if (min < 60) return t.agoMin.replace('{n}', min);
      var h = Math.floor(min / 60);
      return t.agoHour.replace('{n}', h);
    }
    function ensureAudio() {
      if (!state.audioCtx) {
        try { state.audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch (e) {}
      }
      if (state.audioCtx && state.audioCtx.state === 'suspended') {
        state.audioCtx.resume().catch(function() {});
      }
    }
    function ding(freq, duration) {
      ensureAudio(); if (!state.audioCtx) return;
      try {
        var osc = state.audioCtx.createOscillator();
        var gain = state.audioCtx.createGain();
        osc.type = 'sine'; osc.frequency.value = freq || 880;
        gain.gain.setValueAtTime(0.0001, state.audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.35, state.audioCtx.currentTime + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, state.audioCtx.currentTime + (duration || 0.5));
        osc.connect(gain).connect(state.audioCtx.destination);
        osc.start(); osc.stop(state.audioCtx.currentTime + (duration || 0.55));
      } catch (e) {}
    }

    // ===== Login =====
    $('login-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      ensureAudio();
      var pw = $('pw').value;
      var err = $('login-err'); err.hidden = true;
      try {
        var res = await fetch('/api/caisse-login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: pw }),
          credentials: 'include',
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || t.wrongPassword);
        // Session unifiée 2h (zéro re-prompt entre pages /cashd/*)
        try { window.cashdAuth.setSession(pw); } catch (e) {}
        state.authed = true;
        $('login').style.display = 'none';
        $('dash').classList.add('show');
        startClock();
        startPoll();
      } catch (ex) {
        err.hidden = false; err.textContent = ex.message || t.loginErrorDefault;
      }
    });

    // Si déjà loggé via cookie OU session localStorage 2h : essaye un poll direct, fallback login.
    // IMPORTANT : si poll renvoie 500 mais session 2h valide → on assume cookie OK et on affiche dash.
    async function tryAutoLogin() {
      var hasSession = false;
      try { hasSession = !!window.cashdAuth.getSession(); } catch (e) {}
      try {
        var res = await fetch('/api/orders/poll?since=0', { credentials: 'include', cache: 'no-store' });
        if (res.status === 401) {
          // Cookie drop → tente ré-auth via session 2h, puis retry
          var ok = await window.cashdAuth.bootAuth();
          if (!ok) return false;
          res = await fetch('/api/orders/poll?since=0', { credentials: 'include', cache: 'no-store' });
          if (res.status === 401) return false; // re-401 = mauvais pw
        } else if (!res.ok) {
          // Server error (500, etc.) : si session 2h valide, on affiche le dash quand meme
          if (hasSession) {
            state.authed = true;
            $('login').style.display = 'none';
            $('dash').classList.add('show');
            startClock();
            render();
            startPoll();
            return true;
          }
          return false;
        }
        // res.ok = true
        var data = null;
        try { data = await res.json(); } catch (e) {}
        if (!data || !data.ok) {
          if (hasSession) {
            state.authed = true;
            $('login').style.display = 'none';
            $('dash').classList.add('show');
            startClock();
            render();
            startPoll();
            return true;
          }
          return false;
        }
        state.orders = data.orders || [];
        state.since = data.now || Date.now();
        state.authed = true;
        $('login').style.display = 'none';
        $('dash').classList.add('show');
        startClock();
        render();
        startPoll();
        return true;
      } catch (e) {
        if (hasSession) {
          state.authed = true;
          $('login').style.display = 'none';
          $('dash').classList.add('show');
          startClock();
          render();
          startPoll();
          return true;
        }
        return false;
      }
    }

    // ===== Clock =====
    function startClock() {
      function tick() {
        var d = new Date();
        $('clock').textContent = String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0');
      }
      tick();
      setInterval(tick, 30000);
    }

    // ===== Poll =====
    async function poll() {
      if (!state.authed) return;
      try {
        if (state.pollAbort) state.pollAbort.abort();
        state.pollAbort = new AbortController();
        var url = '/api/orders/poll?since=' + (state.since || 0);
        var res = await fetch(url, { credentials: 'include', cache: 'no-store', signal: state.pollAbort.signal });
        if (res.status === 401) {
          // Cookie drop runtime → tente ré-auth silencieuse via session 2h
          var ok = await window.cashdAuth.bootAuth();
          if (ok) return; // prochain tick reprendra normalement
          state.authed = false;
          $('login').style.display = 'flex';
          $('dash').classList.remove('show');
          return;
        }
        if (!res.ok) return;
        var data = await res.json();
        if (!data.ok) return;
        var prevNewIds = new Set(state.orders.filter(function(o) { return o.status === 'new'; }).map(function(o) { return o.id; }));
        state.orders = data.orders || [];
        state.since = data.now || Date.now();
        // Ding si nouvelle commande
        var hasNew = state.orders.some(function(o) { return o.status === 'new' && !prevNewIds.has(o.id); });
        if (hasNew) { ding(880, 0.5); setTimeout(function() { ding(1100, 0.5); }, 220); }
        render();
        $('top').classList.remove('offline');
      } catch (e) {
        if (e.name !== 'AbortError') { $('top').classList.add('offline'); }
      }
    }
    function startPoll() {
      poll();
      setInterval(poll, 2500);
    }

    // ===== Render =====
    function tabSwitch(name) {
      state.currentTab = name;
      document.querySelectorAll('.tab').forEach(function(t) {
        t.classList.toggle('active', t.getAttribute('data-tab') === name);
      });
      render();
    }
    document.querySelectorAll('.tab').forEach(function(t) {
      t.addEventListener('click', function() { tabSwitch(t.getAttribute('data-tab')); });
    });

    function render() {
      var pending = state.orders.filter(function(o) { return o.status === 'new'; });
      var prep = state.orders.filter(function(o) { return o.status === 'seen' || o.status === 'ready'; });
      $('badge-pending').textContent = pending.length;
      $('badge-prep').textContent = prep.length;

      var list = state.currentTab === 'pending' ? pending : prep;
      var container = $('list');

      if (list.length === 0) {
        container.innerHTML = '<div class="empty">' + (state.currentTab === 'pending' ? t.emptyPending : t.emptyPrep) + '</div>';
        return;
      }

      // Sort : plus récente d'abord pour pending, plus ancienne pour prep
      list.sort(function(a, b) {
        return state.currentTab === 'pending' ? b.created_at - a.created_at : a.created_at - b.created_at;
      });

      var html = '';
      list.forEach(function(o) { html += renderCard(o); });
      container.innerHTML = html;

      // Bind actions
      container.querySelectorAll('[data-act]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var act = btn.getAttribute('data-act');
          var id = btn.getAttribute('data-id');
          var mode = btn.getAttribute('data-mode');
          if (act === 'validate') openEtaModal(id, mode, 'validate');
          else if (act === 'update-eta') openEtaModal(id, mode, 'update');
          else if (act === 'ready') setStatus(id, 'ready');
          else if (act === 'paid') setStatus(id, 'paid');
          else if (act === 'cancel') {
            if (confirm(t.confirmCancel + id + ' ?')) setStatus(id, 'cancelled');
          }
          else if (act === 'chat') openChatModal(id);
          else if (act === 'call') {
            var phone = btn.getAttribute('data-phone');
            if (phone) window.location.href = 'tel:' + phone;
          }
        });
      });
    }

    function renderCard(o) {
      var isNew = o.status === 'new';
      var isReady = o.status === 'ready';
      var modeClass = o.mode === 'delivery' ? 'delivery' : 'takeaway';
      var modeLbl = o.mode === 'delivery' ? t.modeDelivery : (o.mode === 'surplace' ? t.modeDinein : t.modeTakeaway);

      var itemsHtml = '';
      if (Array.isArray(o.items)) {
        o.items.forEach(function(it) {
          itemsHtml += '<div class="item"><span class="qty">' + escapeHtml(it.qty) + '×</span>'
            + '<span class="nm">' + escapeHtml(it.name) + '</span>'
            + '<span class="pr">' + fmtEUR((it.price || 0) * (it.qty || 0)) + '</span></div>';
        });
      }

      var addressHtml = '';
      if (o.mode === 'delivery' && o.address) {
        addressHtml = '<div class="row"><div class="label">' + t.labelAddress + '</div><div class="val">'
          + escapeHtml(o.address)
          + (o.floor ? ' · ' + t.floorShort + ' ' + escapeHtml(o.floor) : '')
          + (o.bell ? ' · ' + t.bellShort + ' ' + escapeHtml(o.bell) : '')
          + '</div></div>';
      }

      var notesHtml = '';
      if (o.notes) {
        notesHtml = '<div class="notes"><div class="lbl">' + t.labelNote + '</div>' + escapeHtml(o.notes);
        if (o.notes_translated && o.notes_translated !== o.notes) {
          notesHtml += '<div class="tr">🇬🇷 ' + escapeHtml(o.notes_translated) + '</div>';
        }
        notesHtml += '</div>';
      }

      // ETA info si validée
      var etaHtml = '';
      if (!isNew && o.prep_minutes && o.accepted_at) {
        var readyTs = o.accepted_at + o.prep_minutes * 60 * 1000;
        var arriveTs = (o.delivery_minutes != null && o.delivery_minutes > 0)
          ? readyTs + o.delivery_minutes * 60 * 1000 : null;
        var remaining = Math.max(0, Math.floor((readyTs - Date.now()) / 60000));
        etaHtml = '<div class="eta-info"><div>'
          + '<div class="eta-vals">⏱️ ' + t.readyIn + ' <b>' + remaining + ' ' + t.min + '</b>';
        if (o.delivery_minutes != null && o.delivery_minutes > 0) {
          etaHtml += ' + ' + t.deliveryEta + ' <b>' + o.delivery_minutes + ' ' + t.min + '</b>';
        }
        etaHtml += '</div>'
          + '<div class="eta-times">' + t.readyAt + ' ' + fmtTime(readyTs);
        if (arriveTs) etaHtml += ' · ' + t.deliveredAt + ' ' + fmtTime(arriveTs);
        etaHtml += '</div></div></div>';
      }

      var unread = Number(o.unread_client_messages || 0);
      var chatBtn = '<button class="btn btn-msg" data-act="chat" data-id="' + escapeHtml(o.id) + '">' + t.btnMsg
        + (unread > 0 ? ' (' + unread + ')' : '') + '</button>';

      var actionsHtml = '';
      if (isNew) {
        actionsHtml = '<div class="actions">'
          + '<button class="btn btn-validate" data-act="validate" data-id="' + escapeHtml(o.id) + '" data-mode="' + escapeHtml(o.mode) + '">' + t.btnValidate + '</button>'
          + '<button class="btn btn-cancel" data-act="cancel" data-id="' + escapeHtml(o.id) + '">' + t.btnRefuse + '</button>'
          + '</div>';
      } else if (o.status === 'seen') {
        actionsHtml = '<div class="actions">'
          + '<button class="btn btn-eta" data-act="update-eta" data-id="' + escapeHtml(o.id) + '" data-mode="' + escapeHtml(o.mode) + '">' + t.btnUpdateTime + '</button>'
          + '<button class="btn btn-ready" data-act="ready" data-id="' + escapeHtml(o.id) + '">' + t.btnReady + '</button>'
          + '</div>'
          + '<div class="actions" style="padding-top:0;">'
          + chatBtn
          + '<button class="btn btn-cancel" data-act="cancel" data-id="' + escapeHtml(o.id) + '">' + t.btnCancel + '</button>'
          + '</div>';
      } else if (isReady) {
        actionsHtml = '<div class="actions">'
          + '<button class="btn btn-done" data-act="paid" data-id="' + escapeHtml(o.id) + '">' + t.btnDone + '</button>'
          + chatBtn
          + '</div>';
      }

      var totalAll = (Array.isArray(o.items) ? o.items.reduce(function(s, it) { return s + (it.price || 0) * (it.qty || 0); }, 0) : 0);

      return '<div class="card ' + (isNew ? 'new' : (isReady ? 'ready' : 'seen')) + '">'
        + '<div class="card-head">'
        + '<div class="id-block"><div class="id">' + escapeHtml(o.id) + '</div>'
        + '<div class="when">' + fmtTime(o.created_at) + ' · ' + fmtAgo(o.created_at) + '</div></div>'
        + '<div class="mode-pill ' + modeClass + '">' + modeLbl + '</div>'
        + '</div>'
        + '<div class="card-body">'
        + '<div class="row"><div class="label">' + t.labelClient + '</div><div class="val">' + escapeHtml(o.name) + '</div></div>'
        + '<div class="row"><div class="label">' + t.labelPhone + '</div><div class="val phone"><a href="tel:' + escapeHtml(o.phone) + '">' + escapeHtml(o.phone) + '</a></div></div>'
        + addressHtml
        + '<div class="items">' + itemsHtml
        + '<div class="sep"></div>'
        + '<div class="tot"><span>' + t.labelTotal + '</span><span>' + fmtEUR(o.total || totalAll) + '</span></div>'
        + '</div>'
        + notesHtml
        + etaHtml
        + '</div>'
        + actionsHtml
        + '</div>';
    }

    // Re-render every 30s for countdowns
    setInterval(function() { if (state.authed) render(); }, 30000);

    // ===== Modal ETA =====
    function openEtaModal(id, mode, kind) {
      var order = state.orders.find(function(o) { return o.id === id; });
      if (!order) return;
      state.modalEtaCtx = { orderId: id, mode: order.mode, kind: kind };

      var isUpdate = (kind === 'update');
      $('modal-eta-title').textContent = (isUpdate ? t.modalUpdateTitle : t.modalValidateTitle) + ' — ' + id;
      $('modal-eta-sub').textContent = isUpdate ? t.modalUpdateSub : t.modalValidateSub;
      $('reason-block').hidden = !isUpdate;

      // Reset selections
      $('prep-custom').value = '';
      $('delivery-custom').value = '';
      $('eta-reason').value = '';
      document.querySelectorAll('#prep-grid .time-btn').forEach(function(b) { b.classList.remove('selected'); });
      document.querySelectorAll('#delivery-grid .time-btn').forEach(function(b) { b.classList.remove('selected'); });

      // Pré-sélection si update : valeurs actuelles
      if (isUpdate) {
        if (order.prep_minutes) {
          var prepBtn = document.querySelector('#prep-grid .time-btn[data-min="' + order.prep_minutes + '"]');
          if (prepBtn) prepBtn.classList.add('selected');
          else $('prep-custom').value = order.prep_minutes;
        }
        if (order.delivery_minutes != null) {
          var delBtn = document.querySelector('#delivery-grid .time-btn[data-min="' + order.delivery_minutes + '"]');
          if (delBtn) delBtn.classList.add('selected');
          else $('delivery-custom').value = order.delivery_minutes;
        }
      } else {
        // Default validate : preselect 20 prep, et 15 delivery si livraison sinon 0
        document.querySelector('#prep-grid .time-btn[data-min="20"]').classList.add('selected');
        var defDel = order.mode === 'delivery' ? 15 : 0;
        var defDelBtn = document.querySelector('#delivery-grid .time-btn[data-min="' + defDel + '"]');
        if (defDelBtn) defDelBtn.classList.add('selected');
      }

      // Cache delivery block si takeaway (commande à emporter, pas de livraison)
      var deliveryBlock = $('delivery-block');
      if (deliveryBlock) {
        if (order.mode === 'delivery') {
          deliveryBlock.style.display = '';
        } else {
          deliveryBlock.style.display = 'none';
          // Force delivery=0 pour takeaway (zéro temps de livraison)
          $('delivery-custom').value = '';
          document.querySelectorAll('#delivery-grid .time-btn').forEach(function(x) { x.classList.remove('selected'); });
          var zeroBtn = document.querySelector('#delivery-grid .time-btn[data-min="0"]');
          if (zeroBtn) zeroBtn.classList.add('selected');
        }
      }
      $('modal-eta-back').classList.add('show');
    }
    function closeEtaModal() {
      $('modal-eta-back').classList.remove('show');
      state.modalEtaCtx = null;
    }
    $('modal-eta-cancel').addEventListener('click', closeEtaModal);
    $('modal-eta-back').addEventListener('click', function(e) {
      if (e.target.id === 'modal-eta-back') closeEtaModal();
    });
    var modalEtaCloseX = $('modal-eta-close-x');
    if (modalEtaCloseX) modalEtaCloseX.addEventListener('click', closeEtaModal);

    // Toggle prep buttons
    document.querySelectorAll('#prep-grid .time-btn').forEach(function(b) {
      b.addEventListener('click', function() {
        document.querySelectorAll('#prep-grid .time-btn').forEach(function(x) { x.classList.remove('selected'); });
        b.classList.add('selected');
        $('prep-custom').value = '';
      });
    });
    document.querySelectorAll('#delivery-grid .time-btn').forEach(function(b) {
      b.addEventListener('click', function() {
        document.querySelectorAll('#delivery-grid .time-btn').forEach(function(x) { x.classList.remove('selected'); });
        b.classList.add('selected');
        $('delivery-custom').value = '';
      });
    });
    $('prep-custom').addEventListener('input', function() {
      if (this.value) document.querySelectorAll('#prep-grid .time-btn').forEach(function(x) { x.classList.remove('selected'); });
    });
    $('delivery-custom').addEventListener('input', function() {
      if (this.value !== '') document.querySelectorAll('#delivery-grid .time-btn').forEach(function(x) { x.classList.remove('selected'); });
    });

    function getSelectedMin(gridId, customId) {
      var custom = $(customId).value.trim();
      if (custom !== '') {
        var n = Number(custom);
        if (Number.isFinite(n) && n >= 0 && n <= 180) return Math.round(n);
        return null;
      }
      var btn = document.querySelector('#' + gridId + ' .time-btn.selected');
      if (!btn) return null;
      return Number(btn.getAttribute('data-min'));
    }

    $('modal-eta-ok').addEventListener('click', async function() {
      if (!state.modalEtaCtx) return;
      var ctx = state.modalEtaCtx;
      var prep = getSelectedMin('prep-grid', 'prep-custom');
      var delivery = getSelectedMin('delivery-grid', 'delivery-custom');

      if (prep == null || prep < 1) {
        showToast(t.toastNeedPrep, 'err'); return;
      }
      if (delivery == null) {
        showToast(t.toastNeedDelivery, 'err'); return;
      }

      var btn = this; btn.disabled = true;
      try {
        var url, payload;
        if (ctx.kind === 'validate') {
          url = '/api/orders/' + encodeURIComponent(ctx.orderId) + '/ack';
          payload = { prep_minutes: prep, delivery_minutes: delivery };
        } else {
          url = '/api/orders/' + encodeURIComponent(ctx.orderId) + '/eta';
          payload = { prep_minutes: prep, delivery_minutes: delivery };
          var reason = $('eta-reason').value.trim();
          if (reason) payload.reason = reason;
        }
        var res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || t.apiError);
        showToast(ctx.kind === 'validate' ? t.toastValidated : t.toastUpdated, 'ok');
        closeEtaModal();
        // Switch tab vers "en cours" après validation
        if (ctx.kind === 'validate') tabSwitch('prep');
        poll();
      } catch (err) {
        showToast(t.toastError + (err.message || err), 'err');
      } finally {
        btn.disabled = false;
      }
    });

    async function setStatus(id, status) {
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ status: status }),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || t.loginErrorDefault);
        showToast(t.toastStatus + status, 'ok');
        poll();
      } catch (err) {
        showToast(t.toastError + (err.message || err), 'err');
      }
    }

    // ===== Modal Chat =====
    function openChatModal(id) {
      var order = state.orders.find(function(o) { return o.id === id; });
      if (!order) return;
      state.modalChatCtx = { orderId: id, lastMsgId: 0 };
      $('modal-chat-title').textContent = t.chatTitle + ' — ' + id;
      $('modal-chat-sub').textContent = order.name + ' · ' + order.phone;
      $('chat-msgs').innerHTML = '<div class="chat-empty">' + t.chatLoading + '</div>';
      $('chat-input').value = '';
      $('modal-chat-back').classList.add('show');
      fetchChat();
      state.modalChatCtx.pollTimer = setInterval(fetchChat, 3000);
    }
    function closeChatModal() {
      if (state.modalChatCtx && state.modalChatCtx.pollTimer) clearInterval(state.modalChatCtx.pollTimer);
      state.modalChatCtx = null;
      $('modal-chat-back').classList.remove('show');
    }
    $('modal-chat-close').addEventListener('click', closeChatModal);
    $('modal-chat-back').addEventListener('click', function(e) {
      if (e.target.id === 'modal-chat-back') closeChatModal();
    });
    var modalChatCloseX = $('modal-chat-close-x');
    if (modalChatCloseX) modalChatCloseX.addEventListener('click', closeChatModal);

    // Esc ferme le modal ouvert (priorité : chat > eta)
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      var chatBack = $('modal-chat-back');
      var etaBack = $('modal-eta-back');
      if (chatBack && chatBack.classList.contains('show')) { closeChatModal(); return; }
      if (etaBack && etaBack.classList.contains('show')) { closeEtaModal(); return; }
    });

    async function fetchChat() {
      if (!state.modalChatCtx) return;
      var id = state.modalChatCtx.orderId;
      // Réutilise endpoint poll pour récupérer juste l'order, ou messages : utilise public + phone
      // Mais public nécessite phone. On va plutôt utiliser un poll filtré : prend l'order de state, et fetch direct chat
      // Solution : fetch direct via SQL... non. On va passer par poll (déjà fait), et messages via reuse public.
      // Astuce : récupérer phone last4 depuis state pour interroger /public
      var order = state.orders.find(function(o) { return o.id === id; });
      if (!order) return;
      var phone4 = String(order.phone || '').replace(/\D/g, '').slice(-4);
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(id) + '/public?phone=' + phone4 + '&since=' + state.modalChatCtx.lastMsgId, {
          cache: 'no-store',
        });
        if (!res.ok) return;
        var data = await res.json();
        if (!data.ok) return;
        if (data.messages && data.messages.length > 0) {
          renderChatMsgs(data.messages);
        } else if (state.modalChatCtx.lastMsgId === 0) {
          $('chat-msgs').innerHTML = '<div class="chat-empty">' + t.chatEmpty + '</div>';
        }
      } catch (e) {}
    }
    function renderChatMsgs(msgs) {
      var container = $('chat-msgs');
      if (state.modalChatCtx.lastMsgId === 0) container.innerHTML = '';
      msgs.forEach(function(m) {
        var cls, text;
        if (m.sender === 'patron') { cls = 'from-patron'; text = m.text; }
        else if (m.sender === 'client') { cls = 'from-client'; text = m.text; ding(660, 0.3); }
        else {
          cls = 'from-system';
          var raw = String(m.text || '');
          if (raw.indexOf('accepted:') === 0) {
            var p = raw.slice(9).split(':');
            text = t.sysAcceptedPrefix + p[0] + ' ' + t.min + (p[1] ? t.sysDeliveryExtra + p[1] + ' ' + t.min : '');
          } else if (raw.indexOf('eta:') === 0) {
            var rest = raw.slice(4); var reason = '';
            var pi = rest.indexOf('|');
            if (pi !== -1) { reason = rest.slice(pi + 1); rest = rest.slice(0, pi); }
            var pp = rest.split(':');
            text = t.sysEtaPrefix + pp[0] + ' ' + t.min;
            if (pp[1] && /^\d+$/.test(pp[1])) text += t.sysDeliveryExtra + pp[1] + ' ' + t.min;
            if (reason) text += ' (' + reason + ')';
          } else { text = raw; }
        }
        var el = document.createElement('div');
        el.className = 'chat-msg ' + cls;
        el.innerHTML = escapeHtml(text) + '<div class="meta">' + fmtTime(m.created_at) + '</div>';
        container.appendChild(el);
        state.modalChatCtx.lastMsgId = Math.max(state.modalChatCtx.lastMsgId, m.id || m.created_at);
      });
      container.scrollTop = container.scrollHeight;
    }

    document.querySelectorAll('.chat-shortcuts button').forEach(function(b) {
      b.addEventListener('click', function() {
        var tpl = b.getAttribute('data-tpl');
        var inp = $('chat-input');
        inp.value = tpl;
        inp.focus();
      });
    });

    $('chat-send').addEventListener('click', sendChatMsg);
    $('chat-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); sendChatMsg(); }
    });

    async function sendChatMsg() {
      if (!state.modalChatCtx) return;
      var inp = $('chat-input');
      var text = inp.value.trim();
      if (!text) return;
      inp.disabled = true;
      try {
        var res = await fetch('/api/orders/' + encodeURIComponent(state.modalChatCtx.orderId) + '/message-patron', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ text: text }),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || t.loginErrorDefault);
        inp.value = '';
        fetchChat();
      } catch (err) {
        showToast(t.toastError + (err.message || err), 'err');
      } finally {
        inp.disabled = false;
        inp.focus();
      }
    }

    // ===== Init =====
    tryAutoLogin().then(function(ok) {
      if (!ok) $('login').style.display = 'flex';
    });

    // Pause poll si page invisible
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        if (state.pollAbort) state.pollAbort.abort();
      } else if (state.authed) {
        poll();
      }
    });
  })();
  </script>
</body>
</html>
