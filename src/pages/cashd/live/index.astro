        tplOnTheWay:    { label: "Καθ' οδόν",       text: 'Ο διανομέας είναι καθ\' οδόν.' },
        tplDelay:       { label: 'Καθυστέρηση',    text: 'Συγγνώμη, μικρή καθυστέρηση.' },
        tplReplacement: { label: 'Αντικατάσταση',  text: 'Το προϊόν είναι μη διαθέσιμο, OK για αντικατάσταση;' },
        modeDelivery: '🛵 Παράδοση',
