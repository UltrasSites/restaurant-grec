---
// Page POS (caisse en boutique) pour Kalamaki.
// Auth : réutilise le cookie caisse_auth (déjà posé par /cashd via /api/caisse-login).
// Si pas de cookie → redirige vers /cashd (qui demande le mot de passe).
import PosCaisse from "../../components/pos/PosCaisse.astro";
import CashdNav from "../../components/cashd/CashdNav.astro";
import { kalamakiPosConfig, getKalamakiProducts } from "../../data/pos-config";

const products = getKalamakiProducts();
---
<!doctype html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="robots" content="noindex, nofollow" />
  <title>POS — Καλαμάκι Της Τρούμπας</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: #0a0a0a; color: #fff; min-height: 100vh; }
    body { overflow-x: hidden; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }

    .pos-topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.6rem 1rem; background: #000;
      border-bottom: 2px solid rgba(229,179,42,0.4);
      gap: 0.5rem;
      position: sticky; top: 0; z-index: 50;
    }
    .pos-topbar h1 { margin: 0; font-size: 0.95rem; color: #E5B32A; letter-spacing: 0.05em; }
    .pos-topbar .links { display: flex; gap: 0.4rem; }
    .pos-topbar a {
      padding: 0.5rem 0.85rem; font-size: 0.78rem;
      background: #1a1a1a; color: #ccc;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.4rem; text-decoration: none;
      letter-spacing: 0.04em; font-weight: 700;
    }
    .pos-topbar a:hover { background: #222; color: #E5B32A; }

    .auth-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.85);
      display: none; align-items: center; justify-content: center;
      flex-direction: column; gap: 1rem; z-index: 500;
      color: #fff; text-align: center; padding: 1rem;
    }
    .auth-overlay.show { display: flex; }
    .auth-overlay a {
      padding: 0.85rem 1.4rem; background: #E5B32A; color: #000;
      border-radius: 0.5rem; text-decoration: none; font-weight: 800;
      letter-spacing: 0.05em;
    }
  </style>
</head>
<body>
  <CashdNav />
  <header class="pos-topbar">
    <h1>🧾 POS — ΚΑΛΑΜΑΚΙ</h1>
    <div class="links">
      <a href="/cashd">📟 Online</a>
      <a href="/cashd/history">📋 Ιστορικό</a>
    </div>
  </header>

  <main>
    <PosCaisse products={products} config={kalamakiPosConfig} />
  </main>

  <div class="auth-overlay" id="auth-overlay">
    <div>🔒 Απαιτείται σύνδεση</div>
    <a href="/cashd">Σύνδεση</a>
  </div>

  <script is:inline>
    // Vérifie le cookie caisse_auth via un appel léger (poll endpoint qui renvoie 401 si KO)
    fetch('/api/orders/poll?since=0', { credentials: 'include', cache: 'no-store' })
      .then(function(r) {
        if (r.status === 401) {
          document.getElementById('auth-overlay').classList.add('show');
        }
      })
      .catch(function() { /* offline = on laisse passer, PWA usage */ });

    // PWA register (réutilise le SW existant)
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/caisse-sw.js').catch(function(){});
    }
  </script>
</body>
</html>
