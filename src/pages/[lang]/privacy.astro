---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Lang } from "../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: "el" } },
    { params: { lang: "en" } },
  ];
}

const param = (Astro.params.lang || "el") as string;
const isEl = param === "el";
const isEn = param === "en";

const layoutLang: Lang = isEl ? "el" : "en";

const TITLES: Record<string, string> = {
  el: "Πολιτική απορρήτου",
  en: "Privacy policy",
  fr: "Politique de confidentialité",
};
const title = TITLES[param] || TITLES.el;
---

<BaseLayout lang={layoutLang} title={`${title} — Το Καλαμάκι Της Τρούμπας`} description={title}>
  <section class="bg-[#0a0a0a] pt-32 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-serif italic text-white mb-8">{title}</h1>

      {isEl && (
        <div class="space-y-6 text-gray-300 leading-relaxed text-[0.95rem]">
          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">1. Υπεύθυνος επεξεργασίας</h2>
            <p>Το Καλαμάκι Της Τρούμπας — Μπουμπουλίνας 8 & Νοταρά, 185 35 Πειραιάς, Ελλάδα.</p>
            <p>Email: <a href="mailto:kalamaki.troubas@gmail.com" class="text-[#E5B32A] hover:underline">kalamaki.troubas@gmail.com</a></p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">2. Ποια δεδομένα συλλέγουμε</h2>
            <p>Όταν κάνετε παραγγελία online συλλέγουμε αποκλειστικά:</p>
            <ul class="list-disc pl-6 mt-2 space-y-1">
              <li><strong>Όνομα</strong> — για να σας αναγνωρίσουμε κατά την παραλαβή ή την παράδοση</li>
              <li><strong>Τηλέφωνο</strong> — για επικοινωνία σε περίπτωση προβλήματος με την παραγγελία</li>
              <li><strong>Διεύθυνση</strong> — μόνο για παραγγελίες με παράδοση κατ' οίκον</li>
              <li>Περιεχόμενο καλαθιού και επιλογές πληρωμής/παραλαβής</li>
            </ul>
            <p class="mt-2">Δεν συλλέγουμε στοιχεία πληρωμής (όλες οι πληρωμές γίνονται με μετρητά ή κάρτα στον υπάλληλο/διανομέα).</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">3. Διάρκεια διατήρησης</h2>
            <ul class="list-disc pl-6 mt-2 space-y-1">
              <li><strong>Ονομαστική παραγγελία</strong> (όνομα, τηλέφωνο, διεύθυνση): <strong>24 ώρες</strong>, στη συνέχεια διαγράφεται αυτόματα.</li>
              <li><strong>Ανώνυμο ιστορικό</strong> (μόνο αριθμός παραγγελίας, σύνολο, ημερομηνία, κατάσταση — χωρίς προσωπικά στοιχεία): <strong>50 ημέρες</strong>, για λόγους λογιστικού ελέγχου και επίλυσης διαφορών.</li>
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">4. Cookies</h2>
            <p>Χρησιμοποιούμε μόνο τεχνικά cookies απαραίτητα: αποθήκευση γλώσσας, καλαθιού αγορών, σύνδεσης ταμείου. Δεν χρησιμοποιούνται cookies παρακολούθησης, ούτε διαφημιστικά, ούτε analytics.</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">5. Παραλήπτες</h2>
            <p>Τα δεδομένα σας δεν διαβιβάζονται σε τρίτους. Επεξεργάζονται μόνο από το προσωπικό του εστιατορίου για την εκτέλεση της παραγγελίας σας.</p>
            <p>Φιλοξενία τεχνικών δεδομένων: Cloudflare, Inc. (ΗΠΑ — Standard Contractual Clauses).</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">6. Τα δικαιώματά σας (GDPR)</h2>
            <p>Έχετε δικαίωμα: πρόσβασης, διόρθωσης, διαγραφής, περιορισμού της επεξεργασίας, φορητότητας, εναντίωσης. Δεδομένου ότι τα στοιχεία διαγράφονται αυτόματα μετά από 24 ώρες, η άσκηση των δικαιωμάτων αυτών είναι κυρίως σχετική με ανώνυμα δεδομένα.</p>
            <p>Για κάθε αίτημα: <a href="mailto:kalamaki.troubas@gmail.com" class="text-[#E5B32A] hover:underline">kalamaki.troubas@gmail.com</a></p>
            <p>Μπορείτε επίσης να υποβάλετε καταγγελία στην <a href="https://www.dpa.gr" target="_blank" rel="noopener" class="text-[#E5B32A] hover:underline">Αρχή Προστασίας Δεδομένων Προσωπικού Χαρακτήρα (ΑΠΔΠΧ)</a>.</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">7. Ενημέρωση πολιτικής</h2>
            <p>Τελευταία ενημέρωση: Μάιος 2026.</p>
          </div>
        </div>
      )}

      {isEn && (
        <div class="space-y-6 text-gray-300 leading-relaxed text-[0.95rem]">
          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">1. Data controller</h2>
            <p>To Kalamaki Tis Troumpas — Bouboulinas 8 & Notara, 185 35 Piraeus, Greece.</p>
            <p>Email: <a href="mailto:kalamaki.troubas@gmail.com" class="text-[#E5B32A] hover:underline">kalamaki.troubas@gmail.com</a></p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">2. What data we collect</h2>
            <p>When you place an online order we collect strictly:</p>
            <ul class="list-disc pl-6 mt-2 space-y-1">
              <li><strong>Name</strong> — to identify you at pickup or delivery</li>
              <li><strong>Phone number</strong> — to reach you if there is an issue</li>
              <li><strong>Address</strong> — only for home-delivery orders</li>
              <li>Cart content and payment/pickup options</li>
            </ul>
            <p class="mt-2">We do not collect any payment data (all payments are made in cash or by card to the staff/courier in person).</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">3. Retention period</h2>
            <ul class="list-disc pl-6 mt-2 space-y-1">
              <li><strong>Identified order</strong> (name, phone, address): <strong>24 hours</strong>, then automatically deleted.</li>
              <li><strong>Anonymous history</strong> (order ID, total, date, status — no personal data): <strong>50 days</strong>, for accounting traceability and dispute resolution.</li>
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">4. Cookies</h2>
            <p>We only use essential technical cookies: language, cart, cashier login. No tracking, advertising or analytics cookies.</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">5. Recipients</h2>
            <p>Your data is not transferred to any third party. It is processed only by the restaurant staff to fulfil your order.</p>
            <p>Technical hosting: Cloudflare, Inc. (USA — Standard Contractual Clauses).</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">6. Your rights (GDPR)</h2>
            <p>You have the right to: access, rectification, erasure, restriction, portability, objection. Because data is auto-deleted after 24h, these rights mostly concern the anonymised history.</p>
            <p>To exercise your rights: <a href="mailto:kalamaki.troubas@gmail.com" class="text-[#E5B32A] hover:underline">kalamaki.troubas@gmail.com</a></p>
            <p>You can also lodge a complaint with the <a href="https://www.dpa.gr/en" target="_blank" rel="noopener" class="text-[#E5B32A] hover:underline">Hellenic Data Protection Authority (HDPA)</a>.</p>
          </div>

          <div>
            <h2 class="text-xl font-serif text-[#E5B32A] mb-2">7. Policy updates</h2>
            <p>Last updated: May 2026.</p>
          </div>
        </div>
      )}

      <div class="mt-12 pt-8 border-t border-white/10 flex flex-wrap items-center justify-between gap-4">
        <a href={`/${isEl ? "el" : "en"}/`} class="text-[#E5B32A] hover:underline text-sm">
          ← {isEl ? "Επιστροφή στην αρχική" : "Back to home"}
        </a>
        <a href="/fr/privacy/" class="text-gray-400 hover:text-[#E5B32A] text-xs uppercase tracking-widest">Version française</a>
      </div>
    </div>
  </section>
</BaseLayout>
