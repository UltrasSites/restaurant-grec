---
export function getStaticPaths() {
  return [
    { params: { lang: "el" } },
    { params: { lang: "en" } },
  ];
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBar from "../../components/NavBar.astro";
import SocialLinks from "../../components/SocialLinks.astro";
import MenuBook from "../../components/MenuBook.astro";
import ReviewsSection from "../../components/ReviewsSection.astro";
import Flag from "../../components/Flag.astro";
import { getLangFromParam } from "../../i18n/utils";
import { translations, getMenu } from "../../i18n/translations";
import { SPECIALITIES } from "../../data/efood-photos-map.mjs";

const currentLang = getLangFromParam(Astro.params.lang);
const t = translations[currentLang];
const menu = getMenu(currentLang);
const baseUrl = `/${currentLang}`;
---

<style>
  /* === MOBILE HERO — Exact restaurant-bar pattern + carrousel === */
  @media (max-width: 767px) {
    .hero-card-viewport {
      perspective: 2000px;
      padding: 0.5rem;
      margin-top: 0.5rem;
      width: 100%;
      box-sizing: border-box;
    }
    .hero-card-3d {
      /* MOBILE-ONLY (parent @media max-width:767px) — perf : pas de backdrop-filter
         (rasterisation GPU coûteuse sur mobile) ni d'animation continue sur cet élément.
         Fond légèrement plus opaque pour garder le look "glass" sans le blur. */
      background: linear-gradient(135deg, rgba(229, 179, 42, 0.12) 0%, rgba(10, 10, 10, 0.78) 100%);
      border: 1px solid rgba(229, 179, 42, 0.30);
      border-radius: 2rem;
      padding: 2rem 1.5rem !important;
      width: 100%;
      box-sizing: border-box;
      overflow: hidden;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 0 !important;
      transform: rotateX(8deg) rotateY(-4deg);
      box-shadow:
        0 30px 60px -12px rgba(0, 0, 0, 0.8),
        0 18px 36px -18px rgba(0, 0, 0, 0.9),
        0 0 40px rgba(229, 179, 42, 0.1);
      position: relative;
    }
    /* Force all direct children to fit */
    .hero-card-3d > * {
      max-width: 100% !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }
    .hero-card-3d h1 {
      font-size: 2.1rem !important;
      white-space: nowrap;
      margin-bottom: 0.35rem !important;
      text-align: center !important;
    }
    .hero-card-3d p {
      font-size: 0.85rem !important;
      margin-bottom: 0.4rem !important;
      text-align: center !important;
      line-height: 1.5 !important;
    }
    .hero-card-3d .flex.mb-1 {
      margin-bottom: 0.25rem !important;
      justify-content: center !important;
    }
    .hero-card-3d .hero-photo-strip {
      border-radius: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .hero-card-3d aside {
      margin-top: 0.25rem !important;
    }
    .hero-card-3d aside .flex.flex-col.gap-3 a {
      padding: 0.85rem 1.25rem !important;
      font-size: 12px !important;
    }
    .resa-card-inner-mobile a {
      padding: 0.85rem 1.25rem !important;
      font-size: 12px !important;
    }
    /* Badge smaller */
    .hero-card-3d span[class*="tracking"] {
      font-size: 8px !important;
      padding: 0.3rem 0.75rem !important;
      margin-bottom: 0.5rem !important;
    }
    /* Aside inner : transparent comme le modele restaurant-bar */
    .resa-card-inner-mobile {
      background: transparent !important;
      border: none !important;
      backdrop-filter: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      margin-left: auto !important;
      margin-right: auto !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    .resa-card-inner-mobile p[class*="uppercase"] {
      margin-bottom: 0.35rem !important;
      text-align: center !important;
    }
    .resa-card-inner-mobile .flex.flex-col.gap-3 {
      gap: 0.5rem !important;
    }
    /* Masquer adresse/phone/hours sur mobile */
    .mobile-hide-details { display: none !important; }
    @keyframes hero-card-float {
      0%, 100% { transform: rotateX(8deg) rotateY(-4deg) translateY(0); }
      50%      { transform: rotateX(6deg) rotateY(-2deg) translateY(-15px); }
    }
  }

  /* Carrousel hero — entre la pastille et le titre */
  .hero-photo-strip {
    width: 100%;
    overflow: hidden;
    height: 70px;
    border-radius: 0.85rem;
    margin-bottom: 0.5rem;
    position: relative;
  }
  @media (min-width: 768px) {
    .hero-photo-strip { height: 90px; margin-bottom: 1rem; }
  }

  /* Sur mobile, on remonte la carte CTA du hero pour la rendre visible dès le chargement */
  @media (max-width: 767px) {
    .mobile-hero-card-shift {
      margin-top: -3.5cm;
      position: relative;
      z-index: 5;
    }
  }
  .strip-track {
    display: flex;
    gap: 6px;
    height: 100%;
    width: max-content;
    animation: strip-scroll 28s linear infinite;
  }
  .strip-track img {
    height: 100%;
    width: 120px;
    object-fit: cover;
    border-radius: 0.6rem;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .strip-track img { width: 170px; }
  }
  @keyframes strip-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  /* MOBILE-ONLY perf : on fige le carrousel hero (pas de boucle compositeur permanente
     qui empêche la page de devenir idle). Les photos restent visibles. Desktop inchangé. */
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    .strip-track { animation: none !important; }
  }
  .gold-shine-text {
    background: linear-gradient(
      to right,
      #e5b32a 0%, #fff3ad 25%, #e5b32a 50%, #fff3ad 75%, #e5b32a 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gold-shimmer 4s linear infinite;
  }
  .dish-name-gold { color: #e5b32a; }
  #histoire .histoire-img { max-width: 100%; height: auto; border-radius: 0.5rem; }
  @keyframes gold-shimmer {
    from { background-position: 0% center; }
    to { background-position: 200% center; }
  }
  /* Perf machines faibles : ban background-position animation mobile + reduced-motion */
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    .gold-shine-text {
      animation: none !important;
      background: none !important;
      -webkit-text-fill-color: #e5b32a !important;
      color: #e5b32a !important;
    }
  }

  /* ═══════════════════════════════════════════════════════════
     BEAM-TO-CTA — toutes les animations du hero convergent vers
     la seule CTA illuminée : "Commandez en ligne" (.cta-beam-target).
     Palette Kalamaki : or #E5B32A. Animations transform/opacity only.
     (restauré du travail 27/05) */

  /* Fond ambient : 2 blobs dorés qui dérivent lentement */
  .hero-ambient {
    position: absolute;
    inset: -10% -10% 0 -10%;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .hero-blob {
    position: absolute;
    width: 520px; height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, rgba(229,179,42,0.16) 0%, rgba(229,179,42,0) 60%);
    transform: translate3d(0, 0, 0);
    will-change: transform;
  }
  .hero-blob.b1 { top: -10%; left: -8%; animation: hero-blob-drift-a 38s ease-in-out infinite; }
  .hero-blob.b2 { bottom: -15%; right: -10%; width: 600px; height: 600px;
                  background: radial-gradient(circle at 50% 50%, rgba(229,179,42,0.10) 0%, rgba(229,179,42,0) 60%);
                  animation: hero-blob-drift-b 46s ease-in-out infinite; }
  @keyframes hero-blob-drift-a {
    0%,100% { transform: translate3d(0,0,0); }
    50%     { transform: translate3d(40px, 30px, 0); }
  }
  @keyframes hero-blob-drift-b {
    0%,100% { transform: translate3d(0,0,0); }
    50%     { transform: translate3d(-50px, -20px, 0); }
  }
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    /* perf mobile : pas d'animation ET pas de will-change (sinon layer GPU promu pour rien) */
    .hero-blob { animation: none !important; will-change: auto !important; }
  }

  /* CTA principale "Commandez en ligne" — la SEULE illuminée du hero.
     Gradient or profond + halo radial qui pulse (::before, scale+opacity = composé GPU)
     + shine interne qui traverse le bouton (::after). box-shadow statique (perf). */
  .cta-beam-target {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #E5B32A 0%, #FBBF24 48%, #E5B32A 100%) !important;
    color: #1a1206 !important;
    box-shadow:
      0 8px 22px rgba(229, 179, 42, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transform: translateZ(0);
    z-index: 1;
  }
  /* ::before = halo or qui pulse en scale+opacity (composé GPU, zero paint) */
  .cta-beam-target::before {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 50%, rgba(229, 179, 42, 0.55) 0%, rgba(229, 179, 42, 0.18) 50%, transparent 75%);
    transform: translate3d(0, 0, 0) scale(0.92);
    opacity: 0.5;
    will-change: transform, opacity;
    animation: cta-beam-halo 3s ease-in-out infinite;
    pointer-events: none;
    z-index: -1;
  }
  /* ::after = shine qui traverse l'INTÉRIEUR de la CTA toutes les 3s (overflow hidden = reste dans) */
  .cta-beam-target::after {
    content: "";
    position: absolute;
    top: -10%;
    left: -55%;
    width: 55%;
    height: 120%;
    background: linear-gradient(100deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.92) 50%, rgba(255, 255, 255, 0) 100%);
    transform: translate3d(0, 0, 0) skewX(-18deg);
    animation: cta-beam-shine 3s ease-in-out infinite;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  .cta-beam-target:hover {
    transform: translateY(-2px);
    box-shadow:
      0 12px 28px rgba(229, 179, 42, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.55);
  }
  .cta-beam-target:active { transform: scale(0.98); }
  @keyframes cta-beam-halo {
    0%, 100% { transform: translate3d(0, 0, 0) scale(0.94); opacity: 0.45; }
    50%      { transform: translate3d(0, 0, 0) scale(1.06); opacity: 0.85; }
  }
  @keyframes cta-beam-shine {
    0%   { transform: translate3d(0, 0, 0) skewX(-18deg); opacity: 0; }
    18%  { opacity: 0.95; }
    60%  { transform: translate3d(360%, 0, 0) skewX(-18deg); opacity: 0.95; }
    62%  { opacity: 0; }
    100% { transform: translate3d(360%, 0, 0) skewX(-18deg); opacity: 0; }
  }
  /* Reduced motion : on coupe les boucles, la CTA reste illuminée (halo statique) */
  @media (prefers-reduced-motion: reduce) {
    .cta-beam-target::before { animation: none !important; opacity: 0.6; transform: translate3d(0,0,0) scale(1); }
    .cta-beam-target::after  { animation: none !important; opacity: 0; }
  }
  /* MOBILE-ONLY perf : on coupe les 2 boucles de la CTA (halo pulse + shine mix-blend).
     mix-blend-mode:screen force un layer composite + blending par frame = cher sur mobile.
     La CTA reste illuminée (gradient or + box-shadow + halo statique). Desktop inchangé. */
  @media (max-width: 767px) {
    .cta-beam-target::before { animation: none !important; opacity: 0.55; transform: translate3d(0,0,0) scale(1); }
    .cta-beam-target::after  { animation: none !important; opacity: 0; mix-blend-mode: normal; }
  }

  /* Beam SVG : trait pointillé doré qui "respire" du titre vers la CTA (desktop only).
     27/05 perf : opacity-pulse (composé GPU) au lieu de stroke-dashoffset (repaint/frame). */
  .hero-beam-svg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    width: 100%; height: 100%;
    z-index: 2;
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-beam-svg { display: block; }
  }
  .hero-beam-svg .beam-path {
    fill: none;
    stroke: url(#beamGradient);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 8 12;
    stroke-dashoffset: 0;
    opacity: 0.55;
    will-change: opacity;
    animation: beam-flow-opacity 5s ease-in-out infinite;
  }
  @keyframes beam-flow-opacity {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 0.85; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-beam-svg .beam-path { animation: none !important; opacity: 0.3; }
  }

  /* =====================================================================
     SCROLL HINT — Vertical Beam Drop (signature Ultras-Sites, palette or)
     Ligne verticale + goutte lumineuse or. Disparaît au scroll > 80px.
     ===================================================================== */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.35s ease;
    z-index: 5;
  }
  .scroll-hint:hover { opacity: 1; }
  .scroll-hint-label {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(232, 232, 237, 0.55);
    font-weight: 600;
    white-space: nowrap;
  }
  .scroll-hint-svg {
    width: 4px;
    height: 60px;
    overflow: visible;
  }
  .scroll-hint-dot {
    animation: beamDrop 2.6s cubic-bezier(.55, .08, .45, 1) infinite;
    filter: drop-shadow(0 0 4px rgba(229, 179, 42, 0.7));
  }
  @keyframes beamDrop {
    0%   { transform: translateY(0);  opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { transform: translateY(60px); opacity: 0; }
  }
  .scroll-hint.is-hidden {
    opacity: 0;
    pointer-events: none;
  }
  @media (max-width: 480px) {
    .scroll-hint-label { letter-spacing: 0.22em; font-size: 9px; }
    .scroll-hint { bottom: 20px; gap: 8px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hint-dot {
      animation: none;
      transform: translateY(30px);
      opacity: 1;
    }
  }
</style>

<BaseLayout
  lang={currentLang}
  title={t.meta_title}
  description={t.meta_description}
  includeMenu={true}
  breadcrumbs={[
    { name: currentLang === 'el' ? 'Αρχική' : 'Home', path: `/${currentLang}/` },
  ]}
>

  <!-- HERO -->
  <section id="home" class="relative min-h-screen w-full flex flex-col overflow-x-hidden bg-neutral-950">
    <div class="absolute inset-0 z-0">
      <img
        src="/photos/efood-00-1600w.webp"
        srcset="/photos/efood-00-800w.webp 800w, /photos/efood-00-1600w.webp 1600w"
        sizes="100vw"
        alt={currentLang === 'el' ? 'Αυθεντικό ψητοπωλείο στην Τρούμπα, Πειραιάς' : 'Authentic charcoal souvlaki shop in Troumpa, Piraeus'}
        class="w-full h-full object-cover opacity-55"
        width="1600" height="900"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/40 to-neutral-950/75"></div>
    </div>

    {/* Ambient blobs Kalamaki — palette or, dérive lente, transform only */}
    <div class="hero-ambient" aria-hidden="true">
      <div class="hero-blob b1"></div>
      <div class="hero-blob b2"></div>
    </div>

    {/* Beam SVG — trait pointillé qui converge du titre vers la CTA principale (desktop only) */}
    <svg class="hero-beam-svg" viewBox="0 0 1200 800" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="beamGradient" x1="0%" y1="0%" x2="100%" y2="50%">
          <stop offset="0%"  stop-color="#E5B32A" stop-opacity="0"/>
          <stop offset="40%" stop-color="#E5B32A" stop-opacity="0.7"/>
          <stop offset="100%" stop-color="#E5B32A" stop-opacity="1"/>
        </linearGradient>
      </defs>
      <path class="beam-path" d="M 280 380 Q 500 320 720 400 T 980 460" />
    </svg>

    <NavBar lang={currentLang} />

    <div class="relative z-10 px-6 w-full flex-1 flex items-center justify-center py-4 md:py-20">
      <div class="hero-card-viewport">
        <div class="hero-card-3d max-w-screen-2xl mx-auto grid md:grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] gap-8 lg:gap-16 items-center text-left w-full">

          <div class="flex flex-col items-center lg:items-start max-w-xl">
            <span class="inline-block border border-[#E5B32A]/50 px-6 py-2 rounded-full text-[10px] uppercase tracking-[0.4em] mb-3 bg-black/30 backdrop-blur-sm text-[#E5B32A] font-bold">
              {t.hero_badge}
            </span>

            {/* Carrousel hero — photos haute résolution du resto.
                Affichage 120px (mobile) / 170px (desktop) → 400w est suffisant + 800w pour retina. */}
            <div class="hero-photo-strip">
              <div class="strip-track">
                {[
                  "trouba-storefront",
                  "trouba-grill-skewers",
                  "trouba-grill-chops",
                  "efood-00",
                  "trouba-storefront",
                  "trouba-grill-skewers",
                  "trouba-grill-chops",
                  "efood-25",
                  "trouba-storefront",
                ].map((stem) => (
                  <img
                    src={`/photos/${stem}-400w.webp`}
                    srcset={`/photos/${stem}-400w.webp 400w, /photos/${stem}-800w.webp 800w`}
                    sizes="(max-width: 767px) 120px, 170px"
                    alt=""
                    width="400" height="300"
                    loading="lazy" decoding="async"
                  />
                ))}
              </div>
            </div>

            <h1 class="text-5xl md:text-5xl lg:text-6xl font-serif italic text-white mb-2 md:mb-3 leading-none drop-shadow-2xl text-center lg:text-left whitespace-nowrap">
              {t.hero_title}
            </h1>
            <p class="text-gray-300 max-w-xl md:max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-4 md:mb-6 font-light text-base md:text-lg text-center lg:text-left">
              {t.hero_lead}
            </p>
            <div class="flex mb-1 justify-center lg:justify-start opacity-100 visible">
              <SocialLinks lang={currentLang} />
            </div>
            <p class="hidden md:block text-xs text-gray-300 italic">{t.hero_demo_note}</p>
          </div>

          <aside class="w-full md:mt-0 mt-1 mobile-hero-card-shift">
            <div class="resa-card-inner-mobile bg-gradient-to-b from-[#E5B32A]/12 to-black/70 border border-[#E5B32A]/30 rounded-3xl p-6 md:p-8 backdrop-blur-xl shadow-2xl w-full max-w-md ml-auto">
              <p class="text-[9px] md:text-[9px] uppercase tracking-[0.3em] text-[#E5B32A] font-bold mb-2 md:mb-3">{t.resa_title}</p>
              <h2 class="hidden md:block text-lg font-serif text-white mb-4">{t.resa_subtitle}</h2>
              <div class="mobile-hide-details space-y-2 text-xs text-gray-300 mb-4">
                <p class="leading-snug">
                  <span class="font-semibold text-white text-[10px] uppercase tracking-wider">{t.resa_label_address}</span><br />
                  <span class="font-medium text-white/90 text-[11px]">{t.resa_address}</span>
                </p>
                <p class="leading-snug">
                  <span class="font-semibold text-white text-[10px] uppercase tracking-wider">{t.resa_label_phone}</span><br />
                  <a href="tel:+302104222233" aria-label={currentLang === 'el' ? 'Τηλέφωνο 1 — Καλαμάκι Της Τρούμπας' : 'Phone 1 — Kalamaki Tis Troumpas'} class="font-medium text-[#E5B32A] hover:underline block text-[11px] tabular-nums py-1.5 -my-1.5 px-2 -mx-2">{t.resa_phone}</a>
                  <a href="tel:+302104222273" aria-label={currentLang === 'el' ? 'Τηλέφωνο 2 — Καλαμάκι Της Τρούμπας' : 'Phone 2 — Kalamaki Tis Troumpas'} class="font-medium text-[#E5B32A] hover:underline block text-[11px] tabular-nums mt-0.5 py-1.5 -my-1.5 px-2 -mx-2">+30 210 422 2273</a>
                </p>
              </div>
              {/* Horaires : visible aussi sur mobile (assez de place) */}
              <div class="space-y-2 text-xs text-gray-300 mb-4">
                <p class="leading-snug">
                  <span class="font-semibold text-white text-[10px] uppercase tracking-wider">{t.resa_label_hours}</span><br />
                  <span class="font-medium text-white/90 text-[11px]">{t.resa_hours}</span>
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <a href={`${baseUrl}/delivery`} class="cta-beam-target w-full px-8 py-3.5 text-black text-[11px] font-bold uppercase tracking-[0.2em] text-center rounded-lg transition-all duration-300">
                  {t.order_cta} <span class="ml-1 text-[9px] opacity-70">· 0%</span>
                </a>
                <a href={`${baseUrl}/#carte`} class="w-full px-8 py-2.5 bg-transparent border border-white/15 text-white/80 text-[10px] font-bold uppercase tracking-[0.2em] text-center rounded-lg hover:bg-white/5 transition-all duration-300">
                  {t.resa_cta3}
                </a>
              </div>
              <div id="cta-card-sentinel" class="h-px w-full absolute bottom-0" aria-hidden="true"></div>
            </div>
          </aside>

        </div>
      </div>
    </div>

    {/* Scroll hint Beam Drop — signature Ultras-Sites, palette or Kalamaki */}
    <a href="#histoire" class="scroll-hint" aria-label={t.scroll_hint_aria}>
      <span class="scroll-hint-label">{t.scroll_hint_label}</span>
      <svg class="scroll-hint-svg" viewBox="0 0 4 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="dropGrad-kalamaki" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#E5B32A"/>
            <stop offset="100%" stop-color="#FBBF24"/>
          </linearGradient>
        </defs>
        <line x1="2" y1="0" x2="2" y2="60" stroke="rgba(255,255,255,.12)" stroke-width="1"/>
        <circle class="scroll-hint-dot" cx="2" cy="0" r="2.4" fill="url(#dropGrad-kalamaki)"/>
      </svg>
    </a>
