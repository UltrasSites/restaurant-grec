        if (!vids.length) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            const v = e.target;
            if (e.isIntersecting) {
              if (!v.src && v.dataset.src) v.src = v.dataset.src;
              v.play().catch(() => {});
            } else { v.pause(); }
          });
        }, { rootMargin: '200px 0px', threshold: 0.1 });
        vids.forEach((v) => io.observe(v));
