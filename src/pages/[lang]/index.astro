---
export function getStaticPaths() {
  return [
    { params: { lang: "el" } },
    { params: { lang: "en" } },
  ];
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBar from "../../components/NavBar.astro";
import SocialLinks from "../../components/SocialLinks.astro";
import MenuBook from "../../components/MenuBook.astro";
import ReviewsSection from "../../components/ReviewsSection.astro";
import { getLangFromParam } from "../../i18n/utils";
import { translations, getMenu } from "../../i18n/translations";

const currentLang = getLangFromParam(Astro.params.lang);
const t = translations[currentLang];
const menu = getMenu(currentLang);
const baseUrl = `/${currentLang}`;
---

<style>
  /* === MOBILE HERO — Exact restaurant-bar pattern + carrousel === */
  @media (max-width: 767px) {
    .hero-card-viewport {
      perspective: 2000px;
      padding: 0.75rem;
      margin-top: 0.75rem;
      width: 100%;
      box-sizing: border-box;
    }
    .hero-card-3d {
      background: linear-gradient(135deg, rgba(229, 179, 42, 0.2) 0%, rgba(10, 10, 10, 0.95) 100%);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid rgba(229, 179, 42, 0.4);
      border-radius: 2rem;
      padding: 1.5rem 1.25rem !important;
      width: 100%;
      box-sizing: border-box;
      overflow: hidden;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 0 !important;
      transform: rotateX(8deg) rotateY(-4deg);
      box-shadow:
        0 30px 60px -12px rgba(0, 0, 0, 0.8),
        0 18px 36px -18px rgba(0, 0, 0, 0.9),
        0 0 40px rgba(229, 179, 42, 0.1);
      animation: hero-card-float 8s ease-in-out infinite;
      position: relative;
    }
    /* Force all direct children to fit */
    .hero-card-3d > * {
      max-width: 100% !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }
    .hero-card-3d h1 {
      font-size: 1.75rem !important;
      white-space: nowrap;
      margin-bottom: 0.35rem !important;
      text-align: center !important;
    }
    .hero-card-3d p {
      font-size: 0.75rem !important;
      margin-bottom: 0.4rem !important;
      text-align: center !important;
      line-height: 1.4 !important;
    }
    .hero-card-3d .flex.mb-1 {
      margin-bottom: 0.25rem !important;
      justify-content: center !important;
    }
    .hero-card-3d .hero-photo-strip {
      border-radius: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .hero-card-3d aside {
      margin-top: 0.25rem !important;
    }
    .hero-card-3d aside .flex.flex-col.gap-3 a {
      padding: 0.6rem 1rem !important;
      font-size: 10px !important;
    }
    /* Badge smaller */
    .hero-card-3d span[class*="tracking"] {
      font-size: 8px !important;
      padding: 0.3rem 0.75rem !important;
      margin-bottom: 0.5rem !important;
    }
    /* Aside inner : transparent comme le modele restaurant-bar */
    .resa-card-inner-mobile {
      background: transparent !important;
      border: none !important;
      backdrop-filter: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      margin-left: auto !important;
      margin-right: auto !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    .resa-card-inner-mobile p[class*="uppercase"] {
      margin-bottom: 0.35rem !important;
      text-align: center !important;
    }
    .resa-card-inner-mobile .flex.flex-col.gap-3 {
      gap: 0.5rem !important;
    }
    /* Masquer adresse/phone/hours sur mobile */
    .mobile-hide-details { display: none !important; }
    @keyframes hero-card-float {
      0%, 100% { transform: rotateX(8deg) rotateY(-4deg) translateY(0); }
      50%      { transform: rotateX(6deg) rotateY(-2deg) translateY(-15px); }
    }
  }

  /* Carrousel hero — entre la pastille et le titre */
  .hero-photo-strip {
    width: 100%;
    overflow: hidden;
    height: 70px;
    border-radius: 0.85rem;
    margin-bottom: 0.5rem;
    position: relative;
  }
  @media (min-width: 768px) {
    .hero-photo-strip { height: 90px; margin-bottom: 1rem; }
  }
  .strip-track {
    display: flex;
    gap: 6px;
    height: 100%;
    width: max-content;
    animation: strip-scroll 28s linear infinite;
  }
  .strip-track img {
    height: 100%;
    width: 120px;
    object-fit: cover;
    border-radius: 0.6rem;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .strip-track img { width: 170px; }
  }
  @keyframes strip-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .gold-shine-text {
    background: linear-gradient(
      to right,
      #e5b32a 0%, #fff3ad 25%, #e5b32a 50%, #fff3ad 75%, #e5b32a 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gold-shimmer 4s linear infinite;
  }
  .dish-name-gold { color: #e5b32a; }
  #histoire .histoire-img { max-width: 100%; height: auto; border-radius: 0.5rem; }
  @keyframes gold-shimmer {
    from { background-position: 0% center; }
    to { background-position: 200% center; }
  }
</style>

<BaseLayout lang={currentLang} title={t.meta_title} description={t.meta_description}>

  <!-- HERO -->
  <section id="home" class="relative min-h-screen w-full flex flex-col overflow-x-hidden bg-neutral-950">
    <div class="absolute inset-0 z-0">
      <img
        src="/photos/efood-00-1600w.webp"
        alt="Αυθεντικό ψητοπωλείο Τρούμπα Πειραιάς"
        class="w-full h-full object-cover opacity-55"
        width="1600" height="900"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/40 to-neutral-950/75"></div>
    </div>

    <NavBar lang={currentLang} />

    <div class="relative z-10 px-6 w-full flex-1 flex items-center justify-center py-4 md:py-20">
      <div class="hero-card-viewport">
        <div class="hero-card-3d max-w-screen-2xl mx-auto grid md:grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] gap-8 lg:gap-16 items-center text-left w-full">

          <div class="flex flex-col items-center lg:items-start max-w-xl">
            <span class="inline-block border border-[#E5B32A]/50 px-6 py-2 rounded-full text-[10px] uppercase tracking-[0.4em] mb-3 bg-black/30 backdrop-blur-sm text-[#E5B32A] font-bold">
              {t.hero_badge}
            </span>

            {/* Carrousel : remplacé temporairement — photos haute résolution clientes à fournir */}
            <div class="hero-photo-strip">
              <div class="strip-track">
                {[
                  "/photos/efood-00-800w.webp",
                  "/photos/efood-15-800w.webp",
                  "/photos/facebook-03-400w.webp",
                  "/photos/efood-30-800w.webp",
                  "/photos/efood-00-800w.webp",
                  "/photos/efood-45-800w.webp",
                  "/photos/facebook-03-400w.webp",
                  "/photos/efood-25-800w.webp",
                  "/photos/efood-00-800w.webp",
                ].map((src) => (
                  <img src={src} alt="" loading="lazy" decoding="async" />
                ))}
              </div>
            </div>

            <h1 class="text-5xl md:text-5xl lg:text-6xl font-serif italic text-white mb-2 md:mb-3 leading-none drop-shadow-2xl text-center lg:text-left whitespace-nowrap">
              {t.hero_title}
            </h1>
            <p class="text-gray-300 max-w-xl md:max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-4 md:mb-6 font-light text-base md:text-lg text-center lg:text-left">
              {t.hero_lead}
            </p>
            <div class="flex mb-1 justify-center lg:justify-start opacity-100 visible">
              <SocialLinks />
            </div>
            <p class="hidden md:block text-xs text-gray-300 italic">{t.hero_demo_note}</p>
          </div>

          <aside class="w-full md:mt-0 mt-1">
            <div class="resa-card-inner-mobile bg-gradient-to-b from-[#E5B32A]/12 to-black/70 border border-[#E5B32A]/30 rounded-3xl p-8 md:p-10 backdrop-blur-xl shadow-2xl w-full max-w-lg ml-auto">
              <p class="text-[10px] uppercase tracking-[0.3em] text-[#E5B32A] font-bold mb-2 md:mb-4">{t.resa_title}</p>
              <h2 class="hidden md:block text-2xl font-serif text-white mb-6">{t.resa_subtitle}</h2>
              <div class="mobile-hide-details space-y-3 text-sm text-gray-300 mb-6">
                <p>
                  <span class="font-semibold text-white">{t.resa_label_address} :</span><br />
                  <span class="font-medium text-white/90">{t.resa_address}</span>
                </p>
                <p>
                  <span class="font-semibold text-white">{t.resa_label_phone} :</span><br />
                  <a href="tel:+302104222233" class="font-medium text-[#E5B32A] hover:underline">{t.resa_phone}</a>
                </p>
                <p>
                  <span class="font-semibold text-white">{t.resa_label_hours} :</span><br />
                  <span class="font-medium text-white/90">{t.resa_hours}</span>
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <a href={`${baseUrl}/commander`} class="w-full px-8 py-3 bg-[#E5B32A] text-black text-[11px] font-bold uppercase tracking-[0.2em] text-center rounded-lg shadow-[0_8px_24px_rgba(229,179,42,0.28)] hover:bg-white hover:shadow-[0_12px_32px_rgba(229,179,42,0.45)] transition-all duration-300">
                  {t.order_cta}
                </a>
                <a href={`${baseUrl}/#contact`} class="w-full px-8 py-3 bg-transparent border-2 border-[#E5B32A]/45 text-white text-[11px] font-bold uppercase tracking-[0.2em] text-center rounded-lg hover:bg-white/5 hover:border-[#E5B32A]/70 transition-all duration-300">
                  {t.resa_cta2}
                </a>
                <a href={`${baseUrl}/#carte`} class="w-full px-8 py-3 bg-transparent border border-white/15 text-white/80 text-[11px] font-bold uppercase tracking-[0.2em] text-center rounded-lg hover:bg-white/5 transition-all duration-300">
                  {t.resa_cta3}
                </a>
              </div>
              <div id="cta-card-sentinel" class="h-px w-full absolute bottom-0" aria-hidden="true"></div>
            </div>
          </aside>

        </div>
      </div>
    </div>
  </section>

  <!-- HISTOIRE -->
  <section id="histoire" class="histoire-section bg-[#0a0a0a] py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-[10px] uppercase tracking-[0.4em] text-[#E5B32A] font-bold mb-4">{t.story_label}</p>
        <h2 class="text-3xl md:text-4xl font-serif italic text-white mb-6 gold-shine-text">{t.story_title}</h2>
        <p class="text-gray-400 leading-relaxed mb-4">{t.story_p1}</p>
        <p class="text-gray-400 leading-relaxed">{t.story_p2}</p>
      </div>
      <div class="flex justify-center items-center relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-[#E5B32A]/20 to-transparent rounded-2xl blur-2xl -z-10"></div>
        <img
          src="/photos/efood-00-1600w.webp"
          alt="Σχάρα και κάρβουνα — αυθεντικό ψήσιμο"
          class="histoire-img no-invert w-full max-w-md object-cover rounded-2xl shadow-2xl border border-white/10"
          width="800" height="800"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- BLOG / AMBIANCE CARDS -->
  <section id="blog" class="bg-[#050505] py-24 px-6 border-t border-white/5">
    <div class="max-w-7xl mx-auto text-center mb-16">
      <p class="text-[10px] uppercase tracking-[0.4em] text-[#E5B32A] font-bold mb-4">{t.blog_label}</p>
      <h2 class="text-3xl md:text-4xl font-serif italic text-white mb-4">{t.blog_title}</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">{t.blog_lead}</p>
    </div>
    <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <article class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#E5B32A]/30 transition-colors">
        <h3 class="text-lg font-serif italic text-[#E5B32A] mb-2 dish-name-gold">{t.card1_title}</h3>
        <p class="text-sm text-gray-300">{t.card1_desc}</p>
      </article>
      <article class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#E5B32A]/30 transition-colors">
        <h3 class="text-lg font-serif italic text-[#E5B32A] mb-2 dish-name-gold">{t.card2_title}</h3>
        <p class="text-sm text-gray-300">{t.card2_desc}</p>
      </article>
      <article class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#E5B32A]/30 transition-colors">
        <h3 class="text-lg font-serif italic text-[#E5B32A] mb-2 dish-name-gold">{t.card3_title}</h3>
        <p class="text-sm text-gray-300">{t.card3_desc}</p>
      </article>
      <article class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#E5B32A]/30 transition-colors">
        <h3 class="text-lg font-serif italic text-[#E5B32A] mb-2 dish-name-gold">{t.card4_title}</h3>
        <p class="text-sm text-gray-300">{t.card4_desc}</p>
      </article>
      <article class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#E5B32A]/30 transition-colors">
        <h3 class="text-lg font-serif italic text-[#E5B32A] mb-2 dish-name-gold">{t.card5_title}</h3>
        <p class="text-sm text-gray-300">{t.card5_desc}</p>
      </article>
      <article class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#E5B32A]/30 transition-colors">
        <h3 class="text-lg font-serif italic text-[#E5B32A] mb-2 dish-name-gold">{t.card6_title}</h3>
        <p class="text-sm text-gray-300">{t.card6_desc}</p>
      </article>
    </div>
  </section>

  <!-- MENU LIVRE -->
  <div id="carte">
    <MenuBook lang={currentLang} />
  </div>

  <!-- PDF + QR Code -->
  <div class="bg-[#050505] py-10 px-4 border-t border-white/5">
    <div class="max-w-3xl mx-auto flex flex-col md:flex-row items-center gap-8 bg-gradient-to-br from-[#E5B32A]/8 to-black/60 border border-[#E5B32A]/20 rounded-3xl p-6 md:p-8">
      <!-- QR Code -->
      <div class="shrink-0 flex flex-col items-center">
        <div class="bg-white p-3 rounded-2xl shadow-2xl">
          <img src="/menu-qr.png" alt={currentLang === 'el' ? 'QR Code Μενού' : 'Menu QR Code'} class="w-32 h-32" width="128" height="128" />
        </div>
        <p class="text-[9px] uppercase tracking-[0.2em] text-white/40 mt-2 font-bold">
          {currentLang === 'el' ? 'Σκανάρε' : 'Scan'}
        </p>
      </div>
      <!-- Text + CTA -->
      <div class="flex-1 text-center md:text-left">
        <p class="text-[10px] uppercase tracking-[0.3em] text-[#E5B32A] font-bold mb-2">
          {currentLang === 'el' ? 'Κατάλογος PDF' : 'PDF Menu'}
        </p>
        <h3 class="text-xl md:text-2xl font-serif italic text-white mb-3">
          {currentLang === 'el' ? 'Πάρε τον κατάλογο μαζί σου.' : 'Take the menu with you.'}
        </h3>
        <p class="text-sm text-gray-400 mb-3 leading-relaxed">
          {currentLang === 'el'
            ? 'Σκανάρε το QR ή κατέβασε το PDF — όλος ο κατάλογος, παντού, χωρίς ίντερνετ.'
            : 'Scan the QR or download the PDF — full menu, anywhere, no internet needed.'}
        </p>
        <p class="text-[10px] uppercase tracking-[0.25em] text-[#E5B32A]/85 font-bold mb-2 flex items-center gap-2">
          <svg viewBox="0 0 24 24" class="w-3 h-3 fill-current"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          {currentLang === 'el' ? 'Διαθέσιμο σε 7 γλώσσες :' : 'Available in 7 languages :'}
        </p>
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 mb-5">
          {[
            { code: 'el', flag: '🇬🇷', label: 'Ελληνικά' },
            { code: 'en', flag: '🇬🇧', label: 'English' },
            { code: 'fr', flag: '🇫🇷', label: 'Français' },
            { code: 'es', flag: '🇪🇸', label: 'Español' },
            { code: 'it', flag: '🇮🇹', label: 'Italiano' },
            { code: 'pt', flag: '🇵🇹', label: 'Português' },
            { code: 'zh', flag: '🇨🇳', label: '中文' },
          ].map((l) => (
            <a
              href={`/menu-${l.code}.pdf`}
              target="_blank"
              rel="noopener"
              aria-label={`${currentLang === 'el' ? 'Κατέβασε τον κατάλογο' : 'Download menu'} — ${l.label}`}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/75 text-[11px] font-semibold hover:bg-[#E5B32A]/15 hover:border-[#E5B32A]/50 hover:text-white transition-all duration-200"
            >
              <span class="text-[15px] leading-none" aria-hidden="true">{l.flag}</span>
              <span>{l.label}</span>
            </a>
          ))}
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center md:justify-start gap-3">
          <a href="/menu-download" class="inline-flex items-center gap-2 px-6 py-3 bg-[#E5B32A] text-black text-xs font-bold uppercase tracking-widest rounded-full hover:bg-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
            {currentLang === 'el' ? 'Επιλέξτε γλώσσα' : 'Choose language'}
          </a>
          <a href={`${baseUrl}/#contact`} class="inline-flex items-center gap-2 px-6 py-3 border border-white/25 text-white text-xs font-bold uppercase tracking-widest rounded-full hover:bg-white/10 transition-colors">
            {t.carte_reserver}
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pb-10 px-4">
    <a href="https://www.e-food.gr/delivery/peiraias/to-kalamaki-ths-troympas" target="_blank" rel="noopener" class="px-6 py-3 border border-white/30 text-white text-xs font-bold uppercase tracking-widest rounded-full hover:bg-white/10 transition-colors">
      {currentLang === 'el' ? 'Παραγγελία e-food' : 'Order on e-food'}
    </a>
  </div>

  <!-- AVIS GOOGLE -->
  <ReviewsSection lang={currentLang} />

  <!-- CONTACT -->
  <section id="contact" class="bg-[#050505] py-24 px-6 border-t border-white/5">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif italic text-white mb-4">{t.contact_title}</h2>
      <p class="text-gray-300 mb-8">{t.contact_lead}</p>
      <p class="text-sm text-gray-300 mb-2">
        <a href={`mailto:${t.contact_email}`} class="text-[#E5B32A] hover:underline">{t.contact_email}</a>
      </p>
      <p class="text-sm text-gray-300 mb-2">
        <a href="tel:+302104222233" class="text-[#E5B32A] hover:underline">{t.contact_demo}</a>
      </p>
      <p class="text-xs text-gray-300 mb-8">{t.contact_hours}</p>

      <form id="contact-form" class="space-y-4" data-lang={currentLang}>
        <div>
          <label for="name" class="sr-only">{t.form_name}</label>
          <input
            type="text" id="name" name="name"
            placeholder={t.form_name} required
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg placeholder-white/30 focus:border-[#E5B32A] focus:outline-none transition-colors"
          />
        </div>
        <div>
          <label for="guests" class="sr-only">{t.form_guests}</label>
          <input
            type="text" id="guests" name="guests"
            placeholder={t.form_guests}
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg placeholder-white/30 focus:border-[#E5B32A] focus:outline-none transition-colors"
          />
        </div>
        <div>
          <label for="message" class="sr-only">{currentLang === 'el' ? 'Μήνυμα (προαιρετικό)' : 'Message (optional)'}</label>
          <textarea id="message" name="message" rows="3"
            placeholder={currentLang === 'el' ? 'Μήνυμα (προαιρετικό)' : 'Message (optional)'}
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg placeholder-white/30 focus:border-[#E5B32A] focus:outline-none transition-colors"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-6 py-4 bg-[#E5B32A] text-black text-sm font-bold uppercase tracking-widest rounded-full hover:bg-white transition-colors"
        >{t.form_confirm}</button>
        <p id="contact-status" class="text-xs text-gray-400 text-center min-h-[1rem]" aria-live="polite"></p>
      </form>

      <script is:inline>
        (function () {
          const form = document.getElementById('contact-form');
          if (!form) return;
          const status = document.getElementById('contact-status');
          form.addEventListener('submit', async function (e) {
            e.preventDefault();
            const lang = form.getAttribute('data-lang') || 'el';
            const fd = new FormData(form);
            const payload = {
              name: fd.get('name') || '',
              guests: fd.get('guests') || '',
              message: fd.get('message') || '',
              lang,
            };
            if (status) status.textContent = lang === 'el' ? 'Αποστολή...' : 'Sending...';
            try {
              const r = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              });
              const data = await r.json().catch(() => ({}));
              if (r.ok && data.ok) {
                if (status) status.textContent = lang === 'el'
                  ? 'Το μήνυμά σας στάλθηκε. Θα σας απαντήσουμε σύντομα.'
                  : 'Your message has been sent. We will get back to you shortly.';
                form.reset();
              } else {
                throw new Error('send_failed');
              }
            } catch (err) {
              if (status) status.textContent = lang === 'el'
                ? 'Σφάλμα. Καλέστε μας στο +30 210 422 2233.'
                : 'Error. Please call +30 210 422 2233.';
            }
          });
        })();
      </script>

      <div class="mt-8 flex justify-center">
        <SocialLinks />
      </div>
    </div>
