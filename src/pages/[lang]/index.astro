---
export function getStaticPaths() {
  return [
    { params: { lang: "el" } },
    { params: { lang: "en" } },
    { params: { lang: "de" } },
    { params: { lang: "ru" } },
    { params: { lang: "ja" } },
  ];
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBar from "../../components/NavBar.astro";
import SocialLinks from "../../components/SocialLinks.astro";
import MenuBook from "../../components/MenuBook.astro";
import ReviewsSection from "../../components/ReviewsSection.astro";
import Flag from "../../components/Flag.astro";
import { getLangFromParam } from "../../i18n/utils";
import { translations, getMenu } from "../../i18n/translations";
import { SPECIALITIES } from "../../data/efood-photos-map.mjs";

const currentLang = getLangFromParam(Astro.params.lang);
const t = translations[currentLang];
const menu = getMenu(currentLang);
const baseUrl = `/${currentLang}`;
---

<style>
  /* === MOBILE HERO — Exact restaurant-bar pattern + carrousel === */
  @media (max-width: 767px) {
    .hero-card-viewport {
      perspective: 2000px;
      padding: 0.5rem;
      margin-top: 0.5rem;
      width: 100%;
      box-sizing: border-box;
    }
    .hero-card-3d {
      background: linear-gradient(135deg, rgba(229, 179, 42, 0.2) 0%, rgba(10, 10, 10, 0.95) 100%);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid rgba(229, 179, 42, 0.4);
      border-radius: 2rem;
      padding: 2rem 1.5rem !important;
      width: 100%;
      box-sizing: border-box;
      overflow: hidden;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 0 !important;
      transform: rotateX(8deg) rotateY(-4deg);
      box-shadow:
        0 30px 60px -12px rgba(0, 0, 0, 0.8),
        0 18px 36px -18px rgba(0, 0, 0, 0.9),
        0 0 40px rgba(229, 179, 42, 0.1);
      animation: hero-card-float 8s ease-in-out infinite;
      position: relative;
    }
    /* Force all direct children to fit */
    .hero-card-3d > * {
      max-width: 100% !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }
    .hero-card-3d h1 {
      font-size: 2.1rem !important;
      white-space: nowrap;
      margin-bottom: 0.35rem !important;
      text-align: center !important;
    }
    .hero-card-3d p {
      font-size: 0.85rem !important;
      margin-bottom: 0.4rem !important;
      text-align: center !important;
      line-height: 1.5 !important;
    }
    .hero-card-3d .flex.mb-1 {
      margin-bottom: 0.25rem !important;
      justify-content: center !important;
    }
    .hero-card-3d .hero-photo-strip {
      border-radius: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .hero-card-3d aside {
      margin-top: 0.25rem !important;
    }
    .hero-card-3d aside .flex.flex-col.gap-3 a {
      padding: 0.85rem 1.25rem !important;
      font-size: 12px !important;
    }
    .resa-card-inner-mobile a {
      padding: 0.85rem 1.25rem !important;
      font-size: 12px !important;
    }
    /* Badge smaller */
    .hero-card-3d span[class*="tracking"] {
      font-size: 8px !important;
      padding: 0.3rem 0.75rem !important;
      margin-bottom: 0.5rem !important;
    }
    /* Aside inner : transparent comme le modele restaurant-bar */
    .resa-card-inner-mobile {
      background: transparent !important;
      border: none !important;
      backdrop-filter: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      margin-left: auto !important;
      margin-right: auto !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    .resa-card-inner-mobile p[class*="uppercase"] {
      margin-bottom: 0.35rem !important;
      text-align: center !important;
    }
    .resa-card-inner-mobile .flex.flex-col.gap-3 {
      gap: 0.5rem !important;
    }
    /* Masquer adresse/phone/hours sur mobile */
    .mobile-hide-details { display: none !important; }
    @keyframes hero-card-float {
      0%, 100% { transform: rotateX(8deg) rotateY(-4deg) translateY(0); }
      50%      { transform: rotateX(6deg) rotateY(-2deg) translateY(-15px); }
    }
  }

  /* Carrousel hero — entre la pastille et le titre */
  .hero-photo-strip {
    width: 100%;
    overflow: hidden;
    height: 70px;
    border-radius: 0.85rem;
    margin-bottom: 0.5rem;
    position: relative;
  }
  @media (min-width: 768px) {
    .hero-photo-strip { height: 90px; margin-bottom: 1rem; }
  }

  /* Sur mobile, on remonte la carte CTA du hero pour la rendre visible dès le chargement */
  @media (max-width: 767px) {
    .mobile-hero-card-shift {
      margin-top: -3.5cm;
      position: relative;
      z-index: 5;
    }
  }
  .strip-track {
    display: flex;
    gap: 6px;
    height: 100%;
    width: max-content;
    animation: strip-scroll 28s linear infinite;
  }
  .strip-track img {
    height: 100%;
    width: 120px;
    object-fit: cover;
    border-radius: 0.6rem;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .strip-track img { width: 170px; }
  }
  @keyframes strip-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .gold-shine-text {
    background: linear-gradient(
      to right,
      #e5b32a 0%, #fff3ad 25%, #e5b32a 50%, #fff3ad 75%, #e5b32a 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gold-shimmer 4s linear infinite;
  }
  .dish-name-gold { color: #e5b32a; }
  #histoire .histoire-img { max-width: 100%; height: auto; border-radius: 0.5rem; }
  @keyframes gold-shimmer {
    from { background-position: 0% center; }
    to { background-position: 200% center; }
  }
</style>

<BaseLayout
  lang={currentLang}
  title={t.meta_title}
  description={t.meta_description}
  includeMenu={true}
  breadcrumbs={[
    { name: currentLang === 'el' ? 'Αρχική' : 'Home', path: `/${currentLang}/` },
  ]}
>

  <!-- HERO -->
  <section id="home" class="relative min-h-screen w-full flex flex-col overflow-x-hidden bg-neutral-950">
    <div class="absolute inset-0 z-0">
      <img
        src="/photos/efood-00-1600w.webp"
        alt={currentLang === 'el' ? 'Αυθεντικό ψητοπωλείο στην Τρούμπα, Πειραιάς' : 'Authentic charcoal souvlaki shop in Troumpa, Piraeus'}
        class="w-full h-full object-cover opacity-55"
        width="1600" height="900"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/40 to-neutral-950/75"></div>
    </div>

    <NavBar lang={currentLang} />

    <div class="relative z-10 px-6 w-full flex-1 flex items-center justify-center py-4 md:py-20">
      <div class="hero-card-viewport">
        <div class="hero-card-3d max-w-screen-2xl mx-auto grid md:grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] gap-8 lg:gap-16 items-center text-left w-full">

          <div class="flex flex-col items-center lg:items-start max-w-xl">
            <span class="inline-block border border-[#E5B32A]/50 px-6 py-2 rounded-full text-[10px] uppercase tracking-[0.4em] mb-3 bg-black/30 backdrop-blur-sm text-[#E5B32A] font-bold">
              {t.hero_badge}
            </span>

            {/* Carrousel hero — photos haute résolution du resto.
                Affichage 120px (mobile) / 170px (desktop) → 400w est suffisant + 800w pour retina. */}
            <div class="hero-photo-strip">
              <div class="strip-track">
                {[
                  "trouba-storefront",
                  "trouba-grill-skewers",
                  "trouba-grill-chops",
                  "efood-00",
                  "trouba-storefront",
                  "trouba-grill-skewers",
                  "trouba-grill-chops",
                  "efood-25",
                  "trouba-storefront",
                ].map((stem) => (
                  <img
                    src={`/photos/${stem}-400w.webp`}
                    srcset={`/photos/${stem}-400w.webp 400w, /photos/${stem}-800w.webp 800w`}
                    sizes="(max-width: 767px) 120px, 170px"
                    alt=""
                    width="400" height="300"
                    loading="lazy" decoding="async"
                  />
                ))}
              </div>
            </div>

            <h1 class="text-5xl md:text-5xl lg:text-6xl font-serif italic text-white mb-2 md:mb-3 leading-none drop-shadow-2xl text-center lg:text-left whitespace-nowrap">
              {t.hero_title}
            </h1>
            <p class="text-gray-300 max-w-xl md:max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-4 md:mb-6 font-light text-base md:text-lg text-center lg:text-left">
              {t.hero_lead}
            </p>
            <div class="flex mb-1 justify-center lg:justify-start opacity-100 visible">
              <SocialLinks lang={currentLang} />
            </div>
            <p class="hidden md:block text-xs text-gray-300 italic">{t.hero_demo_note}</p>
          </div>

          <aside class="w-full md:mt-0 mt-1 mobile-hero-card-shift">
            <div class="resa-card-inner-mobile bg-gradient-to-b from-[#E5B32A]/12 to-black/70 border border-[#E5B32A]/30 rounded-3xl p-6 md:p-8 backdrop-blur-xl shadow-2xl w-full max-w-md ml-auto">
              <p class="text-[9px] md:text-[9px] uppercase tracking-[0.3em] text-[#E5B32A] font-bold mb-2 md:mb-3">{t.resa_title}</p>
              <h2 class="hidden md:block text-lg font-serif text-white mb-4">{t.resa_subtitle}</h2>
              <div class="mobile-hide-details space-y-2 text-xs text-gray-300 mb-4">
                <p class="leading-snug">
                  <span class="font-semibold text-white text-[10px] uppercase tracking-wider">{t.resa_label_address}</span><br />
                  <span class="font-medium text-white/90 text-[11px]">{t.resa_address}</span>
                </p>
                <p class="leading-snug">
                  <span class="font-semibold text-white text-[10px] uppercase tracking-wider">{t.resa_label_phone}</span><br />
                  <a href="tel:+302104222233" aria-label={currentLang === 'el' ? 'Τηλέφωνο 1 — Καλαμάκι Της Τρούμπας' : 'Phone 1 — Kalamaki Tis Troumpas'} class="font-medium text-[#E5B32A] hover:underline block text-[11px] tabular-nums py-1.5 -my-1.5 px-2 -mx-2">{t.resa_phone}</a>
                  <a href="tel:+302104222273" aria-label={currentLang === 'el' ? 'Τηλέφωνο 2 — Καλαμάκι Της Τρούμπας' : 'Phone 2 — Kalamaki Tis Troumpas'} class="font-medium text-[#E5B32A] hover:underline block text-[11px] tabular-nums mt-0.5 py-1.5 -my-1.5 px-2 -mx-2">+30 210 422 2273</a>
                </p>
              </div>
              {/* Horaires : visible aussi sur mobile (assez de place) */}
              <div class="space-y-2 text-xs text-gray-300 mb-4">
                <p class="leading-snug">
                  <span class="font-semibold text-white text-[10px] uppercase tracking-wider">{t.resa_label_hours}</span><br />
                  <span class="font-medium text-white/90 text-[11px]">{t.resa_hours}</span>
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <a href={`${baseUrl}/delivery`} class="w-full px-8 py-3 bg-[#E5B32A] text-black text-[11px] font-bold uppercase tracking-[0.2em] text-center rounded-lg shadow-[0_8px_24px_rgba(229,179,42,0.28)] hover:bg-white hover:shadow-[0_12px_32px_rgba(229,179,42,0.45)] transition-all duration-300">
                  {t.order_cta} <span class="ml-1 text-[9px] opacity-70">· 0%</span>
                </a>
                {/* Partenaires delivery — logos brand-colored */}
                <div class="grid grid-cols-3 gap-2 mt-1">
                  <a href="https://www.e-food.gr/delivery/peiraias/to-kalamaki-ths-troympas" target="_blank" rel="noopener" class="flex items-center justify-center gap-1.5 px-2 py-2.5 bg-[#a8104a] text-white rounded-lg hover:bg-[#8a0c3e] transition-colors shadow-md">
                    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-current shrink-0" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 12v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V4.07c3.94.49 7 3.85 7 7.93 0 2.53-1.18 4.77-3.1 6.39z"/></svg>
                    <span class="font-black text-[11px] tracking-tight whitespace-nowrap" style="font-family:'Helvetica',sans-serif;">e-food</span>
                  </a>
                  <a href="https://wolt.com/el/grc/piraeus/restaurant/to-kalamaki-tis-troumpas" target="_blank" rel="noopener" class="flex items-center justify-center gap-1.5 px-2 py-2.5 bg-[#005c70] text-white rounded-lg hover:bg-[#00485a] transition-colors shadow-md">
                    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-current shrink-0" aria-hidden="true"><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.8"/></svg>
                    <span class="font-black text-[12px] tracking-tight" style="font-family:'Inter',sans-serif;">Wolt</span>
                  </a>
                  <a href="https://box.gr" target="_blank" rel="noopener" class="flex items-center justify-center gap-1.5 px-2 py-2.5 bg-[#8a3d00] text-white rounded-lg hover:bg-[#6f3000] transition-colors shadow-md">
                    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-current shrink-0" aria-hidden="true"><path d="M3 7l9-4 9 4v10l-9 4-9-4V7zm9 1.9L6.4 6.4 12 4.1l5.6 2.3L12 8.9zm-7 1.5l6 2.5v7.2l-6-2.7v-7zm14 0v7l-6 2.7v-7.2l6-2.5z"/></svg>
                    <span class="font-black text-[12px] tracking-tight" style="font-family:'Arial',sans-serif;">Box</span>
                  </a>
                </div>
                <a href={`${baseUrl}/#carte`} class="w-full px-8 py-2.5 bg-transparent border border-white/15 text-white/80 text-[10px] font-bold uppercase tracking-[0.2em] text-center rounded-lg hover:bg-white/5 transition-all duration-300">
                  {t.resa_cta3}
                </a>
              </div>
              <div id="cta-card-sentinel" class="h-px w-full absolute bottom-0" aria-hidden="true"></div>
            </div>
          </aside>

        </div>
      </div>
    </div>
  </section>

  <!-- ZONE LIVRAISON — mise en avant (Tiago 19/05) -->
  <section id="livraison" class="bg-[#0a0a0a] py-12 md:py-16 px-6 border-t border-white/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8">
        <p class="text-[10px] uppercase tracking-[0.4em] text-[#E5B32A] font-bold mb-3">{currentLang === 'el' ? 'Παράδοση' : currentLang === 'de' ? 'Lieferung' : currentLang === 'ru' ? 'Доставка' : currentLang === 'ja' ? '配達' : currentLang === 'tr' ? 'Teslimat' : 'Delivery'}</p>
        <h2 class="text-2xl md:text-4xl font-serif italic text-white mb-3 gold-shine-text">
          {currentLang === 'el' ? 'Παραδίδουμε στον Πειραιά' : currentLang === 'de' ? 'Wir liefern in Piräus' : currentLang === 'ru' ? 'Доставка по Пирею' : currentLang === 'ja' ? 'ピレウス全域に配達' : currentLang === 'tr' ? 'Pire bölgesine teslimat' : 'We deliver across Piraeus'}
        </h2>
        <p class="text-sm md:text-base text-white/65 max-w-2xl mx-auto">
          {currentLang === 'el' ? 'Τρούμπα, λιμάνι, Πασαλιμάνι, Καστέλλα, Αγία Σοφία, Φρεαττύδα — δύο ζώνες, ελάχιστη παραγγελία διαφορετική.' : currentLang === 'de' ? 'Trouba, Hafen, Pasalimani, Kastella, Agia Sofia, Freattyda — zwei Zonen, unterschiedliche Mindestbestellung.' : currentLang === 'ru' ? 'Трумба, порт, Пасалимани, Кастелла, Айя София, Фреаттида — две зоны, разная минимальная сумма заказа.' : currentLang === 'ja' ? 'トルンバ、港、パサリマニ、カステラ、アギア・ソフィア、フレアティダ — 2エリア、最低注文額が異なる。' : currentLang === 'tr' ? 'Trumba, liman, Pasalimani, Kastella, Agia Sofia, Freattyda — iki bölge, farklı minimum sipariş.' : 'Trouba, port, Pasalimani, Kastella, Agia Sofia, Freattyda — two zones, different minimum order.'}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto mb-6">
        <!-- Zone verte (centre) -->
        <div class="relative rounded-2xl border-2 border-emerald-400/40 bg-emerald-500/5 p-5">
          <div class="flex items-start gap-3">
            <span class="inline-block w-4 h-4 rounded-full bg-emerald-400 mt-1 flex-shrink-0 shadow-[0_0_12px_rgba(34,197,94,0.5)]"></span>
            <div>
              <p class="text-emerald-300 font-bold text-sm uppercase tracking-wider mb-1">
                {currentLang === 'el' ? 'Ζώνη Κέντρο (Τρούμπα)' : currentLang === 'de' ? 'Zentrum-Zone (Trouba)' : currentLang === 'ru' ? 'Центр (Трумба)' : currentLang === 'ja' ? '中心地（トルンバ）' : currentLang === 'tr' ? 'Merkez Bölge (Trumba)' : 'Centre Zone (Trouba)'}
              </p>
              <p class="text-xs text-white/70 mb-2">{currentLang === 'el' ? 'Τρούμπα · Λιμάνι · Πασαλιμάνι' : currentLang === 'de' ? 'Trouba · Hafen · Pasalimani' : currentLang === 'ru' ? 'Трумба · Порт · Пасалимани' : currentLang === 'ja' ? 'トルンバ · 港 · パサリマニ' : currentLang === 'tr' ? 'Trumba · Liman · Pasalimani' : 'Trouba · Port · Pasalimani'}</p>
              <p class="text-[11px] text-white/55">
                <span class="text-emerald-300 font-bold">{currentLang === 'el' ? 'Ελάχιστη παραγγελία' : currentLang === 'de' ? 'Mindestbestellung' : currentLang === 'ru' ? 'Минимум' : currentLang === 'ja' ? '最低注文' : currentLang === 'tr' ? 'Minimum' : 'Min order'} : 6€</span>
                · {currentLang === 'el' ? '~20 λεπτά' : currentLang === 'de' ? '~20 Min' : currentLang === 'ru' ? '~20 мин' : currentLang === 'ja' ? '~20分' : currentLang === 'tr' ? '~20 dk' : '~20 min'}
              </p>
            </div>
          </div>
        </div>

        <!-- Zone rouge (élargie) -->
        <div class="relative rounded-2xl border-2 border-red-400/40 bg-red-500/5 p-5">
          <div class="flex items-start gap-3">
            <span class="inline-block w-4 h-4 rounded-full bg-red-400 mt-1 flex-shrink-0 shadow-[0_0_12px_rgba(239,68,68,0.5)]"></span>
            <div>
              <p class="text-red-300 font-bold text-sm uppercase tracking-wider mb-1">
                {currentLang === 'el' ? 'Ζώνη Ευρύτερη' : currentLang === 'de' ? 'Erweiterte Zone' : currentLang === 'ru' ? 'Расширенная зона' : currentLang === 'ja' ? '拡張エリア' : currentLang === 'tr' ? 'Genişletilmiş Bölge' : 'Extended Zone'}
              </p>
              <p class="text-xs text-white/70 mb-2">{currentLang === 'el' ? 'Καστέλλα · Φρεαττύδα · Αγία Σοφία' : currentLang === 'de' ? 'Kastella · Freattyda · Agia Sofia' : currentLang === 'ru' ? 'Кастелла · Фреаттида · Айя София' : currentLang === 'ja' ? 'カステラ · フレアティダ · アギア・ソフィア' : currentLang === 'tr' ? 'Kastella · Freattyda · Agia Sofia' : 'Kastella · Freattyda · Agia Sofia'}</p>
              <p class="text-[11px] text-white/55">
                <span class="text-red-300 font-bold">{currentLang === 'el' ? 'Ελάχιστη παραγγελία' : currentLang === 'de' ? 'Mindestbestellung' : currentLang === 'ru' ? 'Минимум' : currentLang === 'ja' ? '最低注文' : currentLang === 'tr' ? 'Minimum' : 'Min order'} : 8€</span>
                · {currentLang === 'el' ? '~35 λεπτά' : currentLang === 'de' ? '~35 Min' : currentLang === 'ru' ? '~35 мин' : currentLang === 'ja' ? '~35分' : currentLang === 'tr' ? '~35 dk' : '~35 min'}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center">
        <a href={`/${currentLang}/delivery/`} class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#E5B32A] text-black font-bold text-sm uppercase tracking-wider hover:bg-[#fff] transition-colors">
          {currentLang === 'el' ? 'Παράγγειλε online' : currentLang === 'de' ? 'Online bestellen' : currentLang === 'ru' ? 'Заказать онлайн' : currentLang === 'ja' ? 'オンライン注文' : currentLang === 'tr' ? 'Online sipariş' : 'Order online'}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HISTOIRE -->
  <section id="histoire" class="histoire-section bg-[#0a0a0a] py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-[10px] uppercase tracking-[0.4em] text-[#E5B32A] font-bold mb-4">{t.story_label}</p>
        <h2 class="text-3xl md:text-4xl font-serif italic text-white mb-6 gold-shine-text">{t.story_title}</h2>
        <p class="text-gray-400 leading-relaxed mb-4">{t.story_p1}</p>
        <p class="text-gray-400 leading-relaxed">{t.story_p2}</p>
      </div>
      <div class="flex justify-center items-center relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-[#E5B32A]/20 to-transparent rounded-2xl blur-2xl -z-10"></div>
        <img
          src="/photos/trouba-storefront-800w.webp"
