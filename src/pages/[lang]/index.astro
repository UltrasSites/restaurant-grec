  <!-- FAB Commander online — visible sur mobile, discret desktop -->
  <a href={`${baseUrl}/commander`} class="order-fab" aria-label={t.order_cta}>
    <span class="order-fab-icon">🛒</span>
    <span class="order-fab-label">{t.order_cta}</span>
  </a>

  <style>
    .order-fab {
      position: fixed;
      right: 1rem; bottom: 1rem;
      z-index: 55;
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.15rem;
      background: linear-gradient(135deg, #E5B32A 0%, #c89324 100%);
      color: #0a0a0a;
      border-radius: 999px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 800; font-size: 0.78rem;
      text-decoration: none;
      letter-spacing: 0.08em; text-transform: uppercase;
      box-shadow: 0 12px 28px rgba(229,179,42,0.4), 0 4px 12px rgba(0,0,0,0.4);
      transition: transform 0.2s, box-shadow 0.2s;
      animation: fab-pulse 2.6s ease-in-out infinite;
    }
    .order-fab:hover { transform: translateY(-3px) scale(1.04); box-shadow: 0 16px 36px rgba(229,179,42,0.55), 0 6px 16px rgba(0,0,0,0.5); }
    .order-fab-icon { font-size: 1rem; }
    @keyframes fab-pulse {
      0%, 100% { box-shadow: 0 12px 28px rgba(229,179,42,0.4), 0 4px 12px rgba(0,0,0,0.4); }
      50%      { box-shadow: 0 14px 36px rgba(229,179,42,0.65), 0 6px 18px rgba(0,0,0,0.5); }
    }
    @media (max-width: 767px) {
      .order-fab { padding-bottom: calc(0.85rem + env(safe-area-inset-bottom, 0)); }
    }
  </style>

  <script>
    const sentinel = document.getElementById('cta-card-sentinel');
    if (sentinel) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) document.body.classList.add('cta-visible');
          else document.body.classList.remove('cta-visible');
        });
      }, { threshold: 0.1 });
      observer.observe(sentinel);
    }
  </script>

</BaseLayout>
