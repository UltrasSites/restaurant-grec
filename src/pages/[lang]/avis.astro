---
// Variante /el/avis et /en/avis (route directe sans query string)
export function getStaticPaths() {
  return [{ params: { lang: "el" } }, { params: { lang: "en" } }];
}

import BaseLayout from "../../layouts/BaseLayout.astro";

const { lang } = Astro.params as { lang: "el" | "en" };

const t = {
  el: {
    title: "Αφήστε μια κριτική",
    subtitle: "Η γνώμη σας μετράει",
    body: "Ευχαριστούμε για την επίσκεψή σας! Επιλέξτε πού θέλετε να αφήσετε την κριτική σας:",
    google: "Αφήστε αξιολόγηση στο Google",
    tripadvisor: "Αφήστε κριτική στο TripAdvisor",
    thanks: "Σας ευχαριστούμε από καρδιάς ❤️",
    back: "← Επιστροφή στην αρχική",
  },
  en: {
    title: "Leave a review",
    subtitle: "Your feedback matters",
    body: "Thank you for visiting us! Choose where you'd like to leave your review:",
    google: "Leave a Google review",
    tripadvisor: "Leave a TripAdvisor review",
    thanks: "Thank you from the bottom of our heart ❤️",
    back: "← Back to home",
  },
}[lang];

const GOOGLE_REVIEW_URL = "https://maps.google.com/?cid=4117845882351786324";
const TRIPADVISOR_URL = "https://www.tripadvisor.com/Restaurant_Review-g189403-d10042662-Reviews-To_Kalamaki_tis_Troumpas-Piraeus_Piraeus_Region_Attica.html";
---

<BaseLayout lang={lang} title={`${t.title} — Το Καλαμάκι Της Τρούμπας`} description={t.body} hideHeader>
  <main class="min-h-screen flex flex-col items-center justify-center px-4 py-12 bg-neutral-950">
    <div class="max-w-md w-full text-center">
      <a href={`/${lang}/#home`} class="inline-block mb-6 text-white/60 hover:text-[#E5B32A] text-sm transition-colors">{t.back}</a>

      <div class="mb-8">
        <img src="/photos/logo-main.png" alt="Το Καλαμάκι Της Τρούμπας" class="h-20 mx-auto mb-4" width="200" height="80" />
        <p class="text-[#E5B32A] uppercase tracking-[0.3em] text-xs font-bold mb-2">{t.subtitle}</p>
        <h1 class="text-3xl sm:text-4xl font-serif italic text-white mb-4">{t.title}</h1>
        <p class="text-white/70 text-sm">{t.body}</p>
      </div>

      <div class="space-y-4">
        <a
          href={GOOGLE_REVIEW_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 w-full px-6 py-5 rounded-2xl bg-white text-neutral-900 hover:bg-[#E5B32A] hover:text-black transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1"
        >
          <svg class="w-10 h-10 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span class="flex-1 text-left font-bold text-base">{t.google}</span>
          <svg class="w-5 h-5 text-neutral-400 group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>

        <a
          href={TRIPADVISOR_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 w-full px-6 py-5 rounded-2xl bg-white text-neutral-900 hover:bg-[#E5B32A] hover:text-black transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1"
        >
          <svg class="w-10 h-10 flex-shrink-0" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="48" fill="#34E0A1"/>
            <circle cx="32" cy="55" r="14" fill="white"/>
            <circle cx="68" cy="55" r="14" fill="white"/>
            <circle cx="32" cy="55" r="6" fill="#000"/>
            <circle cx="68" cy="55" r="6" fill="#000"/>
            <path d="M30 30 Q50 20 70 30" stroke="#000" stroke-width="3" fill="none" stroke-linecap="round"/>
          </svg>
          <span class="flex-1 text-left font-bold text-base">{t.tripadvisor}</span>
          <svg class="w-5 h-5 text-neutral-400 group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <p class="text-[#E5B32A] font-serif italic text-sm mt-8">{t.thanks}</p>
    </div>
  </main>
</BaseLayout>
