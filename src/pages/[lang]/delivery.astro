    cart_empty: t.order_cart_empty,
    error: t.order_error,
    success_body: t.order_success_body,
    aria_remove: isEl ? 'Αφαίρεση' : 'Remove',
    lang: currentLang,
    isEl,
    review_title: isEl ? '✓ Επιβεβαίωση παραγγελίας' : '✓ Confirm your order',
    review_sub: isEl ? 'Έλεγξε καλά πριν συνεχίσεις. Μπορείς να αλλάξεις ποσότητες ή να αφαιρέσεις προϊόντα.' : 'Double-check before continuing. You can change quantities or remove items.',
    review_total: isEl ? 'Σύνολο' : 'Total',
