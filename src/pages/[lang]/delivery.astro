  <script is:inline>
  (function() {
    var itemsData = JSON.parse(document.getElementById('order-items-data').textContent || '[]');
    var i18n = JSON.parse(document.getElementById('order-i18n-data').textContent || '{}');
    var byId = {};
    itemsData.forEach(function(it) { byId[it.id] = it; });

    var cart = {}; // { id: qty }

    var $ = function(s) { return document.querySelector(s); };

    var viewMenu = $('#order-view-menu');
    var viewCheckout = $('#order-view-checkout');
    var viewSuccess = $('#order-view-success');
    var floater = $('#cart-floater');
    var drawer = $('#cart-drawer');

    function fmt(n) { return (Math.round(n * 100) / 100).toFixed(2).replace('.', ',') + '€'; }

    function totalAmount() {
      var t = 0;
      Object.keys(cart).forEach(function(id) {
        var q = cart[id] || 0;
        var it = byId[id];
        if (it && q > 0) t += it.price * q;
      });
      return t;
    }
    function totalCount() {
      var n = 0;
      Object.keys(cart).forEach(function(id) { n += cart[id] || 0; });
      return n;
    }

    function updateRow(id) {
      var qty = cart[id] || 0;
      var disp = document.querySelector('[data-qty="' + id + '"]');
      if (disp) disp.textContent = String(qty);
      var row = document.querySelector('[data-item-row="' + id + '"]');
      if (row) row.classList.toggle('has-qty', qty > 0);
    }

    function updateCart() {
      var count = totalCount();
      var total = totalAmount();
      $('#cart-count').textContent = String(count);
      $('#cart-total').textContent = fmt(total);
      $('#cart-drawer-total').textContent = fmt(total);
      floater.hidden = count === 0;
      var validate = $('#cart-validate-btn');
      validate.disabled = count === 0;

      var list = $('#cart-list');
      var empty = $('#cart-empty');
      list.innerHTML = '';
      var hasItems = false;
      Object.keys(cart).forEach(function(id) {
        var q = cart[id] || 0;
        if (q <= 0) return;
        hasItems = true;
        var it = byId[id];
        if (!it) return;
        var li = document.createElement('li');
        li.className = 'cart-list-item';
        var name = i18n.isEl ? it.name_el : it.name_en;
        li.innerHTML = '<span class="cart-item-name">' + name + '</span>'
          + '<span class="cart-item-qty">×' + q + '</span>'
          + '<span class="cart-item-price">' + fmt(it.price * q) + '</span>'
          + '<button type="button" class="cart-item-remove" data-remove="' + id + '" aria-label="' + (i18n.aria_remove || 'Remove') + '">×</button>';
        list.appendChild(li);
      });
      empty.hidden = hasItems;
    }

    function add(id) {
      cart[id] = (cart[id] || 0) + 1;
      updateRow(id);
      updateCart();
    }
    function sub(id) {
      cart[id] = Math.max(0, (cart[id] || 0) - 1);
      if (cart[id] === 0) delete cart[id];
      updateRow(id);
      updateCart();
    }
    function removeAll(id) {
      delete cart[id];
      updateRow(id);
      updateCart();
    }

    document.addEventListener('click', function(e) {
      var t = e.target;
      if (!(t instanceof Element)) return;
      if (t.classList.contains('qty-plus')) { add(t.getAttribute('data-id')); }
      else if (t.classList.contains('qty-minus')) { sub(t.getAttribute('data-id')); }
      else if (t.hasAttribute && t.hasAttribute('data-remove')) { removeAll(t.getAttribute('data-remove')); }
    });

    // Drawer open/close
    function openDrawer() {
      drawer.hidden = false;
      drawer.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(function() { drawer.classList.add('open'); });
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer.classList.remove('open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(function() { drawer.hidden = true; }, 320);
    }
    $('#cart-open-btn').addEventListener('click', openDrawer);
    $('#cart-close-btn').addEventListener('click', closeDrawer);
    $('#cart-backdrop').addEventListener('click', closeDrawer);

    // Swipe to close (mobile)
    var startY = 0, deltaY = 0, panel = drawer.querySelector('.cart-panel');
    panel.addEventListener('touchstart', function(e) { startY = e.touches[0].clientY; deltaY = 0; }, { passive: true });
    panel.addEventListener('touchmove', function(e) {
      deltaY = e.touches[0].clientY - startY;
      if (deltaY > 0) { panel.style.transform = 'translateY(' + deltaY + 'px)'; }
    }, { passive: true });
    panel.addEventListener('touchend', function() {
      panel.style.transform = '';
      if (deltaY > 120) closeDrawer();
      deltaY = 0;
    });

    // Validate -> checkout view
    $('#cart-validate-btn').addEventListener('click', function() {
      closeDrawer();
      viewMenu.hidden = true;
      floater.hidden = true;
      viewCheckout.hidden = false;
      renderCheckoutSummary();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    $('#back-to-menu').addEventListener('click', function() {
      viewCheckout.hidden = true;
      viewMenu.hidden = false;
      floater.hidden = totalCount() === 0;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // CSS injecté pour les boutons +/- du checkout
    (function() {
      var s = document.createElement('style');
      s.textContent = '.checkout-qty-btn { width: 28px; height: 28px; border-radius: 9999px; border: 1px solid rgba(229,179,42,0.4); background: rgba(229,179,42,0.08); color: #E5B32A; font-size: 1.1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; transition: background .15s, transform .15s; } .checkout-qty-btn:hover { background: rgba(229,179,42,0.25); transform: scale(1.05); } .checkout-qty-btn:active { transform: scale(0.92); }';
      document.head.appendChild(s);
    })();

    /* ===== SEARCH MENU ===== */
    var searchInput = $('#menu-search-input');
    var searchClear = $('#menu-search-clear');
    var searchCount = $('#menu-search-count');
    var searchEmpty = $('#menu-search-empty');
    var allRows = Array.prototype.slice.call(document.querySelectorAll('[data-item-row]'));
    var allSections = Array.prototype.slice.call(document.querySelectorAll('#order-view-menu section'));
    var totalItemsLabel = (i18n.search_count_total || 'items');

    function normalize(s) {
      return (s || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '');
    }

    // Pré-calcul du texte cherchable (nom + description, on prend textContent complet
    // de la ligne — la query partielle gère bien le bruit "− 0 +" et le prix).
    var rowSearchText = new Map();
    allRows.forEach(function(row) {
      // On exclut juste les boutons +/- en collectant le texte du body + prix
      var bodyEl = row.querySelector('.flex-1');
      var txt = bodyEl ? bodyEl.textContent : row.textContent;
      rowSearchText.set(row, normalize(txt));
    });

    function setSearchCountTotal() {
      if (searchCount) searchCount.textContent = allRows.length + ' ' + totalItemsLabel;
    }

    function applySearch(rawQuery) {
      var q = normalize(rawQuery.trim());
      if (searchClear) searchClear.hidden = q.length === 0;

      if (q.length === 0) {
        allRows.forEach(function(row) { row.style.display = ''; });
        allSections.forEach(function(s) { s.style.display = ''; });
        setSearchCountTotal();
        if (searchEmpty) searchEmpty.hidden = true;
        return;
      }

      var visibleCount = 0;
      allRows.forEach(function(row) {
        var txt = rowSearchText.get(row) || '';
        var match = txt.indexOf(q) !== -1;
        row.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });

      // Cacher les sections sans aucun item visible
      allSections.forEach(function(section) {
        var rows = section.querySelectorAll('[data-item-row]');
        var anyVisible = false;
        for (var i = 0; i < rows.length; i++) {
          if (rows[i].style.display !== 'none') { anyVisible = true; break; }
        }
        section.style.display = anyVisible ? '' : 'none';
      });

      var label = visibleCount === 1 ? (i18n.search_count_one || 'result') : (i18n.search_count_many || 'results');
      if (searchCount) searchCount.textContent = visibleCount + ' ' + label;
      if (searchEmpty) searchEmpty.hidden = visibleCount > 0;
    }

    if (searchInput) {
      searchInput.addEventListener('input', function() { applySearch(searchInput.value); });
    }
    if (searchClear) {
      searchClear.addEventListener('click', function() {
        if (searchInput) { searchInput.value = ''; searchInput.focus(); }
        applySearch('');
      });
    }
    setSearchCountTotal();

    function escapeHtml(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function renderCheckoutSummary() {
      var box = $('#checkout-cart-summary');
      if (totalCount() === 0) {
        box.innerHTML = '<p class="text-center text-gray-400 py-4">' + escapeHtml(i18n.review_empty || 'Empty cart.') + '</p>';
        return;
      }

      var html = '';
      // Titre + sous-titre
      html += '<h3 class="checkout-review-title">' + escapeHtml(i18n.review_title || 'Confirm your order') + '</h3>';
      html += '<p class="checkout-review-sub">' + escapeHtml(i18n.review_sub || '') + '</p>';

      // Cartes
      html += '<ul class="checkout-review-list">';
      Object.keys(cart).forEach(function(id) {
        var q = cart[id]; if (!q) return;
        var it = byId[id]; if (!it) return;
        var name = i18n.isEl ? it.name_el : it.name_en;

        var imgHtml;
        if (it.photo && it.photo.src) {
          imgHtml = '<img class="checkout-card-img" src="' + escapeHtml(it.photo.src) + '" srcset="' + escapeHtml(it.photo.srcset || '') + '" sizes="64px" alt="" loading="lazy" decoding="async" width="64" height="64" />';
        } else {
          imgHtml = '<div class="checkout-card-fallback" aria-hidden="true">'
            + '<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z"/></svg>'
            + '</div>';
        }

        html += '<li class="checkout-card">'
          + imgHtml
          + '<div class="checkout-card-body">'
          +   '<span class="checkout-card-name">' + escapeHtml(name) + '</span>'
          +   '<span class="checkout-card-price-line">' + fmt(it.price) + ' × ' + q + ' = <strong>' + fmt(it.price * q) + '</strong></span>'
          + '</div>'
          + '<div class="checkout-card-controls">'
          +   '<div class="checkout-card-qty">'
          +     '<button type="button" class="checkout-qty-btn" data-act="minus" data-id="' + id + '" aria-label="-">−</button>'
          +     '<span class="checkout-card-qty-display">' + q + '</span>'
          +     '<button type="button" class="checkout-qty-btn" data-act="plus" data-id="' + id + '" aria-label="+">+</button>'
          +   '</div>'
          + '</div>'
          + '<button type="button" class="checkout-card-remove" data-act="remove" data-id="' + id + '" aria-label="' + escapeHtml(i18n.review_remove_aria || 'Remove') + '" title="' + escapeHtml(i18n.review_remove_aria || 'Remove') + '">×</button>'
          + '</li>';
      });
      html += '</ul>';

      // Total
      html += '<div class="checkout-review-total">'
        + '<span class="checkout-review-total-label">' + escapeHtml(i18n.review_total || 'Total') + '</span>'
        + '<span class="checkout-review-total-amount">' + fmt(totalAmount()) + '</span>'
        + '</div>';

      // Actions : continuer + vider
      html += '<div class="checkout-review-actions">'
        + '<button type="button" class="checkout-continue-btn" data-act="continue">' + escapeHtml(i18n.review_continue || 'Continue →') + '</button>'
        + '<button type="button" class="checkout-clear-link" data-act="clear">' + escapeHtml(i18n.review_clear || 'Clear cart') + '</button>'
        + '</div>';

      box.innerHTML = html;

      // Wire up actions (qty +/-, remove, clear, continue)
      box.querySelectorAll('button[data-act]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var act = btn.getAttribute('data-act');
          var id = btn.getAttribute('data-id');

          if (act === 'plus' && id) {
            cart[id] = (cart[id] || 0) + 1;
          } else if (act === 'minus' && id) {
            cart[id] = Math.max(0, (cart[id] || 0) - 1);
            if (cart[id] === 0) delete cart[id];
          } else if (act === 'remove' && id) {
            delete cart[id];
          } else if (act === 'clear') {
            if (!window.confirm(i18n.review_clear_confirm || 'Empty the cart?')) return;
            cart = {};
            // re-sync visual qty on menu rows
            allRows.forEach(function(row) {
              var rid = row.getAttribute('data-item-row');
              var disp = row.querySelector('[data-qty="' + rid + '"]');
              if (disp) disp.textContent = '0';
              row.classList.remove('has-qty');
            });
          } else if (act === 'continue') {
            // Scroll to the form
            var form = $('#order-form');
            if (form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
            return;
          }

          updateCart();
          renderCheckoutSummary();

          if (totalCount() === 0) {
            // Si plus rien dans le panier, retour au menu
            viewCheckout.hidden = true;
            viewMenu.hidden = false;
            floater.hidden = true;
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
      });
    }

    // Submit
    $('#order-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = $('#order-submit-btn');
      var errEl = $('#order-error');
      errEl.hidden = true;
      btn.disabled = true;
      btn.textContent = '…';

      var fd = new FormData(e.target);
      var name = String(fd.get('name') || '').trim();
      var phoneCode = String(fd.get('phone_code') || '+30').trim();
      var phoneRaw = String(fd.get('phone') || '').trim();
      var phone = phoneCode + ' ' + phoneRaw;
      var mode = String(fd.get('mode') || 'takeaway');
      // Si takeaway → payment forcé "on_site". Sinon (delivery) → cash/card du formulaire.
      var payment = mode === 'takeaway' ? 'on_site' : String(fd.get('payment') || 'cash');
      // Pickup-time : pertinent pour takeaway uniquement (delivery = le restaurant appelle quand il part)
      var pickup_time = mode === 'takeaway' ? String(fd.get('pickup_time') || '15') : '';
      var address = String(fd.get('address') || '').trim();
      var floor = String(fd.get('floor') || '').trim();
      var bell = String(fd.get('bell') || '').trim();
      var notes = String(fd.get('notes') || '').trim();
      var delivery_zone = String(fd.get('delivery_zone') || '').trim();

      // Validation min selon zone (côté client — le serveur revalide)
      if (mode === 'delivery') {
        if (!delivery_zone) {
          errEl.textContent = i18n.isEl ? 'Παρακαλώ διάλεξε ζώνη παράδοσης' : 'Please select a delivery zone';
          errEl.hidden = false;
          btn.disabled = false;
          btn.textContent = document.querySelector('#order-submit-btn').getAttribute('data-original') || '';
          return;
        }
        var minByZone = { green: 5, red: 7 };
        var minRequired = minByZone[delivery_zone] || 5;
        if (totalAmount() < minRequired) {
          errEl.textContent = (i18n.isEl ? 'Ελάχιστη παραγγελία : ' : 'Minimum order: ') + minRequired + '€';
          errEl.hidden = false;
          btn.disabled = false;
          btn.textContent = document.querySelector('#order-submit-btn').getAttribute('data-original') || '';
          return;
        }
      }

      var items = [];
      Object.keys(cart).forEach(function(id) {
        var q = cart[id]; if (!q) return;
        var it = byId[id]; if (!it) return;
        items.push({ id: id, name: i18n.isEl ? it.name_el : it.name_en, price: it.price, qty: q });
      });

      try {
        var res = await fetch('/api/order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, phone: phone, items: items, total: totalAmount(), lang: i18n.lang, mode: mode, payment: payment, pickup_time: pickup_time, address: address, floor: floor, bell: bell, notes: notes, delivery_zone: delivery_zone || undefined })
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'Server error');

        // Redirige vers la page de suivi live de la commande
        var orderId = data.order_id || '';
        var phoneDigits = (phone || '').replace(/\D/g, '');
        var last4 = phoneDigits.slice(-4);
        if (orderId && last4) {
          // localStorage save pour retrouver la commande après refresh / sortie
          try {
            var key = 'kalamaki_order_' + orderId;
            localStorage.setItem(key, JSON.stringify({ id: orderId, phone4: last4, ts: Date.now() }));
          } catch (e) { /* ignore */ }
          window.location.href = '/' + (i18n.lang || 'el') + '/order/?id=' + encodeURIComponent(orderId) + '&p=' + last4;
          return;
        }

        // Fallback : ancienne success view si pas de redirect
        viewCheckout.hidden = true;
        viewSuccess.hidden = false;
        $('#order-success-msg').textContent = (i18n.success_body || '')
          .replace('{ID}', data.order_id || '?');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (err) {
        errEl.textContent = (err && err.message) || i18n.error || 'Error';
        errEl.hidden = false;
        btn.disabled = false;
        btn.textContent = document.querySelector('#order-submit-btn').getAttribute('data-original') || '';
      }
    });

    // Toggle delivery fields when mode changes
    function refreshMode() {
      var modeVal = document.querySelector('input[name="mode"]:checked');
      var isDelivery = modeVal && modeVal.value === 'delivery';
      var delivFields = $('#delivery-fields');
      var paymentFields = $('#payment-fields');
      var pickupTimeFields = $('#pickup-time-fields');
      var callInfoTakeaway = $('#call-info-takeaway');
      var callInfoDelivery = $('#call-info-delivery');
      var addressInput = delivFields.querySelector('input[name="address"]');
      var zoneInputs = delivFields.querySelectorAll('input[name="delivery_zone"]');
      delivFields.hidden = !isDelivery;
      if (paymentFields) paymentFields.hidden = !isDelivery;
      if (pickupTimeFields) pickupTimeFields.hidden = isDelivery; // pickup-time uniquement pour takeaway
      if (addressInput) addressInput.required = isDelivery;
      zoneInputs.forEach(function(inp) { inp.required = isDelivery; });
      if (callInfoTakeaway) callInfoTakeaway.hidden = isDelivery;
      if (callInfoDelivery) callInfoDelivery.hidden = !isDelivery;
    }
    document.querySelectorAll('[data-mode-toggle]').forEach(function(r) {
      r.addEventListener('change', refreshMode);
    });

    // Init
    var submitBtn = $('#order-submit-btn');
    submitBtn.setAttribute('data-original', submitBtn.textContent);
    updateCart();
    refreshMode();
  })();
  </script>
</BaseLayout>
