---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CookieConsent from "../../components/CookieConsent.astro";
import { getLangFromParam } from "../../i18n/utils";
import { translations } from "../../i18n/translations";
import { menuPages, parsePrice, itemId } from "../../data/menu-data";
import { getPhotoData } from "../../data/efood-photos-map.mjs";

export function getStaticPaths() {
  return [
    { params: { lang: "el" } },
    { params: { lang: "en" } },
    { params: { lang: "de" } },
    { params: { lang: "ru" } },
    { params: { lang: "ja" } },
  ];
}

const currentLang = getLangFromParam(Astro.params.lang);
const t = translations[currentLang];
const isEl = currentLang === "el";

// Index plat des items (pour JS panier + serveur)
const flatItems = menuPages.flatMap((p, pi) =>
  p.items
    .filter((it) => !it.price.startsWith("+")) // pas d'extras isolés
    .map((it, ii) => {
      const photo = getPhotoData(it.el);
      return {
        id: itemId(pi, ii),
        name_el: it.el,
        name_en: it.en,
        desc_el: it.desc_el || "",
        desc_en: it.desc_en || "",
        price: parsePrice(it.price),
        priceLabel: it.price,
        page: pi,
        photo: photo ? { src: photo.src, srcset: photo.srcset } : null,
      };
    })
);
---

<BaseLayout
  lang={currentLang}
  title={isEl
    ? 'Παραγγελία online — Καλαμάκι Της Τρούμπας Πειραιάς | Παράδοση & Παραλαβή'
    : 'Order online — Trouba Souvlaki Piraeus | Delivery & Takeaway'}
  description={isEl
    ? 'Παράγγειλε απευθείας απ\'το Καλαμάκι Της Τρούμπας — χωρίς προμήθεια. Σουβλάκια, πίτες, μερίδες, veggie. Παράδοση και παραλαβή στην Τρούμπα Πειραιά.'
    : 'Order direct from Trouba Souvlaki — no commission. Skewers, pita wraps, plates, veggie options. Delivery and takeaway in Troumpa Piraeus.'}
  includeMenu={true}
  breadcrumbs={[
    { name: isEl ? 'Αρχική' : 'Home', path: `/${currentLang}/` },
    { name: isEl ? 'Παραγγελία online' : 'Order online', path: `/${currentLang}/delivery/` },
  ]}
>
  <section class="order-page bg-[#0a0a0a] pt-28 pb-40 px-4">
    <div class="max-w-5xl mx-auto">

      {/* Bouton retour vers la home — toujours visible */}
      <a href={`/${currentLang}/`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/15 text-white/80 hover:bg-white/10 hover:text-white text-xs font-bold uppercase tracking-widest mb-6 transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        {isEl ? 'Πίσω στην αρχική' : 'Back to home'}
      </a>

      <header class="text-center mb-10">
        <p class="text-[10px] uppercase tracking-[0.35em] text-[#E5B32A] font-bold mb-2">{t.order_title}</p>
        <h1 class="text-3xl md:text-4xl font-serif italic text-white mb-3">{isEl ? "Παραγγελία online" : "Order online"}</h1>
        <p class="text-gray-400 max-w-xl mx-auto">{t.order_subtitle}</p>
        <p class="text-xs text-gray-500 mt-2">{t.order_form_pay_note}</p>
      </header>

      <!-- VUE MENU -->
      <div id="order-view-menu">

        <!-- BARRE DE RECHERCHE STICKY -->
        <div id="menu-search-wrap" class="menu-search-wrap mb-6">
          <div class="menu-search-box">
            <svg class="menu-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
            <input
              type="search"
              id="menu-search-input"
              autocomplete="off"
              placeholder={isEl ? "🔍 Αναζήτηση... (π.χ. καλαμάκι, πίτα, μπύρα)" : "🔍 Search... (e.g. souvlaki, pita, beer)"}
            />
            <button type="button" id="menu-search-clear" class="menu-search-clear" aria-label={isEl ? 'Καθάρισμα' : 'Clear'} hidden>×</button>
            <span id="menu-search-count" class="menu-search-count"></span>
          </div>
          <p id="menu-search-empty" class="menu-search-empty" hidden>{isEl ? 'Κανένα προϊόν δεν ταιριάζει.' : 'No matching items.'}</p>
        </div>

        <div class="grid gap-8">
          {menuPages.map((p, pi) => (
            <section class="rounded-2xl bg-white/3 border border-white/10 p-5 md:p-6">
              <h2 class="text-xl md:text-2xl font-serif italic text-[#E5B32A] mb-4">{isEl ? p.title_el : p.title_en}</h2>
              {(isEl ? p.note_el : p.note_en) && (
                <p class="text-xs text-gray-400 italic mb-4">{isEl ? p.note_el : p.note_en}</p>
              )}
              <ul class="divide-y divide-white/5">
                {p.items.map((it, ii) => {
                  const id = itemId(pi, ii);
                  const isExtra = it.price.startsWith("+");
                  const photo = getPhotoData(it.el);
                  return (
                    <li class="flex items-start gap-3 py-3" data-item-row={id}>
                      {photo ? (
                        <img
                          src={photo.src}
                          srcset={photo.srcset}
                          sizes="80px"
                          alt={it.el}
                          width="80" height="80"
                          loading="lazy" decoding="async"
                          class="shrink-0 w-20 h-20 rounded-lg object-cover border border-white/10"
                        />
                      ) : (
                        <div
                          class="shrink-0 w-20 h-20 rounded-lg border border-[#E5B32A]/25 flex items-center justify-center"
                          style="background: linear-gradient(135deg, rgba(229,179,42,0.18) 0%, rgba(0,0,0,0.9) 80%);"
                          aria-hidden="true"
                        >
                          <svg viewBox="0 0 24 24" class="w-6 h-6 text-[#E5B32A]/60" fill="currentColor"><path d="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z"/></svg>
                        </div>
                      )}
                      <div class="flex-1 min-w-0">
                        <p class="text-sm md:text-base text-white font-medium leading-snug">{isEl ? it.el : it.en}</p>
                        {(isEl ? it.desc_el : it.desc_en) && (
                          <p class="text-xs text-gray-500 mt-0.5 leading-snug">{isEl ? it.desc_el : it.desc_en}</p>
                        )}
                        <p class="text-sm text-[#E5B32A] font-bold mt-1">{it.price}</p>
                      </div>
                      {!isExtra && (
                        <div class="flex items-center gap-2 shrink-0 mt-1">
                          <button type="button" class="qty-btn qty-minus" data-id={id} aria-label={t.order_remove}>−</button>
                          <span class="qty-display w-7 text-center text-white font-bold text-base" data-qty={id}>0</span>
                          <button type="button" class="qty-btn qty-plus" data-id={id} aria-label={t.order_add}>+</button>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </section>
          ))}
        </div>
      </div>

      <!-- VUE CHECKOUT -->
      <div id="order-view-checkout" hidden>
        <button type="button" id="back-to-menu" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/15 text-[#E5B32A] hover:bg-[#E5B32A]/15 hover:border-[#E5B32A]/60 text-xs font-bold uppercase tracking-widest mb-6 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          {t.order_form_back}
        </button>
        <div class="bg-white/3 border border-white/10 rounded-2xl p-6 md:p-8">
          <h2 class="text-2xl font-serif italic text-white mb-6">{t.order_form_title}</h2>

          <div id="checkout-cart-summary" class="mb-6 text-sm space-y-2"></div>

          <form id="order-form" class="space-y-5">
            {/* Mode : livraison vs à emporter */}
            <div>
              <label class="block text-xs uppercase tracking-wider text-gray-400 mb-2">{isEl ? 'Παραλαβή ή παράδοση' : 'Collection or delivery'}</label>
              <div class="grid grid-cols-2 gap-2">
                <label class="pickup-radio"><input type="radio" name="mode" value="takeaway" checked required data-mode-toggle /><span>{isEl ? 'Παραλαβή απ\'το μαγαζί' : 'Takeaway'}</span></label>
                <label class="pickup-radio"><input type="radio" name="mode" value="delivery" data-mode-toggle /><span>{isEl ? 'Παράδοση κατ\'οίκον' : 'Delivery'}</span></label>
              </div>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-wider text-gray-400 mb-1">{t.order_form_name}</label>
              <input type="text" name="name" required minlength="2" maxlength="60" class="w-full bg-black/40 border border-white/15 text-white px-4 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs uppercase tracking-wider text-gray-400 mb-1">{t.order_form_phone}</label>
              <div class="flex gap-2">
                <select name="phone_code" class="bg-black/40 border border-white/15 text-white px-2 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none text-sm" style="max-width:130px">
                  <option value="+30" selected>🇬🇷 +30</option>
                  <option value="+44">🇬🇧 +44</option>
                  <option value="+1">🇺🇸 +1</option>
                  <option value="+33">🇫🇷 +33</option>
                  <option value="+34">🇪🇸 +34</option>
                  <option value="+49">🇩🇪 +49</option>
                  <option value="+39">🇮🇹 +39</option>
                  <option value="+351">🇵🇹 +351</option>
                  <option value="+31">🇳🇱 +31</option>
                  <option value="+32">🇧🇪 +32</option>
                  <option value="+41">🇨🇭 +41</option>
                  <option value="+90">🇹🇷 +90</option>
                  <option value="+357">🇨🇾 +357</option>
                  <option value="+359">🇧🇬 +359</option>
                  <option value="+40">🇷🇴 +40</option>
                  <option value="+381">🇷🇸 +381</option>
                  <option value="+212">🇲🇦 +212</option>
                  <option value="+213">🇩🇿 +213</option>
                  <option value="+216">🇹🇳 +216</option>
                  <option value="+20">🇪🇬 +20</option>
                  <option value="+971">🇦🇪 +971</option>
                  <option value="+966">🇸🇦 +966</option>
                  <option value="+86">🇨🇳 +86</option>
                  <option value="+81">🇯🇵 +81</option>
                  <option value="+82">🇰🇷 +82</option>
                  <option value="+91">🇮🇳 +91</option>
                  <option value="+61">🇦🇺 +61</option>
                  <option value="+7">🇷🇺 +7</option>
                  <option value="+380">🇺🇦 +380</option>
                </select>
                <input type="tel" name="phone" required minlength="6" maxlength="20" pattern="[0-9\\s\\-().]+" class="flex-1 bg-black/40 border border-white/15 text-white px-4 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none" placeholder={isEl ? '210 422 2233' : '210 422 2233'} />
              </div>
            </div>

            {/* Note client — toujours visible (takeaway et delivery) */}
            <div>
              <label class="block text-xs uppercase tracking-wider text-gray-400 mb-1">{isEl ? 'Σημείωση (προαιρετικό)' : 'Note (optional)'}</label>
              <textarea name="notes" maxlength="300" rows="2" placeholder={isEl ? 'π.χ. Χωρίς κρεμμύδι, αλλεργία στο γλουτένη...' : 'e.g. No onion, gluten allergy...'} class="w-full bg-black/40 border border-white/15 text-white px-4 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none resize-none"></textarea>
            </div>

            {/* Pickup-time — visible UNIQUEMENT pour takeaway (livraison = le restaurant appelle quand il part) */}
            <div id="pickup-time-fields">
              <label class="block text-xs uppercase tracking-wider text-gray-400 mb-2">{isEl ? 'Πότε θα έρθεις να την πάρεις;' : 'When will you come pick it up?'}</label>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                <label class="pickup-radio"><input type="radio" name="pickup_time" value="15" checked /><span>{isEl ? 'Περίπου 15 λεπτά' : 'About 15 min'}</span></label>
                <label class="pickup-radio"><input type="radio" name="pickup_time" value="30" /><span>{isEl ? 'Περίπου 30 λεπτά' : 'About 30 min'}</span></label>
                <label class="pickup-radio"><input type="radio" name="pickup_time" value="45" /><span>{isEl ? 'Περίπου 45 λεπτά' : 'About 45 min'}</span></label>
                <label class="pickup-radio"><input type="radio" name="pickup_time" value="60" /><span>{isEl ? 'Περίπου 1 ώρα' : 'About 1 h'}</span></label>
              </div>
            </div>

            {/* Adresse — visible UNIQUEMENT si livraison */}
            <div id="delivery-fields" hidden class="space-y-4 p-4 rounded-lg bg-[#E5B32A]/5 border border-[#E5B32A]/20">
              <p class="text-[10px] uppercase tracking-widest text-[#E5B32A] font-bold">{isEl ? 'Ζώνη παράδοσης' : 'Delivery zone'}</p>

              {/* Mini-carte SVG stylisée Pirée — zone verte centre / zone rouge élargie */}
              <div class="zones-map-wrap" style="border-radius: 0.6rem; overflow: hidden; background: #1e3a5f; padding: 0.5rem;">
                <svg viewBox="0 0 280 160" style="width:100%; height:auto; display:block;">
                  {/* terre */}
                  <rect x="0" y="0" width="280" height="160" fill="#3a5b7a" />
                  {/* mer / golfe */}
                  <path d="M0,90 Q60,110 90,120 L110,160 L0,160 Z" fill="#1e3a5f" />
                  {/* zone rouge (anneau) */}
                  <ellipse cx="140" cy="80" rx="105" ry="55" fill="rgba(239,68,68,0.45)" stroke="rgba(239,68,68,0.85)" stroke-width="1.5" stroke-dasharray="4,2" />
                  {/* zone verte (centre) */}
                  <ellipse cx="125" cy="100" rx="45" ry="28" fill="rgba(34,197,94,0.55)" stroke="rgba(34,197,94,1)" stroke-width="2" />
                  {/* pin Trouba */}
                  <circle cx="125" cy="100" r="5" fill="#E5B32A" stroke="#000" stroke-width="1.2" />
                  <text x="125" y="115" font-size="7" fill="#fff" text-anchor="middle" font-weight="bold">TROUBA</text>
                  {/* labels villes */}
                  <text x="80" y="40" font-size="8" fill="#fff" font-weight="600">Αιγάλεω</text>
                  <text x="195" y="38" font-size="8" fill="#fff" font-weight="600">Αθήνα</text>
                  <text x="60" y="75" font-size="7" fill="#fff">Κερατσίνι</text>
                  <text x="155" y="60" font-size="7" fill="#fff">Κορυδαλλός</text>
                  <text x="180" y="120" font-size="7" fill="#fff">Καλλιθέα</text>
                </svg>
              </div>

              <div class="grid grid-cols-1 gap-2">
                <label class="zone-radio" style="display:flex; align-items:center; gap:0.6rem; padding:0.75rem 1rem; border:2px solid rgba(34,197,94,0.4); border-radius:0.6rem; cursor:pointer; background:rgba(34,197,94,0.06);">
                  <input type="radio" name="delivery_zone" value="green" style="accent-color:#22c55e;" />
                  <span style="flex:1;">
                    <span style="color:#4ade80; font-weight:700;">● {isEl ? 'Πειραιάς (κέντρο)' : 'Piraeus centre'}</span>
                    <span style="display:block; font-size:0.78rem; color:#bbb; margin-top:0.15rem;">{isEl ? 'Ελάχιστη παραγγελία : 5€' : 'Minimum order: 5€'}</span>
                  </span>
                </label>
                <label class="zone-radio" style="display:flex; align-items:center; gap:0.6rem; padding:0.75rem 1rem; border:2px solid rgba(239,68,68,0.4); border-radius:0.6rem; cursor:pointer; background:rgba(239,68,68,0.06);">
                  <input type="radio" name="delivery_zone" value="red" style="accent-color:#ef4444;" />
                  <span style="flex:1;">
                    <span style="color:#f87171; font-weight:700;">● {isEl ? 'Κορυδαλλός / Κερατσίνι / Αιγάλεω' : 'Korydallós / Keratsíni / Aigáleo'}</span>
                    <span style="display:block; font-size:0.78rem; color:#bbb; margin-top:0.15rem;">{isEl ? 'Ελάχιστη παραγγελία : 7€' : 'Minimum order: 7€'}</span>
                  </span>
                </label>
              </div>
              <p id="zone-min-warn" class="text-xs text-red-400" hidden></p>

              <p class="text-[10px] uppercase tracking-widest text-[#E5B32A] font-bold pt-2">{isEl ? 'Διεύθυνση παράδοσης' : 'Delivery address'}</p>
              <div>
                <label class="block text-xs uppercase tracking-wider text-gray-400 mb-1">{isEl ? 'Διεύθυνση (οδός & αριθμός)' : 'Street & number'}</label>
                <input type="text" name="address" maxlength="200" placeholder={isEl ? 'π.χ. Μπουμπουλίνας 12' : 'e.g. Bouboulinas 12'} class="w-full bg-black/40 border border-white/15 text-white px-4 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs uppercase tracking-wider text-gray-400 mb-1">{isEl ? 'Όροφος' : 'Floor'}</label>
                  <input type="text" name="floor" maxlength="30" placeholder={isEl ? '3ος' : '3rd'} class="w-full bg-black/40 border border-white/15 text-white px-4 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none" />
                </div>
                <div>
                  <label class="block text-xs uppercase tracking-wider text-gray-400 mb-1">{isEl ? 'Όνομα στο κουδούνι' : 'Buzzer / name'}</label>
                  <input type="text" name="bell" maxlength="40" placeholder={isEl ? 'Παπαδόπουλος' : 'Smith'} class="w-full bg-black/40 border border-white/15 text-white px-4 py-3 rounded-lg focus:border-[#E5B32A] focus:outline-none" />
                </div>
              </div>
            </div>

            {/* Paiement : visible UNIQUEMENT si livraison (takeaway = paiement sur place) */}
            <div id="payment-fields" hidden>
              <label class="block text-xs uppercase tracking-wider text-gray-400 mb-2">{isEl ? 'Τρόπος πληρωμής' : 'Payment method'}</label>
              <div class="grid grid-cols-2 gap-2">
                <label class="pickup-radio"><input type="radio" name="payment" value="cash" checked /><span>{isEl ? '💶 Μετρητά' : '💶 Cash'}</span></label>
                <label class="pickup-radio"><input type="radio" name="payment" value="card" /><span>{isEl ? '💳 Κάρτα' : '💳 Card'}</span></label>
              </div>
              <p class="text-xs text-gray-500 italic mt-2">{isEl ? 'Πληρωμή στον διανομέα κατά την παράδοση.' : 'Pay the courier on delivery.'}</p>
            </div>

            {/* Bandeau info appel */}
            <div id="call-info-takeaway" class="p-3 rounded-lg bg-[#E5B32A]/10 border border-[#E5B32A]/30 text-sm text-[#E5B32A] text-center font-medium">
              {isEl ? '📞 Το μαγαζί θα σε ειδοποιήσει όταν είναι έτοιμη η παραγγελία.' : '📞 The shop will call you when your order is ready.'}
            </div>
            <div id="call-info-delivery" hidden class="p-3 rounded-lg bg-[#E5B32A]/10 border border-[#E5B32A]/30 text-sm text-[#E5B32A] text-center font-medium">
              {isEl ? '📞 Το μαγαζί θα σε καλέσει όταν φύγει ο διανομέας — σύντομα μετά την παραγγελία.' : '📞 The shop will call you when the courier leaves — shortly after ordering.'}
            </div>

            <button type="submit" id="order-submit-btn" class="w-full bg-[#E5B32A] text-black font-bold uppercase tracking-[0.2em] py-4 rounded-lg text-sm hover:bg-white transition-all">{t.order_form_submit}</button>
            <p id="order-error" class="text-red-400 text-sm text-center" hidden></p>
          </form>
        </div>
      </div>

      <!-- VUE SUCCESS -->
      <div id="order-view-success" hidden class="max-w-xl mx-auto text-center py-10">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#E5B32A]/15 border-2 border-[#E5B32A] mb-6">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#E5B32A" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-serif italic text-white mb-4">{t.order_success_title}</h2>
        <p id="order-success-msg" class="text-gray-300 mb-8"></p>
        <a href={`/${currentLang}/`} class="inline-block text-[#E5B32A] hover:underline text-sm">{t.order_success_back}</a>
      </div>

    </div>
  </section>

  <!-- PANIER FLOTTANT -->
  <div id="cart-floater" class="cart-floater" hidden>
    <button type="button" id="cart-open-btn" class="cart-bar">
      <span class="cart-count" id="cart-count">0</span>
      <span class="cart-label">{t.order_cart}</span>
      <span class="cart-total" id="cart-total">0,00€</span>
    </button>
  </div>

  <!-- DRAWER PANIER (mobile + desktop) -->
  <div id="cart-drawer" class="cart-drawer" hidden aria-hidden="true">
    <div class="cart-backdrop" id="cart-backdrop"></div>
    <div class="cart-panel" role="dialog" aria-labelledby="cart-drawer-title">
      <div class="cart-handle"></div>
      <div class="cart-header">
        <h3 id="cart-drawer-title" class="text-lg font-serif italic text-white">{t.order_cart}</h3>
        <button type="button" id="cart-close-btn" class="text-gray-400 hover:text-white text-2xl leading-none" aria-label={isEl ? 'Κλείσιμο' : 'Close'}>×</button>
      </div>
      <div class="cart-body" id="cart-body">
        <p class="text-gray-400 text-sm" id="cart-empty">{t.order_cart_empty}</p>
        <ul class="cart-list" id="cart-list"></ul>
      </div>
      <div class="cart-footer">
        <div class="flex items-center justify-between mb-3">
