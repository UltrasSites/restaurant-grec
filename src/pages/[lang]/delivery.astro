    review_clear: isEl ? 'Άδειασμα καλαθιού' : 'Clear cart',
    review_clear_confirm: isEl ? 'Σίγουρα θες να αδειάσεις το καλάθι;' : 'Empty the entire cart?',
    review_remove_aria: isEl ? 'Αφαίρεση προϊόντος' : 'Remove item',
    review_empty: isEl ? 'Άδειο καλάθι. Γύρνα πίσω στο μενού.' : 'Empty cart. Go back to the menu.',
    search_count_one: isEl ? 'αποτέλεσμα' : 'result',
