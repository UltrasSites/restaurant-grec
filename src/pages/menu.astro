---
import Flag from "../components/Flag.astro";
// Standalone language picker — clients land here after scanning the QR.
// On click, opens the PDF inline in browser.
const LANGS = [
  { code: "el", label: "Ελληνικά",  sub: "Greek",       hello: "Καλώς ήρθατε" },
  { code: "en", label: "English",   sub: "English",     hello: "Welcome", pdf: "/menu-en.pdf" },
  { code: "de", label: "Deutsch",   sub: "German",      hello: "Willkommen" },
  { code: "ru", label: "Русский",   sub: "Russian",     hello: "Добро пожаловать" },
  { code: "ja", label: "日本語",     sub: "Japanese",    hello: "ようこそ" },
  { code: "tr", label: "Türkçe",    sub: "Turkish",     hello: "Hoş geldiniz" },
  { code: "fr", label: "Français",  sub: "French",      hello: "Bienvenue" },
  { code: "es", label: "Español",   sub: "Spanish",     hello: "Bienvenido" },
  { code: "it", label: "Italiano",  sub: "Italian",     hello: "Benvenuto" },
  { code: "pt", label: "Português", sub: "Portuguese",  hello: "Bem-vindo" },
  { code: "nl", label: "Nederlands", sub: "Dutch",      hello: "Welkom" },
  { code: "zh", label: "中文",      sub: "Chinese",     hello: "欢迎光临" },
];
---
<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>Menu · Καλαμάκι Της Τρούμπας</title>
    <meta name="description" content="Choisissez votre langue pour consulter le menu." />
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        min-height: 100dvh;
        background:
          radial-gradient(ellipse at 50% -20%, rgba(229,179,42,0.18) 0%, transparent 55%),
          radial-gradient(ellipse at 50% 120%, rgba(229,179,42,0.08) 0%, transparent 50%),
          #0a0a0a;
        color: #fff;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .wrap {
        min-height: 100dvh;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 32px 20px;
        max-width: 720px; margin: 0 auto;
      }
      .brand {
        text-align: center;
        margin-bottom: 28px;
      }
      .brand-mark {
        display: inline-block;
        font-family: 'Playfair Display', serif;
        font-style: italic; font-weight: 700;
        color: #E5B32A;
        font-size: 11px;
        letter-spacing: 0.4em; text-transform: uppercase;
        padding: 6px 14px;
        border: 1px solid rgba(229,179,42,0.4);
        border-radius: 999px;
        margin-bottom: 16px;
      }
      .brand h1 {
        font-family: 'Playfair Display', serif;
        font-weight: 700; font-style: italic;
        font-size: clamp(28px, 6vw, 42px);
        margin: 0 0 6px;
        color: #fff;
        line-height: 1.1;
      }
      .brand p {
        font-size: 11px;
        color: rgba(255,255,255,0.55);
        letter-spacing: 0.22em; text-transform: uppercase;
        margin: 0;
      }
      .divider {
        margin: 18px auto 0;
        text-align: center;
        color: rgba(229,179,42,0.55);
        letter-spacing: 0.4em;
        font-size: 12px;
      }
      .title-block {
        text-align: center;
        margin: 24px auto 28px;
      }
      .title-eyebrow {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        color: #E5B32A;
        letter-spacing: 0.4em; text-transform: uppercase;
        margin-bottom: 8px;
      }
      .title-block h2 {
        font-family: 'Playfair Display', serif;
        font-weight: 700; font-style: italic;
        font-size: clamp(22px, 5vw, 32px);
        margin: 0;
        color: #fff;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        width: 100%;
        max-width: 520px;
      }
      .lang-btn {
        appearance: none;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 22px 14px 18px;
        background: linear-gradient(160deg, rgba(229,179,42,0.06) 0%, rgba(20,20,20,0.85) 60%, rgba(10,10,10,0.95) 100%);
        border: 1px solid rgba(229,179,42,0.22);
        border-radius: 22px;
        color: #fff;
        cursor: pointer;
        transition: transform 0.18s cubic-bezier(0.4,0,0.2,1), border-color 0.2s, background 0.25s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
        font-family: 'Space Grotesk', sans-serif;
      }
      .lang-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 0%, rgba(229,179,42,0.18), transparent 60%);
        opacity: 0;
        transition: opacity 0.25s;
        pointer-events: none;
      }
      .lang-btn:hover, .lang-btn:focus-visible {
        transform: translateY(-2px);
        border-color: rgba(229,179,42,0.7);
        box-shadow: 0 12px 28px -10px rgba(229,179,42,0.35), 0 0 0 1px rgba(229,179,42,0.25);
      }
      .lang-btn:hover::before, .lang-btn:focus-visible::before { opacity: 1; }
      .lang-btn:active { transform: translateY(0) scale(0.98); }
      .flag-wrap {
        display: inline-flex;
        line-height: 1;
        margin-bottom: 4px;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.4));
      }
      .label {
        font-family: 'Playfair Display', serif;
        font-style: italic; font-weight: 700;
        font-size: 18px;
        color: #fff;
        letter-spacing: 0.01em;
      }
      .sub {
        font-size: 9px;
        color: rgba(229,179,42,0.75);
        letter-spacing: 0.25em; text-transform: uppercase;
        font-weight: 700;
      }
      .hello {
        font-size: 11px;
        color: rgba(255,255,255,0.45);
        font-style: italic;
        margin-top: 2px;
      }
      .hint {
        margin-top: 28px;
        text-align: center;
        font-size: 11px;
        color: rgba(255,255,255,0.4);
        letter-spacing: 0.18em; text-transform: uppercase;
      }
      .home {
        margin-top: 14px;
        font-size: 10px;
        color: rgba(229,179,42,0.7);
        text-decoration: none;
        letter-spacing: 0.25em; text-transform: uppercase;
        font-weight: 700;
        border-bottom: 1px solid rgba(229,179,42,0.3);
        padding-bottom: 2px;
      }
      .home:hover { color: #E5B32A; border-color: #E5B32A; }

      /* Larger screens: 3 columns */
      @media (min-width: 560px) {
        .grid { grid-template-columns: repeat(3, 1fr); max-width: 640px; }
      }

      @media (max-width: 360px) {
        .flag { font-size: 32px; }
        .label { font-size: 16px; }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="brand">
        <span class="brand-mark">Bouboulinas 8 · Piraeus</span>
        <h1>Το Καλαμάκι Της Τρούμπας</h1>
        <p>Authentic Piraeus Flavour</p>
      </div>

      <div class="divider">◆ · · · ◆</div>

      <div class="title-block">
        <div class="title-eyebrow">Choose your language</div>
        <h2>Επιλέξτε γλώσσα / Choisissez votre langue</h2>
      </div>

      <div class="grid">
        {LANGS.map((l) => (
          <a
            class="lang-btn"
            href={l.pdf ?? `/menu-${l.code}.pdf`}
            target="_blank"
            rel="noopener"
            data-lang={l.code}
            aria-label={`Open menu in ${l.sub}`}
          >
            <span class="flag-wrap"><Flag code={l.code} size={56} rounded /></span>
            <span class="label">{l.label}</span>
            <span class="sub">{l.sub}</span>
            <span class="hello">{l.hello}</span>
          </a>
        ))}
      </div>

      <p class="hint">Bouboulinas 8 &amp; Notara · Piraeus · +30 210 422 2233</p>
      <a class="home" href="/">← kalamakitroubas.gr</a>
    </main>
  </body>
</html>
