    "https://www.tripadvisor.com/Restaurant_Review-g189403-d10042662-Reviews-To_Kalamaki_tis_Troumpas-Piraeus_Piraeus_Region_Attica.html",
    "https://maps.google.com/?cid=4117845882351786324",
  ],
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": lang === 'en' ? "Takeaway" : "Take away", "value": true },
    { "@type": "LocationFeatureSpecification", "name": lang === 'en' ? "Delivery" : "Παράδοση κατ' οίκον", "value": true },
    { "@type": "LocationFeatureSpecification", "name": lang === 'en' ? "Vegetarian options" : "Χορτοφαγικές επιλογές", "value": true },
    { "@type": "LocationFeatureSpecification", "name": lang === 'en' ? "Vegan options" : "Vegan επιλογές", "value": true },
    { "@type": "LocationFeatureSpecification", "name": lang === 'en' ? "Late night food" : "Φαγητό μέχρι αργά", "value": true },
    { "@type": "LocationFeatureSpecification", "name": lang === 'en' ? "Charcoal grill" : "Ψήσιμο στα κάρβουνα", "value": true },
  ],
  "potentialAction": [
    {
      "@type": "OrderAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${origin}/${lang}/delivery/`,
        "actionPlatform": ["http://schema.org/DesktopWebPlatform","http://schema.org/MobileWebPlatform"],
