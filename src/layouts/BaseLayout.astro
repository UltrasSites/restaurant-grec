---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import A2hsPrompt from "../components/A2hsPrompt.astro";
import DeliveryPartnersWidget from "../components/DeliveryPartnersWidget.astro";
import "../styles/global.css";
import type { Lang } from "../i18n/utils";
import { menuPages, parsePrice } from "../data/menu-data";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  hideHeader?: boolean;
  /** Optional BreadcrumbList items (label + path). When provided, BreadcrumbList JSON-LD is emitted. */
  breadcrumbs?: { name: string; path: string }[];
  /** When true, includes the Menu schema (only on pages that show the menu). */
  includeMenu?: boolean;
  /** When true, loads Leaflet CSS+JS (only needed on delivery page). */
  includeLeaflet?: boolean;
}

const {
  title = "Καλαμάκι Της Τρούμπας — Σουβλάκια στον Πειραιά | Παραγγελία online",
  description = "Αυθεντικά καλαμάκια, γύρος και πίτες στην καρδιά της Τρούμπας Πειραιά. Μπουμπουλίνας 8 & Νοταρά.",
  lang = "el",
  hideHeader = false,
  breadcrumbs = [],
  includeMenu = false,
  includeLeaflet = false,
} = Astro.props;
const HTML_LANG_MAP: Record<string, string> = { el: 'el-GR', en: 'en-GB' };
const htmlLang = HTML_LANG_MAP[lang] ?? 'el-GR';
const origin = Astro.url.origin;

