// ===== JSON-LD : Organization (parent — autorité du domaine) =====
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${origin}/#organization`,
  "name": "Το Καλαμάκι Της Τρούμπας",
  "url": origin,
  "logo": {
    "@type": "ImageObject",
    "url": `${origin}/photos/logo-main.png`,
    "width": 512,
    "height": 481,
  },
  "sameAs": [
    "https://www.facebook.com/to.kalamaki.tis.troumpas/",
    "https://maps.google.com/?cid=4117845882351786324",
    "https://www.tripadvisor.com/Restaurant_Review-g189403-d10042662-Reviews-To_Kalamaki_tis_Troumpas-Piraeus_Piraeus_Region_Attica.html",
  ],
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+302104222233",
      "contactType": "reservations",
      "areaServed": "GR",
      "availableLanguage": ["el", "en"],
    },
    {
      "@type": "ContactPoint",
      "telephone": "+302104222273",
      "contactType": "customer service",
      "areaServed": "GR",
      "availableLanguage": ["el", "en"],
    },
  ],
};

// ===== JSON-LD : WebSite + SearchAction =====
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${origin}/#website`,
  "url": `${origin}/`,
  "name": "Το Καλαμάκι Της Τρούμπας",
  "alternateName": "Trouba Souvlaki",
  "description": "Αυθεντικά σουβλάκια στην Τρούμπα, Πειραιάς.",
  "publisher": { "@id": `${origin}/#restaurant` },
  "inLanguage": ["el-GR", "en-GB"],
};

// ===== JSON-LD : BreadcrumbList (optional, per page) =====
const breadcrumbSchema = breadcrumbs.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": b.name,
        "item": `${origin}${b.path.startsWith('/') ? b.path : '/' + b.path}`,
      })),
    }
  : null;

// ===== JSON-LD : Menu (sections + sample items + prices) =====
const menuSchema = includeMenu
  ? {
      "@context": "https://schema.org",
      "@type": "Menu",
      "@id": `${origin}/#menu`,
      "name": lang === 'en' ? "Trouba Souvlaki menu" : "Κατάλογος Καλαμάκι Της Τρούμπας",
      "inLanguage": lang === 'en' ? 'en-GB' : 'el-GR',
      "url": `${origin}/menu/`,
      "provider": { "@id": `${origin}/#restaurant` },
      "hasMenuSection": menuPages.map((page) => ({
        "@type": "MenuSection",
        "name": lang === 'en' ? page.title_en : page.title_el,
        "description": lang === 'en' ? (page.note_en || undefined) : (page.note_el || undefined),
        "image": `${origin}${page.photo}`,
        "hasMenuItem": page.items
          .filter((it) => !it.price.startsWith('+'))
          .map((it) => ({
            "@type": "MenuItem",
            "name": lang === 'en' ? it.en : it.el,
            "description": lang === 'en' ? (it.desc_en || undefined) : (it.desc_el || undefined),
            "offers": {
              "@type": "Offer",
              "price": parsePrice(it.price).toFixed(2),
              "priceCurrency": "EUR",
              "availability": "https://schema.org/InStock",
            },
          })),
      })),
    }
  : null;

// ===== JSON-LD : FAQPage (always included on all pages — boosts SERP coverage) =====
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": lang === 'en' ? "Where is Trouba Souvlaki located?" : "Πού βρίσκεται το Καλαμάκι Της Τρούμπας;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Bouboulinas 8 & Notara, in the heart of Troumpa, Piraeus 185 35, Greece. A 5-minute walk from the central port."
          : "Μπουμπουλίνας 8 & Νοταρά, στην καρδιά της Τρούμπας, Πειραιάς 185 35. 5 λεπτά από το κεντρικό λιμάνι.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "What are your opening hours?" : "Ποιες είναι οι ώρες λειτουργίας;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Monday to Thursday 13:00–02:30, Friday 13:00–04:00, Saturday 20:00–05:00."
          : "Δευτέρα έως Πέμπτη 13:00–02:30, Παρασκευή 13:00–04:00, Σάββατο 20:00–05:00.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "Can I order online?" : "Μπορώ να παραγγείλω online;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Yes — order direct on our website (no commission), or via e-food, Wolt and Box.gr."
          : "Ναι — παραγγείλτε απευθείας από εμάς (χωρίς προμήθεια), ή μέσω e-food, Wolt και Box.gr.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "Do you have vegetarian options?" : "Έχετε χορτοφαγικές επιλογές;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Yes — full vegetarian and vegan menu: zucchini and chickpea fritters, seitan skewers, veggie burger and more."
          : "Ναι — πλήρες veggie & vegan μενού: κολοκυθοκεφτέδες, ρεβυθοκεφτέδες, καλαμάκι σεϊτάν, veggie burger και άλλα.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "Is the souvlaki really cooked over charcoal?" : "Τα σουβλάκια ψήνονται πραγματικά στα κάρβουνα;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Yes — every skewer, every chop and every pita is grilled over real charcoal, every day from open to close."
          : "Ναι — κάθε καλαμάκι, κάθε μπριζολάκι και κάθε πίτα ψήνονται πάνω από αληθινά κάρβουνα, κάθε μέρα.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "Do you deliver to the Piraeus port and cruise terminals?" : "Κάνετε delivery στο λιμάνι του Πειραιά και στα κρουαζιερόπλοια;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Yes — we deliver across Piraeus, including the ferry terminals and the cruise port. Order direct on our site (no commission) or via e-food, Wolt and Box.gr."
          : "Ναι — παραδίδουμε σε όλο τον Πειραιά, συμπεριλαμβανομένων των φέρι και του λιμανιού κρουαζιέρας. Παραγγείλτε απευθείας από εμάς (χωρίς προμήθεια) ή μέσω e-food, Wolt και Box.gr.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "How much does a souvlaki cost?" : "Πόσο κοστίζει ένα σουβλάκι;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Our charcoal-grilled chicken or pork kalamaki starts at €2.20. Pita gyros from €3.50. Souvlaki platters (with fries, pita, tzatziki and salad) from €11.50. Honest Piraeus pricing."
          : "Το καλαμάκι κοτόπουλο ή χοιρινό στα κάρβουνα ξεκινά από 2,20€. Πίτα γύρος από 3,50€. Μερίδες σουβλάκι (με πατάτες, πίτα, τζατζίκι και σαλάτα) από 11,50€. Τίμιες τιμές Πειραιά.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "Are you open late at night?" : "Είστε ανοιχτά αργά το βράδυ;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "Yes — we stay open until 02:30 Monday to Thursday, 04:00 on Friday, and 05:00 on Saturday. Perfect for night-time arrivals and ferry departures."
          : "Ναι — είμαστε ανοιχτά μέχρι 02:30 Δευτέρα-Πέμπτη, 04:00 την Παρασκευή και 05:00 το Σάββατο. Ιδανικό για νυχτερινές αφίξεις και αναχωρήσεις φέρι.",
      },
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "How do I get to Trouba Souvlaki from the central port?" : "Πώς πάω στο Καλαμάκι Της Τρούμπας από το κεντρικό λιμάνι;",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en'
          ? "We are a 5-minute walk from the central Piraeus port. Address: Bouboulinas 8 & Notara, Piraeus 185 35. Tap the address to open Google Maps."
          : "Είμαστε 5 λεπτά με τα πόδια από το κεντρικό λιμάνι. Διεύθυνση: Μπουμπουλίνας 8 & Νοταρά, Πειραιάς 185 35. Πατήστε τη διεύθυνση για άνοιγμα στο Google Maps.",
      },
    },
  ],
};
