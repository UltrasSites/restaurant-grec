---
const { lang = "el" } = Astro.props;
const isEl = lang === "el";

// HAQQ: avis Google reels VERBATIM scrapes le 2026-05-19 depuis
// https://www.google.com/maps/place/.../Kalamaki+Trumpa+Piraeus
// Source : reviews-vrais.json (40 avis extraits, 291 au total).
// Texte conserve dans la langue d'origine (anglais) sur toutes les pages : pas de traduction inventee.
type Review = { name: string; date: string; rating: number; text: string; text_el: string };

// HAQQ : texte original anglais conservé verbatim. Traduction grecque fournie
// pour le confort des lecteurs grecs (la majorité des clients Trouba).
// Texte affiché selon la langue de la page.
const reviews: Review[] = [
  {
    name: "Joschka Fischer",
    date: "2025",
    rating: 5,
    text: "Fantastic place that is open until 04:00 in the morning. Went here while waiting for an early morning ferry. The food was great and you can sit in peace nearby the harbour. The owners are very kind people who will take a good care of you. Highly recommended if you need to spend some time in this area.",
    text_el: "Φανταστικό μέρος που είναι ανοιχτό μέχρι τις 04:00 το πρωί. Πήγαμε εδώ ενώ περιμέναμε ένα πρωινό φέρι. Το φαγητό ήταν εξαιρετικό και μπορείς να καθίσεις ήρεμα κοντά στο λιμάνι. Οι ιδιοκτήτες είναι πολύ καλοί άνθρωποι που θα σε φροντίσουν. Συνιστάται ανεπιφύλακτα αν χρειάζεται να περάσεις χρόνο σε αυτή την περιοχή.",
  },
  {
    name: "Eric Schwa",
    date: "2025",
    rating: 5,
    text: "Just wow! My wife and I stumbled upon this gem while staying at a hotel close by before a cruise. Place was empty and we placed our order at the counter. We got the pork souvlaki platter and greek salad. It was fresh and absolutely delicious. We are going back again somehow before we leave!",
    text_el: "Απλά εκπληκτικό! Η γυναίκα μου κι εγώ ανακαλύψαμε αυτό το διαμάντι ενώ μέναμε σε ένα κοντινό ξενοδοχείο πριν από μια κρουαζιέρα. Το μαγαζί ήταν άδειο και παραγγείλαμε στον πάγκο. Πήραμε την πιατέλα χοιρινό σουβλάκι και χωριάτικη σαλάτα. Ήταν φρέσκα και απολύτως νόστιμα. Θα ξαναπάμε σίγουρα πριν φύγουμε!",
  },
  {
    name: "Beata Berg Malmborg",
    date: "2024",
    rating: 5,
    text: "My warmest recommendations for this restaurant! Good food and the staff is so sweet and helpful, especially Aurora! We came here to eat and wait for our ferry which was leaving late in the night (03 am).",
    text_el: "Οι θερμότερες συστάσεις μου για αυτό το εστιατόριο! Καλό φαγητό και το προσωπικό είναι πολύ γλυκό και εξυπηρετικό, ειδικά η Αυρόρα! Ήρθαμε εδώ να φάμε και να περιμένουμε το φέρι μας που έφευγε αργά τη νύχτα (03 πμ).",
  },
  {
    name: "Momchil Petrinski",
    date: "2024",
    rating: 5,
    text: "Everything is fabulous! Great food, good portions, very reasonable price, lovely owners - I can’t recommend it enough! Hats down to the lady running the restaurant who was extremely friendly.",
    text_el: "Όλα είναι υπέροχα! Εξαιρετικό φαγητό, καλές μερίδες, πολύ λογική τιμή, υπέροχοι ιδιοκτήτες — δεν μπορώ να το συστήσω αρκετά! Καπέλο κάτω για την κυρία που διευθύνει το εστιατόριο, ήταν εξαιρετικά φιλική.",
  },
];

// Note Google reelle de l'etablissement (verifiee 2026-05-19, source Google Maps panel)
const avg = "4.3";
---

<section id="avis" class="bg-[#0a0a0a] py-20 px-4 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-[10px] font-['Space_Grotesk'] uppercase tracking-[0.35em] text-[#E5B32A] font-bold mb-3">
        {isEl ? "Τι λένε οι πελάτες μας" : "What our customers say"}
      </p>
      <div class="flex flex-col items-center gap-2 mb-2">
        <div class="flex items-center gap-3">
          <span class="text-5xl font-serif italic gold-shine-text">{avg}</span>
          <div class="flex flex-col items-start">
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-[#E5B32A] fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="text-[10px] text-white/75 uppercase tracking-widest font-bold mt-0.5">
              {isEl ? `Αυθεντικές αξιολογήσεις Google` : `Authentic Google reviews`}
            </span>
          </div>
        </div>
      </div>
      <h2 class="text-3xl md:text-4xl font-serif italic text-white mt-4">
        {isEl ? "Η εμπιστοσύνη μας είναι κερδισμένη." : "Trust earned, one plate at a time."}
      </h2>
    </div>

    <!-- Reviews grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {reviews.map((r) => (
        <article class="review-card bg-gradient-to-br from-white/5 to-white/[0.02] border border-[#E5B32A]/15 rounded-2xl p-5 md:p-6 hover:border-[#E5B32A]/40 transition-all duration-300 relative overflow-hidden">
          {/* Google badge */}
          <div class="absolute top-4 right-4 opacity-50">
            <svg viewBox="0 0 24 24" class="w-4 h-4">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285f4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34a853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#fbbc05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#ea4335"/>
            </svg>
          </div>
          <div class="flex gap-0.5 mb-3">
            {Array.from({length: r.rating}).map(() => (
              <svg class="w-3.5 h-3.5 text-[#E5B32A] fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-gray-300 leading-relaxed italic mb-4 font-['Space_Grotesk']">
            "{isEl ? r.text_el : r.text}"
          </p>
          <div class="flex items-center justify-between pt-3 border-t border-white/5">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-gradient-to-br from-[#E5B32A]/30 to-[#E5B32A]/10 border border-[#E5B32A]/30 flex items-center justify-center text-[10px] font-bold text-[#E5B32A]">
                {r.name.charAt(0)}
              </div>
              <span class="text-xs font-bold text-white/85 font-['Space_Grotesk']">{r.name}</span>
            </div>
            <span class="text-[10px] text-white/35 uppercase tracking-widest">{r.date}</span>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA Google -->
    <div class="text-center mt-10">
      <a
        href="https://www.google.com/maps/place/%CE%A4%CE%BF+%CE%9A%CE%B1%CE%BB%CE%B1%CE%BC%CE%AC%CE%BA%CE%B9+%CE%A4%CE%B7%CF%82+%CE%A4%CF%81%CE%BF%CF%8D%CE%BC%CF%80%CE%B1%CF%82/@37.9419284,23.6439786,17z"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 border border-white/20 text-white text-xs font-bold uppercase tracking-widest rounded-full hover:bg-white/5 hover:border-[#E5B32A]/50 transition-all duration-300"
      >
        <svg viewBox="0 0 24 24" class="w-4 h-4">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285f4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34a853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#fbbc05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#ea4335"/>
        </svg>
        {isEl ? "Δείτε όλες τις αξιολογήσεις" : "See all reviews on Google"}
      </a>
    </div>
  </div>
</section>
