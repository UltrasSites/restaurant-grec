---
// Sidebar + topbar mobile drawer pour toutes les pages /cashd/*.
// Non-intrusif : injecte un overlay fixed + applique padding-left au body via CSS global.
// Le drawer mobile utilise un checkbox hack pour zero-JS.
// Lien actif : determine via Astro.url.pathname.
// Desktop : sidebar collapsible (220px <-> 60px), persistant via localStorage.
// i18n : EL par défaut (restaurant grec), EN dispo via toggle (clé localStorage 'caisse_lang').
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/cashd";
function isActive(href: string) {
  const target = href.replace(/\/$/, "") || "/cashd";
  if (target === "/cashd") return currentPath === "/cashd" || currentPath === "";
  return currentPath === target || currentPath.startsWith(target + "/");
}
// Default labels = Greek (the patron is Greek). EN applied via JS toggle.
const items = [
  { href: "/cashd",          key: "dashboard", el: "Πίνακας",         en: "Dashboard",        icon: "📡", desc_el: "Ζωντανές παραγγελίες & έλεγχος", desc_en: "Live orders & control" },
  { href: "/cashd/pos",      key: "neworder",  el: "Νέα παραγγελία",  en: "New order",        icon: "🆕", desc_el: "Καταχώρηση πώλησης στο κατάστημα", desc_en: "Enter in-store sale" },
  { href: "/cashd/messages", key: "messages",  el: "Μηνύματα",        en: "Messages",         icon: "💬", desc_el: "Συνομιλίες πελατών", desc_en: "Customer chats" },
  { href: "/cashd/history",  key: "history",   el: "Ιστορικό",        en: "History",          icon: "📋", desc_el: "Παραγγελίες 60 ημερών", desc_en: "60-day orders" },
  { href: "/cashd/admin",    key: "admin",     el: "Ρυθμίσεις",       en: "Settings",         icon: "⚙️", desc_el: "Ωράρια & ρυθμίσεις", desc_en: "Hours & settings" },
];
---
<style is:global>
  /* ====== Layout shell global (sidebar desktop + drawer mobile) ====== */
  body { padding-left: 0 !important; }
  @media (min-width: 769px) {
    body { padding-left: 220px !important; transition: padding-left 0.22s ease; }
    body.cashd-sidebar-collapsed { padding-left: 60px !important; }
  }

  .cashd-nav-burger-input { display: none; }

  /* Sidebar desktop / drawer mobile */
  .cashd-sidebar {
    position: fixed; top: 0; left: 0; bottom: 0;
    width: 220px;
    background: #050505;
    border-right: 1px solid rgba(229,179,42,0.25);
    z-index: 90;
    display: flex; flex-direction: column;
    overflow-y: auto; overflow-x: hidden;
    transition: transform 0.22s ease, width 0.22s ease;
  }
  @media (min-width: 769px) {
    .cashd-sidebar.collapsed { width: 60px; }
  }
  .cashd-sidebar .cs-logo {
    padding: 1rem 1rem 0.85rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center; gap: 0.55rem;
    color: #E5B32A;
    font-weight: 800; letter-spacing: 0.06em; font-size: 0.78rem;
    text-transform: uppercase;
    min-height: 56px;
  }
  .cashd-sidebar .cs-logo .cs-logo-icon {
    width: 28px; height: 28px; border-radius: 50%;
    background: rgba(229,179,42,0.15); color: #E5B32A;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.85rem; flex-shrink: 0;
  }
  .cashd-sidebar .cs-logo .cs-logo-text { line-height: 1.15; white-space: nowrap; }
  .cashd-sidebar .cs-logo .cs-logo-text small { display: block; font-size: 0.6rem; color: #888; letter-spacing: 0.08em; }
  .cashd-sidebar.collapsed .cs-logo { padding: 1rem 0.5rem 0.85rem; justify-content: center; }
  .cashd-sidebar.collapsed .cs-logo-text { display: none; }

  /* Toggle collapse button (desktop only) */
  .cs-collapse-btn {
    display: none;
    margin: 0.4rem 0.6rem 0.2rem;
    padding: 0.45rem 0.55rem;
    background: rgba(229,179,42,0.08); color: #E5B32A;
    border: 1px solid rgba(229,179,42,0.2);
    border-radius: 0.45rem; cursor: pointer;
    font-size: 0.85rem; font-weight: 700;
    align-items: center; justify-content: center; gap: 0.35rem;
    transition: background 0.18s;
  }
  .cs-collapse-btn:hover { background: rgba(229,179,42,0.18); color: #fff; }
  .cs-collapse-btn .cs-collapse-icon {
    display: inline-block;
    transition: transform 0.22s ease;
    font-size: 0.95rem;
  }
  .cashd-sidebar.collapsed .cs-collapse-icon { transform: rotate(180deg); }
  .cashd-sidebar.collapsed .cs-collapse-label { display: none; }
  @media (min-width: 769px) {
    .cs-collapse-btn { display: inline-flex; }
  }

  .cashd-sidebar nav { flex: 1; padding: 0.55rem 0.5rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .cashd-sidebar nav a {
    display: flex; align-items: center; gap: 0.65rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.55rem;
    color: #bbb; text-decoration: none;
    font-weight: 600; font-size: 0.92rem;
    letter-spacing: 0.02em;
    min-height: 48px;
    border: 1px solid transparent;
    white-space: nowrap; overflow: hidden;
    position: relative;
  }
  .cashd-sidebar nav a .cs-ic { font-size: 1.1rem; width: 1.4rem; text-align: center; flex-shrink: 0; }
  .cashd-sidebar nav a:hover { background: rgba(255,255,255,0.04); color: #fff; }
  .cashd-sidebar nav a.active {
    background: rgba(229,179,42,0.12);
    color: #E5B32A;
    border-color: rgba(229,179,42,0.35);
  }
  .cashd-sidebar.collapsed nav { padding: 0.55rem 0.35rem; }
  .cashd-sidebar.collapsed nav a { padding: 0.7rem 0.4rem; justify-content: center; }
  .cashd-sidebar.collapsed nav a .cs-label { display: none; }
  /* Tooltip on hover when collapsed */
  .cashd-sidebar.collapsed nav a:hover::after {
    content: attr(data-label);
    position: absolute;
    left: 100%; top: 50%; transform: translateY(-50%);
    margin-left: 0.5rem;
    padding: 0.4rem 0.7rem;
    background: #1a1a1a; color: #E5B32A;
    border: 1px solid rgba(229,179,42,0.35);
    border-radius: 0.4rem; font-size: 0.8rem; font-weight: 700;
    white-space: nowrap;
    z-index: 200; pointer-events: none;
    box-shadow: 0 6px 16px rgba(0,0,0,0.5);
  }

  .cashd-sidebar .cs-bottom {
    padding: 0.55rem 0.5rem 0.85rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .cashd-sidebar .cs-bottom button {
    width: 100%; padding: 0.7rem 0.85rem;
    background: transparent; color: #f87171;
    border: 1px solid rgba(239,68,68,0.4);
    border-radius: 0.55rem;
    font-weight: 700; font-size: 0.85rem; cursor: pointer;
    letter-spacing: 0.05em;
    min-height: 44px;
    white-space: nowrap; overflow: hidden;
  }
  .cashd-sidebar .cs-bottom button:hover { background: rgba(239,68,68,0.1); color: #fca5a5; }
  .cashd-sidebar.collapsed .cs-bottom button { padding: 0.7rem 0.35rem; font-size: 1rem; }
  .cashd-sidebar.collapsed .cs-bottom .cs-logout-label { display: none; }

  /* ====== Topbar mobile (burger) ====== */
  .cashd-mobile-topbar {
    display: none;
    position: fixed; top: 0; left: 0; right: 0;
    height: 52px;
    background: #050505;
    border-bottom: 1px solid rgba(229,179,42,0.25);
    z-index: 89;
    align-items: center; padding: 0 0.65rem;
    gap: 0.6rem;
  }
  .cashd-mobile-topbar .cs-burger-label {
    width: 48px; height: 48px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent; color: #E5B32A;
    border: 1px solid rgba(229,179,42,0.35);
    border-radius: 0.5rem;
    cursor: pointer; font-size: 1.4rem;
    line-height: 1;
  }
  .cashd-mobile-topbar .cs-mobile-title {
    color: #E5B32A; font-weight: 800; font-size: 0.85rem;
    letter-spacing: 0.08em; text-transform: uppercase;
  }

  .cashd-drawer-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 88;
  }

  @media (max-width: 768px) {
    body { padding-top: 52px !important; padding-left: 0 !important; }
    body.cashd-sidebar-collapsed { padding-left: 0 !important; }
    .cashd-mobile-topbar { display: flex; }
    .cashd-sidebar {
      transform: translateX(-100%);
      width: 250px !important;
      box-shadow: 0 0 40px rgba(0,0,0,0.7);
    }
    .cashd-sidebar.collapsed { width: 250px !important; }
    .cashd-sidebar.collapsed nav a { padding: 0.7rem 0.85rem; justify-content: flex-start; }
    .cashd-sidebar.collapsed nav a .cs-label { display: inline; }
    .cashd-sidebar.collapsed .cs-logo-text { display: block; }
    .cashd-sidebar.collapsed .cs-bottom .cs-logout-label { display: inline; }
    .cs-collapse-btn { display: none !important; }
    .cashd-nav-burger-input:checked ~ .cashd-sidebar { transform: translateX(0); }
    .cashd-nav-burger-input:checked ~ .cashd-drawer-backdrop { display: block; }
  }

  /* Ne JAMAIS apparaitre en mode print */
  @media print {
    body { padding: 0 !important; }
    .cashd-sidebar, .cashd-mobile-topbar, .cashd-drawer-backdrop, .cashd-nav-burger-input { display: none !important; }
  }
</style>

<input type="checkbox" id="cashd-burger" class="cashd-nav-burger-input" aria-hidden="true" />

<header class="cashd-mobile-topbar">
  <label for="cashd-burger" class="cs-burger-label" aria-label="Menu">☰</label>
  <span class="cs-mobile-title">Kalamaki</span>
</header>

<label for="cashd-burger" class="cashd-drawer-backdrop" aria-hidden="true"></label>

<aside class="cashd-sidebar" aria-label="Navigation">
  <div class="cs-logo">
    <span class="cs-logo-icon">🥙</span>
    <span class="cs-logo-text">Kalamaki<small>Trouba</small></span>
  </div>
  <button type="button" id="cashd-sidebar-toggle" class="cs-collapse-btn" aria-label="Toggle sidebar">
    <span class="cs-collapse-icon">‹</span>
    <span class="cs-collapse-label" data-i18n="collapse">Σύμπτυξη</span>
  </button>
  <nav>
    {items.map((it) => (
      <a href={it.href} class={isActive(it.href) ? "active" : ""}
         data-label={it.el} data-key={it.key}
         data-el={it.el} data-en={it.en}
         data-desc-el={it.desc_el} data-desc-en={it.desc_en}
         title={`${it.el} — ${it.desc_el}`}>
        <span class="cs-ic">{it.icon}</span>
        <span class="cs-label">{it.el}</span>
      </a>
    ))}
  </nav>
  <div class="cs-bottom">
    <button type="button" id="cashd-logout-btn">
      <span class="cs-logout-label" data-i18n="logout">Αποσύνδεση</span>
      <span class="cs-logout-icon" aria-hidden="true" style="display:none;">⎋</span>
    </button>
  </div>
</aside>

<script is:inline>
  (function() {
    // ===== i18n CashdNav (EL default, EN via toggle 'caisse_lang') =====
    var NAV_I18N = {
      el: { collapse: 'Σύμπτυξη', logout: 'Αποσύνδεση', confirmLogout: 'Αποσύνδεση;' },
      en: { collapse: 'Collapse', logout: 'Sign out',    confirmLogout: 'Sign out?' },
    };
    function getNavLang() {
      try { return 'el'; /* dashboard grec uniquement */ }
      catch (e) { return 'el'; }
    }
    function applyNavI18n() {
      var lang = getNavLang();
      var t = NAV_I18N[lang] || NAV_I18N.el;
      document.querySelectorAll('.cashd-sidebar [data-i18n]').forEach(function(el) {
        var k = el.getAttribute('data-i18n');
        if (t[k]) el.textContent = t[k];
      });
      document.querySelectorAll('.cashd-sidebar nav a[data-key]').forEach(function(a) {
        var label = a.getAttribute('data-' + lang) || a.getAttribute('data-el');
        var desc = a.getAttribute('data-desc-' + lang) || a.getAttribute('data-desc-el') || '';
        if (label) {
          var span = a.querySelector('.cs-label');
          if (span) span.textContent = label;
          a.setAttribute('data-label', label);
          a.setAttribute('title', desc ? (label + ' — ' + desc) : label);
        }
      });
    }
    applyNavI18n();
    // Re-apply if another page changes caisse_lang while this sidebar is mounted
    window.addEventListener('storage', function(e) {
      if (e.key === 'caisse_lang') applyNavI18n();
    });
    // Expose so other scripts can trigger after toggling
    window.applyCashdNavI18n = applyNavI18n;

    // Auto-close drawer mobile on nav click
    var burger = document.getElementById('cashd-burger');
    document.querySelectorAll('.cashd-sidebar nav a').forEach(function(a) {
      a.addEventListener('click', function() {
        if (burger) burger.checked = false;
      });
    });
    // Backdrop click handled via label, but also escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && burger && burger.checked) burger.checked = false;
    });
    // Logout : clear cookie via endpoint si dispo, sinon fetch + reload
    var logoutBtn = document.getElementById('cashd-logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', function() {
        var t = NAV_I18N[getNavLang()] || NAV_I18N.el;
        if (!confirm(t.confirmLogout)) return;
        // Best-effort : suppression cookie client-side
        document.cookie = 'caisse_auth=; Path=/; Max-Age=0; SameSite=Lax';
        document.cookie = 'caisse_auth=; Path=/; Max-Age=0; SameSite=Lax; Secure';
        // Clear la session unifiée + legacy (sinon ré-auth auto la ramène)
        try { if (window.cashdAuth) window.cashdAuth.clearSession(); } catch (e) {}
        try { localStorage.removeItem('cashd_token_b64'); } catch (e) {}
        try { localStorage.removeItem('cashd_session'); } catch (e) {}
        window.location.href = '/cashd';
      });
    }

    // ====== Sidebar collapse (desktop only) ======
    var collapseBtn = document.getElementById('cashd-sidebar-toggle');
    var sidebar = document.querySelector('.cashd-sidebar');
    function applyCollapsed(c) {
      document.body.classList.toggle('cashd-sidebar-collapsed', !!c);
      if (sidebar) sidebar.classList.toggle('collapsed', !!c);
      try { localStorage.setItem('cashd_sidebar_collapsed', c ? '1' : '0'); } catch (e) {}
    }
    // Sidebar collapsed BY DEFAULT on desktop (Tiago request 22/05 video v2)
    // User can still open it manually via the burger/toggle button.
    try {
      var stored = localStorage.getItem('cashd_sidebar_collapsed');
      // If never set (first visit) OR explicitly collapsed → collapse on desktop
      if (window.matchMedia && window.matchMedia('(min-width: 769px)').matches) {
        if (stored !== '0') {
          applyCollapsed(true);
        }
      }
    } catch (e) {
      // On error, default to collapsed
      try { applyCollapsed(true); } catch (e2) {}
    }
    if (collapseBtn && sidebar) {
      collapseBtn.addEventListener('click', function() {
        applyCollapsed(!sidebar.classList.contains('collapsed'));
      });
    }
  })();
</script>
