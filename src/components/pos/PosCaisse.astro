---
// ════════════════════════════════════════════════════════════════════════════
// PosCaisse — Drop-in POS component for any Astro project.
//
// USAGE :
//   import PosCaisse from "../components/pos/PosCaisse.astro";
//   import { kalamakiPosConfig, getKalamakiProducts } from "../data/pos-config";
//   const products = getKalamakiProducts();
//   <PosCaisse products={products} config={kalamakiPosConfig} />
//
// All logic in the inline script — fully client-side (no server, no DB).
// Sales saved to localStorage per shop (config.storageKey).
// ════════════════════════════════════════════════════════════════════════════
import type { PosProduct, PosConfig } from "../../data/pos-config";

export interface Props {
  products: PosProduct[];
  config: PosConfig;
}

const { products, config } = Astro.props;

// Pre-compute categories preserving first-occurrence order + EL→EN map
const categories: string[] = [];
const categoriesAlt: Record<string, string> = {};
for (const p of products) {
  if (!categories.includes(p.category)) categories.push(p.category);
  if (p.category_alt && !categoriesAlt[p.category]) categoriesAlt[p.category] = p.category_alt;
}

// Serialise data for client (avoids re-fetch)
const dataPayload = JSON.stringify({ products, config, categories, categoriesAlt });
---

<div class="pos-root" data-pos-payload={dataPayload}>

  <!-- OPENING MODAL : bypassed — POS now boots directly with openingFloat=0, no server name -->
  <div class="pos-modal-back" id="pos-open-modal" role="dialog" aria-modal="true" style="display:none !important;">
    <div class="pos-modal">
      <input type="hidden" id="pos-open-server" value="" />
      <input type="hidden" id="pos-open-float" value="0" />
      <button type="button" id="pos-open-confirm" style="display:none;">✓</button>
    </div>
  </div>

  <!-- MAIN LAYOUT : LEFT = products | RIGHT = cart -->
  <div class="pos-layout" id="pos-layout" style="display:none;">

    <!-- LEFT : product grid -->
    <section class="pos-left">
      <div class="pos-search-row">
        <input type="search" id="pos-search" placeholder="🔍 Αναζήτηση…" autocomplete="off" />
        <button type="button" class="pos-icon-btn" id="pos-stats-btn" title="Στατιστικά">📊</button>
        <button type="button" class="pos-icon-btn" id="pos-archive-btn" title="Αρχείο">📅</button>
        <button type="button" class="pos-icon-btn" id="pos-close-btn" title="Κλείσιμο ταμείου">🔒</button>
      </div>
      <div class="pos-cats" id="pos-cats"></div>
      <div class="pos-grid" id="pos-grid"></div>
    </section>

    <!-- RIGHT : cart + totals + pay -->
    <aside class="pos-right">
      <div class="pos-cart-head">
        <div class="pos-shop-name" id="pos-shop-name"></div>
        <div class="pos-clock" id="pos-clock">--:--</div>
      </div>
      <div class="pos-cart-meta">
        <span id="pos-server-display"></span>
        <button type="button" id="pos-clear-cart" class="pos-text-btn">🗑 Άδειο</button>
      </div>

      <div class="pos-cart" id="pos-cart">
        <div class="pos-cart-empty">Πατήστε προϊόν για προσθήκη</div>
      </div>

      <div class="pos-totals" id="pos-totals">
        <div class="pos-totals-row"><span id="pos-sub-ht-label">Υποσύνολο (χωρίς ΦΠΑ)</span><span id="pos-sub-ht">0,00</span></div>
        <div class="pos-totals-row"><span id="pos-vat-label">ΦΠΑ</span><span id="pos-sub-vat">0,00</span></div>
        <div class="pos-totals-row pos-grand"><span id="pos-grand-label">ΣΥΝΟΛΟ</span><span id="pos-grand-total">0,00</span></div>
      </div>

      <button type="button" id="pos-pay-btn" class="pos-pay-cta" disabled>💰 Πληρωμή</button>
    </aside>
  </div>

  <!-- PAYMENT MODAL -->
  <div class="pos-modal-back" id="pos-pay-modal" role="dialog" aria-modal="true">
    <div class="pos-modal pos-modal-wide">
      <button type="button" class="pos-modal-close" data-close-modal="pos-pay-modal" aria-label="Κλείσιμο">×</button>
      <h2 id="pos-pay-title">💰 Πληρωμή</h2>
      <div class="pos-pay-total">
        <span id="pos-pay-total-label">Σύνολο</span>
        <strong id="pos-pay-amount">0,00</strong>
      </div>

      <div class="pos-pay-modes" id="pos-pay-modes"></div>

      <div class="pos-pay-split" id="pos-pay-split">
        <!-- payment lines added dynamically -->
      </div>

      <div class="pos-pay-summary">
        <div class="pos-pay-row"><span id="pos-pay-paid-label">Πληρωμένα</span><span id="pos-pay-paid">0,00</span></div>
        <div class="pos-pay-row"><span id="pos-pay-remaining-label">Υπόλοιπο</span><span id="pos-pay-remaining">0,00</span></div>
      </div>

      <div class="pos-pay-cash-block" id="pos-pay-cash-block" style="display:none;">
        <label class="pos-field">
          <span id="pos-pay-given-label">Δόθηκαν μετρητά</span>
          <input type="number" id="pos-pay-given" step="0.01" min="0" />
        </label>
        <div class="pos-pay-change"><span id="pos-pay-change-label">Ρέστα</span> : <strong id="pos-pay-change">0,00</strong></div>
        <div class="pos-quick-cash" id="pos-quick-cash"></div>
      </div>

      <div class="pos-time-block" id="pos-time-block" style="display:none;">
        <div class="pos-time-head">
          <span id="pos-time-head-label">⏱️ Χρόνος</span>
          <button type="button" id="pos-time-auto" class="pos-btn-mini">↻ Auto</button>
        </div>
        <div class="pos-time-row">
          <span class="pos-time-label" id="pos-time-prep-label">Ετοιμασία</span>
          <div class="pos-time-ctrl">
            <button type="button" data-prep="-5">−5</button>
            <button type="button" data-prep="-1">−1</button>
            <input type="number" id="pos-time-prep" min="0" max="120" step="1" />
            <span class="pos-time-unit">min</span>
            <button type="button" data-prep="1">+1</button>
            <button type="button" data-prep="5">+5</button>
          </div>
        </div>
        <div class="pos-time-row" id="pos-time-delivery-row" style="display:none;">
          <span class="pos-time-label" id="pos-time-deliv-label">Διανομή</span>
          <div class="pos-time-ctrl">
            <button type="button" data-deliv="-5">−5</button>
            <button type="button" data-deliv="-1">−1</button>
            <input type="number" id="pos-time-delivery" min="0" max="120" step="1" />
            <span class="pos-time-unit">min</span>
            <button type="button" data-deliv="1">+1</button>
            <button type="button" data-deliv="5">+5</button>
          </div>
        </div>
        <div class="pos-time-eta" id="pos-time-eta"></div>
      </div>

      <div class="pos-modal-actions">
        <button type="button" id="pos-pay-cancel" class="pos-btn-cancel">Άκυρο</button>
        <button type="button" id="pos-pay-confirm" class="pos-btn-primary" disabled>✓ Ολοκλήρωση & Εκτύπωση</button>
      </div>
    </div>
  </div>

  <!-- CLOSE TILL MODAL -->
  <div class="pos-modal-back" id="pos-close-modal" role="dialog" aria-modal="true">
    <div class="pos-modal">
      <button type="button" class="pos-modal-close" data-close-modal="pos-close-modal" aria-label="Κλείσιμο">×</button>
      <h2 id="pos-close-title">🔒 Κλείσιμο ταμείου</h2>
      <div id="pos-close-summary"></div>
      <label class="pos-field">
        <span id="pos-close-counted-label">Μετρητά στο κουτί τώρα</span>
        <input type="number" id="pos-close-counted" step="0.01" min="0" />
      </label>
      <div class="pos-close-gap" id="pos-close-gap"></div>
      <div class="pos-modal-actions">
        <button type="button" id="pos-close-cancel" class="pos-btn-cancel">Άκυρο</button>
        <button type="button" id="pos-close-csv" class="pos-btn-secondary">📥 CSV</button>
        <button type="button" id="pos-close-confirm" class="pos-btn-primary">✓ Κλείσιμο</button>
      </div>
    </div>
  </div>

  <!-- STATS MODAL -->
  <div class="pos-modal-back" id="pos-stats-modal" role="dialog" aria-modal="true">
    <div class="pos-modal pos-modal-wide">
      <button type="button" class="pos-modal-close" data-close-modal="pos-stats-modal" aria-label="Κλείσιμο">×</button>
      <h2 id="pos-stats-title">📊 Στατιστικά συνεδρίας</h2>
      <div id="pos-stats-body"></div>
      <div class="pos-modal-actions">
        <button type="button" id="pos-stats-close" class="pos-btn-cancel">Κλείσιμο</button>
      </div>
    </div>
  </div>

  <!-- ARCHIVE MODAL -->
  <div class="pos-modal-back" id="pos-archive-modal" role="dialog" aria-modal="true">
    <div class="pos-modal pos-modal-wide">
      <button type="button" class="pos-modal-close" data-close-modal="pos-archive-modal" aria-label="Κλείσιμο">×</button>
      <h2 id="pos-archive-title">📅 Αρχείο κλεισιμάτων</h2>
      <div id="pos-archive-body"></div>
      <div class="pos-modal-actions">
        <button type="button" id="pos-archive-close" class="pos-btn-cancel">Κλείσιμο</button>
      </div>
    </div>
  </div>

  <!-- HIDDEN TICKET (printed via window.print on a clone) -->
  <div id="pos-ticket-host" style="display:none;"></div>
</div>

<style is:global>
  .pos-root {
    --gold: #E5B32A;
    --bg: #0a0a0a;
    --bg-card: #111;
    --bg-soft: #1a1a1a;
    --border: rgba(255,255,255,0.08);
    --txt: #fff;
    --txt-dim: #aaa;
    color: var(--txt);
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  }

  /* ───── Modals ───── */
  .pos-modal-back {
    position: fixed; inset: 0; background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    padding: 1rem; z-index: 200;
  }
  .pos-modal-back.show { display: flex; }
  .pos-modal-back#pos-open-modal { display: none !important; }
  .pos-modal {
    position: relative;
    width: 100%; max-width: 460px;
    background: var(--bg-card);
    border: 1px solid rgba(229,179,42,0.4);
    border-radius: 1rem; padding: 1.5rem;
    box-shadow: 0 30px 80px rgba(0,0,0,0.7);
    max-height: 92vh; overflow-y: auto;
  }
  .pos-modal-close {
    position: absolute; top: 10px; right: 14px;
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.85); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem; line-height: 1;
    transition: background 0.15s, color 0.15s;
    z-index: 5;
  }
  .pos-modal-close:hover { background: rgba(255,255,255,0.2); color: #fff; }
  .pos-modal-wide { max-width: 640px; }
  .pos-modal h2 { margin: 0 0 0.5rem; color: var(--gold); font-size: 1.15rem; letter-spacing: 0.05em; }
  .pos-sub { color: var(--txt-dim); font-size: 0.85rem; margin-bottom: 1rem; }

  .pos-field { display: block; margin-bottom: 1rem; }
  .pos-field span { display: block; font-size: 0.78rem; color: var(--txt-dim); margin-bottom: 0.3rem; letter-spacing: 0.04em; text-transform: uppercase; }
  .pos-field input {
    width: 100%; padding: 0.8rem 1rem;
    background: #000; color: var(--txt);
    border: 1.5px solid var(--border);
    border-radius: 0.5rem; font-size: 1rem;
  }
  .pos-field input:focus { outline: none; border-color: var(--gold); }

  .pos-modal-actions {
    display: flex; gap: 0.5rem; justify-content: flex-end; flex-wrap: wrap;
    margin-top: 0.75rem;
  }
  .pos-btn-primary {
    padding: 0.85rem 1.4rem; background: var(--gold); color: #000;
    border: none; border-radius: 0.5rem;
    font-weight: 900; cursor: pointer; letter-spacing: 0.05em;
    font-size: 0.95rem; text-transform: uppercase;
  }
  .pos-btn-primary:hover:not(:disabled) { background: #fff; }
  .pos-btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
  .pos-btn-cancel {
    padding: 0.85rem 1.2rem; background: transparent; color: var(--txt-dim);
    border: 1px solid var(--border); border-radius: 0.5rem; cursor: pointer;
  }
  .pos-btn-cancel:hover { color: var(--txt); }
  .pos-btn-secondary {
    padding: 0.85rem 1.2rem; background: var(--bg-soft); color: var(--gold);
    border: 1px solid rgba(229,179,42,0.4); border-radius: 0.5rem; cursor: pointer; font-weight: 700;
  }
  .pos-btn-secondary:hover { background: rgba(229,179,42,0.12); }

  /* ───── Main layout : grid + cart ───── */
  .pos-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 1rem;
    height: calc(100vh - 1rem);
    max-height: calc(100vh - 1rem);
    padding: 0.5rem;
    max-width: 100vw;
    min-width: 0;
    overflow-x: hidden;
  }
  @media (max-width: 900px) {
    .pos-layout { grid-template-columns: 1fr; height: auto; max-height: none; padding: 0.5rem 0.4rem; gap: 0.75rem; }
    .pos-search-row { flex-wrap: wrap; }
    .pos-search-row input { min-width: 0; flex: 1 1 100%; }
    .pos-cats { width: 100%; max-width: 100%; }
    .pos-right { padding: 0.65rem; }
    .pos-modal { max-width: calc(100vw - 1rem); }
    .pos-modal-wide { max-width: calc(100vw - 1rem); }
  }
  @media (max-width: 480px) {
    .pos-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)) !important; }
  }

  /* LEFT */
  .pos-left { display: flex; flex-direction: column; min-height: 0; min-width: 0; gap: 0.6rem; max-width: 100%; }
  .pos-search-row {
    display: flex; gap: 0.5rem; align-items: center;
    min-width: 0; max-width: 100%;
  }
  .pos-search-row input {
    flex: 1; padding: 0.75rem 1rem;
    background: #000; color: var(--txt);
    border: 1px solid var(--border);
    border-radius: 0.55rem; font-size: 0.95rem;
  }
  .pos-search-row input:focus { outline: none; border-color: var(--gold); }
  .pos-icon-btn {
    width: 46px; height: 46px;
    background: var(--bg-soft); color: var(--txt);
    border: 1px solid var(--border);
    border-radius: 0.55rem; cursor: pointer;
    font-size: 1.15rem;
  }
  .pos-icon-btn:hover { background: rgba(229,179,42,0.12); color: var(--gold); border-color: rgba(229,179,42,0.4); }

  .pos-cats {
    display: flex; gap: 0.4rem; overflow-x: auto;
    padding-bottom: 0.4rem;
    min-width: 0; max-width: 100%;
    -webkit-overflow-scrolling: touch;
  }
  .pos-cats::-webkit-scrollbar { height: 6px; }
  .pos-cats::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 3px; }
  .pos-cat-btn {
    padding: 0.6rem 0.95rem;
    background: var(--bg-soft); color: var(--txt-dim);
    border: 1px solid var(--border);
    border-radius: 999px; cursor: pointer;
    white-space: nowrap;
    font-size: 0.82rem; font-weight: 600;
  }
  .pos-cat-btn.active {
    background: var(--gold); color: #000; border-color: var(--gold);
    font-weight: 800;
  }

  .pos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.6rem;
    overflow-y: auto;
    padding: 0.25rem 0.1rem 1rem;
    flex: 1;
    min-height: 0; min-width: 0; max-width: 100%;
  }
  .pos-grid::-webkit-scrollbar { width: 8px; }
  .pos-grid::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

  .pos-prod {
    background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    padding: 0.75rem 0.7rem;
    cursor: pointer;
    text-align: left;
    color: var(--txt);
    transition: transform 0.1s, border-color 0.15s;
    display: flex; flex-direction: column; gap: 0.3rem;
    min-height: 88px;
  }
  .pos-prod:hover { border-color: var(--gold); transform: translateY(-2px); }
  .pos-prod:active { transform: scale(0.97); }
  .pos-prod .p-name {
    font-size: 0.85rem; font-weight: 700; line-height: 1.25;
    color: var(--txt);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pos-prod .p-alt {
    font-size: 0.7rem; color: var(--txt-dim);
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pos-prod .p-price {
    margin-top: auto;
    font-size: 1rem; font-weight: 900; color: var(--gold);
    font-variant-numeric: tabular-nums;
  }

  /* Variante avec image — boutons visuels (chaque produit = image unique cf. module commande) */
  .pos-prod-img {
    align-items: stretch;
    text-align: center;
    padding: 0.5rem 0.4rem;
    gap: 0.25rem;
    min-height: 150px;
  }
  .pos-prod-img .p-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 0.55rem;
    background: #0a0a0a;
    display: block;
  }
  .pos-prod-img .p-name {
    font-size: 0.78rem;
    text-align: center;
    -webkit-line-clamp: 2;
  }
  .pos-prod-img .p-alt {
    text-align: center;
    -webkit-line-clamp: 1;
  }
  .pos-prod-img .p-price {
    text-align: center;
    font-size: 0.95rem;
  }

  /* RIGHT */
  .pos-right {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    padding: 0.85rem;
    display: flex; flex-direction: column;
    min-height: 0; min-width: 0; max-width: 100%;
  }
  .pos-cart-head {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
  }
  .pos-shop-name { font-weight: 800; color: var(--gold); font-size: 0.9rem; letter-spacing: 0.04em; }
  .pos-clock { font-variant-numeric: tabular-nums; color: var(--txt-dim); font-weight: 700; font-size: 0.85rem; }
  .pos-cart-meta {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.45rem 0; font-size: 0.78rem; color: var(--txt-dim);
  }
  .pos-text-btn {
    background: transparent; color: var(--txt-dim);
    border: none; cursor: pointer; font-size: 0.78rem;
    text-decoration: underline;
  }
  .pos-text-btn:hover { color: #ef4444; }

  .pos-cart {
    flex: 1; overflow-y: auto;
    background: rgba(0,0,0,0.25);
    border-radius: 0.55rem;
    padding: 0.4rem;
    min-height: 100px;
  }
  .pos-cart-empty {
    text-align: center; color: #555; padding: 2rem 1rem; font-style: italic;
  }
  .pos-line {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.3rem;
    padding: 0.5rem 0.55rem;
    border-bottom: 1px dashed var(--border);
  }
  .pos-line:last-child { border-bottom: none; }
  .pos-line .l-name { font-weight: 700; font-size: 0.88rem; line-height: 1.2; }
  .pos-line .l-price-unit { font-size: 0.72rem; color: var(--txt-dim); }
  .pos-line .l-tot { font-weight: 800; color: var(--gold); font-variant-numeric: tabular-nums; align-self: start; }
  .pos-line-ctrls {
    grid-column: 1 / -1;
    display: flex; gap: 0.4rem; align-items: center;
    margin-top: 0.35rem;
  }
  .pos-qty-btn {
    width: 30px; height: 30px;
    background: var(--bg-soft); color: var(--txt);
    border: 1px solid var(--border);
    border-radius: 0.4rem; cursor: pointer;
    font-size: 1rem; font-weight: 800;
  }
  .pos-qty-btn:hover { background: rgba(229,179,42,0.18); color: var(--gold); }
  .pos-qty-val { min-width: 28px; text-align: center; font-weight: 800; font-variant-numeric: tabular-nums; }
  .pos-line-del {
    margin-left: auto;
    background: transparent; color: #777; border: none; cursor: pointer; font-size: 1rem;
  }
  .pos-line-del:hover { color: #ef4444; }

  .pos-totals {
    border-top: 1px solid var(--border);
    padding-top: 0.6rem; margin-top: 0.4rem;
    font-size: 0.85rem;
  }
  .pos-totals-row {
    display: flex; justify-content: space-between;
    padding: 0.18rem 0;
    color: var(--txt-dim);
    font-variant-numeric: tabular-nums;
  }
  .pos-totals-row.pos-grand {
    border-top: 1px solid var(--border);
    margin-top: 0.4rem; padding-top: 0.55rem;
    color: var(--gold); font-size: 1.4rem; font-weight: 900;
  }

  .pos-pay-cta {
    margin-top: 0.65rem;
    padding: 1.1rem; background: linear-gradient(180deg, #22c55e 0%, #16a34a 100%);
    color: #fff; border: none; border-radius: 0.7rem;
    font-size: 1.15rem; font-weight: 900; letter-spacing: 0.06em;
    cursor: pointer; text-transform: uppercase;
    box-shadow: 0 8px 22px rgba(34,197,94,0.4);
  }
  .pos-pay-cta:hover:not(:disabled) { box-shadow: 0 12px 28px rgba(34,197,94,0.55); }
  .pos-pay-cta:disabled { opacity: 0.4; cursor: not-allowed; box-shadow: none; }

  /* ── Pay modal specifics ── */
  .pos-pay-total {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 0.7rem 1rem; background: rgba(229,179,42,0.1);
    border: 1px solid rgba(229,179,42,0.3);
    border-radius: 0.55rem; margin-bottom: 1rem;
  }
  .pos-pay-total strong { font-size: 1.6rem; color: var(--gold); font-variant-numeric: tabular-nums; }
  .pos-pay-modes {
