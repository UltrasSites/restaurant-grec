  // ════════════════════════════════════════════════════════════════════════
  function ensureSession() {
    if (!session || session.dateKey !== nowDateKey() || session.closedAt) {
      session = {
        dateKey: nowDateKey(),
        openedAt: Date.now(),
        openingFloat: 0,
        sales: [],
        server: undefined
      };
      saveSession(session);
    }
  }
  function showOpenModal() {
    // No modal — boot directly into the POS layout.
    ensureSession();
    $('pos-layout').style.display = 'grid';
    showLayout();
  }
  function hideOpenModal() { /* no-op */ }

  // ════════════════════════════════════════════════════════════════════════
  // MAIN LAYOUT
  // ════════════════════════════════════════════════════════════════════════
  function showLayout() {
    $('pos-layout').style.display = 'grid';
    $('pos-shop-name').textContent = config.shopName;
    $('pos-server-display').textContent = session && session.server ? ('👤 ' + session.server) : '';
    $('pos-vat-label').textContent = config.vatLabel;
    renderCats();
    renderGrid();
    renderCart();
    applyPosI18n();
  }

  function renderCats() {
    var html = '';
    var useAlt = (POS_LANG === 'en');
    for (var i = 0; i < categories.length; i++) {
      var c = categories[i];
      var label = (useAlt && categoriesAlt[c]) ? categoriesAlt[c] : c;
      html += '<button type="button" class="pos-cat-btn' + (c === activeCategory ? ' active' : '') + '" data-cat="' + esc(c) + '">' + esc(label) + '</button>';
    }
    var el = $('pos-cats');
    el.innerHTML = html;
    el.querySelectorAll('.pos-cat-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeCategory = btn.getAttribute('data-cat');
        searchQuery = '';
        $('pos-search').value = '';
        renderCats();
        renderGrid();
      });
    });
  }

  function renderGrid() {
    var q = (searchQuery || '').trim().toLowerCase();
    var list = products.filter(function(p) {
      if (q) {
        return (p.name && p.name.toLowerCase().indexOf(q) >= 0) ||
               (p.name_alt && p.name_alt.toLowerCase().indexOf(q) >= 0);
      }
      return p.category === activeCategory;
    });
    var useAlt = (POS_LANG === 'en');
    var html = '';
    for (var i = 0; i < list.length; i++) {
      var p = list[i];
      // EN mode : name_alt (EN) as primary, name (EL) as secondary
      var primary = (useAlt && p.name_alt) ? p.name_alt : p.name;
      var secondary = (useAlt && p.name_alt) ? p.name : p.name_alt;
      html += '<button type="button" class="pos-prod' + (p.photo ? ' pos-prod-img' : '') + '" data-pid="' + esc(p.id) + '">'
        + (p.photo ? '<img class="p-img" src="' + esc(p.photo) + '" alt="" decoding="async" loading="lazy" />' : '')
        + '<div class="p-name">' + esc(primary) + '</div>'
        + (secondary ? '<div class="p-alt">' + esc(secondary) + '</div>' : '')
        + '<div class="p-price">' + fmt(p.price) + '</div>'
        + '</button>';
    }
    if (html === '') html = '<div style="grid-column:1/-1; padding:2rem; text-align:center; color:#555;">' + esc(POS_T.noProducts) + '</div>';
    var el = $('pos-grid');
    el.innerHTML = html;
    el.querySelectorAll('.pos-prod').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var pid = btn.getAttribute('data-pid');
        var prod = products.find(function(x) { return x.id === pid; });
        if (prod) addToCart(prod);
      });
    });
  }

  $('pos-search').addEventListener('input', function() {
    searchQuery = $('pos-search').value;
    renderGrid();
  });

  function addToCart(prod) {
    var idx = -1;
    for (var i = 0; i < cart.length; i++) if (cart[i].productId === prod.id) { idx = i; break; }
    if (idx >= 0) cart[idx].qty++;
    else cart.push({
      productId: prod.id,
      name: prod.name,
      unitPrice: prod.price,
      qty: 1,
      vat: (prod.vat != null ? prod.vat : config.defaultVat)
    });
    renderCart();
  }
  function changeQty(pid, delta) {
    var idx = -1;
    for (var i = 0; i < cart.length; i++) if (cart[i].productId === pid) { idx = i; break; }
    if (idx < 0) return;
    cart[idx].qty += delta;
    if (cart[idx].qty <= 0) cart.splice(idx, 1);
    renderCart();
  }
  function removeLine(pid) {
    cart = cart.filter(function(l) { return l.productId !== pid; });
    renderCart();
  }

  function renderCart() {
    var el = $('pos-cart');
    if (cart.length === 0) {
      el.innerHTML = '<div class="pos-cart-empty">' + esc(POS_T.emptyCart) + '</div>';
    } else {
      var useAlt = (POS_LANG === 'en');
      var html = '';
      for (var i = 0; i < cart.length; i++) {
        var l = cart[i];
        // Look up product for name_alt (EN) — fallback to stored name (EL source-of-truth for ticket print)
        var prodLook = products.find(function(p) { return p.id === l.productId; });
        var displayName = (useAlt && prodLook && prodLook.name_alt) ? prodLook.name_alt : l.name;
        html += '<div class="pos-line" data-pid="' + esc(l.productId) + '">'
          + '<div><div class="l-name">' + esc(displayName) + '</div>'
          + '<div class="l-price-unit">' + fmt(l.unitPrice) + ' × ' + l.qty + '</div></div>'
          + '<div class="l-tot">' + fmt(lineTtc(l)) + '</div>'
          + '<div class="pos-line-ctrls">'
            + '<button type="button" class="pos-qty-btn" data-act="minus">−</button>'
            + '<span class="pos-qty-val">' + l.qty + '</span>'
            + '<button type="button" class="pos-qty-btn" data-act="plus">+</button>'
            + '<button type="button" class="pos-line-del" data-act="del" title="' + esc(POS_T.remove) + '">✕</button>'
          + '</div>'
        + '</div>';
      }
      el.innerHTML = html;
      el.querySelectorAll('.pos-line').forEach(function(line) {
        var pid = line.getAttribute('data-pid');
        line.querySelector('[data-act="minus"]').addEventListener('click', function() { changeQty(pid, -1); });
        line.querySelector('[data-act="plus"]').addEventListener('click', function() { changeQty(pid, 1); });
        line.querySelector('[data-act="del"]').addEventListener('click', function() { removeLine(pid); });
      });
    }
    var t = totals();
    $('pos-sub-ht').textContent = fmtNoCurr(t.ht);
    $('pos-sub-vat').textContent = fmtNoCurr(t.vat);
    $('pos-grand-total').textContent = fmt(t.ttc);
    $('pos-pay-btn').disabled = (cart.length === 0);
  }

  $('pos-clear-cart').addEventListener('click', function() {
    if (cart.length === 0) return;
    if (confirm(POS_T.emptyCartConfirm)) { cart = []; renderCart(); }
  });

  // ════════════════════════════════════════════════════════════════════════
  // PAYMENT FLOW
  // ════════════════════════════════════════════════════════════════════════
  function openPayModal() {
    var t = totals();
    payments = [];
    cashGiven = 0;
    $('pos-pay-amount').textContent = fmt(t.ttc);
    renderPayModes();
    renderPaySplit();
    renderPaySummary();
    renderQuickCash(t.ttc);
    initTimeBlock();
    $('pos-pay-modal').classList.add('show');
  }
  function closePayModal() {
    $('pos-pay-modal').classList.remove('show');
  }
  $('pos-pay-btn').addEventListener('click', openPayModal);
  $('pos-pay-cancel').addEventListener('click', closePayModal);

  // ────── Time block (prep + delivery estimate) ──────
  function initTimeBlock() {
    if (!TIME_ENABLED) {
      $('pos-time-block').style.display = 'none';
      prepMinutes = 0;
      deliveryMinutes = 0;
      timeOverridden = false;
      return;
    }
    var itemsCount = 0;
    for (var i = 0; i < cart.length; i++) itemsCount += cart[i].qty;
    prepMinutes = calcAutoPrep(itemsCount);
    deliveryMinutes = TIME_HAS_DELIVERY ? DELIVERY_DEFAULT : 0;
    timeOverridden = false;
    $('pos-time-block').style.display = 'block';
    $('pos-time-prep').value = String(prepMinutes);
    $('pos-time-delivery').value = String(deliveryMinutes);
    $('pos-time-delivery-row').style.display = TIME_HAS_DELIVERY ? 'flex' : 'none';
    renderTimeEta();
  }
  function renderTimeEta() {
    if (!TIME_ENABLED) { $('pos-time-eta').textContent = ''; return; }
    var ready = new Date(Date.now() + prepMinutes * 60000);
    var hh = pad(ready.getHours()) + ':' + pad(ready.getMinutes());
    var line = POS_T.readyBy + ' : ' + prepMinutes + ' min → ' + hh;
    if (TIME_HAS_DELIVERY && deliveryMinutes > 0) {
      var arrived = new Date(Date.now() + (prepMinutes + deliveryMinutes) * 60000);
      line += '  ·  ' + POS_T.deliveryAt + ' : +' + deliveryMinutes + ' min → '
        + pad(arrived.getHours()) + ':' + pad(arrived.getMinutes());
    }
    if (timeOverridden) line += '  (' + POS_T.manual + ')';
    $('pos-time-eta').textContent = line;
  }
  function setPrep(v) {
    var n = Math.max(0, Math.min(120, Math.round(Number(v) || 0)));
    prepMinutes = n;
    $('pos-time-prep').value = String(n);
    renderTimeEta();
  }
  function setDelivery(v) {
    var n = Math.max(0, Math.min(120, Math.round(Number(v) || 0)));
    deliveryMinutes = n;
    $('pos-time-delivery').value = String(n);
    renderTimeEta();
  }
  $('pos-time-prep').addEventListener('input', function(e) {
    timeOverridden = true;
    setPrep(e.target.value);
  });
  $('pos-time-delivery').addEventListener('input', function(e) {
    timeOverridden = true;
    setDelivery(e.target.value);
  });
  document.querySelectorAll('[data-prep]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      timeOverridden = true;
      setPrep(prepMinutes + parseInt(btn.getAttribute('data-prep'), 10));
    });
  });
  document.querySelectorAll('[data-deliv]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      timeOverridden = true;
      setDelivery(deliveryMinutes + parseInt(btn.getAttribute('data-deliv'), 10));
    });
  });
  $('pos-time-auto').addEventListener('click', function() {
    var itemsCount = 0;
    for (var i = 0; i < cart.length; i++) itemsCount += cart[i].qty;
    setPrep(calcAutoPrep(itemsCount));
    setDelivery(TIME_HAS_DELIVERY ? DELIVERY_DEFAULT : 0);
    timeOverridden = false;
    renderTimeEta();
  });

  function renderPayModes() {
    var useAlt = (POS_LANG === 'en');
    var html = '';
    for (var i = 0; i < config.paymentModes.length; i++) {
      var m = config.paymentModes[i];
      var lbl = (useAlt && m.label_alt) ? m.label_alt : m.label;
      html += '<button type="button" class="pos-pay-mode" data-mode="' + esc(m.id) + '">'
        + (m.icon ? m.icon + ' ' : '') + esc(lbl) + '</button>';
    }
    var el = $('pos-pay-modes');
    el.innerHTML = html;
    el.querySelectorAll('.pos-pay-mode').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var mid = btn.getAttribute('data-mode');
        addPaymentLine(mid);
      });
    });
  }

  function addPaymentLine(modeId) {
    var t = totals();
    var paidSoFar = payments.reduce(function(s, p) { return s + p.amount; }, 0);
    var remaining = round2(Math.max(0, t.ttc - paidSoFar));
    // If single-mode behaviour (no mixed), reset
    if (!config.allowMixedPayment) { payments = []; remaining = t.ttc; }
    payments.push({ mode: modeId, amount: remaining });
    renderPaySplit();
    renderPaySummary();
  }

  function renderPaySplit() {
    var el = $('pos-pay-split');
    if (payments.length === 0) { el.innerHTML = ''; return; }
    var useAlt = (POS_LANG === 'en');
    var html = '';
    for (var i = 0; i < payments.length; i++) {
      var p = payments[i];
      var mode = config.paymentModes.find(function(m) { return m.id === p.mode; });
      var mLbl = mode ? ((useAlt && mode.label_alt) ? mode.label_alt : mode.label) : p.mode;
      html += '<div class="pos-pay-split-line" data-i="' + i + '">'
        + '<span class="mode">' + (mode ? (mode.icon || '') + ' ' + esc(mLbl) : esc(p.mode)) + '</span>'
        + '<input type="number" step="0.01" min="0" value="' + p.amount.toFixed(2) + '" />'
        + '<button type="button" title="' + esc(POS_T.remove) + '">✕</button>'
        + '</div>';
    }
    el.innerHTML = html;
    el.querySelectorAll('.pos-pay-split-line').forEach(function(line) {
      var i = Number(line.getAttribute('data-i'));
      line.querySelector('input').addEventListener('input', function(e) {
        var v = parseFloat(e.target.value);
        payments[i].amount = isNaN(v) ? 0 : round2(v);
        renderPaySummary();
      });
      line.querySelector('button').addEventListener('click', function() {
        payments.splice(i, 1);
        renderPaySplit();
        renderPaySummary();
      });
    });
  }

  function renderPaySummary() {
    var t = totals();
    var paid = round2(payments.reduce(function(s, p) { return s + p.amount; }, 0));
    var remaining = round2(t.ttc - paid);
    $('pos-pay-paid').textContent = fmt(paid);
    $('pos-pay-remaining').textContent = fmt(remaining);

    // Show cash block only if there's a cash payment that needs change
    var cashPay = payments.find(function(p) { return p.mode === 'cash'; });
    var cashMode = config.paymentModes.find(function(m) { return m.id === 'cash' && m.needsChange; });
    if (cashPay && cashMode) {
      $('pos-pay-cash-block').style.display = 'block';
      var g = parseFloat($('pos-pay-given').value);
      if (isNaN(g) || g < cashPay.amount) {
        $('pos-pay-given').value = cashPay.amount.toFixed(2);
        cashGiven = cashPay.amount;
      } else {
        cashGiven = g;
      }
      var change = round2(Math.max(0, cashGiven - cashPay.amount));
      $('pos-pay-change').textContent = fmt(change);
    } else {
      $('pos-pay-cash-block').style.display = 'none';
      cashGiven = 0;
    }

    // Confirm only if total paid >= total ttc and not over-paid (allow exact)
    var canConfirm = Math.abs(paid - t.ttc) < 0.005 && payments.length > 0;
    $('pos-pay-confirm').disabled = !canConfirm;
  }

  $('pos-pay-given').addEventListener('input', function() {
    var v = parseFloat($('pos-pay-given').value);
    cashGiven = isNaN(v) ? 0 : round2(v);
    var cashPay = payments.find(function(p) { return p.mode === 'cash'; });
    if (cashPay) {
      var change = round2(Math.max(0, cashGiven - cashPay.amount));
      $('pos-pay-change').textContent = fmt(change);
    }
  });

  function renderQuickCash(total) {
    var rounded = Math.ceil(total / 5) * 5;
    var candidates = [total, rounded, rounded + 5, rounded + 10, 20, 50, 100];
    // dedupe + sort ascending
    candidates = candidates.filter(function(v, i, a) { return v >= total && a.indexOf(v) === i; })
      .sort(function(a, b) { return a - b; }).slice(0, 6);
    var html = '';
    for (var i = 0; i < candidates.length; i++) {
      html += '<button type="button" data-q="' + candidates[i] + '">' + fmt(candidates[i]) + '</button>';
    }
    var el = $('pos-quick-cash');
    el.innerHTML = html;
    el.querySelectorAll('button').forEach(function(btn) {
      btn.addEventListener('click', function() {
        $('pos-pay-given').value = btn.getAttribute('data-q');
        $('pos-pay-given').dispatchEvent(new Event('input'));
      });
    });
  }

  $('pos-pay-confirm').addEventListener('click', function() {
    completeSale();
  });

  function makeSaleId() {
    var d = new Date();
    var seq = String((session && session.sales ? session.sales.length : 0) + 1).padStart(3, '0');
    return 'T' + d.getFullYear() + pad(d.getMonth() + 1) + pad(d.getDate()) + '-' + seq;
  }

  function completeSale() {
    var t = totals();
    var cashPay = payments.find(function(p) { return p.mode === 'cash'; });
    var sale = {
      id: makeSaleId(),
      ts: Date.now(),
      server: session ? session.server : undefined,
      lines: JSON.parse(JSON.stringify(cart)),
      subtotalHt: t.ht,
      vatTotal: t.vat,
      total: t.ttc,
      payments: JSON.parse(JSON.stringify(payments)),
      given: cashPay ? cashGiven : 0,
      change: cashPay ? round2(Math.max(0, cashGiven - cashPay.amount)) : 0,
      prepMinutes: TIME_ENABLED ? prepMinutes : 0,
      deliveryMinutes: TIME_ENABLED && TIME_HAS_DELIVERY ? deliveryMinutes : 0,
      timeOverridden: TIME_ENABLED ? timeOverridden : false
    };
    session.sales = session.sales || [];
    session.sales.push(sale);
    saveSession(session);

    // Print
    printTicket(sale);

    // Reset
    cart = [];
    payments = [];
    cashGiven = 0;
    prepMinutes = 0;
    deliveryMinutes = 0;
    timeOverridden = false;
    renderCart();
    closePayModal();
  }

  // ════════════════════════════════════════════════════════════════════════
  // TICKET PRINT
  // ════════════════════════════════════════════════════════════════════════
  function printTicket(sale) {
    var host = $('pos-ticket-host');
    host.style.display = 'block';
    var d = new Date(sale.ts);
    var ts = pad(d.getDate()) + '/' + pad(d.getMonth() + 1) + '/' + d.getFullYear()
      + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    var lines = '';
    sale.lines.forEach(function(l) {
      lines += '<div class="t-row"><span>' + l.qty + '× ' + esc(l.name) + '</span><span>' + fmt(lineTtc(l)) + '</span></div>';
    });
    var paid = '';
    sale.payments.forEach(function(p) {
      var m = config.paymentModes.find(function(mm) { return mm.id === p.mode; });
      paid += '<div class="t-row"><span>' + (m ? esc(m.label) : esc(p.mode)) + '</span><span>' + fmt(p.amount) + '</span></div>';
    });
    var changeHtml = sale.change > 0
      ? '<div class="t-row"><span>' + esc(POS_T.ticketCashGiven) + '</span><span>' + fmt(sale.given) + '</span></div>'
        + '<div class="t-row"><span>' + esc(POS_T.ticketChange) + '</span><span>' + fmt(sale.change) + '</span></div>'
      : '';

    var timeHtml = '';
    if (sale.prepMinutes && sale.prepMinutes > 0) {
      var ready = new Date(sale.ts + sale.prepMinutes * 60000);
      timeHtml += '<div class="t-row"><span>' + esc(POS_T.ticketReady) + '</span><span>'
        + pad(ready.getHours()) + ':' + pad(ready.getMinutes())
        + ' (' + sale.prepMinutes + ' min)</span></div>';
      if (sale.deliveryMinutes && sale.deliveryMinutes > 0) {
        var arr = new Date(sale.ts + (sale.prepMinutes + sale.deliveryMinutes) * 60000);
        timeHtml += '<div class="t-row"><span>' + esc(POS_T.ticketDelivery) + '</span><span>'
          + pad(arr.getHours()) + ':' + pad(arr.getMinutes())
          + ' (+' + sale.deliveryMinutes + ' min)</span></div>';
      }
      timeHtml += '<hr/>';
    }

    host.innerHTML = ''
      + '<div id="pos-ticket-print">'
      + '<div class="t-center"><strong>' + esc(config.shopName) + '</strong></div>'
      + (config.shopSubtitle ? '<div class="t-center">' + esc(config.shopSubtitle) + '</div>' : '')
      + (config.vatNumber ? '<div class="t-center">' + esc(config.vatLabel) + ' : ' + esc(config.vatNumber) + '</div>' : '')
      + '<hr/>'
      + '<div class="t-row"><span>' + esc(sale.id) + '</span><span>' + ts + '</span></div>'
      + (sale.server ? '<div>👤 ' + esc(sale.server) + '</div>' : '')
      + '<hr/>'
      + lines
      + '<hr/>'
      + '<div class="t-row"><span>' + esc(POS_T.ticketHt) + '</span><span>' + fmt(sale.subtotalHt) + '</span></div>'
      + '<div class="t-row"><span>' + esc(config.vatLabel) + '</span><span>' + fmt(sale.vatTotal) + '</span></div>'
      + '<div class="t-row t-grand"><span>' + esc(POS_T.ticketTotal) + '</span><span>' + fmt(sale.total) + '</span></div>'
      + '<hr/>'
      + paid
      + changeHtml
      + '<hr/>'
      + timeHtml
      + '<div class="t-center">' + esc(POS_T.ticketThanks) + '</div>'
      + '</div>';
    setTimeout(function() {
      window.print();
      setTimeout(function() {
        host.style.display = 'none';
        host.innerHTML = '';
      }, 600);
    }, 80);
  }

  // ════════════════════════════════════════════════════════════════════════
  // STATS
  // ════════════════════════════════════════════════════════════════════════
  $('pos-stats-btn').addEventListener('click', function() {
    if (!session) return;
    renderStats();
    $('pos-stats-modal').classList.add('show');
  });
  $('pos-stats-close').addEventListener('click', function() {
    $('pos-stats-modal').classList.remove('show');
  });

  function renderStats() {
    var sales = session.sales || [];
    var ca = 0, cash = 0, card = 0, other = 0, items = 0;
    var byP = {};
    sales.forEach(function(s) {
      ca += s.total;
      s.payments.forEach(function(p) {
        if (p.mode === 'cash') cash += p.amount;
        else if (p.mode === 'card') card += p.amount;
        else other += p.amount;
      });
      s.lines.forEach(function(l) {
        items += l.qty;
        if (!byP[l.productId]) byP[l.productId] = { name: l.name, qty: 0, rev: 0 };
        byP[l.productId].qty += l.qty;
        byP[l.productId].rev += lineTtc(l);
      });
    });
    var top = Object.values(byP).sort(function(a, b) { return b.qty - a.qty; }).slice(0, 10);
    var avg = sales.length ? round2(ca / sales.length) : 0;

    var html = '<div class="pos-stats-grid">'
      + '<div class="pos-stat"><div class="l">' + esc(POS_T.statsSales) + '</div><div class="v">' + sales.length + '</div></div>'
      + '<div class="pos-stat"><div class="l">' + esc(POS_T.statsCa) + '</div><div class="v">' + fmt(ca) + '</div></div>'
      + '<div class="pos-stat"><div class="l">' + esc(POS_T.statsAvg) + '</div><div class="v">' + fmt(avg) + '</div></div>'
      + '<div class="pos-stat"><div class="l">' + esc(POS_T.statsItems) + '</div><div class="v">' + items + '</div></div>'
      + '<div class="pos-stat"><div class="l">' + esc(POS_T.statsCash) + '</div><div class="v">' + fmt(cash) + '</div></div>'
      + '<div class="pos-stat"><div class="l">' + esc(POS_T.statsCard) + '</div><div class="v">' + fmt(card) + '</div></div>'
      + (other > 0 ? '<div class="pos-stat"><div class="l">' + esc(POS_T.statsOther) + '</div><div class="v">' + fmt(other) + '</div></div>' : '')
      + '</div>';
    html += '<h3 style="color:var(--gold); margin: 1rem 0 0.5rem; font-size: 0.9rem;">' + esc(POS_T.statsTop) + '</h3>';
    html += '<div class="pos-top-list">';
    if (top.length === 0) html += '<div style="color:#555; text-align:center; padding:1rem;">' + esc(POS_T.statsNoTop) + '</div>';
    top.forEach(function(p) {
      html += '<div class="row"><span class="n">' + esc(p.name) + '</span><span class="q">×' + p.qty + '</span><span class="r">' + fmt(p.rev) + '</span></div>';
    });
    html += '</div>';
    $('pos-stats-body').innerHTML = html;
  }

  // ════════════════════════════════════════════════════════════════════════
  // ARCHIVE
  // ════════════════════════════════════════════════════════════════════════
  $('pos-archive-btn').addEventListener('click', function() {
    renderArchive();
    $('pos-archive-modal').classList.add('show');
  });
  $('pos-archive-close').addEventListener('click', function() {
    $('pos-archive-modal').classList.remove('show');
  });

  function renderArchive() {
    var arch = loadArchive();
    var html = '';
    if (arch.length === 0) html = '<div style="color:#555; text-align:center; padding:1.5rem;">' + esc(POS_T.archiveEmpty) + '</div>';
    else {
      html = '<div class="pos-archive-list">';
      arch.forEach(function(s) {
        var ca = (s.sales || []).reduce(function(a, x) { return a + x.total; }, 0);
        var gap = s.cashGap == null ? '—' : (s.cashGap >= 0 ? '+' : '') + fmt(s.cashGap);
        html += '<div class="pos-archive-row">'
          + '<span class="d">' + esc(s.dateKey) + '</span>'
          + '<span>' + (s.sales ? s.sales.length : 0) + ' ' + esc(POS_T.archiveSales) + ' · ' + (s.server || '—') + '</span>'
          + '<span class="ca">' + fmt(ca) + '</span>'
          + '<span class="g">' + esc(POS_T.archiveGap) + ' ' + gap + '</span>'
          + '</div>';
      });
      html += '</div>';
    }
    $('pos-archive-body').innerHTML = html;
  }

  // ════════════════════════════════════════════════════════════════════════
  // CLOSE SESSION
  // ════════════════════════════════════════════════════════════════════════
  $('pos-close-btn').addEventListener('click', function() {
    if (!session) return;
    var sales = session.sales || [];
    var cashTakings = 0;
    var cardTakings = 0;
    var ca = 0;
    sales.forEach(function(s) {
      ca += s.total;
      s.payments.forEach(function(p) {
        if (p.mode === 'cash') cashTakings += p.amount;
        else if (p.mode === 'card') cardTakings += p.amount;
      });
    });
    $('pos-close-summary').innerHTML = ''
      + '<div class="pos-pay-row"><span>' + esc(POS_T.closeSales) + '</span><span>' + sales.length + '</span></div>'
      + '<div class="pos-pay-row"><span>' + esc(POS_T.closeCash) + '</span><span>' + fmt(cashTakings) + '</span></div>'
      + '<div class="pos-pay-row"><span>' + esc(POS_T.closeCard) + '</span><span>' + fmt(cardTakings) + '</span></div>'
      + '<div class="pos-pay-row" style="border-top:1px solid var(--border); padding-top:0.4rem; margin-top:0.4rem;"><span><strong>' + esc(POS_T.closeTotal) + '</strong></span><span><strong>' + fmt(ca) + '</strong></span></div>';
    $('pos-close-counted').value = cashTakings.toFixed(2);
    updateCloseGap(cashTakings);
    $('pos-close-modal').classList.add('show');
  });

  function updateCloseGap(expected) {
    var counted = parseFloat($('pos-close-counted').value);
    if (isNaN(counted)) counted = 0;
    var gap = round2(counted - expected);
    var el = $('pos-close-gap');
    if (gap === 0) {
      el.className = 'pos-close-gap ok';
      el.textContent = POS_T.gapBalanced;
    } else if (gap > 0) {
      el.className = 'pos-close-gap ok';
      el.textContent = '+ ' + fmt(gap) + ' ' + POS_T.gapOver;
    } else {
      el.className = 'pos-close-gap bad';
      el.textContent = fmt(gap) + ' ' + POS_T.gapShort;
    }
  }
  $('pos-close-counted').addEventListener('input', function() {
    var sales = session.sales || [];
    var cashTakings = 0;
    sales.forEach(function(s) { s.payments.forEach(function(p) { if (p.mode === 'cash') cashTakings += p.amount; }); });
    updateCloseGap(cashTakings);
  });

  $('pos-close-cancel').addEventListener('click', function() {
    $('pos-close-modal').classList.remove('show');
  });

  $('pos-close-csv').addEventListener('click', function() {
    exportCsv(session);
  });

  $('pos-close-confirm').addEventListener('click', function() {
    var sales = session.sales || [];
    var cashTakings = 0;
    sales.forEach(function(s) { s.payments.forEach(function(p) { if (p.mode === 'cash') cashTakings += p.amount; }); });
    var counted = parseFloat($('pos-close-counted').value);
    if (isNaN(counted)) counted = 0;
    session.closedAt = Date.now();
    session.closingFloat = round2(counted);
    session.expectedCash = cashTakings;
    session.cashGap = round2(counted - cashTakings);

    // archive
    try {
      localStorage.setItem(KEY_ARCHIVE(session.dateKey), JSON.stringify(session));
      var idx = JSON.parse(localStorage.getItem(KEY_INDEX) || '[]');
      if (idx.indexOf(session.dateKey) < 0) {
        idx.push(session.dateKey);
        localStorage.setItem(KEY_INDEX, JSON.stringify(idx));
      }
      localStorage.removeItem(KEY_SESSION);
    } catch (e) {}

    // Auto CSV download
    exportCsv(session);

    session = null;
    cart = [];
    $('pos-close-modal').classList.remove('show');
    showOpenModal();
  });

  function exportCsv(s) {
    if (!s) return;
    var sep = ';';
    var rows = [];
    rows.push(['sale_id', 'datetime', 'server', 'items_count', 'subtotal_ht', 'vat', 'total_ttc', 'payment_modes', 'currency'].join(sep));
    (s.sales || []).forEach(function(sale) {
      var d = new Date(sale.ts);
      var dt = d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate())
        + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds());
      var items = sale.lines.reduce(function(a, l) { return a + l.qty; }, 0);
      var pay = sale.payments.map(function(p) { return p.mode + ':' + p.amount.toFixed(2); }).join('|');
      rows.push([
        sale.id, dt,
        (sale.server || '').replace(/[;\n]/g, ' '),
        items, sale.subtotalHt.toFixed(2), sale.vatTotal.toFixed(2), sale.total.toFixed(2),
        pay, config.currencyCode
      ].join(sep));
    });
    var csv = rows.join('\n');
    var blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = (SK + '-' + s.dateKey + '.csv');
    document.body.appendChild(a);
    a.click();
    setTimeout(function() { URL.revokeObjectURL(url); a.remove(); }, 200);
  }

  // ════════════════════════════════════════════════════════════════════════
  // MODAL CLOSE UX — 3 voies : × button + backdrop click + Esc
  // ════════════════════════════════════════════════════════════════════════
  var CLOSABLE_MODALS = ['pos-pay-modal', 'pos-close-modal', 'pos-stats-modal', 'pos-archive-modal'];
  function closeAnyOpenModal() {
    for (var i = 0; i < CLOSABLE_MODALS.length; i++) {
      var el = $(CLOSABLE_MODALS[i]);
      if (el && el.classList.contains('show')) el.classList.remove('show');
    }
  }
  // × buttons
  root.querySelectorAll('.pos-modal-close').forEach(function(btn) {
    btn.addEventListener('click', function(ev) {
      ev.stopPropagation();
      var id = btn.getAttribute('data-close-modal');
      if (id && $(id)) $(id).classList.remove('show');
    });
  });
  // Backdrop click
  CLOSABLE_MODALS.forEach(function(id) {
    var el = $(id);
    if (!el) return;
    el.addEventListener('click', function(ev) {
      if (ev.target === el) el.classList.remove('show');
    });
  });
  // Esc key
  document.addEventListener('keydown', function(ev) {
    if (ev.key === 'Escape' || ev.keyCode === 27) closeAnyOpenModal();
  });

  // ════════════════════════════════════════════════════════════════════════
  // Clock
  // ════════════════════════════════════════════════════════════════════════
  function tickClock() {
    var d = new Date();
    $('pos-clock').textContent = pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds());
  }
  setInterval(tickClock, 1000); tickClock();

  // ════════════════════════════════════════════════════════════════════════
  // BOOT : if existing session for today -> resume, else open modal
  // ════════════════════════════════════════════════════════════════════════
  if (session && session.dateKey === nowDateKey() && !session.closedAt) {
    showLayout();
  } else {
    if (session && session.dateKey !== nowDateKey() && !session.closedAt) {
      // Stale session from another day : auto-archive without closing fund
      try {
        session.closedAt = Date.now();
        localStorage.setItem(KEY_ARCHIVE(session.dateKey), JSON.stringify(session));
        var idx = JSON.parse(localStorage.getItem(KEY_INDEX) || '[]');
        if (idx.indexOf(session.dateKey) < 0) {
          idx.push(session.dateKey);
          localStorage.setItem(KEY_INDEX, JSON.stringify(idx));
        }
        localStorage.removeItem(KEY_SESSION);
      } catch (e) {}
      session = null;
    }
    showOpenModal();
  }
})();
</script>
