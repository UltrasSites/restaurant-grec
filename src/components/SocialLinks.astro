---
const sites = [
    {
        name: "Facebook",
        href: "https://www.facebook.com/to.kalamaki.tis.troumpas/",
        path: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
    },
];
---

<div class="flex gap-4 items-center">
    {
        sites.map((site) => (
            <a href={site.href} aria-label={site.name} target="_blank" rel="noopener" class="relative group">
                <div class="absolute -inset-2 bg-white/5 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out backdrop-blur-sm -z-10" />
                <div class="w-12 h-12 flex items-center justify-center text-white/80 group-hover:text-[#E5B32A] transition-all duration-300 transform group-hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 drop-shadow-lg">
                        <path d={site.path} />
                    </svg>
                </div>
            </a>
        ))
    }
</div>
