---
// Liens sociaux + avis avec notes/étoiles
// Facebook : juste l'icône
// Google + TripAdvisor : icône + note + étoiles + nombre d'avis
import type { Lang } from "../i18n/utils";

interface Props { lang?: Lang; }
const { lang = "el" } = Astro.props;

const ARIA_REVIEWS: Record<string, string> = {
  el: "κριτικές",
  en: "reviews",
  fr: "avis",
};
const reviewsWord = ARIA_REVIEWS[lang] || ARIA_REVIEWS.el;

interface Site {
  name: string;
  href: string;
  rating?: number;        // ex 4.3
  count?: number;         // ex 200
  iconType: "fb" | "google" | "ta";
}

const sites: Site[] = [
  {
    name: "Facebook",
    href: "https://www.facebook.com/to.kalamaki.tis.troumpas/",
    iconType: "fb",
  },
  {
    name: "Google",
    href: "https://maps.google.com/?cid=4117845882351786324",
    rating: 4.3,
    count: 291,
    iconType: "google",
  },
  {
    name: "TripAdvisor",
    href: "https://www.tripadvisor.com/Restaurant_Review-g189403-d10042662-Reviews-To_Kalamaki_tis_Troumpas-Piraeus_Piraeus_Region_Attica.html",
    rating: 4.5,
    count: 37,
    iconType: "ta",
  },
];

// Dessine 5 étoiles avec demi-étoile selon la note
function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating - full >= 0.25 && rating - full < 0.75 ? 1 : 0;
  const fullCount = full + (rating - full >= 0.75 ? 1 : 0);
  const empty = 5 - fullCount - half;
  return { fullCount, half, empty };
}
---

<div class="flex gap-3 sm:gap-4 items-start justify-center">
  {
    sites.map((site) => {
      const stars = site.rating ? renderStars(site.rating) : null;
      return (
        <a
          href={site.href}
          aria-label={site.rating ? `${site.name} ${site.rating}/5 (${site.count} ${reviewsWord})` : site.name}
          target="_blank"
          rel="noopener"
          class="relative group flex flex-col items-center"
        >
          <div class="absolute -inset-2 top-0 bg-white/5 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out backdrop-blur-sm -z-10" style="height:3.5rem;" />
          <div class="w-12 h-12 flex items-center justify-center text-white/80 group-hover:text-[#E5B32A] transition-all duration-300 transform group-hover:-translate-y-1">
            {site.iconType === "fb" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 drop-shadow-lg">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
              </svg>
            )}
            {site.iconType === "google" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 drop-shadow-lg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            )}
            {site.iconType === "ta" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-7 h-7 drop-shadow-lg">
                <circle cx="50" cy="50" r="48" fill="#34E0A1"/>
                <circle cx="32" cy="55" r="14" fill="white"/>
                <circle cx="68" cy="55" r="14" fill="white"/>
                <circle cx="32" cy="55" r="6" fill="#000"/>
                <circle cx="68" cy="55" r="6" fill="#000"/>
                <path d="M30 32 Q50 22 70 32" stroke="#000" stroke-width="3" fill="none" stroke-linecap="round"/>
              </svg>
            )}
          </div>
          {stars && (
            <div class="flex flex-col items-center mt-1 leading-none">
              <span class="text-[10px] font-bold text-[#E5B32A] flex items-center gap-0.5">
                <span>{site.rating}</span>
                <span class="text-[9px]">/5</span>
              </span>
              <div class="flex items-center gap-px mt-0.5" aria-hidden="true">
                {Array.from({ length: stars.fullCount }).map(() => (
                  <svg viewBox="0 0 20 20" class="w-2.5 h-2.5 fill-[#E5B32A]"><path d="M10 1l2.6 5.6 6.1.6-4.6 4.2 1.3 6L10 14.5 4.6 17.4l1.3-6L1.3 7.2l6.1-.6z"/></svg>
                ))}
                {stars.half === 1 && (
                  <svg viewBox="0 0 20 20" class="w-2.5 h-2.5">
                    <defs><linearGradient id={`half-${site.iconType}`} x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="50%" stop-color="#E5B32A"/><stop offset="50%" stop-color="rgba(255,255,255,0.25)"/></linearGradient></defs>
                    <path d="M10 1l2.6 5.6 6.1.6-4.6 4.2 1.3 6L10 14.5 4.6 17.4l1.3-6L1.3 7.2l6.1-.6z" fill={`url(#half-${site.iconType})`}/>
                  </svg>
                )}
                {Array.from({ length: stars.empty }).map(() => (
                  <svg viewBox="0 0 20 20" class="w-2.5 h-2.5 fill-white/25"><path d="M10 1l2.6 5.6 6.1.6-4.6 4.2 1.3 6L10 14.5 4.6 17.4l1.3-6L1.3 7.2l6.1-.6z"/></svg>
                ))}
              </div>
            </div>
          )}
        </a>
      );
    })
  }
</div>
