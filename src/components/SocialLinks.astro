        path: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
    },
    {
        name: "e-food",
        href: "https://www.e-food.gr/delivery/peiraias/to-kalamaki-ths-troympas",
        path: "M17 9V7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7V9H4C2.89543 9 2 9.89543 2 11V19C2 20.6569 3.34315 22 5 22H19C20.6569 22 22 20.6569 22 19V11C22 9.89543 21.1046 9 20 9H17ZM9 7C9 5.34315 10.3431 4 12 4C13.6569 4 15 5.34315 15 7V9H9V7ZM20 19C20 19.5523 19.5523 20 19 20H5C4.44772 20 4 19.5523 4 19V11H20V19Z",
    },
    {
        name: "Instagram",
        href: "https://www.instagram.com",
        path: "M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 5 5 5.001 5.001 0 0 0-5-5zm0 2a3 3 0 1 1-3 3 3.001 3.001 0 0 1 3-3zm6.5-2.75a1.25 1.25 0 1 0 1.25 1.25 1.25 1.25 0 0 0-1.25-1.25z",
    },
];
---

<div class="flex gap-4 items-center">
    {
        sites.map((site) => (
            <a href={site.href} aria-label={site.name} target="_blank" rel="noopener" class="relative group">
                <div class="absolute -inset-2 bg-white/5 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out backdrop-blur-sm -z-10" />
                <div class="w-12 h-12 flex items-center justify-center text-white/80 group-hover:text-[#E5B32A] transition-all duration-300 transform group-hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 drop-shadow-lg">
                        <path d={site.path} />
                    </svg>
                </div>
            </a>
        ))
    }
</div>
