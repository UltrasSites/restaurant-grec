---
import { supportedLangs, type Lang } from '../i18n/utils';

interface Props {
  currentLang: Lang;
  variant?: 'header' | 'drawer';
}

const { currentLang, variant = 'header' } = Astro.props;
const isDrawer = variant === 'drawer';

const flags: Record<string, string> = {
  el: '🇬🇷',
  en: '🇬🇧',
};
const labels: Record<string, string> = {
  el: 'ΕΛΛ',
  en: 'ENG',
};
---

<div class:list={['lang-switcher', isDrawer ? 'lang-switcher--drawer' : 'lang-switcher--header']} role="navigation" aria-label="Choose language">
  {supportedLangs.map((l) => {
    const isActive = l === currentLang;
    const href = `/${l}/`;
    return (
      <a
        href={href}
        class:list={['lang-switcher__link', isActive && 'lang-switcher__link--active']}
        aria-current={isActive ? 'true' : undefined}
        data-lang={l}
      >
        <span class="lang-flag" aria-hidden="true">{flags[l]}</span>
        <span class="lang-code">{labels[l]}</span>
      </a>
    );
  })}
</div>

<style>
  .lang-switcher { display: flex; align-items: center; gap: 0.5rem; }
  .lang-flag { font-size: 1.05rem; line-height: 1; display: inline-block; transform: translateY(-1px); }
  .lang-code { font-size: 10px; letter-spacing: 0.1em; }

  .lang-switcher__link {
    font-family: 'Inter', sans-serif;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
  }

  .lang-switcher--header { gap: 0.25rem; }
  .lang-switcher--header .lang-switcher__link {
    padding: 0.5rem 0.75rem;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .lang-switcher--header .lang-switcher__link:hover {
    color: #fff;
    background: rgba(255,255,255,0.05);
  }
  .lang-switcher--header .lang-switcher__link--active {
    color: #E5B32A;
    background: rgba(229, 179, 42, 0.1);
  }
  .lang-switcher--header .lang-switcher__link--active::after {
    content: '';
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #E5B32A;
  }

  .lang-switcher--drawer {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    width: 100%;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 1rem;
  }
  .lang-switcher--drawer .lang-switcher__link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
  }
  .lang-switcher--drawer .lang-switcher__link:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
    border-color: rgba(255,255,255,0.1);
  }
  .lang-switcher--drawer .lang-switcher__link--active {
    background: rgba(229, 179, 42, 0.1);
    color: #E5B32A;
    border-color: rgba(229, 179, 42, 0.3);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }
</style>
