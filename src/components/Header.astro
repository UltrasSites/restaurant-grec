---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { translations } from "../i18n/translations";
import type { Lang } from "../i18n/utils";

interface Props {
    lang?: Lang;
}
const { lang = "el" } = Astro.props;
const t = translations[lang];
const base = `/${lang}`;
const links = [
    { name: t.nav_home, href: `${base}/#home` },
    { name: t.nav_ambiance, href: `${base}/#histoire` },
    { name: t.nav_carte, href: `${base}/#carte` },
    { name: t.nav_contact, href: `${base}/#contact` },
];
---

<header
    id="desktop-header"
    class="hidden md:flex fixed top-0 left-0 right-0 w-full z-50 h-16 items-center justify-between px-6 lg:px-10 bg-black/25 backdrop-blur-sm border-b border-white/10 transition-all duration-300"
>
    <a href={`${base}/#home`} class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-full border border-[#E5B32A]/40 overflow-hidden bg-black/60 flex items-center justify-center flex-shrink-0">
            <img
                src="https://graph.facebook.com/to.kalamaki.tis.troumpas/picture?type=square"
                alt="Το Καλαμάκι Της Τρούμπας"
                class="w-full h-full object-cover"
                width="40"
                height="40"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <span style="display:none" class="w-full h-full items-center justify-center text-[9px] font-bold tracking-widest uppercase text-[#E5B32A]">Κ.Τ.</span>
        </div>
        <span class="text-base lg:text-lg font-serif tracking-wide text-white">
            Το Καλαμάκι <span class="text-[#E5B32A]">Τρούμπας</span>.
        </span>
    </a>

    <nav class="flex gap-8 lg:gap-10 text-[11px] font-bold text-white uppercase tracking-[0.2em]">
        {links.map((link) => (
            <a href={link.href} class="hover:text-[#E5B32A] transition-colors py-2">{link.name}</a>
        ))}
    </nav>

    <div class="flex items-center gap-4 lg:gap-6">
        <div class="relative flex items-center gap-2 px-2 py-1 rounded-full border border-white/15 bg-black/20 backdrop-blur-sm">
            <button
                id="lang-menu-btn"
                type="button"
                class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.12em] text-white/80 hover:text-white hover:bg-white/10 border border-white/10 transition-colors"
                aria-haspopup="menu"
                aria-expanded="false"
                aria-controls="lang-menu-panel"
            >
                {lang.toUpperCase()}
            </button>

            <div
                id="lang-menu-panel"
                class="hidden absolute right-0 top-full mt-4 w-36 rounded-2xl border border-white/10 bg-neutral-900/90 backdrop-blur-2xl shadow-[0_20px_50px_rgba(0,0,0,0.5)] overflow-hidden"
                role="menu"
            >
                <div class="p-2 space-y-1">
                    <LanguageSwitcher currentLang={lang} variant="header" />
                </div>
            </div>

            <button
                type="button"
                class="theme-btn-desktop w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white/90 hover:bg-white/15 hover:border-[#E5B32A]/50 transition-all duration-300 relative"
                onclick="window.__toggleTheme && window.__toggleTheme()"
                aria-label={t.drawer_theme}
            >
                <span class="relative inline-flex items-center justify-center w-5 h-5">
                    <svg class="theme-icon-sun w-5 h-5 absolute inset-0 m-auto transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                    <svg class="theme-icon-moon w-5 h-5 absolute inset-0 m-auto transition-opacity duration-300 opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                    </svg>
                </span>
            </button>
        </div>

        <a
            id="desktop-call-link"
            href="tel:+302104222233"
            class="hidden lg:inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-white hover:text-[#E5B32A] transition-colors"
            aria-label={t.nav_aria_phone}
        >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 4.5l4.5-1.5 2.25 4.5-2.25 1.5a11.25 11.25 0 005.25 5.25l1.5-2.25 4.5 2.25-1.5 4.5A2.25 2.25 0 0114.25 21 13.5 13.5 0 013 9.75 2.25 2.25 0 012.25 4.5z"></path>
            </svg>
            <span>{t.nav_aria_phone}</span>
        </a>

        <a
            id="desktop-reserver-link"
            href={`${base}/#contact`}
            class="px-6 lg:px-8 py-3 bg-[#E5B32A] text-black text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-white transition-colors hidden lg:inline"
        >{t.nav_reserver}</a>
    </div>
</header>

<div id="menu-overlay" class="menu-overlay fixed inset-0 z-[65] md:hidden"></div>

<div id="menu-panel" class="menu-panel-drawer fixed z-[70] flex flex-col md:hidden touch-pan-y">
    <div style="width:40px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin:12px auto;"></div>
    <button id="drawer-close-btn" type="button" style="position:absolute;top:1rem;right:1.5rem;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.8);cursor:pointer;" aria-label="Κλείσιμο μενού">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <div id="mobile-drawer-inner" class="px-8 pb-12 flex flex-col overflow-y-auto">
        <nav class="flex flex-col gap-8 mt-2">
            {links.map((link, i) => (
                <a href={link.href} class="drawer-link text-2xl sm:text-3xl font-serif italic text-white/60 hover:text-white transition-colors hover:translate-x-2 duration-300 flex items-center gap-4 group">
                    <span class="text-xs font-sans text-[#E5B32A] font-bold opacity-0 group-hover:opacity-100 transition-opacity">0{i + 1}</span>
                    {link.name}
                </a>
            ))}
            <a href={`${base}/#contact`} class="drawer-link text-2xl sm:text-3xl font-serif italic text-[#E5B32A] hover:text-white transition-colors hover:translate-x-2 duration-300 mt-4 flex items-center gap-4 group">
                <span class="text-xs font-sans text-white font-bold opacity-0 group-hover:opacity-100 transition-opacity">05</span>
                {t.nav_reserver}
            </a>
        </nav>
        <LanguageSwitcher currentLang={lang} variant="drawer" />
        <div class="mt-auto mb-8 border-t border-white/10 pt-6">
            <button type="button" id="drawer-theme-btn" class="w-full py-2 text-[10px] uppercase tracking-widest text-white/50 hover:text-white transition-colors text-left">{t.drawer_theme}</button>
        </div>
        <div class="text-[10px] text-white/30 uppercase tracking-widest text-center">{t.drawer_brand}</div>
    </div>
</div>

<script>
    (function () {
        function updateThemeIcons() {
            const isDark = document.documentElement.dataset.theme === "dark";
            document.querySelectorAll<HTMLElement>(".theme-icon-sun").forEach((el) => { el.style.opacity = isDark ? "0" : "1"; });
            document.querySelectorAll<HTMLElement>(".theme-icon-moon").forEach((el) => { el.style.opacity = isDark ? "1" : "0"; });
        }
        document.addEventListener("DOMContentLoaded", updateThemeIcons);
        const orig = (window as any).__toggleTheme as undefined | (() => void);
        if (orig) {
            (window as any).__toggleTheme = function () { orig(); setTimeout(updateThemeIcons, 0); };
        }
    })();

    (function () {
        const langBtn = document.getElementById("lang-menu-btn");
        const panel = document.getElementById("lang-menu-panel");
        if (!langBtn || !panel) return;
        function setExpanded(v: boolean) { langBtn!.setAttribute("aria-expanded", v ? "true" : "false"); }
        langBtn.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); panel.classList.toggle("hidden"); setExpanded(!panel.classList.contains("hidden")); });
        document.addEventListener("click", () => { panel.classList.add("hidden"); setExpanded(false); });
        document.addEventListener("keydown", (e) => { if ((e as KeyboardEvent).key === "Escape") { panel.classList.add("hidden"); setExpanded(false); } });
    })();

    const desktopHeader = document.getElementById("desktop-header");
    window.addEventListener("scroll", () => {
        if (!desktopHeader) return;
        if (window.scrollY > 50) {
            desktopHeader.classList.add("bg-black/95", "backdrop-blur-xl");
            desktopHeader.classList.remove("bg-black/25", "backdrop-blur-sm");
        } else {
            desktopHeader.classList.add("bg-black/25", "backdrop-blur-sm");
            desktopHeader.classList.remove("bg-black/95", "backdrop-blur-xl");
        }
        desktopHeader.style.height = window.scrollY > 50 ? "3.25rem" : "4rem";
    }, { passive: true });

    const drawer = document.getElementById("menu-panel");
    const backdrop = document.getElementById("menu-overlay");
    const drawerLinks = document.querySelectorAll(".drawer-link");
    let drawerOpen = false;
    function openDrawer() { if (!drawer || !backdrop) return; drawerOpen = true; backdrop.classList.add("open"); drawer.classList.add("open"); document.body.style.overflow = "hidden"; }
    function closeDrawer() { if (!drawer || !backdrop) return; drawerOpen = false; backdrop.classList.remove("open"); drawer.classList.remove("open"); document.body.style.overflow = ""; }
    const drawerCloseBtn = document.getElementById("drawer-close-btn");
    if (drawerCloseBtn) drawerCloseBtn.addEventListener("click", closeDrawer);
    document.addEventListener("open-drawer", openDrawer);
    backdrop?.addEventListener("click", () => { if (drawerOpen) closeDrawer(); });
    drawerLinks.forEach((l) => l.addEventListener("click", () => { if (drawerOpen) closeDrawer(); }));
    const drawerThemeBtn = document.getElementById("drawer-theme-btn");
    if (drawerThemeBtn) { drawerThemeBtn.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); if ((window as any).__toggleTheme) (window as any).__toggleTheme(); }); }
</script>
