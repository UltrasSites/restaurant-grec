---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import Flag from "./Flag.astro";
import { translations } from "../i18n/translations";
import type { Lang } from "../i18n/utils";

interface Props {
    lang?: Lang;
}
const { lang = "el" } = Astro.props;
const t = translations[lang];
const base = `/${lang}`;
const links = [
    { name: t.nav_home, href: `${base}/#home` },
    { name: t.nav_ambiance, href: `${base}/#histoire` },
    { name: t.nav_carte, href: `${base}/#carte` },
    { name: t.nav_contact, href: `${base}/#contact` },
];
---

<header
    id="desktop-header"
    class="hidden md:flex fixed top-0 left-0 right-0 w-full z-50 h-16 items-center justify-between px-6 lg:px-10 bg-transparent border-b border-transparent transition-all duration-500"
    style="will-change: background-color, border-color;"
>
    <a href={`${base}/#home`} class="flex items-center group shrink-0" aria-label="Το Καλαμάκι Τρούμπας">
        <img
            src="/photos/logo-main-200w.webp"
            alt="Το Καλαμάκι Τρούμπας"
            class="header-desktop-logo h-11 lg:h-12 w-auto select-none transition-opacity duration-300"
            width="200"
            height="188"
            loading="eager"
            decoding="async"
        />
    </a>

    <nav class="absolute left-1/2 -translate-x-1/2 flex gap-8 lg:gap-10 text-[11px] font-bold text-white uppercase tracking-[0.2em]">
        {links.map((link) => (
            <a href={link.href} class="hover:text-[#E5B32A] transition-colors py-2">{link.name}</a>
        ))}
    </nav>

    <div class="flex items-center gap-3 lg:gap-4 shrink-0">
        <div class="relative flex items-center gap-2 px-2 py-1 rounded-full border border-white/15 bg-black/20 backdrop-blur-sm">
            <button
                id="lang-menu-btn"
                type="button"
                class="flex items-center gap-1.5 px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.12em] text-white/80 hover:text-white hover:bg-white/10 border border-white/10 transition-colors"
                aria-haspopup="menu"
                aria-expanded="false"
                aria-controls="lang-menu-panel"
            >
                <Flag code={lang} size={15} rounded />
                {lang.toUpperCase()}
            </button>

            <div
                id="lang-menu-panel"
                class="hidden absolute right-0 top-full mt-4 w-36 rounded-2xl border border-white/10 bg-neutral-900/90 backdrop-blur-2xl shadow-[0_20px_50px_rgba(0,0,0,0.5)] overflow-hidden"
                role="menu"
            >
                <div class="p-2 space-y-1">
                    <LanguageSwitcher currentLang={lang} variant="header" />
                </div>
            </div>

            <button
                type="button"
                class="theme-btn-desktop w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white/90 hover:bg-white/15 hover:border-[#E5B32A]/50 transition-all duration-300 relative"
                onclick="window.__toggleTheme && window.__toggleTheme()"
                aria-label={t.drawer_theme}
            >
                <span class="relative inline-flex items-center justify-center w-5 h-5">
                    <svg class="theme-icon-sun w-5 h-5 absolute inset-0 m-auto transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                    <svg class="theme-icon-moon w-5 h-5 absolute inset-0 m-auto transition-opacity duration-300 opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                    </svg>
                </span>
            </button>
        </div>

        <a
            id="desktop-call-link"
            class="tel-link inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest text-white hover:text-[#E5B32A] transition-colors"
            data-p="MzAyMTA0MjIyMjMz"
            aria-label={t.nav_aria_phone}
        >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 4.5l4.5-1.5 2.25 4.5-2.25 1.5a11.25 11.25 0 005.25 5.25l1.5-2.25 4.5 2.25-1.5 4.5A2.25 2.25 0 0114.25 21 13.5 13.5 0 013 9.75 2.25 2.25 0 012.25 4.5z"></path>
            </svg>
            <span class="hidden lg:inline">{t.nav_aria_phone}</span>
        </a>

        <a
            id="desktop-reserver-link"
            href={`${base}/delivery`}
            class="inline-flex items-center px-3.5 py-1.5 bg-[#E5B32A] text-black text-[10px] font-bold uppercase tracking-[0.14em] rounded-full hover:bg-white transition-colors"
        >{t.order_cta}</a>
    </div>
</header>
<style>
  :global(body.hero-logo-visible) .header-desktop-logo { opacity: 0; pointer-events: none; }
</style>

{/* Logo flottant mobile — centre en haut apres scroll past hero */}
<div id="mobile-logo-float" class="md:hidden fixed top-3 left-1/2 -translate-x-1/2 z-40 pointer-events-none drop-shadow-xl opacity-0 transition-opacity duration-300">
    <a href={`${base}/#home`} class="pointer-events-auto inline-flex items-center" aria-label="Το Καλαμάκι Τρούμπας">
        <img
            src="/photos/logo-main-200w.webp"
            alt="Το Καλαμάκι Τρούμπας"
            class="h-9 w-auto"
            width="100"
            height="94"
            loading="lazy"
            decoding="async"
        />
    </a>
</div>

<div id="menu-overlay" class="menu-overlay fixed inset-0 z-[65] md:hidden"></div>

<div id="menu-panel" class="menu-panel-drawer fixed z-[70] flex flex-col md:hidden touch-pan-y" aria-hidden="true" role="dialog" aria-modal="true">
    <div style="width:40px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin:12px auto;"></div>
    <button id="drawer-close-btn" type="button" style="position:absolute;top:14px;right:14px;width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(229,179,42,0.18);border:1.5px solid rgba(229,179,42,0.55);color:#E5B32A;cursor:pointer;transition:transform .15s ease, background .2s ease;-webkit-tap-highlight-color:transparent;" aria-label="Κλείσιμο μενού" onmouseover="this.style.background='rgba(229,179,42,0.32)'" onmouseout="this.style.background='rgba(229,179,42,0.18)'" ontouchstart="this.style.transform='scale(0.92)'" ontouchend="this.style.transform='scale(1)'">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <div id="mobile-drawer-inner" class="px-8 pb-12 flex flex-col overflow-y-auto">
        <nav class="flex flex-col gap-8 mt-2">
            {links.map((link, i) => (
                <a href={link.href} class="drawer-link text-2xl sm:text-3xl font-serif italic text-white/60 hover:text-white transition-colors hover:translate-x-2 duration-300 flex items-center gap-4 group">
                    <span class="text-xs font-sans text-[#E5B32A] font-bold opacity-0 group-hover:opacity-100 transition-opacity">0{i + 1}</span>
                    {link.name}
                </a>
            ))}
        </nav>

        {/* CTA principal — Commander en ligne */}
        <a
            href={`${base}/delivery`}
            class="drawer-link mt-8 w-full text-center font-bold bg-[#E5B32A] text-black text-base uppercase tracking-[0.18em] py-5 px-6 rounded-full shadow-[0_12px_30px_rgba(229,179,42,0.35)] hover:bg-white transition-colors"
        >
            {t.order_cta}
        </a>

        {/* CTA secondaire — Reservation */}
        <a
            href={`${base}/#contact`}
            class="drawer-link mt-4 w-full text-center text-sm font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white py-3 transition-colors"
        >
            {t.nav_reserver}
        </a>

        <div class="mt-auto pt-8 text-[10px] text-white/30 uppercase tracking-widest text-center">{t.drawer_brand}</div>
    </div>
</div>

<script>
    (function () {
        function updateThemeIcons() {
            const isDark = document.documentElement.dataset.theme === "dark";
            document.querySelectorAll<HTMLElement>(".theme-icon-sun").forEach((el) => { el.style.opacity = isDark ? "0" : "1"; });
            document.querySelectorAll<HTMLElement>(".theme-icon-moon").forEach((el) => { el.style.opacity = isDark ? "1" : "0"; });
        }
        document.addEventListener("DOMContentLoaded", updateThemeIcons);
        const orig = (window as any).__toggleTheme as undefined | (() => void);
        if (orig) {
            (window as any).__toggleTheme = function () { orig(); setTimeout(updateThemeIcons, 0); };
        }
    })();

    (function () {
        const langBtn = document.getElementById("lang-menu-btn");
        const panel = document.getElementById("lang-menu-panel");
        if (!langBtn || !panel) return;
        function setExpanded(v: boolean) { langBtn!.setAttribute("aria-expanded", v ? "true" : "false"); }
        langBtn.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); panel.classList.toggle("hidden"); setExpanded(!panel.classList.contains("hidden")); });
        document.addEventListener("click", () => { panel.classList.add("hidden"); setExpanded(false); });
        document.addEventListener("keydown", (e) => { if ((e as KeyboardEvent).key === "Escape") { panel.classList.add("hidden"); setExpanded(false); } });
    })();

    const desktopHeader = document.getElementById("desktop-header");
    window.addEventListener("scroll", () => {
        if (!desktopHeader) return;
        if (window.scrollY > 60) {
            // Au scroll : barre apparaît (bg sombre opaque + border)
            desktopHeader.classList.add("bg-black/95", "backdrop-blur-xl", "border-white/10");
            desktopHeader.classList.remove("bg-transparent", "border-transparent");
            desktopHeader.style.height = "3.25rem";
        } else {
            // Top de page : barre invisible — seuls les liens flottent sur le hero (pattern Sara/Ultras-Sites)
            desktopHeader.classList.add("bg-transparent", "border-transparent");
            desktopHeader.classList.remove("bg-black/95", "backdrop-blur-xl", "border-white/10");
            desktopHeader.style.height = "4rem";
        }
    }, { passive: true });

    const drawer = document.getElementById("menu-panel");
    const backdrop = document.getElementById("menu-overlay");
    const drawerInner = document.getElementById("mobile-drawer-inner");
    const drawerLinks = document.querySelectorAll(".drawer-link");
    let drawerOpen = false;
    let savedScrollY = 0;

    // Methode iOS-safe : position:fixed sur body avec scrollY preserve.
    // overflow:hidden seul ne bloque PAS le scroll touch sur iOS Safari + plusieurs Android.
    // Le swipe pour fermer le drawer ne doit JAMAIS scroller la page derriere.
    function lockBodyScroll() {
        savedScrollY = window.scrollY || window.pageYOffset || 0;
        document.body.dataset.scrollY = String(savedScrollY);
        document.body.style.position = "fixed";
        document.body.style.top = `-${savedScrollY}px`;
        document.body.style.left = "0";
        document.body.style.right = "0";
        document.body.style.width = "100%";
        document.body.style.overflow = "hidden";
        document.body.style.touchAction = "none";
        document.documentElement.style.overflow = "hidden";
        document.body.classList.add("drawer-open");
    }
    function unlockBodyScroll() {
        const y = parseInt(document.body.dataset.scrollY || "0", 10);
        document.body.classList.remove("drawer-open");
        document.body.style.position = "";
        document.body.style.top = "";
        document.body.style.left = "";
        document.body.style.right = "";
        document.body.style.width = "";
        document.body.style.overflow = "";
        document.body.style.touchAction = "";
        document.documentElement.style.overflow = "";
        delete document.body.dataset.scrollY;
        // Restaurer la position de scroll exacte (sans animation)
        window.scrollTo(0, y);
    }
    function unlockBodyScrollNoRestore() {
        // Pour ancres internes : on laisse le browser scroller vers la cible
        document.body.classList.remove("drawer-open");
        document.body.style.position = "";
        document.body.style.top = "";
        document.body.style.left = "";
        document.body.style.right = "";
        document.body.style.width = "";
        document.body.style.overflow = "";
        document.body.style.touchAction = "";
        document.documentElement.style.overflow = "";
        delete document.body.dataset.scrollY;
    }
    function openDrawer() { if (!drawer || !backdrop) return; drawerOpen = true; backdrop.classList.add("open"); drawer.classList.add("open"); drawer.setAttribute("aria-hidden", "false"); lockBodyScroll(); }
    function closeDrawer() { if (!drawer || !backdrop) return; drawerOpen = false; backdrop.classList.remove("open"); drawer.classList.remove("open"); drawer.setAttribute("aria-hidden", "true"); unlockBodyScroll(); }
    const drawerCloseBtn = document.getElementById("drawer-close-btn");
    if (drawerCloseBtn) drawerCloseBtn.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); closeDrawer(); });
    document.addEventListener("open-drawer", openDrawer);
    backdrop?.addEventListener("click", (e) => { if (drawerOpen) { e.preventDefault(); e.stopPropagation(); closeDrawer(); } });
    // Bloquer tout touchmove sur le backdrop (safety net : empeche scroll page derriere)
    backdrop?.addEventListener("touchmove", (e) => { if (drawerOpen) e.preventDefault(); }, { passive: false });
    // Esc key pour fermer
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && drawerOpen) closeDrawer(); });
    drawerLinks.forEach((l) => l.addEventListener("click", () => {
        if (!drawerOpen) return;
        const href = (l as HTMLAnchorElement).getAttribute("href") || "";
        // Si lien d'ancre interne (commencant par `#` ou contenant `/#xxx` en fin),
        // on laisse le browser scroller vers l'ancre — pas de restore
        const isAnchor = href.startsWith("#") || /\/#[^/]*$/.test(href);
        drawerOpen = false;
        backdrop?.classList.remove("open");
        drawer?.classList.remove("open");
        drawer?.setAttribute("aria-hidden", "true");
        if (isAnchor) unlockBodyScrollNoRestore();
        else unlockBodyScroll();
    }));

    // Swipe down depuis n'importe où dans le drawer pour fermer
    let swipeStartY = 0;
    let swipeStartScrollTop = 0;
    drawer?.addEventListener('touchstart', (e) => {
        swipeStartY = e.changedTouches[0].screenY;
        swipeStartScrollTop = drawerInner?.scrollTop ?? 0;
    }, { passive: true });
    drawer?.addEventListener('touchend', (e) => {
        const delta = e.changedTouches[0].screenY - swipeStartY;
        // Ne fermer que si le drawer interne est deja en haut (sinon on scrollait du contenu)
        if (delta > 60 && drawerOpen && swipeStartScrollTop <= 0) closeDrawer();
    }, { passive: true });

    // Logo flottant mobile (top-centre) : visible UNIQUEMENT quand le logo du hero n'est plus
    // a l'ecran (§11.bis.C). IntersectionObserver sur #hero-logo ; fallback scroll si absent.
    const mobileLogoFloat = document.getElementById('mobile-logo-float');
    const heroLogo = document.getElementById('hero-logo');
    if (mobileLogoFloat) {
        if (heroLogo && 'IntersectionObserver' in window) {
            const io = new IntersectionObserver((entries) => {
                const visible = entries[0].isIntersecting;
                document.body.classList.toggle('hero-logo-visible', visible);
                mobileLogoFloat.style.opacity = visible ? '0' : '1';
            }, { rootMargin: '-12px 0px 0px 0px', threshold: 0 });
            io.observe(heroLogo);
        } else {
            window.addEventListener('scroll', () => {
                mobileLogoFloat.style.opacity = window.scrollY > 200 ? '1' : '0';
            }, { passive: true });
        }
    }
</script>
