---
import { menuPages } from "../data/menu-data";
const { lang = "el" } = Astro.props;
const isEl = lang === "el";

const pages = menuPages;

// Resolveurs multilingues — fallback EN puis EL si la traduction manque
const pickTitle = (p: typeof pages[number]) => {
  if (lang === 'el') return p.title_el;
  return p.title_en;
};
const pickNote = (p: typeof pages[number]) => {
  if (lang === 'el') return p.note_el;
  return p.note_en;
};
const pickItemName = (item: any) => {
  if (lang === 'el') return item.el;
  return item.en;
};
const pickItemDesc = (item: any) => {
  if (lang === 'el') return item.desc_el;
  return item.desc_en;
};

// Labels d'interface (cover + arrows + hints)
const L = {
  el: { cover_label: "Εξώφυλλο", our_menu: "Ο Κατάλογός Μας", flavour: "Αυθεντική Γεύση Πειραιά.", swipe_hint: "Γλίστρα με το δάχτυλο για να γυρίσεις σελίδα", turn_pages: "Γύρισε τις σελίδες", name1: "Το Καλαμάκι", name2: "Της Τρούμπας", addr: "Μπουμπουλίνας 8 & Νοταρά — Πειραιάς", swipe_browse: "← Γύρισε για να ανοίξεις", prev: "Προηγούμενη σελίδα", prev_short: "Πίσω", next: "Επόμενη σελίδα", next_short: "Επόμενη", swipe_short: "← Γλίστρα →" },
  en: { cover_label: "Cover", our_menu: "Our Menu", flavour: "Authentic Piraeus Flavour.", swipe_hint: "Swipe with your finger to turn the page", turn_pages: "Turn the pages", name1: "To Kalamaki", name2: "Tis Troumpas", addr: "Bouboulinas 8 & Notara — Piraeus", swipe_browse: "← Swipe to browse", prev: "Previous page", prev_short: "Previous", next: "Next page", next_short: "Next", swipe_short: "← Swipe →" },
};
const t = (L as any)[lang] ?? L.en;

// Titres pour l'indicateur de section
const sectionTitles = [
  t.cover_label,
  ...pages.map(p => pickTitle(p) || p.title_en)
];
const totalPages = pages.length + 1;
---

<section id="menu-book" class="bg-[#050505] pt-5 pb-6 px-4 border-t border-white/5">
  <div class="max-w-3xl mx-auto">

    <!-- Titre — collé au livre -->
    <div class="text-center mb-3">
      <p class="text-[10px] font-['Space_Grotesk'] uppercase tracking-[0.35em] text-[#E5B32A] font-bold mb-1">
        {t.our_menu}
      </p>
      <h2 class="text-xl md:text-2xl font-serif italic text-white">
        {t.flavour}
      </h2>
    </div>

    <!-- Bandeau swipe hint mobile (toujours visible) -->
    <div class="book-swipe-banner" aria-hidden="true">
      <span class="swipe-arrow">←</span>
      <span class="swipe-finger">👆</span>
      <span class="swipe-label">
        {t.swipe_hint}
      </span>
      <span class="swipe-arrow">→</span>
    </div>

    <!-- Livre -->
    <div class="book-container" id="menu-book-container">

      <!-- Tutorial hint (premiere visite) -->
      <div class="book-tutorial" id="book-tutorial" aria-hidden="true">
        <div class="tutorial-hand">👉</div>
        <div class="tutorial-text">
          {t.turn_pages}
        </div>
      </div>

      <!-- Spine + tranche de pages (decoratif) -->
      <div class="book-spine" aria-hidden="true"></div>
      <div class="book-edges book-edges--right" aria-hidden="true"></div>
      <div class="book-edges book-edges--left" aria-hidden="true"></div>

      <!-- Pages wrapper -->
      <div class="book-pages" id="book-pages">

        <!-- PAGE 0 — COUVERTURE -->
        <div class="book-page active" data-page="0">
          <div class="page-inner page-cover">
            <img
              src="/photos/logo-main-200w.webp"
              alt="Το Καλαμάκι Τρούμπας"
              class="cover-logo-img"
              width="320"
              height="120"
              loading="eager"
              decoding="async"
            />
            <h3 class="cover-title sr-only">{t.name1} {t.name2}</h3>
            <p class="cover-sub">{t.addr}</p>
            <div class="cover-dots">◆ · · · ◆</div>
            <p class="cover-swipe">{t.swipe_browse}</p>
            <!-- Coin corne -->
            <div class="page-corner" aria-hidden="true"></div>
          </div>
        </div>

        {pages.map((p, idx) => (
          <div class="book-page" data-page={idx + 1}>
            <div class="page-inner">
              <h3 class="page-title">{pickTitle(p)}</h3>
              <div class="page-divider"></div>
              <img
                src={p.photo}
                srcset={`${p.photo.replace('-800w.', '-400w.')} 400w, ${p.photo} 800w, ${p.photo.replace('-800w.', '-1600w.')} 1600w`}
                sizes="(max-width: 640px) 90vw, 480px"
                alt=""
                class="page-photo"
                loading="lazy"
                decoding="async"
                width="800"
                height="600"
              />
              {pickNote(p) && (
                <p class="page-note">{pickNote(p)}</p>
              )}
              <ul class="menu-list">
                {p.items.map((item) => (
                  <li class={item.price.startsWith("+") ? "menu-item menu-item--extra" : "menu-item"}>
                    <span class="item-name">
                      {pickItemName(item)}
                      {pickItemDesc(item) && (
                        <em>{pickItemDesc(item)}</em>
                      )}
                    </span>
                    <span class="item-price">{item.price}</span>
                  </li>
                ))}
              </ul>
              <!-- Numero de page -->
              <div class="page-number">
                <span class="page-number-current">{idx + 2}</span>
                <span class="page-number-sep">/</span>
                <span class="page-number-total">{totalPages}</span>
              </div>
              <!-- Coin corne -->
              <div class="page-corner" aria-hidden="true"></div>
            </div>
          </div>
        ))}

      </div><!-- /book-pages -->

      <!-- Arrows -->
      <div class="book-arrow-wrap book-arrow-wrap--prev">
        <button class="book-arrow book-arrow--prev" id="book-prev" aria-label={t.prev}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="book-arrow-label">{t.prev_short}</span>
      </div>
      <div class="book-arrow-wrap book-arrow-wrap--next">
        <button class="book-arrow book-arrow--next" id="book-next" aria-label={t.next}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <span class="book-arrow-label">{t.next_short}</span>
      </div>

    </div><!-- /book-container -->

    <!-- Footer livre : dots + section actuelle -->
    <div class="book-footer">
      <div class="book-dots" id="book-dots" aria-label="Pages"></div>
      <div class="book-pagination">
        <span class="pagination-counter">
          <span id="book-current-page">1</span>
          <span class="pagination-sep">/</span>
          <span>{totalPages}</span>
        </span>
        <span class="pagination-dot">·</span>
        <span class="pagination-section" id="book-current-section">{sectionTitles[0]}</span>
      </div>
      <p class="book-swipe-hint mobile-only">{t.swipe_short}</p>
    </div>

    <!-- Data sections pour le JS -->
    <script type="application/json" id="book-sections-data" set:html={JSON.stringify(sectionTitles)} />
  </div>
</section>

<style>
  .book-container {
    position: relative;
    max-width: 780px;
    margin: 0 auto;
    perspective: 2000px;
    /* Touch-action : par défaut, autorise scroll vertical de la page.
       Le JS swap à 'none' dès qu'un swipe horizontal est détecté pour bloquer
       le scroll pendant qu'on tourne les pages. */
    touch-action: pan-y;
  }

  /* Bandeau swipe hint — visible en permanence sur mobile, discret sur desktop */
  .book-swipe-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    max-width: 580px;
    margin: 0 auto 1rem;
    padding: 0.7rem 1rem;
    background: linear-gradient(135deg, rgba(229,179,42,0.18) 0%, rgba(229,179,42,0.08) 100%);
    border: 1px solid rgba(229,179,42,0.45);
    border-radius: 999px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    color: #E5B32A;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-align: center;
    box-shadow: 0 4px 12px rgba(229,179,42,0.12);
  }
  .book-swipe-banner .swipe-arrow {
    font-size: 1.1rem;
    color: #E5B32A;
    animation: swipe-arrow-pulse 1.8s ease-in-out infinite;
  }
  .book-swipe-banner .swipe-finger {
    font-size: 1.05rem;
    animation: swipe-finger-bounce 1.6s ease-in-out infinite;
  }
  .book-swipe-banner .swipe-label {
    flex: 1;
    min-width: 0;
  }
  @keyframes swipe-arrow-pulse {
    0%, 100% { opacity: 0.55; transform: translateX(0); }
    50%      { opacity: 1;    transform: translateX(2px); }
  }
  @keyframes swipe-finger-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-2px); }
  }
  @media (min-width: 768px) {
    .book-swipe-banner { font-size: 0.72rem; padding: 0.55rem 1rem; opacity: 0.7; }
  }
  @media (max-width: 480px) {
    .book-swipe-banner { font-size: 0.7rem; padding: 0.55rem 0.85rem; gap: 0.45rem; }
    .book-swipe-banner .swipe-finger { display: none; }
  }

  /* Spine (dos du livre) */
  .book-spine {
    position: absolute;
    top: 8px; bottom: 8px;
    left: 50%; transform: translateX(-50%);
    width: 2px;
    background: linear-gradient(180deg, transparent, rgba(229,179,42,0.18), rgba(229,179,42,0.28), rgba(229,179,42,0.18), transparent);
    pointer-events: none;
    z-index: 5;
    opacity: 0.5;
    display: none;
  }

  /* Tranche de pages empilees (droite et gauche) */
  .book-edges {
    position: absolute;
    top: 14px; bottom: 14px;
    width: 8px;
    pointer-events: none;
    z-index: 2;
    border-radius: 2px;
  }
  .book-edges--right {
    right: -6px;
    background: repeating-linear-gradient(
      180deg,
      rgba(229,179,42,0.18) 0px,
      rgba(229,179,42,0.18) 1px,
      rgba(0,0,0,0.6) 1px,
      rgba(0,0,0,0.6) 3px
    );
    box-shadow: 2px 0 6px rgba(0,0,0,0.5), inset -1px 0 0 rgba(229,179,42,0.15);
  }
  .book-edges--left {
    left: -6px;
    background: repeating-linear-gradient(
      180deg,
      rgba(229,179,42,0.12) 0px,
      rgba(229,179,42,0.12) 1px,
      rgba(0,0,0,0.6) 1px,
      rgba(0,0,0,0.6) 3px
    );
    box-shadow: -2px 0 6px rgba(0,0,0,0.5), inset 1px 0 0 rgba(229,179,42,0.1);
  }

  .book-pages {
    position: relative;
    /* Hauteur fixe : toutes les pages occupent la même hauteur quelle que soit leur contenu.
       Cela évite que le livre saute/grandisse quand on tourne. */
    min-height: clamp(420px, 56vh, 540px);
    transform-style: preserve-3d;
    display: grid;
    grid-template-areas: "stack";
  }

  .book-page {
    grid-area: stack;
    visibility: hidden;
    pointer-events: none;
    position: relative;
    transform-style: preserve-3d;
    backface-visibility: hidden;
    width: 100%;
  }
  .book-page.active {
    visibility: visible;
    pointer-events: auto;
    z-index: 2;
  }
  .book-page .page-inner {
    height: 100%;
  }

  /* Animations 3D — pages tournent (visibility + animations) */
  .book-page.flip-out-left {
    visibility: visible;
    pointer-events: none;
    animation: flip-out-left 600ms cubic-bezier(0.4, 0.0, 0.2, 1) forwards;
    transform-origin: left center;
    z-index: 4;
  }
  .book-page.flip-in-left {
    visibility: visible;
    pointer-events: none;
    animation: flip-in-left 600ms cubic-bezier(0.4, 0.0, 0.2, 1) forwards;
    transform-origin: left center;
    z-index: 3;
  }
  .book-page.flip-out-right {
    visibility: visible;
    pointer-events: none;
    animation: flip-out-right 600ms cubic-bezier(0.4, 0.0, 0.2, 1) forwards;
    transform-origin: right center;
    z-index: 4;
  }
  .book-page.flip-in-right {
    visibility: visible;
    pointer-events: none;
    animation: flip-in-right 600ms cubic-bezier(0.4, 0.0, 0.2, 1) forwards;
    transform-origin: right center;
    z-index: 3;
  }

  @keyframes flip-out-left {
    0%   { transform: rotateY(0deg); opacity: 1; box-shadow: 0 0 0 rgba(0,0,0,0); }
    50%  { transform: rotateY(-85deg); opacity: 0.85; box-shadow: -30px 0 40px rgba(0,0,0,0.6); }
    100% { transform: rotateY(-180deg); opacity: 0; }
  }
  @keyframes flip-in-left {
    0%   { transform: rotateY(15deg); opacity: 0; }
    100% { transform: rotateY(0deg); opacity: 1; }
  }
  @keyframes flip-out-right {
    0%   { transform: rotateY(0deg); opacity: 1; }
    50%  { transform: rotateY(85deg); opacity: 0.85; box-shadow: 30px 0 40px rgba(0,0,0,0.6); }
    100% { transform: rotateY(180deg); opacity: 0; }
  }
  @keyframes flip-in-right {
    0%   { transform: rotateY(-15deg); opacity: 0; }
    100% { transform: rotateY(0deg); opacity: 1; }
  }

  .page-inner {
    background: linear-gradient(135deg, #111 0%, #0a0a0a 100%);
    border: 1px solid rgba(229,179,42,0.2);
    border-radius: 1rem;
    padding: 0.85rem 1.15rem 1.3rem;
    min-height: 240px;
    position: relative;
    box-shadow: 0 20px 50px -20px rgba(0,0,0,0.7), inset 0 0 30px rgba(229,179,42,0.03);
    overflow: hidden;
  }
  .page-inner::before {
    content: '';
    position: absolute;
    top: 0; left: 1.5rem; right: 1.5rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(229,179,42,0.4), transparent);
  }
  /* Coin corne en haut a droite */
  .page-corner {
    position: absolute;
    top: 0; right: 0;
    width: 36px; height: 36px;
    background: linear-gradient(225deg, rgba(229,179,42,0.18) 0%, rgba(229,179,42,0.08) 45%, transparent 50%);
    border-bottom-left-radius: 8px;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
    z-index: 6;
  }
  .page-corner::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 0; height: 0;
    border-style: solid;
    border-width: 0 14px 14px 0;
    border-color: transparent rgba(229,179,42,0.35) transparent transparent;
    transition: all 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
  }
  .page-inner:hover .page-corner {
    width: 56px; height: 56px;
    background: linear-gradient(225deg, rgba(229,179,42,0.32) 0%, rgba(229,179,42,0.15) 45%, transparent 50%);
  }
  .page-inner:hover .page-corner::after {
    border-width: 0 22px 22px 0;
    border-color: transparent rgba(229,179,42,0.6) transparent transparent;
  }

  /* Numero de page en bas */
  .page-number {
    position: absolute;
    bottom: 0.9rem; right: 1.3rem;
    font-family: 'Playfair Display', serif;
    font-size: 0.7rem;
    color: rgba(229,179,42,0.5);
    letter-spacing: 0.15em;
    display: flex; gap: 0.3rem;
    pointer-events: none;
  }
  .page-number-current { color: rgba(229,179,42,0.85); font-weight: 700; }
  .page-number-sep { opacity: 0.5; }

  .page-cover {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    background: linear-gradient(160deg, #1a1200 0%, #0a0a0a 60%, #0d1500 100%);
    border-color: rgba(229,179,42,0.4);
    padding: 3rem 2rem;
  }
  .cover-logo-img {
    display: block;
    width: auto; height: clamp(90px, 18vw, 140px);
    margin: 0 auto 1.25rem;
    object-fit: contain;
    filter: drop-shadow(0 4px 12px rgba(229,179,42,0.18));
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .cover-title {
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 2rem; color: #fff;
    line-height: 1.25; margin-bottom: 0.75rem;
  }
  .cover-sub { font-size: 0.75rem; color: rgba(255,255,255,0.45); letter-spacing: 0.06em; margin-bottom: 1.5rem; }
  .cover-dots { color: rgba(229,179,42,0.5); font-size: 0.9rem; letter-spacing: 0.3em; margin-bottom: 1.5rem; }
  .cover-swipe { font-size: 0.7rem; color: rgba(255,255,255,0.4); letter-spacing: 0.1em; text-transform: uppercase; }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 1.1rem; color: #E5B32A;
    margin-bottom: 0.2rem; line-height: 1.15;
  }
  .page-divider {
    width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(229,179,42,0.3), transparent);
    margin: 0.35rem 0 0.5rem;
  }
  .page-photo {
    width: 100%; max-width: 380px; height: 130px; object-fit: cover; object-position: center;
    border-radius: 0.65rem; margin: 0 auto 0.55rem;
    display: block;
    border: 1px solid rgba(229,179,42,0.25);
    filter: brightness(0.94) contrast(1.06);
    box-shadow: 0 4px 14px rgba(0,0,0,0.5);
  }
  @media (max-width: 640px) {
    .page-photo { height: 110px; max-width: 100%; border-radius: 0.55rem; margin-bottom: 0.45rem; }
  }
  @media (min-width: 980px) {
    .page-photo { height: 160px; max-width: 440px; }
  }
  .page-note {
    font-size: 0.66rem; color: rgba(255,255,255,0.35);
    font-style: italic; margin-bottom: 0.5rem; letter-spacing: 0.02em;
  }
  .menu-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .menu-item {
    display: flex; justify-content: space-between; align-items: flex-start; gap: 0.65rem;
    padding-bottom: 0.28rem; border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .menu-item:last-child { border-bottom: none; padding-bottom: 0; }
  .menu-item--extra { opacity: 0.7; }
  .item-name {
    font-size: 0.68rem; color: #fff; font-weight: 600; line-height: 1.3;
    display: flex; flex-direction: column;
    font-family: 'Inter', sans-serif;
  }
  .item-name em {
    font-style: normal; font-size: 0.56rem; color: rgba(255,255,255,0.4);
    font-weight: 400; margin-top: 0.08rem;
  }
  .item-price {
    font-family: 'Playfair Display', serif;
    font-size: 0.75rem; color: #E5B32A;
    white-space: nowrap; font-weight: 700; flex-shrink: 0; margin-top: 0.05rem;
  }

  /* ============== FLECHES ============== */
  .book-arrow-wrap {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex; flex-direction: column; align-items: center;
    gap: 0.5rem;
    z-index: 12;
  }
  .book-arrow-wrap--prev { left: -82px; }
  .book-arrow-wrap--next { right: -82px; }

  .book-arrow {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(229,179,42,0.18) 0%, rgba(20,20,20,0.95) 100%);
    border: 2px solid rgba(229,179,42,0.5);
    color: #E5B32A;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0.0, 0.2, 1);
    position: relative;
    animation: arrow-pulse 2.2s ease-in-out infinite;
    box-shadow: 0 0 18px rgba(229,179,42,0.18), 0 4px 12px rgba(0,0,0,0.5);
  }
  @keyframes arrow-pulse {
    0%, 100% {
      box-shadow: 0 0 18px rgba(229,179,42,0.18), 0 4px 12px rgba(0,0,0,0.5);
      border-color: rgba(229,179,42,0.5);
    }
    50% {
      box-shadow: 0 0 32px rgba(229,179,42,0.45), 0 4px 16px rgba(0,0,0,0.5);
      border-color: rgba(229,179,42,0.85);
    }
  }
  .book-arrow:hover {
    transform: scale(1.12);
    background: linear-gradient(135deg, rgba(229,179,42,0.4) 0%, rgba(40,30,5,0.95) 100%);
    border-color: #E5B32A;
    color: #fff;
    box-shadow: 0 0 38px rgba(229,179,42,0.7), 0 4px 18px rgba(0,0,0,0.6);
    animation-play-state: paused;
  }
  .book-arrow:active { transform: scale(0.96); }
  .book-arrow:disabled {
    opacity: 0.25; pointer-events: none;
    animation: none;
    border-color: rgba(229,179,42,0.2);
    box-shadow: none;
  }
  .book-arrow svg { width: 26px; height: 26px; }

  .book-arrow-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(229,179,42,0.75);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    white-space: nowrap;
    user-select: none;
    pointer-events: none;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }

  /* Responsive arrows */
  @media (max-width: 980px) {
    .book-arrow-wrap--prev { left: -10px; }
    .book-arrow-wrap--next { right: -10px; }
    .book-arrow { width: 52px; height: 52px; background: linear-gradient(135deg, rgba(229,179,42,0.25) 0%, rgba(20,20,20,0.97) 100%); }
    .book-arrow svg { width: 22px; height: 22px; }
  }
  @media (max-width: 640px) {
    .book-arrow-wrap--prev { left: 4px; }
    .book-arrow-wrap--next { right: 4px; }
    .book-arrow { width: 46px; height: 46px; }
    .book-arrow svg { width: 20px; height: 20px; }
    .book-arrow-label { font-size: 0.55rem; letter-spacing: 0.1em; }
    .page-inner { padding: 1.5rem 1.25rem 2.5rem; }
    .page-title { font-size: 1.3rem; }
  }

  /* ============== FOOTER : dots + pagination ============== */
  .book-footer {
    margin-top: 1.5rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
  }
  .book-dots {
    display: flex; justify-content: center; gap: 8px;
    flex-wrap: wrap;
  }
  .book-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(229,179,42,0.2); border: 1px solid rgba(229,179,42,0.3);
    cursor: pointer; transition: all 0.25s; padding: 0;
  }
  .book-dot:hover { background: rgba(229,179,42,0.45); border-color: rgba(229,179,42,0.6); }
  .book-dot.active {
    background: #E5B32A; border-color: #E5B32A;
    transform: scale(1.35);
    box-shadow: 0 0 10px rgba(229,179,42,0.6);
  }

  .book-pagination {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pagination-counter { color: #E5B32A; font-weight: 700; }
  .pagination-sep { opacity: 0.5; margin: 0 0.15rem; }
  .pagination-dot { color: rgba(229,179,42,0.5); }
  .pagination-section { color: rgba(255,255,255,0.75); font-weight: 500; }

  .book-swipe-hint {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    color: rgb(229,179,42);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    animation: swipe-hint 2.4s ease-in-out infinite;
    margin: 0;
  }
  @keyframes swipe-hint {
    0%, 100% { opacity: 0.92; transform: translateX(0); }
    50%      { opacity: 1; transform: translateX(2px); }
  }
  .mobile-only { display: none; }
  @media (max-width: 720px) {
    .mobile-only { display: block; }
  }

  /* ============== TUTORIAL HINT ============== */
  .book-tutorial {
    position: absolute;
    top: 18px;
    right: 12px;
    z-index: 20;
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    background: linear-gradient(135deg, rgba(229,179,42,0.95) 0%, rgba(200,150,30,0.95) 100%);
    color: #0a0a0a;
    border-radius: 999px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    box-shadow: 0 8px 24px rgba(229,179,42,0.45), 0 0 0 4px rgba(229,179,42,0.18);
    pointer-events: none;
    opacity: 0;
  }
  .book-tutorial.show {
    display: flex;
    animation: tutorial-pop 2800ms ease-in-out forwards;
  }
  .tutorial-hand {
    font-size: 1.1rem;
    animation: tutorial-point 0.9s ease-in-out infinite;
    display: inline-block;
  }
  @keyframes tutorial-point {
    0%, 100% { transform: translateX(0) rotate(0deg); }
    50%      { transform: translateX(6px) rotate(-8deg); }
  }
  @keyframes tutorial-pop {
    0%   { opacity: 0; transform: translateY(-8px) scale(0.92); }
    12%  { opacity: 1; transform: translateY(0) scale(1.04); }
    20%  { transform: translateY(0) scale(1); }
    85%  { opacity: 1; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-6px) scale(0.96); }
  }

  /* Show spine sur grand ecran */
  @media (min-width: 980px) {
    .book-spine { display: block; }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .book-arrow { animation: none; }
    .book-tutorial.show { animation: none; opacity: 1; display: flex; }
    .book-page.flip-out-left,
    .book-page.flip-in-left,
    .book-page.flip-out-right,
    .book-page.flip-in-right {
      animation: none;
    }
    .book-swipe-hint { animation: none; }
  }
</style>

<script is:inline>
(function() {
  const pages = document.querySelectorAll('.book-page');
  const dotsContainer = document.getElementById('book-dots');
  const prevBtn = document.getElementById('book-prev');
  const nextBtn = document.getElementById('book-next');
  const currentPageEl = document.getElementById('book-current-page');
  const currentSectionEl = document.getElementById('book-current-section');
  const tutorial = document.getElementById('book-tutorial');
  const sectionsDataEl = document.getElementById('book-sections-data');
  let sections = [];
  try { sections = JSON.parse(sectionsDataEl ? sectionsDataEl.textContent : '[]'); } catch (e) { sections = []; }

  let current = 0;
  let isAnimating = false;
  const total = pages.length;

  // Build dots
  pages.forEach(function(_, i) {
    var d = document.createElement('button');
    d.className = 'book-dot' + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Page ' + (i + 1));
    d.type = 'button';
    d.addEventListener('click', function() { goTo(i); });
    dotsContainer.appendChild(d);
  });

  function updateUI(n) {
    // Dots
    Array.prototype.forEach.call(dotsContainer.children, function(dot, idx) {
      dot.classList.toggle('active', idx === n);
    });
    // Pagination
    if (currentPageEl) currentPageEl.textContent = String(n + 1);
    if (currentSectionEl && sections[n]) currentSectionEl.textContent = sections[n];
    // Arrows
    prevBtn.disabled = n === 0;
    nextBtn.disabled = n === total - 1;
  }

  function goTo(n, direction) {
    if (isAnimating) return;
    n = Math.max(0, Math.min(total - 1, n));
    if (n === current) return;

    const dir = direction || (n > current ? 'next' : 'prev');
    const oldPage = pages[current];
    const newPage = pages[n];
    isAnimating = true;

    if (dir === 'next') {
      oldPage.classList.add('flip-out-left');
      newPage.classList.add('flip-in-left', 'active');
    } else {
      oldPage.classList.add('flip-out-right');
      newPage.classList.add('flip-in-right', 'active');
    }

    current = n;
    updateUI(current);

    setTimeout(function() {
      oldPage.classList.remove('active', 'flip-out-left', 'flip-out-right');
      newPage.classList.remove('flip-in-left', 'flip-in-right');
      isAnimating = false;
    }, 620);
  }

  prevBtn.addEventListener('click', function() { goTo(current - 1, 'prev'); });
  nextBtn.addEventListener('click', function() { goTo(current + 1, 'next'); });

  // Keyboard nav
  document.addEventListener('keydown', function(e) {
    var book = document.getElementById('menu-book-container');
    if (!book) return;
    var rect = book.getBoundingClientRect();
    var visible = rect.top < window.innerHeight && rect.bottom > 0;
    if (!visible) return;
    if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1, 'next'); }
    if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(current - 1, 'prev'); }
  });

  // Swipe gestures + lock vertical scroll quand swipe horizontal détecté
  var sx = 0, sy = 0;
  var swipeAxis = ''; // '' | 'x' | 'y'
  var bookEl = document.getElementById('menu-book-container');
  bookEl.addEventListener('touchstart', function(e) {
    sx = e.changedTouches[0].screenX;
    sy = e.changedTouches[0].screenY;
    swipeAxis = '';
    bookEl.style.touchAction = 'pan-y'; // reset
  }, { passive: true });
  bookEl.addEventListener('touchmove', function(e) {
    if (swipeAxis) return; // axe déjà déterminé
    var dx = e.touches[0].screenX - sx;
    var dy = e.touches[0].screenY - sy;
    if (Math.abs(dx) > 8 || Math.abs(dy) > 8) {
      if (Math.abs(dx) > Math.abs(dy)) {
        // Swipe horizontal — bloquer scroll vertical de la page
        swipeAxis = 'x';
        bookEl.style.touchAction = 'none';
      } else {
        swipeAxis = 'y';
        // Laisser le scroll vertical se faire normalement
      }
    }
  }, { passive: true });
  bookEl.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].screenX - sx;
    var dy = e.changedTouches[0].screenY - sy;
    bookEl.style.touchAction = 'pan-y'; // restore
    if (swipeAxis === 'x' && Math.abs(dx) > 45 && Math.abs(dx) > Math.abs(dy)) {
      goTo(dx < 0 ? current + 1 : current - 1, dx < 0 ? 'next' : 'prev');
    }
    swipeAxis = '';
  }, { passive: true });
  bookEl.addEventListener('touchcancel', function() {
    bookEl.style.touchAction = 'pan-y';
    swipeAxis = '';
  }, { passive: true });

  // Init
  updateUI(0);

  // Tutorial hint — premiere visite (IntersectionObserver = pas de forced reflow)
  try {
    var seen = localStorage.getItem('menubook_seen');
    if (!seen && tutorial && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            io.disconnect();
            setTimeout(function() {
              tutorial.classList.add('show');
              setTimeout(function() { tutorial.classList.remove('show'); }, 2900);
            }, 350);
            try { localStorage.setItem('menubook_seen', '1'); } catch (e) {}
            break;
          }
        }
      }, { threshold: 0.15 });
      io.observe(bookEl);
    }
  } catch (e) { /* localStorage indisponible */ }
})();
</script>
