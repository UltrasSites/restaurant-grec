      { el: "Μπιφτέκι μοσχαρίσιο", en: "Beef Burger pc", desc_el: "ντομάτα, κρεμμύδι, τζατζίκι, πατάτες", desc_en: "tomato, onion, tzatziki, fries", price: "3,50€" },
    ],
  },
  {
