      { el: "Καλαμάκι κοτομπέικον (4 τμχ)", en: "Skewered chicken with bacon (4 pcs)", desc_el: "ντομάτα, μαρούλι, σως, πατάτες, 2 πίτες", desc_en: "tomato, lettuce, sauce, fries, 2 pita", price: "9,50€" },
