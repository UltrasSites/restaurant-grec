      { el: "Τυλιχτό Σεϊτάν", en: "Wrapped Seitan", desc_el: "σεϊτάν, ντομάτα, κρεμμύδι, σως, πατάτες", desc_en: "seitan, tomato, onion, sauce, fries", price: "4,00€" },
      { el: "Πλατέ Σεϊτάν", en: "Seitan plate", desc_el: "3 σούβλες σεϊτάν, πίτα, πατάτες, σαλάτα", desc_en: "3 seitan skewers, pita, fries, salad", price: "9,00€" },
