---
// Dock mobile « application restaurant » — gabarit canonique ocaso (Ultras-Brain/01-rules/modele-restaurant-canonique.md)
// Barre basse type app : 4 onglets icône+label + FAB central « Παραγγελία » surélevé qui brille.
import { translations } from "../i18n/translations";
import { type Lang } from "../i18n/utils";

const { lang = "el" } = Astro.props as { lang?: Lang };
const base = lang ? `/${lang}` : "";
const t = lang ? translations[lang] : null;
const telP = "MzAyMTA0MjIyMjMz"; // base64(302104222233) — numéro hors DOM (anti-bot)

// Toggle EL ↔ EN seulement (Tiago 28/05 — cycle complet confusant)
const otherLang: Lang = (lang === "el" ? "en" : "el") as Lang;
const otherLangBase = `/${otherLang}/`;
const FLAG_MAP: Record<string, string> = { el: "/flags/gr.svg", en: "/flags/gb.svg" };
const flagSrc = FLAG_MAP[lang] ?? "/flags/gr.svg";
const orderHref = `${base}/delivery`;
// Adresse EXACTE Trouba : Μπουμπουλίνας 8 & Νοταρά, 18535 Πειραιάς (Tiago 28/05)
const mapsHref = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent("Καλαμάκι της Τρούμπας Μπουμπουλίνας 8 Νοταρά 18535 Πειραιάς");

const L = lang === "el"
  ? { call: "Κλήση", menu: "Μενού", order: "Παραγγελία", loc: "Πειραιάς", lang: "EL" }
  : { call: "Call", menu: "Menu", order: "Order", loc: "Piraeus", lang: "EN" };
---

<div id="nav-pill-logo" class="nav-pill-logo md:hidden absolute top-4 left-3 sm:left-5 z-20" style="transition:opacity .25s ease">
    <a href={`${base}/#home`} class="inline-flex items-center gap-2">
        <img src="/photos/logo-dark-bg-88w.webp" alt="" width="44" height="44" class="w-11 h-11 object-contain drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)]" loading="eager" decoding="async" />
        <span class="text-[11px] font-semibold tracking-wide uppercase text-white/90 leading-tight">Το Καλαμάκι<br/>Της Τρούμπας</span>
    </a>
</div>

<div class="rdock md:hidden" id="ultras-mobile-dock" aria-label={t?.nav_menu ?? "Actions"}>
  <div class="rdock-bar">
    <a class="tel-link rdock-item" data-p={telP} aria-label={L.call}>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      <span>{L.call}</span>
    </a>
    <button type="button" id="mobile-open-drawer-btn" class="rdock-item" aria-label={L.menu}>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h10"/></svg>
      <span>{L.menu}</span>
    </button>

    <div class="rdock-fab-wrap">
      <a href={orderHref} class="rdock-fab" aria-label={L.order}>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 18h18M12 6a8 8 0 00-8 8h16a8 8 0 00-8-8zM12 6V3.5"/></svg>
      </a>
      <span class="rdock-fab-lb">{L.order}</span>
    </div>

    <a href={mapsHref} target="_blank" rel="noopener" class="rdock-item" aria-label={L.loc}>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="2.5"/></svg>
      <span>{L.loc}</span>
    </a>
    <a href={otherLangBase} class="rdock-item" aria-label={`Switch to ${otherLang.toUpperCase()}`}>
      <img src={flagSrc} alt="" width="20" height="20" class="rdock-flag" loading="eager" decoding="async" />
      <span>{L.lang}</span>
    </a>
  </div>
</div>

<style>
  /* Le logo du hero est la signature : tant qu'il est visible, on cache la pastille top-left (anti double logo §11.bis.C) */
  :global(body.hero-logo-visible) .nav-pill-logo { opacity: 0; pointer-events: none; }

  .rdock {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 60;
    display: flex; justify-content: center; pointer-events: none;
    padding: 0 12px calc(9px + env(safe-area-inset-bottom));
  }
  @media (min-width: 768px) { .rdock { display: none !important; } }
  .rdock-bar {
    pointer-events: auto; position: relative;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 2px;
    width: 100%; max-width: 412px; height: 54px; padding: 5px 10px;
    border-radius: 22px;
    background: linear-gradient(180deg, #1d160c 0%, #140f08 100%);
    backdrop-filter: blur(16px) saturate(1.4); -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow: 0 14px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .rdock-item {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    flex: 1; min-width: 0; padding: 3px 0;
    color: #e8d9c4; text-decoration: none;
    background: none; border: none; cursor: pointer;
    transition: color 0.18s ease, transform 0.14s ease;
  }
  .rdock-item:active { transform: scale(0.9); }
  .rdock-item svg { width: 19px; height: 19px; }
  .rdock-item span { font-size: 9px; font-weight: 700; letter-spacing: 0.01em; white-space: nowrap; }
  .rdock-flag { width: 18px; height: 18px; border-radius: 50%; object-fit: cover; }

  /* action centrale surélevée — Παραγγελία, elle brille */
  .rdock-fab-wrap {
    flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; gap: 2px;
    transform: translateY(-14px); width: 58px;
  }
  .rdock-fab {
    width: 50px; height: 50px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #1a1208; position: relative;
    background: linear-gradient(135deg, #E5B32A, #F59E0B);
    box-shadow: 0 10px 26px -6px rgba(229, 179, 42, 0.78);
    border: 2px solid rgba(255,255,255,0.18);
    transition: transform 0.16s ease;
  }
  .rdock-fab:active { transform: scale(0.93); }
  .rdock-fab svg { width: 23px; height: 23px; }
  .rdock-fab::after {
    content: ''; position: absolute; inset: -2px; border-radius: 50%; pointer-events: none;
    box-shadow: 0 0 0 0 rgba(229, 179, 42, 0.6);
    animation: rdockGlowK 2.4s ease-in-out infinite;
  }
  @keyframes rdockGlowK {
    0%, 100% { box-shadow: 0 0 0 0 rgba(229, 179, 42, 0.6); }
    50%      { box-shadow: 0 0 0 9px rgba(229, 179, 42, 0); }
  }
  .rdock-fab-lb { font-size: 10px; font-weight: 800; color: #E5B32A; letter-spacing: 0.02em; }
  @media (prefers-reduced-motion: reduce) { .rdock-fab::after { animation: none; } }

  @media (max-width: 767px) { :global(main), :global(body) { padding-bottom: 86px; } }
</style>

<script>
    const openDrawerBtn = document.getElementById("mobile-open-drawer-btn");
    const dock = document.getElementById("ultras-mobile-dock");
    if (dock && dock.parentNode !== document.body) document.body.appendChild(dock);
    if (openDrawerBtn) { openDrawerBtn.addEventListener("click", (e) => { e.preventDefault(); document.dispatchEvent(new CustomEvent("open-drawer")); }); }
</script>
