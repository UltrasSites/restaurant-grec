---
import { translations } from "../i18n/translations";
import type { Lang } from "../i18n/utils";

const { lang } = Astro.props as { lang?: Lang };
const base = lang ? `/${lang}` : "";
const contactHref = `${base}/#contact`;
const t = lang ? translations[lang] : null;
const tel = "tel:+302104222233";
---

<div class="md:hidden absolute top-4 left-3 sm:left-5 z-20">
    <a href={`${base}/#home`} class="inline-flex items-center gap-2" aria-label="Καλαμάκι Της Τρούμπας">
        <img src="/photos/logo-dark-bg.png" alt="Καλαμάκι Της Τρούμπας" width="44" height="44" class="w-11 h-11 object-contain drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)]" loading="eager" decoding="async" />
        <span class="text-[11px] font-semibold tracking-wide uppercase text-white/90 leading-tight">Καλαμάκι<br/>Της Τρούμπας</span>
    </a>
</div>

<div class="mobile-dock md:hidden" id="mobile-fab-wrapper" aria-label="Κύριες ενέργειες">
    <div class="mobile-dock-inner">
        <button type="button" id="mobile-theme-btn" class="dock-btn dock-btn-theme" aria-label={t?.drawer_theme ?? "Αλλαγή θέματος"}>
            <span class="relative inline-flex w-5 h-5">
                <svg class="theme-icon-sun w-5 h-5 absolute inset-0 m-auto transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <svg class="theme-icon-moon w-5 h-5 absolute inset-0 m-auto transition-opacity duration-300 opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            </span>
        </button>
        <span class="dock-sep"></span>
        <a href={`${base}/delivery`} class="dock-btn dock-btn-order" aria-label={lang === 'el' ? 'Παραγγελία' : 'Order'}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
            </svg>
        </a>
        <span class="dock-sep"></span>
        <button type="button" id="mobile-open-drawer-btn" class="dock-btn dock-btn-menu" aria-label={t?.nav_menu ?? "Μενού"}>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path></svg>
        </button>
        <span class="dock-sep"></span>
        <a href={tel} class="dock-btn dock-btn-phone" aria-label={t?.nav_aria_phone ?? 'Τηλέφωνο'}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        </a>
    </div>
</div>

<style>
    .mobile-dock { position: fixed; bottom: calc(1.5rem + env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); z-index: 60; display: flex; justify-content: center; }
    @media (min-width: 768px) { .mobile-dock { display: none !important; } }
    .mobile-dock-inner { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 99px; background: rgba(23, 23, 23, 0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4); }
    .dock-btn { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.2s ease; box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25); color: inherit; text-decoration: none; border: none; cursor: pointer; }
    .dock-btn:active { transform: scale(0.9); }
    .dock-btn-theme { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.95); }
    .dock-btn-phone { background: linear-gradient(135deg, #22c55e 0%, #15803d 100%); color: #fff; }
    .dock-btn-menu { background: #E5B32A; color: #000; }
    .dock-btn-reserve { background: rgba(255,255,255,0.95); color: #000; }
    .dock-btn-order { background: linear-gradient(135deg, #E5B32A 0%, #c89a1e 100%); color: #000; position: relative; }
    .dock-btn-order::after { content: ''; position: absolute; inset: -2px; border-radius: 50%; box-shadow: 0 0 0 0 rgba(229,179,42,0.5); animation: pulse-ring 2s ease-in-out infinite; pointer-events: none; }
    @keyframes pulse-ring {
        0%, 100% { box-shadow: 0 0 0 0 rgba(229,179,42,0.5); }
        50% { box-shadow: 0 0 0 6px rgba(229,179,42,0); }
    }
    .dock-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.2); flex-shrink: 0; }
</style>

<script>
    (function () {
        function updateThemeIcons() {
            const isDark = document.documentElement.dataset.theme === "dark";
            document.querySelectorAll<HTMLElement>(".theme-icon-sun").forEach((el) => { el.style.opacity = isDark ? "0" : "1"; });
            document.querySelectorAll<HTMLElement>(".theme-icon-moon").forEach((el) => { el.style.opacity = isDark ? "1" : "0"; });
        }
        document.addEventListener("DOMContentLoaded", updateThemeIcons);
        const orig = (window as any).__toggleTheme as undefined | (() => void);
        if (orig) {
            (window as any).__toggleTheme = function () { orig(); setTimeout(updateThemeIcons, 0); };
        }
    })();

    const themeBtn = document.getElementById("mobile-theme-btn");
    const openDrawerBtn = document.getElementById("mobile-open-drawer-btn");
    const fabWrapper = document.getElementById("mobile-fab-wrapper");
    if (fabWrapper && fabWrapper.parentNode !== document.body) document.body.appendChild(fabWrapper);
    if (openDrawerBtn) { openDrawerBtn.addEventListener("click", (e) => { e.preventDefault(); document.dispatchEvent(new CustomEvent("open-drawer")); }); }
    if (themeBtn) { themeBtn.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); if ((window as any).__toggleTheme) (window as any).__toggleTheme(); }); }
</script>
