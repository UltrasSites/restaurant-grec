---
import { translations } from "../i18n/translations";
import { supportedLangs, langLabels, type Lang } from "../i18n/utils";

const { lang = "el" } = Astro.props as { lang?: Lang };
const base = lang ? `/${lang}` : "";
const t = lang ? translations[lang] : null;
const tel = "tel:+302104222233";

// Cycle entre les langues supportées
const idx = supportedLangs.indexOf(lang as Lang);
const otherLang: Lang = supportedLangs[(idx + 1) % supportedLangs.length];
const otherLangBase = `/${otherLang}/`;
const FLAG_MAP: Record<Lang, string> = { el: "/flags/gr.svg", en: "/flags/gb.svg", de: "/flags/de.svg", ru: "/flags/ru.svg", ja: "/flags/ja.svg" };
const flagSrc = FLAG_MAP[lang as Lang] ?? "/flags/gr.svg";
const flagAlt = langLabels[lang as Lang] ?? "Ελληνικά";
const orderHref = `${base}/delivery`;
const orderLabel = t?.order_cta ?? (lang === "el" ? "Παραγγελία" : "Order");
---

<div class="md:hidden absolute top-4 left-3 sm:left-5 z-20">
    <a href={`${base}/#home`} class="inline-flex items-center gap-2">
        <img src="/photos/logo-dark-bg-88w.webp" alt="" width="44" height="44" class="w-11 h-11 object-contain drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)]" loading="eager" decoding="async" />
        <span class="text-[11px] font-semibold tracking-wide uppercase text-white/90 leading-tight">Το Καλαμάκι<br/>Της Τρούμπας</span>
    </a>
</div>

<div class="mobile-dock md:hidden" id="mobile-fab-wrapper" aria-label="Κύριες ενέργειες">
    <div class="mobile-dock-inner">
        <a href={tel} class="dock-btn dock-btn-phone" aria-label={t?.nav_aria_phone ?? 'Τηλέφωνο'}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        </a>
        <span class="dock-sep"></span>
        <a href={otherLangBase} class="dock-btn dock-btn-lang" aria-label={`Switch to ${otherLang.toUpperCase()}`}>
            <img src={flagSrc} alt={flagAlt} width="22" height="22" class="dock-flag" loading="eager" decoding="async" />
            <span class="dock-lang-code">{lang.toUpperCase()}</span>
        </a>
        <span class="dock-sep"></span>
        <a href={orderHref} class="dock-btn dock-btn-order" aria-label={orderLabel}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </a>
        <span class="dock-sep"></span>
        <button type="button" id="mobile-open-drawer-btn" class="dock-btn dock-btn-menu" aria-label={t?.nav_menu ?? "Μενού"}>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path></svg>
        </button>
    </div>
</div>

<style>
    .mobile-dock { position: fixed; bottom: calc(1.5rem + env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); z-index: 60; display: flex; justify-content: center; }
    @media (min-width: 768px) { .mobile-dock { display: none !important; } }
    .mobile-dock-inner { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-radius: 99px; background: rgba(23, 23, 23, 0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4); }
    .dock-btn { width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.2s ease; box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25); color: inherit; text-decoration: none; border: none; cursor: pointer; }
    .dock-btn:active { transform: scale(0.9); }
    .dock-btn-theme { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.95); }
    .dock-btn-phone { background: linear-gradient(135deg, #22c55e 0%, #15803d 100%); color: #fff; }
    .dock-btn-menu { background: #E5B32A; color: #000; }
    .dock-btn-reserve { background: rgba(255,255,255,0.95); color: #000; }
    .dock-btn-lang {
        background: rgba(255,255,255,0.1);
        color: #fff;
        flex-direction: column;
        gap: 2px;
        padding: 4px;
    }
    .dock-flag { width: 20px; height: 20px; border-radius: 50%; object-fit: cover; }
    .dock-lang-code { font-size: 9px; font-weight: 700; letter-spacing: 0.05em; line-height: 1; }
    .dock-btn-order { background: linear-gradient(135deg, #E5B32A 0%, #c89a1e 100%); color: #000; position: relative; }
    .dock-btn-order::after { content: ''; position: absolute; inset: -2px; border-radius: 50%; border: 2px solid rgba(229,179,42,0.5); animation: pulse-ring 2s ease-in-out infinite; pointer-events: none; opacity: 0; }
    @keyframes pulse-ring {
        0%, 100% { transform: scale(1); opacity: 0.6; }
        50% { transform: scale(1.25); opacity: 0; }
    }
    /* Perf machines faibles : animation simple desktop, off mobile + reduced-motion */
    @media (max-width: 767px), (prefers-reduced-motion: reduce) {
        .dock-btn-order::after { animation: none; opacity: 0; }
    }
    .dock-sep { width: 1px; height: 26px; background: rgba(255,255,255,0.2); flex-shrink: 0; }
</style>

<script>
    const openDrawerBtn = document.getElementById("mobile-open-drawer-btn");
    const fabWrapper = document.getElementById("mobile-fab-wrapper");
    if (fabWrapper && fabWrapper.parentNode !== document.body) document.body.appendChild(fabWrapper);
    if (openDrawerBtn) { openDrawerBtn.addEventListener("click", (e) => { e.preventDefault(); document.dispatchEvent(new CustomEvent("open-drawer")); }); }
</script>
